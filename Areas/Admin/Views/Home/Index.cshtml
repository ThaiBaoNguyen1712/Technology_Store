@using System.Globalization
@using Tech_Store.Helpers
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Admin/Views/Shared/Layout.cshtml";
}

<div class="py-3 dashboard-page">
    <div class="dashboard-page__hero">
        <div>
            <span class="settings-page__eyebrow">Admin Dashboard</span>
            <h1 class="dashboard-page__title">Tổng quan vận hành</h1>
        </div>
        <div class="dashboard-page__hero-meta">
            <div class="settings-page__meta-card">
                <span class="settings-page__meta-label">Doanh thu 30 ngày</span>
                <strong>@ViewBag.Revenue.ToString("C0", new CultureInfo("vi-VN"))</strong>
            </div>
            <div class="settings-page__meta-card">
                <span class="settings-page__meta-label">Sản phẩm đang bán</span>
                <strong>@ViewBag.Product_count</strong>
            </div>
        </div>
    </div>

    <div class="dashboard-page__stats">
        <div class="dashboard-stat-card">
            <div class="dashboard-stat-card__icon dashboard-stat-card__icon--sky">
                <i class="fas fa-chart-line"></i>
            </div>
            <div class="dashboard-stat-card__body">
                <span>Lượt truy cập</span>
                <strong>1,294</strong>
            </div>
        </div>
        <div class="dashboard-stat-card">
            <div class="dashboard-stat-card__icon dashboard-stat-card__icon--blue">
                <i class="fas fa-user-check"></i>
            </div>
            <div class="dashboard-stat-card__body">
                <span>Khách hàng</span>
                <strong>@ViewBag.User_count</strong>
            </div>
        </div>
        <div class="dashboard-stat-card">
            <div class="dashboard-stat-card__icon dashboard-stat-card__icon--green">
                <i class="fas fa-cube"></i>
            </div>
            <div class="dashboard-stat-card__body">
                <span>Sản phẩm</span>
                <strong>@ViewBag.Product_count</strong>
            </div>
        </div>
        <div class="dashboard-stat-card">
            <div class="dashboard-stat-card__icon dashboard-stat-card__icon--violet">
                <i class="fas fa-shopping-bag"></i>
            </div>
            <div class="dashboard-stat-card__body">
                <span>Đơn hàng</span>
                <strong>@ViewBag.Order_count</strong>
            </div>
        </div>
    </div>

    <div class="dashboard-page__layout">
        <section class="dashboard-panel dashboard-panel--wide">
            <div class="dashboard-panel__header">
                <div>
                    <h2>Thống kê đơn hàng</h2>
                    <p>Biến động số đơn và doanh thu theo ngày trong tháng đã chọn.</p>
                </div>
                <a href="/Admin/Orders/all" class="btn btn-light border">Xem đơn hàng</a>
            </div>

            <form class="brand-admin__filters order-admin__filters row g-3 align-items-end mb-4 dashboard-page__chart-filters" onsubmit="return false;">
                <div class="col-md-4 col-xl-3">
                    <label for="monthFilter" class="form-label fw-semibold text-secondary">Tháng</label>
                    <select id="monthFilter" class="form-select">
                        @for (int i = 1; i <= 12; i++)
                        {
                            if (DateTime.Now.Month == i)
                            {
                                <option value="@i" selected>@i</option>
                            }
                            else
                            {
                                <option value="@i">@i</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-4 col-xl-3">
                    <label for="yearFilter" class="form-label fw-semibold text-secondary">Năm</label>
                    <select id="yearFilter" class="form-select">
                        @for (int year = DateTime.Now.Year - 5; year <= DateTime.Now.Year; year++)
                        {
                            if (DateTime.Now.Year == year)
                            {
                                <option value="@year" selected>@year</option>
                            }
                            else
                            {
                                <option value="@year">@year</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-12 col-xl-4 ms-xl-auto">
                    <div class="order-admin__filter-actions">
                        <button id="filterBtn" type="button" class="btn btn-primary">Lọc dữ liệu</button>
                    </div>
                </div>
            </form>

            <div class="dashboard-page__chart-shell">
                <canvas id="orderChart"></canvas>
            </div>
        </section>

        <section class="dashboard-panel">
            <div class="dashboard-panel__header">
                <div>
                    <h2>Doanh thu gần nhất</h2>
                    <p>Từ @DateTime.Now.AddMonths(-1).ToString("dd/MM/yyyy") đến @DateTime.Now.ToString("dd/MM/yyyy")</p>
                </div>
            </div>

            <div class="dashboard-revenue-card">
                <span class="dashboard-revenue-card__label">Đã thanh toán</span>
                <strong>@ViewBag.Revenue.ToString("C0", new CultureInfo("vi-VN"))</strong>
            </div>

            <div class="dashboard-mini-table">
                <div class="dashboard-panel__header dashboard-panel__header--compact">
                    <div>
                        <h2>Top sản phẩm bán chạy</h2>
                    </div>
                    <a href="/Admin/Products/all" class="btn btn-light border btn-sm">Xem thêm</a>
                </div>

                <div class="table-responsive reusable-admin-table">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 72px;">Ảnh</th>
                                <th>Tên sản phẩm</th>
                                <th style="width: 120px;">SL bán</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in ViewBag.hotSaleProducts)
                            {
                                <tr>
                                    <td>
                                        <div class="brand-admin__logo-shell">
                                            @if (item.Image != null && item.Image.Contains("http"))
                                            {
                                                <img src="@ResizeCDN.Cdn(item.Image,40,40)" width="40" height="40" alt="@item.Name" class="brand-admin__logo" />
                                            }
                                            else if (item.Image == null)
                                            {
                                                <img src="~/Upload/Products/no-image.png" width="40" height="40" alt="@item.Name" class="brand-admin__logo" />
                                            }
                                            else
                                            {
                                                <img src="~/Upload/Products/@item.Image" width="40" height="40" alt="@item.Name" class="brand-admin__logo" />
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <a class="fw-semibold text-dark text-decoration-none" href="/Admin/Products/View/@item.ProductId">
                                            @item.Name
                                        </a>
                                    </td>
                                    <td>@item.OrderItems.Count</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <section class="dashboard-panel dashboard-panel--wide">
            <div class="dashboard-panel__header">
                <div>
                    <h2>Đơn hàng mới</h2>
                    <p>Các đơn hàng mới nhất cần theo dõi.</p>
                </div>
                <a href="/Admin/Orders/all" class="btn btn-light border">Xem thêm</a>
            </div>

            <div class="table-responsive reusable-admin-table">
                <table class="table table-hover align-middle order-admin__table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 120px;">Mã đơn</th>
                            <th>Sản phẩm</th>
                            <th style="width: 200px;">Khách hàng</th>
                            <th style="width: 160px;">Số tiền</th>
                            <th style="width: 170px;">Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in ViewBag.New_orders)
                        {
                            <tr>
                                <td>
                                    <a class="fw-semibold text-decoration-none" href="/Admin/Orders/View/@order.OrderId">#@order.OrderId</a>
                                </td>
                                <td>
                                    <div class="order-admin__product-summary">@order.TopProduct</div>
                                    @if (order.OtherProductsCount > 0)
                                    {
                                        <div class="small text-muted">và @order.OtherProductsCount sản phẩm khác</div>
                                    }
                                </td>
                                <td>
                                    <div class="fw-semibold text-dark">@order.Email</div>
                                </td>
                                <td>
                                    <div class="order-admin__amount">@order.TotalAmount.ToString("C0", new CultureInfo("vi-VN"))</div>
                                </td>
                                <td>
                                    <div class="order-admin__state">
                                        <span class="order-admin__state-dot @($"order-admin__state-dot--{order.OrderStatus?.ToLowerInvariant()}")"></span>
                                        <div class="order-admin__state-body">
                                            <strong>
                                                @(order.OrderStatus == "Pending" ? "Đang chờ" :
                                                    order.OrderStatus == "Confirmed" ? "Đã xác nhận" :
                                                    order.OrderStatus == "Shipping" ? "Đang giao hàng" :
                                                    order.OrderStatus == "Delivered" ? "Đã giao hàng" :
                                                    order.OrderStatus == "Completed" ? "Hoàn thành" :
                                                    order.OrderStatus == "Cancelled" ? "Đã hủy" :
                                                    order.OrderStatus == "Refunded" ? "Đã hoàn tiền" :
                                                    "Không xác định")
                                            </strong>
                                            <span>@order.OrderStatus</span>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="dashboard-panel">
            <div class="dashboard-panel__header">
                <div>
                    <h2>Khách hàng mới</h2>
                    <p>Tài khoản đăng ký gần đây.</p>
                </div>
                <a href="/Admin/Users" class="btn btn-light border btn-sm">Xem thêm</a>
            </div>

            <div class="dashboard-user-list">
                @foreach (var user in ViewBag.New_users)
                {
                    <div class="dashboard-user-list__item">
                        <div class="dashboard-user-list__avatar">
                            @if (user.Img != null)
                            {
                                <img src="/Upload/Avatar/@user.Img" alt="@user.LastName @user.FirstName" class="avatar-img rounded-circle" />
                            }
                            else
                            {
                                <img src="/Upload/Avatar/none.png" alt="@user.LastName @user.FirstName" class="avatar-img rounded-circle" />
                            }
                        </div>
                        <div class="dashboard-user-list__body">
                            <strong>@user.LastName @user.FirstName</strong>
                            <span>@user.CreatedAt</span>
                        </div>
                    </div>
                }
            </div>
        </section>

        <section class="dashboard-panel dashboard-panel--full">
            <div class="dashboard-panel__header">
                <div>
                    <h2>Giao dịch gần đây</h2>
                    <p>Các giao dịch thanh toán mới nhất.</p>
                </div>
                <a href="/Admin/Transactions" class="btn btn-light border">Xem thêm</a>
            </div>

            <div class="table-responsive reusable-admin-table">
                <table class="table table-hover align-middle order-admin__table dashboard-transaction-table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mã giao dịch</th>
                            <th>Thời gian</th>
                            <th>Số tiền</th>
                            <th>Phương thức</th>
                            <th>Thanh toán</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var transaction in ViewBag.Payments)
                        {
                            <tr>
                                <td>
                                    <a class="fw-semibold text-decoration-none" href="/Admin/Transactions/View/@transaction.PaymentId">#@transaction.PaymentId</a>
                                </td>
                                <td>
                                    <div class="text-dark">@transaction.PaymentDate</div>
                                </td>
                                <td>
                                    <div class="order-admin__amount">@transaction.Amount.ToString("C0", new CultureInfo("vi-VN"))</div>
                                </td>
                                <td>@transaction.PaymentMethod</td>
                                <td>
                                    <div class="order-admin__state">
                                        <span class="order-admin__state-dot @(transaction.Status.ToLower() == "paid" ? "order-admin__state-dot--success" : "order-admin__state-dot--danger")"></span>
                                        <div class="order-admin__state-body">
                                            <strong>@(transaction.Status.ToLower() == "paid" ? "Đã thanh toán" : "Chưa thanh toán")</strong>
                                            <span>@transaction.Status</span>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            const ctx = document.getElementById('orderChart');
            let orderChart;

            function renderChart(data) {
                if (orderChart) {
                    orderChart.destroy();
                }

                orderChart = new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: data.map(item => `Ngày ${item.day}`),
                        datasets: [
                            {
                                label: 'Số đơn hàng',
                                data: data.map(item => item.orders),
                                backgroundColor: 'rgba(37, 99, 235, 0.72)',
                                borderColor: 'rgba(37, 99, 235, 1)',
                                borderWidth: 1,
                                borderRadius: 8
                            },
                            {
                                label: 'Doanh thu (VNĐ)',
                                data: data.map(item => item.revenue),
                                backgroundColor: 'rgba(14, 165, 233, 0.58)',
                                borderColor: 'rgba(14, 165, 233, 1)',
                                borderWidth: 1,
                                borderRadius: 8
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        interaction: {
                            mode: 'index',
                            intersect: false
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    callback: function (value) {
                                        return value.toLocaleString('vi-VN');
                                    }
                                }
                            }
                        }
                    }
                });
            }

            function fetchData() {
                $.ajax({
                    url: '/Admin/GetOrderStarts',
                    method: 'GET',
                    data: {
                        month: $('#monthFilter').val(),
                        year: $('#yearFilter').val()
                    },
                    success: function (data) {
                        renderChart(data || []);
                    },
                    error: function () {
                        Swal.fire('Không thể tải dữ liệu', 'Vui lòng thử lại.', 'error');
                    }
                });
            }

            fetchData();
            $('#filterBtn').on('click', fetchData);
        });
    </script>
}
