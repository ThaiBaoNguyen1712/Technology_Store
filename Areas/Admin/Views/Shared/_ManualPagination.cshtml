@model Tech_Store.Models.ViewModel.ManualPaginationViewModel
@{
    if (Model.TotalPages <= 1)
    {
        return;
    }

    var pages = new SortedSet<int> { 1, Model.TotalPages };
    for (var i = Model.CurrentPage - 1; i <= Model.CurrentPage + 1; i++)
    {
        if (i > 1 && i < Model.TotalPages)
        {
            pages.Add(i);
        }
    }

    if (Model.CurrentPage <= 3)
    {
        for (var i = 2; i <= Math.Min(4, Model.TotalPages - 1); i++)
        {
            pages.Add(i);
        }
    }

    if (Model.CurrentPage >= Model.TotalPages - 2)
    {
        for (var i = Math.Max(2, Model.TotalPages - 3); i < Model.TotalPages; i++)
        {
            pages.Add(i);
        }
    }

    string BuildUrl(int page)
    {
        var separator = string.IsNullOrWhiteSpace(Model.QueryString) ? "?" : $"?{Model.QueryString}&";
        return $"{Model.BaseUrl}{separator}page={page}";
    }

    var orderedPages = pages.OrderBy(x => x).ToList();
    int previousPageNumber = 0;
}

<nav class="mt-3" aria-label="Manual pagination">
    <ul class="pagination reusable-admin-pagination justify-content-end flex-wrap mb-0">
        <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
            <a class="page-link" href="@(Model.CurrentPage <= 1 ? "#" : BuildUrl(Model.CurrentPage - 1))">Trước</a>
        </li>

        @foreach (var pageNumber in orderedPages)
        {
            if (previousPageNumber != 0 && pageNumber - previousPageNumber > 1)
            {
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>
            }

            <li class="page-item @(pageNumber == Model.CurrentPage ? "active" : "")">
                <a class="page-link" href="@BuildUrl(pageNumber)">@pageNumber</a>
            </li>

            previousPageNumber = pageNumber;
        }

        <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
            <a class="page-link" href="@(Model.CurrentPage >= Model.TotalPages ? "#" : BuildUrl(Model.CurrentPage + 1))">Sau</a>
        </li>
    </ul>
</nav>
