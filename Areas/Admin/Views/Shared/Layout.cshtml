    <script type="text/javascript">

        $(document).ready(function () {
            $('.loading-container').hide()

            $(document).ajaxStart(function () {
                if (!window.isLoadingNotifications) {
                    $('.loading-container').show();
                }
            });

            $(document).ajaxStop(function () {
                $('.loading-container').hide();
            });

            window.initDataTableSafe = function (selector, options) {
                if (!$.fn.DataTable) {
                    return null;
                }

                var $table = $(selector);
                if (!$table.length) {
                    return null;
                }

                if ($.fn.DataTable.isDataTable($table)) {
                    return $table.DataTable();
                }

                return $table.DataTable($.extend(true, {
                    retrieve: true
                }, options || {}));
            };

            var $defaultTable = $('#add-row');
            if ($defaultTable.length && !$defaultTable.is('[data-skip-auto-datatable]')) {
                window.initDataTableSafe('#add-row', {
                    "order": [],
                    "stateSave": true,
                    "deferRender": true,
                    "drawCallback": function (settings) {
                        $('[data-bs-toggle="tooltip"]').tooltip();
                        initializeStatusSelects();
                    }
                });
            }

            // Hàm khởi tạo các select box
            function initializeStatusSelects() {
                $('.changeStatus').each(function () {
                    var $select = $(this);
                    if (!$select.hasClass('initialized')) {
                        $select.addClass('initialized');
                        // Khởi tạo selectpicker nếu bạn đang sử dụng bootstrap-select
                        if ($.fn.selectpicker) {
                            $select.selectpicker();
                        }
                    }
                });
            }
        });


          window.initDataTableSafe('#add-row-child');

        $(function () {
            $('[data-toggle="tooltip"]').tooltip()
        })
    </script>

