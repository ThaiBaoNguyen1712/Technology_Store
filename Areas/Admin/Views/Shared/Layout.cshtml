<!DOCTYPE html>
<html lang="en">
<head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>@ViewData["Title"]</title>
    <meta content="width=device-width, initial-scale=1.0, shrink-to-fit=no"
          name="viewport" />
    <link rel="stylesheet" href="~/vendor/fonts/inter/inter.css" asp-append-version="true" />
    <link rel="icon"
          href="@ViewBag.LogoUrl"
          type="image/x-icon"  asp-append-version="true"/>

    <!-- Fonts and icons -->
    <script src="~/Admin/assets/js/plugin/webfont/webfont.min.js"></script>


    <script>
        var fontsUrl = '@Url.Content("~/Admin/assets/css/fonts.min.css")'; // Tạo đường dẫn chính xác cho CSS

        WebFont.load({
            custom: {
                families: [
                    "Font Awesome 5 Solid",
                    "Font Awesome 5 Regular",
                    "Font Awesome 5 Brands",
                    "simple-line-icons",
                ],
                urls: [fontsUrl], // Sử dụng biến fontsUrl
            },
            active: function () {
                sessionStorage.fonts = true;
            },
        });
    </script>

    <!-- CSS Files -->
    <link href="@Url.Content("~/css/site.css")" rel="stylesheet" asp-append-version="true" />
    <link rel="stylesheet" href="@Url.Content("~/Admin/assets/css/bootstrap.min.css")" asp-append-version="true" />
    <link rel="stylesheet" href="@Url.Content("~/Admin/assets/css/plugins.min.css")" asp-append-version="true" />
    <link rel="stylesheet" href="@Url.Content("~/Admin/assets/css/kaiadmin.min.css")" asp-append-version="true" />
    <link href="@Url.Content("~/Admin/assets/css/site.css")" rel="stylesheet" asp-append-version="true" />
    <link href="@Url.Content("~/Admin/assets/css/sidebar.css")" rel="stylesheet" asp-append-version="true" />
    <link href="@Url.Content("~/Admin/assets/css/right-drawer.css")" rel="stylesheet" asp-append-version="true" />
    @* Toast JS *@
    <link rel="stylesheet" href="~/vendor/sweetalert2/sweetalert2.min.css" asp-append-version="true">
    <script src="~/vendor/sweetalert2/sweetalert2.min.js" asp-append-version="true"></script>

    <!-- FilePond CSS -->
    <link href="~/vendor/filepond/filepond.min.css" rel="stylesheet" asp-append-version="true">
    <link href="~/vendor/filepond/filepond-plugin-image-preview.min.css" rel="stylesheet" asp-append-version="true">
  
    <!-- FilePond JS -->
    <script src="~/vendor/filepond/filepond.min.js" asp-append-version="true"></script>
    <script src="~/vendor/filepond/filepond-plugin-image-preview.min.js" asp-append-version="true"></script>
    <script src="~/vendor/filepond/filepond-plugin-file-validate-type.min.js" asp-append-version="true"></script>
    <script src="~/vendor/filepond/filepond-plugin-image-exif-orientation.min.js" asp-append-version="true"></script>

    <script src="~/Admin/assets/js/core/jquery-3.7.1.min.js"></script>
    <script src="~/Admin/assets/js/core/core.js"></script>


    @{
        var tagifyCss = Url.Content("~/vendor/tagify/tagify.css");
        var tagifyJs = Url.Content("~/vendor/tagify/tagify.min.js");
    }
    <!-- Tagify CSS -->
    <link rel="stylesheet" href="@tagifyCss">
    <!-- Tagify JS -->
    <script src="@tagifyJs"></script>


    <!-- Bootstrap-select CSS -->
    <link rel="stylesheet" href="~/vendor/bootstrap-select/css/bootstrap-select.min.css" asp-append-version="true">

</head>
<body class="admin-layout">
    @* Lib support *@
    @using Tech_Store.Helpers
    @{
        var adminController = (ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty).Trim();
        var adminAction = (ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty).Trim();
        var pageTitle = (ViewData["Title"]?.ToString() ?? adminController).Trim();

        string GetAdminSectionLabel(string controllerName)
        {
            return controllerName.ToLowerInvariant() switch
            {
                "index" => "Dashboard",
                "pos" => "POS - Bán hàng",
                "categories" => "Danh mục sản phẩm",
                "brands" => "Thương hiệu",
                "products" => "Sản phẩm",
                "stockmanager" => "Quản lý kho hàng",
                "suppliers" => "Nhà cung cấp",
                "orders" => "Đơn hàng",
                "users" => "Khách hàng",
                "transactions" => "Giao dịch",
                "vouchers" => "Voucher",
                "banner" => "Banner",
                "banners" => "Banner",
                "settings" => "Cài đặt trang web",
                "notifications" => "Thông báo",
                _ => controllerName
            };
        }

        var sectionLabel = GetAdminSectionLabel(adminController);
        var showSectionCrumb = !string.IsNullOrWhiteSpace(sectionLabel)
            && !string.Equals(sectionLabel, pageTitle, StringComparison.OrdinalIgnoreCase);
    }


    <div class="wrapper admin-shell sidebar-expanded" id="adminLayout">
        <!-- Sidebar -->
        <button class="admin-sidebar-overlay" type="button" data-sidebar-overlay aria-label="Đóng menu điều hướng"></button>

        <aside class="sidebar admin-sidebar" data-background-color="dark" id="adminSidebar" aria-label="Điều hướng quản trị">
            <div class="sidebar-logo">
                <div class="logo-header admin-sidebar__brand" data-background-color="dark">
                    <a href="/Admin" class="logo admin-sidebar__logo" aria-label="Trang chủ quản trị">
                        <img src="@ViewBag.LogoUrl" alt="Tech Store" class="navbar-brand" height="46" />
                    </a>
                    <button class="btn btn-toggle admin-sidebar__desktop-toggle"
                            type="button"
                            data-sidebar-desktop-toggle
                            aria-label="Thu gọn hoặc mở rộng sidebar">
                        <i class="fas fa-bars"></i>
                    </button>
                </div>
            </div>

            <div class="sidebar-wrapper scrollbar scrollbar-inner">
                <div class="sidebar-content">
                    <ul class="nav nav-secondary admin-sidebar-nav">
                        <li class="nav-item admin-sidebar__item" data-route-exact="/admin,/admin/index">
                            <a href="/Admin/Index" class="nav-link admin-sidebar__link" data-sidebar-link>
                                <span class="admin-sidebar__icon"><i class="fas fa-home"></i></span>
                                <span class="admin-sidebar__label">Dashboard</span>
                            </a>
                        </li>

                        <li class="nav-item admin-sidebar__item" data-route-prefixes="/admin/pos">
                            <a href="/Admin/POS" class="nav-link admin-sidebar__link" data-sidebar-link>
                                <span class="admin-sidebar__icon"><i class="fas fa-store"></i></span>
                                <span class="admin-sidebar__label">POS - Bán hàng</span>
                            </a>
                        </li>

                        <li class="nav-section admin-sidebar__section">
                            <span class="sidebar-mini-icon"><i class="fa fa-ellipsis-h"></i></span>
                            <h4 class="text-section">Quản lý sản phẩm</h4>
                        </li>

                        <li class="nav-item admin-sidebar__item admin-sidebar__item--has-submenu" data-route-prefixes="/admin/categories">
                            <button class="nav-link admin-sidebar__link admin-sidebar__link--submenu"
                                    type="button"
                                    data-sidebar-submenu-trigger
                                    aria-expanded="false"
                                    aria-controls="sidebar-submenu-categories">
                                <span class="admin-sidebar__icon"><i class="fas fa-th-list"></i></span>
                                <span class="admin-sidebar__label">Danh mục sản phẩm</span>
                                <span class="admin-sidebar__caret"><i class="fas fa-chevron-down"></i></span>
                            </button>
                            <div class="admin-sidebar__submenu" id="sidebar-submenu-categories">
                                <div class="admin-sidebar__submenu-inner">
                                    <a href="/Admin/Categories" class="nav-link admin-sidebar__sublink" data-sidebar-link>
                                        <span class="sub-item">Quản lý danh mục</span>
                                    </a>
                                </div>
                            </div>
                        </li>

                        <li class="nav-item admin-sidebar__item admin-sidebar__item--has-submenu" data-route-prefixes="/admin/brands">
                            <button class="nav-link admin-sidebar__link admin-sidebar__link--submenu"
                                    type="button"
                                    data-sidebar-submenu-trigger
                                    aria-expanded="false"
                                    aria-controls="sidebar-submenu-brands">
                                <span class="admin-sidebar__icon"><i class="fas fa-tags"></i></span>
                                <span class="admin-sidebar__label">Thương hiệu</span>
                                <span class="admin-sidebar__caret"><i class="fas fa-chevron-down"></i></span>
                            </button>
                            <div class="admin-sidebar__submenu" id="sidebar-submenu-brands">
                                <div class="admin-sidebar__submenu-inner">
                                    <a href="/Admin/Brands" class="nav-link admin-sidebar__sublink" data-sidebar-link>
                                        <span class="sub-item">Quản lý thương hiệu</span>
                                    </a>
                                </div>
                            </div>
                        </li>

                        <li class="nav-item admin-sidebar__item admin-sidebar__item--has-submenu" data-route-prefixes="/admin/products">
                            <button class="nav-link admin-sidebar__link admin-sidebar__link--submenu"
                                    type="button"
                                    data-sidebar-submenu-trigger
                                    aria-expanded="false"
                                    aria-controls="sidebar-submenu-products">
                                <span class="admin-sidebar__icon"><i class="fas fa-box-open"></i></span>
                                <span class="admin-sidebar__label">Sản phẩm</span>
                                <span class="admin-sidebar__caret"><i class="fas fa-chevron-down"></i></span>
                            </button>
                            <div class="admin-sidebar__submenu" id="sidebar-submenu-products">
                                <div class="admin-sidebar__submenu-inner">
                                    <a href="/Admin/Products/all" class="nav-link admin-sidebar__sublink" data-sidebar-link>
                                        <span class="sub-item">Tổng sản phẩm <span class="badge badge-dark">@ViewBag.Product_all</span></span>
                                    </a>
                                    <a href="/Admin/Products/available" class="nav-link admin-sidebar__sublink" data-sidebar-link>
                                        <span class="sub-item">Sản phẩm sẵn hàng <span class="badge badge-success">@ViewBag.Product_available</span></span>
                                    </a>
                                    <a href="/Admin/Products/outstock" class="nav-link admin-sidebar__sublink" data-sidebar-link>
                                        <span class="sub-item">Sản phẩm hết hàng <span class="badge badge-danger">@ViewBag.Product_outstock</span></span>
                                    </a>
                                    <a href="/Admin/Products/preorder" class="nav-link admin-sidebar__sublink" data-sidebar-link>
                                        <span class="sub-item">Sản phẩm đặt trước <span class="badge badge-warning">@ViewBag.Product_preorder</span></span>
                                    </a>
                                    <a href="/Admin/Products/discontinued" class="nav-link admin-sidebar__sublink" data-sidebar-link>
                                        <span class="sub-item">Sản phẩm ngừng bán <span class="badge badge-secondary">@ViewBag.Product_discontinued</span></span>
                                    </a>
                                </div>
                            </div>
                        </li>

                        <li class="nav-item admin-sidebar__item admin-sidebar__item--has-submenu" data-route-prefixes="/admin/stockmanager,/admin/suppliers">
                            <button class="nav-link admin-sidebar__link admin-sidebar__link--submenu"
                                    type="button"
                                    data-sidebar-submenu-trigger
                                    aria-expanded="false"
                                    aria-controls="sidebar-submenu-inventory">
                                <span class="admin-sidebar__icon"><i class="fas fa-warehouse"></i></span>
                                <span class="admin-sidebar__label">Quản lý kho hàng</span>
                                <span class="admin-sidebar__caret"><i class="fas fa-chevron-down"></i></span>
                            </button>
                            <div class="admin-sidebar__submenu" id="sidebar-submenu-inventory">
                                <div class="admin-sidebar__submenu-inner">
                                    <a href="/Admin/StockManager" class="nav-link admin-sidebar__sublink" data-sidebar-link>
                                        <span class="sub-item">Nhập/Xuất hàng</span>
                                    </a>
                                    <a href="/Admin/Suppliers" class="nav-link admin-sidebar__sublink" data-sidebar-link>
                                        <span class="sub-item">Nhà cung cấp</span>
                                    </a>
                                    <a href="/Admin/StockManager/History" class="nav-link admin-sidebar__sublink" data-sidebar-link>
                                        <span class="sub-item">Lịch sử kho</span>
                                    </a>
                                </div>
                            </div>
                        </li>

                        <li class="nav-section admin-sidebar__section">
                            <span class="sidebar-mini-icon"><i class="fa fa-ellipsis-h"></i></span>
                            <h4 class="text-section">Quản lý đơn hàng</h4>
                        </li>

                        <li class="nav-item admin-sidebar__item admin-sidebar__item--has-submenu" data-route-prefixes="/admin/orders">
                            <button class="nav-link admin-sidebar__link admin-sidebar__link--submenu"
                                    type="button"
                                    data-sidebar-submenu-trigger
                                    aria-expanded="false"
                                    aria-controls="sidebar-submenu-orders">
                                <span class="admin-sidebar__icon"><i class="fas fa-shopping-cart"></i></span>
                                <span class="admin-sidebar__label">Đơn hàng</span>
                                <span class="admin-sidebar__caret"><i class="fas fa-chevron-down"></i></span>
                            </button>
                            <div class="admin-sidebar__submenu" id="sidebar-submenu-orders">
                                <div class="admin-sidebar__submenu-inner">
                                    <a href="/Admin/Orders/all" class="nav-link admin-sidebar__sublink" data-sidebar-link>
                                        <span class="sub-item">Tất cả đơn hàng <span class="badge badge-dark">@ViewBag.Order_all</span></span>
                                    </a>
                                    <a href="/Admin/Orders/pending" class="nav-link admin-sidebar__sublink" data-sidebar-link>
                                        <span class="sub-item">Đang xử lý <span class="badge badge-primary">@ViewBag.Order_pending</span></span>
                                    </a>
                                    <a href="/Admin/Orders/confirmed" class="nav-link admin-sidebar__sublink" data-sidebar-link>
                                        <span class="sub-item">Đã xác nhận <span class="badge badge-info">@ViewBag.Order_confirmed</span></span>
                                    </a>
                                    <a href="/Admin/Orders/shipping" class="nav-link admin-sidebar__sublink" data-sidebar-link>
                                        <span class="sub-item">Đang giao hàng <span class="badge badge-warning">@ViewBag.Order_shipping</span></span>
                                    </a>
                                    <a href="/Admin/Orders/delivered" class="nav-link admin-sidebar__sublink" data-sidebar-link>
                                        <span class="sub-item">Đã giao hàng <span class="badge badge-light">@ViewBag.Order_delivered</span></span>
                                    </a>
                                    <a href="/Admin/Orders/completed" class="nav-link admin-sidebar__sublink" data-sidebar-link>
                                        <span class="sub-item">Hoàn tất <span class="badge badge-success">@ViewBag.Order_completed</span></span>
                                    </a>
                                    <a href="/Admin/Orders/cancelled" class="nav-link admin-sidebar__sublink" data-sidebar-link>
                                        <span class="sub-item">Đã hủy <span class="badge badge-danger">@ViewBag.Order_cancelled</span></span>
                                    </a>
                                    <a href="/Admin/Orders/refunded" class="nav-link admin-sidebar__sublink" data-sidebar-link>
                                        <span class="sub-item">Hoàn tiền <span class="badge badge-secondary">@ViewBag.Order_refunded</span></span>
                                    </a>
                                </div>
                            </div>
                        </li>

                        <li class="nav-item admin-sidebar__item admin-sidebar__item--has-submenu" data-route-prefixes="/admin/users">
                            <button class="nav-link admin-sidebar__link admin-sidebar__link--submenu"
                                    type="button"
                                    data-sidebar-submenu-trigger
                                    aria-expanded="false"
                                    aria-controls="sidebar-submenu-users">
                                <span class="admin-sidebar__icon"><i class="fas fa-user"></i></span>
                                <span class="admin-sidebar__label">Khách hàng</span>
                                <span class="admin-sidebar__caret"><i class="fas fa-chevron-down"></i></span>
                            </button>
                            <div class="admin-sidebar__submenu" id="sidebar-submenu-users">
                                <div class="admin-sidebar__submenu-inner">
                                    <a href="/Admin/Users" class="nav-link admin-sidebar__sublink" data-sidebar-link>
                                        <span class="sub-item">Danh sách khách hàng</span>
                                    </a>
                                </div>
                            </div>
                        </li>

                        <li class="nav-item admin-sidebar__item" data-route-prefixes="/admin/transactions">
                            <a href="/Admin/Transactions" class="nav-link admin-sidebar__link" data-sidebar-link>
                                <span class="admin-sidebar__icon"><i class="fas fa-exchange-alt"></i></span>
                                <span class="admin-sidebar__label">Giao dịch</span>
                            </a>
                        </li>

                        <li class="nav-item admin-sidebar__item" data-route-prefixes="/admin/vouchers">
                            <a href="/Admin/Vouchers" class="nav-link admin-sidebar__link" data-sidebar-link>
                                <span class="admin-sidebar__icon"><i class="fas fa-ticket-alt"></i></span>
                                <span class="admin-sidebar__label">Voucher</span>
                            </a>
                        </li>

                        <li class="nav-section admin-sidebar__section">
                            <span class="sidebar-mini-icon"><i class="fa fa-ellipsis-h"></i></span>
                            <h4 class="text-section">Cài đặt chiến dịch</h4>
                        </li>

                        <li class="nav-item admin-sidebar__item admin-sidebar__item--has-submenu" data-route-prefixes="/admin/banners">
                            <button class="nav-link admin-sidebar__link admin-sidebar__link--submenu"
                                    type="button"
                                    data-sidebar-submenu-trigger
                                    aria-expanded="false"
                                    aria-controls="sidebar-submenu-banners">
                                <span class="admin-sidebar__icon"><i class="fas fa-images"></i></span>
                                <span class="admin-sidebar__label">Banner</span>
                                <span class="admin-sidebar__caret"><i class="fas fa-chevron-down"></i></span>
                            </button>
                            <div class="admin-sidebar__submenu" id="sidebar-submenu-banners">
                                <div class="admin-sidebar__submenu-inner">
                                    <a href="/Admin/Banners/Index" class="nav-link admin-sidebar__sublink" data-sidebar-link>
                                        <span class="sub-item">Danh sách banner</span>
                                    </a>
                                </div>
                            </div>
                        </li>

                        <li class="nav-section admin-sidebar__section">
                            <span class="sidebar-mini-icon"><i class="fa fa-ellipsis-h"></i></span>
                            <h4 class="text-section">Cài đặt hệ thống</h4>
                        </li>

                        <li class="nav-item admin-sidebar__item" data-route-prefixes="/admin/settings">
                            <a href="/Admin/Settings" class="nav-link admin-sidebar__link" data-sidebar-link>
                                <span class="admin-sidebar__icon"><i class="fas fa-cog"></i></span>
                                <span class="admin-sidebar__label">Cài đặt trang web</span>
                            </a>
                        </li>

                        <li class="nav-item admin-sidebar__item" data-route-exact="/admin/notifications/index" data-route-prefixes="/admin/notifications">
                            <a href="/Admin/Notifications/Index" class="nav-link admin-sidebar__link" data-sidebar-link>
                                <span class="admin-sidebar__icon"><i class="fas fa-bell"></i></span>
                                <span class="admin-sidebar__label">Thông báo</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </aside>
        <!-- End Sidebar -->

        <div class="main-panel">
            <div class="main-header">
                <div class="main-header-logo">
                    <!-- Logo Header -->
                    <div class="logo-header admin-mobile-header" data-background-color="dark">
                        <button class="btn btn-toggle admin-sidebar__mobile-toggle"
                                type="button"
                                data-sidebar-mobile-toggle
                                aria-label="Mở menu điều hướng">
                            <i class="fas fa-bars"></i>
                        </button>
                        <a href="/Admin" class="logo">
                            <img src="@ViewBag.LogoUrl"
                                 alt="Tech Store"
                                 class="navbar-brand"
                                 height="32" />
                        </a>
                        <button class="topbar-toggler more">
                            <i class="gg-more-vertical-alt"></i>
                        </button>
                    </div>
                    <!-- End Logo Header -->
                </div>
                <!-- Navbar Header -->
                <nav class="navbar navbar-header navbar-header-transparent navbar-expand-lg border-bottom">
                    <div class="container-fluid">
                        <div class="admin-header-tools d-none d-lg-flex">
                            <nav class="navbar navbar-header-left navbar-expand-lg navbar-form nav-search p-0">
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <button type="submit" class="btn btn-search pe-1">
                                            <i class="fa fa-search search-icon"></i>
                                        </button>
                                    </div>
                                    <input type="text" id="searchInput" class="form-control" placeholder="Tìm kiếm sản phẩm nhanh...">
                                </div>

                                <ul class="list-group position-absolute w-100 mt-1 shadow-sm d-none"
                                    id="searchSuggestions"
                                    style="max-height: 300px; overflow-y: auto; scrollbar-width: none;  top: 100%;">
                                    <!-- Suggestions will be dynamically added here -->
                                </ul>
                            </nav>
                        </div>

                        <ul class="navbar-nav topbar-nav ms-md-auto align-items-center">
                            <li class="nav-item topbar-icon dropdown hidden-caret d-flex d-lg-none">
                                <a class="nav-link dropdown-toggle"
                                   data-bs-toggle="dropdown"
                                   href="#"
                                   role="button"
                                   aria-expanded="false"
                                   aria-haspopup="true">
                                    <i class="fa fa-search"></i>
                                </a>
                                <ul class="dropdown-menu dropdown-search animated fadeIn">
                                    <form class="navbar-left navbar-form nav-search">
                                        <div class="input-group">
                                            <input type="text"
                                                   placeholder="Search ..."
                                                   class="form-control" />
                                        </div>
                                    </form>
                                </ul>
                            </li>
                            <li class="nav-item dropdown hidden-caret">
                                <div class="nav-link dropdown-toggle" id="realtimeClock">
                                    Ngày giờ hiện tại Realtime
                                </div>
                                
                                <a class="nav-link dropdown-toggle"
                                   href="https://dashboard.tawk.to/#/dashboard"
                                   id="messageDropdown"
                                   aria-haspopup="true"
                                   aria-expanded="false"
                                   target="_blank">
                                   <strong class="fw-bold text-warning">
                                        Ứng dụng nhắn tin
                                   </strong>
                           
                                </a>
                     
                            </li>
                            <li class="nav-item topbar-icon dropdown hidden-caret">
                                <a class="nav-link dropdown-toggle"
                                   href="#"
                                   id="notifDropdown"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-haspopup="true"
                                   aria-expanded="false">
                                    <i class="fa fa-bell"></i>
                                    <span class="notification">@ViewBag.Notification_count</span>
                                </a>
                                <ul class="dropdown-menu notif-box animated fadeIn"
                                    aria-labelledby="notifDropdown" style="width:450px">
                                    <li>
                                        <div class="dropdown-title">
                                            Thông báo
                                        </div>

                                        <div class="d-flex justify-content-between align-items-center mt-2">
                                            @if (ViewBag.Notifications.Count > 0)
                                            {
                                                <button class="btn p-0 border-0 text-primary" type="button" id="markAllAsRead">
                                                    Đánh dấu tất cả là đã đọc
                                                </button>
                                            }

                                            <a href="~/admin/notifications/index" class="ms-auto text-decoration-none small">
                                                Xem tất cả
                                            </a>
                                        </div>
                                    </li>
                                    <li>
                                        <div class="notif-scroll scrollbar-outer">
                                            <div class="notif-center">
                                                @if(ViewBag.Notifications.Count >0 )
                                                {
                                                    foreach(var noti in ViewBag.Notifications)
                                                    {
                                                        <a href="@noti.RedirectUrl" class="@(noti.IsRead == false ? "bg-light mark-as-read" : "bg-white") " data-id="@noti.UserNotificationId">
                                                            @if (noti.Type == "new register")
                                                            {
                                                                <div class="notif-icon notif-primary">
                                                                    <i class="fa fa-user-plus"></i>
                                                                </div>
                                                            }
                                                            else if (noti.Type == "order completed")
                                                            {
                                                                <div class="notif-icon notif-success">
