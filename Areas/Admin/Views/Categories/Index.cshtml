@model Tech_Store.Models.ViewModel.AdminCategoryIndexViewModel
@{
    ViewData["Title"] = "Danh mục";
    Layout = "~/Areas/Admin/Views/Shared/Layout.cshtml";
}

<div class="py-3">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-0 pb-0">
            <div class="d-flex flex-wrap gap-3 align-items-center justify-content-between">
                <div>
                    <h4 class="card-title mb-1">Danh sách danh mục</h4>
                </div>
                <a href="@Url.Action("Form", "Categories", new { area = "Admin", page = Model.Page, pageSize = Model.PageSize, keyword = Model.Keyword })"
                   class="btn btn-primary">
                    <i class="fa fa-plus me-1"></i>
                    Thêm danh mục
                </a>
            </div>
        </div>
        <div class="card-body">
            <form method="get" class="brand-admin__filters row g-3 align-items-end mb-4">
                <input type="hidden" name="pageSize" value="@Model.PageSize" />
                <div class="col-lg-9">
                    <label class="form-label fw-semibold text-secondary">Tìm kiếm</label>
                    <input type="text"
                           class="form-control"
                           name="keyword"
                           value="@Model.Keyword"
                           placeholder="Tên danh mục, slug hoặc mô tả..." />
                </div>
                <div class="col-lg-3">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-grow-1">Tìm kiếm</button>
                        <a href="/Admin/Categories" class="btn btn-light border">Làm mới</a>
                    </div>
                </div>
            </form>

            <div class="table-responsive reusable-admin-table">
                <table class="table table-hover align-middle brand-admin__table">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 84px;">Ảnh</th>
                            <th>Danh mục</th>
                            <th style="width: 120px;">Thứ tự</th>
                            <th>Tiêu đề tiếng Anh</th>
                            <th>Mô tả</th>
                            <th style="width:15%">Hiển thị trang chủ</th>
                            <th style="width:10%" class="text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Categories.Count == 0)
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-5">
                                    Không có danh mục phù hợp với bộ lọc hiện tại.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var cate in Model.Categories)
                            {
                                <tr>
                                    <td>
                                        <div class="brand-admin__logo-shell">
                                            <img src="/Upload/Logo/@(cate.Image ?? "none.jpg")"
                                                 alt="@cate.Name"
                                                 class="brand-admin__logo" />
                                        </div>
                                    </td>
                                    <td class="fw-semibold">@cate.Name</td>
                                    <td>
                                        <span class="badge text-bg-light border brand-admin__order-badge">@cate.SortOrder</span>
                                    </td>
                                    <td>@cate.EngTitle</td>
                                    <td class="text-muted">@(string.IsNullOrWhiteSpace(cate.Description) ? "-" : cate.Description)</td>
                                    <td>
                                        <div class="form-check form-switch d-flex justify-content-center">
                                            <input class="form-check-input"
                                                   type="checkbox"
                                                   id="flexSwitchCheckChecked"
                                                   @(cate.Visible == 1 ? "checked" : "")
                                                   data-id="@cate.CategoryId">
                                            <label class="form-check-label" for="flexSwitchCheckChecked">
                                                Ẩn/Hiện
                                            </label>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="form-button-action justify-content-center">
                                            <a href="@Url.Action("Form", "Categories", new { area = "Admin", id = cate.CategoryId, page = Model.Page, pageSize = Model.PageSize, keyword = Model.Keyword })"
                                               class="btn btn-link btn-primary btn-lg"
                                               data-bs-toggle="tooltip"
                                               title="Edit">
                                                <i class="fa fa-edit"></i>
                                            </a>
                                            <button type="button"
                                                    data-bs-toggle="tooltip"
                                                    class="btn btn-link btn-danger"
                                                    data-id="@cate.CategoryId"
                                                    id="removeCate"
                                                    data-original-title="Remove">
                                                <i class="fa fa-times"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_ManualPagination.cshtml", new Tech_Store.Models.ViewModel.ManualPaginationViewModel
            {
                CurrentPage = Model.Page,
                TotalPages = Model.TotalPages,
                BaseUrl = "/Admin/Categories",
                QueryString = string.Join("&", new[]
                {
                    !string.IsNullOrWhiteSpace(Model.Keyword) ? $"keyword={Uri.EscapeDataString(Model.Keyword)}" : null,
                    $"pageSize={Model.PageSize}"
                }.Where(x => !string.IsNullOrWhiteSpace(x)))
            })
        </div>
    </div>
</div>

<script type="text/javascript">
    $(document).ready(function () {
        $(document).on('click', '#removeCate', function () {
            var id_cate = $(this).data('id');

            Swal.fire({
                title: 'Bạn có chắc chắn muốn xóa danh mục này không?',
                text: "Hành động này không thể hoàn tác!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Xóa',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    $('.loading-container').show();

                    $.ajax({
                        method: 'DELETE',
                        url: 'Categories/Delete/' + id_cate,
                        success: function () {
                            $('.loading-container').hide();
                            location.reload();
                        },
                        error: function (xhr, status, error) {
                            $('.loading-container').hide();
                            Swal.fire({
                                icon: 'error',
                                title: 'Lỗi',
                                text: 'Đã xảy ra lỗi khi xóa danh mục: ' + error
                            });
                        }
                    });
                }
            });
        });

        $(document).on('change', '#flexSwitchCheckChecked', function () {
            var id = $(this).data('id');
            var isVisible = $(this).is(':checked') ? 1 : 0;

            var confirmMessage = isVisible
                ? "Bạn có chắc chắn muốn hiển thị danh mục này không?"
                : "Bạn có chắc chắn muốn ẩn danh mục này không?";

            Swal.fire({
                title: 'Xác nhận',
                text: confirmMessage,
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Đồng ý',
                cancelButtonText: 'Hủy',
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        method: 'POST',
                        url: '/Admin/Categories/ChangeVisible',
                        data: { id: id },
                        success: function (response) {
                            if (response.success) {
                                Swal.fire({
                                    title: 'Thành công!',
                                    text: response.message,
                                    icon: 'success',
                                    timer: 2000,
                                    showConfirmButton: false
                                });
                            } else {
                                Swal.fire({
                                    title: 'Lỗi!',
                                    text: response.message,
                                    icon: 'error',
                                });
                            }
                        },
                        error: function (xhr, status, error) {
                            Swal.fire({
                                title: 'Đã xảy ra lỗi!',
                                text: error,
                                icon: 'error',
                            });
                        }
                    });
                } else {
                    $(this).prop('checked', !isVisible);
                }
            });
        });
    });
</script>
