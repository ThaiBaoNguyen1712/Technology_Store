@model Tech_Store.Models.ViewModel.AdminTransactionIndexViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Giao dịch";
    Layout = "~/Areas/Admin/Views/Shared/Layout.cshtml";
}

<div class="py-3 transaction-admin-page">
    @Html.AntiForgeryToken()

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-0 pb-0">
            <div class="d-flex flex-wrap gap-3 align-items-center justify-content-between">
                <div>
                    <h4 class="card-title mb-1">Danh sách giao dịch</h4>
                </div>
                <div class="order-admin__header-meta">
                    <span class="order-admin__header-pill">Tổng giao dịch: @Model.TotalItems</span>
                    <span class="order-admin__header-pill">Trang @Model.Page/@Model.TotalPages</span>
                </div>
            </div>
        </div>

        <div class="card-body">
            <form method="get" class="brand-admin__filters transaction-admin__filters row g-3 align-items-end mb-4">
                <input type="hidden" name="page" value="1" />

                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Mã giao dịch</label>
                    <input type="number"
                           class="form-control"
                           name="transactionId"
                           value="@Model.TransactionId"
                           min="1"
                           placeholder="Nhập mã giao dịch" />
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Mã đơn hàng</label>
                    <input type="number"
                           class="form-control"
                           name="orderId"
                           value="@Model.OrderId"
                           min="1"
                           placeholder="Nhập mã đơn hàng" />
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Khách hàng</label>
                    <input type="text"
                           class="form-control"
                           name="customerName"
                           value="@Model.CustomerName"
                           placeholder="Nhập tên khách hàng" />
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Số điện thoại</label>
                    <input type="text"
                           class="form-control"
                           name="phoneNumber"
                           value="@Model.PhoneNumber"
                           placeholder="Nhập số điện thoại" />
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Thanh toán</label>
                    <select class="form-select" name="paymentStatus">
                        <option value="">Tất cả trạng thái</option>
                        @if (Model.PaymentStatus == "Paid")
                        {
                            <option value="Paid" selected>Đã thanh toán</option>
                        }
                        else
                        {
                            <option value="Paid">Đã thanh toán</option>
                        }
                        @if (Model.PaymentStatus == "Unpaid")
                        {
                            <option value="Unpaid" selected>Chưa thanh toán</option>
                        }
                        else
                        {
                            <option value="Unpaid">Chưa thanh toán</option>
                        }
                    </select>
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Phương thức</label>
                    <select class="form-select" name="paymentMethod">
                        <option value="">Tất cả phương thức</option>
                        @if (Model.PaymentMethod == "COD")
                        {
                            <option value="COD" selected>COD</option>
                        }
                        else
                        {
                            <option value="COD">COD</option>
                        }
                        @if (Model.PaymentMethod == "MoMo")
                        {
                            <option value="MoMo" selected>MoMo</option>
                        }
                        else
                        {
                            <option value="MoMo">MoMo</option>
                        }
                        @if (Model.PaymentMethod == "VNPay")
                        {
                            <option value="VNPay" selected>VNPay</option>
                        }
                        else
                        {
                            <option value="VNPay">VNPay</option>
                        }
                        @if (Model.PaymentMethod == "cash")
                        {
                            <option value="cash" selected>Tiền mặt</option>
                        }
                        else
                        {
                            <option value="cash">Tiền mặt</option>
                        }
                    </select>
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Từ ngày</label>
                    <input type="date"
                           class="form-control"
                           name="dateFrom"
                           value="@(Model.DateFrom?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Đến ngày</label>
                    <input type="date"
                           class="form-control"
                           name="dateTo"
                           value="@(Model.DateTo?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Giá trị từ</label>
                    <input type="number"
                           class="form-control"
                           name="amountFrom"
                           value="@Model.AmountFrom"
                           min="0"
                           placeholder="0" />
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Giá trị đến</label>
                    <input type="number"
                           class="form-control"
                           name="amountTo"
                           value="@Model.AmountTo"
                           min="0"
                           placeholder="0" />
                </div>
                <div class="col-md-6 col-xl-3 ms-xl-auto admin-search-actions-col">
                    <div class="admin-search-actions">
                        <button type="submit" class="btn btn-primary">Tìm kiếm</button>
                        <a href="/Admin/Transactions" class="btn btn-light border">Làm mới</a>
                    </div>
                </div>
            </form>

            <div class="table-responsive reusable-admin-table">
                <table class="table table-hover align-middle transaction-admin__table">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 110px;">Mã GD</th>
                            <th style="width: 110px;">Mã đơn</th>
                            <th>Khách hàng</th>
                            <th style="width: 300px;">Phương thức</th>
                            <th style="width: 180px;">Giá trị</th>
                            <th style="width: 170px;">Thanh toán</th>
                            <th style="width: 170px;">Ngày tạo</th>
                            <th style="width: 140px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Transactions.Count == 0)
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-5">
                                    Không có giao dịch phù hợp với bộ lọc hiện tại.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var transaction in Model.Transactions)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-semibold text-dark">#@transaction.PaymentId</div>
                                    </td>
                                    <td>
                                        @if (transaction.OrderId > 0)
                                        {
                                            <a href="/Admin/Orders/View/@transaction.OrderId" class="transaction-admin__order-link">
                                                #@transaction.OrderId
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="user-admin__customer">
                                            <div class="fw-semibold text-dark">@(string.IsNullOrWhiteSpace(transaction.CustomerName) ? "-" : transaction.CustomerName)</div>
                                            <div class="user-admin__meta">
                                                <span>@(string.IsNullOrWhiteSpace(transaction.PhoneNumber) ? "-" : transaction.PhoneNumber)</span>
                                                <span>@(string.IsNullOrWhiteSpace(transaction.Email) ? "Chưa có email" : transaction.Email)</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="transaction-admin__payment">
                                            @if (!string.IsNullOrWhiteSpace(transaction.PaymentMethodAsset))
                                            {
                                                <div class="transaction-admin__payment-icon-shell">
                                                    <img src="@transaction.PaymentMethodAsset"
                                                         class="transaction-admin__payment-icon"
                                                         alt="@transaction.PaymentMethod" />
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="transaction-admin__payment-icon-shell transaction-admin__payment-icon-shell--fallback">
                                                    <i class="fas fa-wallet"></i>
                                                </div>
                                            }
                                            <div class="order-admin__state-body">
                                                <strong>@transaction.PaymentMethodLabel</strong>
                                                <span>@transaction.PaymentMethod</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="transaction-admin__amount">@transaction.Amount.ToString("C0", new CultureInfo("vi-VN"))</div>
                                    </td>
                                    <td>
                                        <div class="order-admin__state">
                                            <span class="order-admin__state-dot @(string.Equals(transaction.Status, "Paid", StringComparison.OrdinalIgnoreCase) ? "order-admin__state-dot--success" : "order-admin__state-dot--danger")"></span>
                                            <div class="order-admin__state-body">
                                                <strong>@transaction.PaymentStatusLabel</strong>
                                                <span>@((transaction.PaymentDate ?? transaction.CreatedAt)?.ToString("dd/MM/yyyy HH:mm:ss") ?? "-")</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="text-dark">@((transaction.CreatedAt ?? transaction.PaymentDate)?.ToString("dd/MM/yyyy") ?? "-")</div>
                                        <div class="small text-muted">@((transaction.CreatedAt ?? transaction.PaymentDate)?.ToString("HH:mm:ss") ?? "-")</div>
                                    </td>
                                    <td>
                                        <button type="button"
                                                class="btn btn-light border transaction-admin__action-button open-transaction-drawer"
                                                data-id="@transaction.PaymentId">
                                            Tác vụ
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_ManualPagination.cshtml", new Tech_Store.Models.ViewModel.ManualPaginationViewModel
            {
                CurrentPage = Model.Page,
                TotalPages = Model.TotalPages,
                BaseUrl = "/Admin/Transactions",
                QueryString = string.Join("&", new[]
                {
                    Model.TransactionId.HasValue ? $"transactionId={Model.TransactionId.Value}" : null,
                    Model.OrderId.HasValue ? $"orderId={Model.OrderId.Value}" : null,
                    !string.IsNullOrWhiteSpace(Model.CustomerName) ? $"customerName={Uri.EscapeDataString(Model.CustomerName)}" : null,
                    !string.IsNullOrWhiteSpace(Model.PhoneNumber) ? $"phoneNumber={Uri.EscapeDataString(Model.PhoneNumber)}" : null,
                    !string.IsNullOrWhiteSpace(Model.PaymentStatus) ? $"paymentStatus={Uri.EscapeDataString(Model.PaymentStatus)}" : null,
                    !string.IsNullOrWhiteSpace(Model.PaymentMethod) ? $"paymentMethod={Uri.EscapeDataString(Model.PaymentMethod)}" : null,
                    Model.DateFrom.HasValue ? $"dateFrom={Model.DateFrom.Value:yyyy-MM-dd}" : null,
                    Model.DateTo.HasValue ? $"dateTo={Model.DateTo.Value:yyyy-MM-dd}" : null,
                    Model.AmountFrom.HasValue ? $"amountFrom={Model.AmountFrom.Value}" : null,
                    Model.AmountTo.HasValue ? $"amountTo={Model.AmountTo.Value}" : null
                }.Where(x => !string.IsNullOrWhiteSpace(x)))
            })
        </div>
    </div>
</div>

@await Html.PartialAsync("~/Areas/Admin/Views/Shared/_AdminRightDrawer.cshtml", new Tech_Store.Models.ViewModel.AdminRightDrawerViewModel
{
    DrawerId = "transactionQuickDrawer",
    Title = "Xử lý giao dịch",
    BodyId = "transactionQuickDrawerBody",
    WidthClass = "admin-right-drawer--lg"
})

<script>
    $(document).ready(function () {
        const drawerElement = document.getElementById('transactionQuickDrawer');
        const drawerBody = $('#transactionQuickDrawerBody');
        const transactionDrawer = drawerElement ? bootstrap.Offcanvas.getOrCreateInstance(drawerElement) : null;
        const antiForgeryToken = $('input[name="__RequestVerificationToken"]').val();

        $(document).on('click', '.open-transaction-drawer', function (e) {
            e.preventDefault();

            if (!transactionDrawer) {
                return;
            }

            const id = $(this).data('id');
            drawerBody.html('<div class="admin-right-drawer__loading">Đang tải thông tin giao dịch...</div>');
            transactionDrawer.show();
            $('.loading-container').show();

            $.ajax({
                method: 'GET',
                url: '/Admin/Transactions/QuickDrawer/' + id,
                success: function (html) {
                    drawerBody.html(html);
                },
                error: function () {
                    drawerBody.html('<div class="alert alert-danger mb-0">Không thể tải thông tin giao dịch.</div>');
                },
                complete: function () {
                    $('.loading-container').hide();
                }
            });
        });

        $(document).on('click', '#confirmDrawerPayment', function (e) {
            e.preventDefault();

            const button = $(this);
            const paymentId = button.data('id');

            if (button.prop('disabled')) {
                return;
            }

            Swal.fire({
                title: 'Xác nhận thanh toán',
                text: 'Bạn có chắc muốn xác nhận giao dịch #' + paymentId + ' đã thanh toán?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Xác nhận',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (!result.isConfirmed) {
                    return;
                }

                button.prop('disabled', true);
                $('.loading-container').show();

                $.ajax({
                    method: 'POST',
                    url: '/Admin/Transactions/UpdateStatus',
                    data: {
                        paymentId: paymentId,
                        __RequestVerificationToken: antiForgeryToken
                    },
                    success: function (response) {
                        if (!response.success) {
                            Swal.fire('Không thể thực hiện', response.message, 'error');
                            button.prop('disabled', false);
                            return;
                        }

                        Swal.fire('Thành công', response.message, 'success').then(() => {
                            location.reload();
                        });
                    },
                    error: function () {
                        Swal.fire('Lỗi', 'Không thể xác nhận thanh toán giao dịch này.', 'error');
                        button.prop('disabled', false);
                    },
                    complete: function () {
                        $('.loading-container').hide();
                    }
                });
            });
        });
    });
</script>
