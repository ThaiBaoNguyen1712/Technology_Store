@model Tech_Store.Models.ViewModel.AdminBrandIndexViewModel

@{
    ViewData["Title"] = "Thương hiệu";
    Layout = "~/Areas/Admin/Views/Shared/Layout.cshtml";
}

<div class="py-3">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-0 pb-0">
            <div class="d-flex flex-wrap gap-3 align-items-center justify-content-between">
                <div>
                    <h4 class="card-title mb-1">Danh sách thương hiệu</h4>
                </div>
                <a href="@Url.Action("Form", "Brands", new { area = "Admin", page = Model.Page, pageSize = Model.PageSize, keyword = Model.Keyword, categoryId = Model.CategoryId })" class="btn btn-primary">
                    <i class="fa fa-plus me-1"></i>
                    Thêm thương hiệu
                </a>
            </div>
        </div>

        <div class="card-body">
            <form method="get" class="brand-admin__filters row g-3 align-items-end mb-4">
                <input type="hidden" name="pageSize" value="@Model.PageSize" />
                <div class="col-lg-5">
                    <label class="form-label fw-semibold text-secondary">Tìm kiếm</label>
                    <input type="text"
                           class="form-control"
                           name="keyword"
                           value="@Model.Keyword"
                           placeholder="Tên thương hiệu hoặc mô tả..." />
                </div>
                <div class="col-lg-4">
                    <label class="form-label fw-semibold text-secondary">Lọc theo danh mục</label>
                    <select class="form-select" name="categoryId">
                        <option value="">Tất cả danh mục</option>
                        @foreach (var category in Model.Categories)
                        {
                            <option value="@category.CategoryId" @(Model.CategoryId == category.CategoryId ? "selected" : "")>
                                @category.Name
                            </option>
                        }
                    </select>
                </div>
                <div class="col-lg-3">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-grow-1">Tìm kiếm</button>
                        <a href="/Admin/Brands" class="btn btn-light border">Làm mới</a>
                    </div>
                </div>
            </form>

            <div class="table-responsive reusable-admin-table">
                <table class="table table-hover align-middle brand-admin__table">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 84px;">Ảnh</th>
                            <th>Thương hiệu</th>
                            <th style="width: 160px;">Thứ tự</th>
                            <th style="width: 340px;">Danh mục hiển thị</th>
                            <th>Mô tả</th>
                            <th style="width: 140px;" class="text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Brands.Count == 0)
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-5">
                                    Không có thương hiệu phù hợp với bộ lọc hiện tại.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var brand in Model.Brands)
                            {
                                <tr>
                                    <td>
                                        <div class="brand-admin__logo-shell">
                                            <img src="/Upload/Logo/@(brand.Image ?? "none.jpg")"
                                                 alt="@brand.Name"
                                                 class="brand-admin__logo" />
                                        </div>
                                    </td>
                                    <td>
                                        <div class="fw-semibold text-dark">@brand.Name</div>
                                        <div class="small text-muted">Cập nhật: @(brand.UpdatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div>
                                    </td>
                                    <td>
                                        <span class="badge text-bg-light border brand-admin__order-badge">@brand.SortOrder</span>
                                    </td>
                                    <td>
                                        @if (brand.CategoryNames.Count == 0)
                                        {
                                            <span class="badge text-bg-warning-subtle text-warning-emphasis border">Tất cả danh mục</span>
                                        }
                                        else
                                        {
                                            <div class="attribute-tag-list brand-admin__tag-list">
                                                @foreach (var categoryName in brand.CategoryNames)
                                                {
                                                    <span class="badge rounded-pill text-bg-light border">@categoryName</span>
                                                }
                                            </div>
                                        }
                                    </td>
                                    <td class="text-muted">@(string.IsNullOrWhiteSpace(brand.Description) ? "-" : brand.Description)</td>
                                    <td>
                                        <div class="form-button-action justify-content-center">
                                            <a href="@Url.Action("Form", "Brands", new { area = "Admin", id = brand.BrandId, page = Model.Page, pageSize = Model.PageSize, keyword = Model.Keyword, categoryId = Model.CategoryId })"
                                               class="btn btn-link btn-primary btn-lg"
                                               data-bs-toggle="tooltip"
                                               title="Cập nhật">
                                                <i class="fa fa-edit"></i>
                                            </a>
                                            <button type="button"
                                                    class="btn btn-link btn-danger"
                                                    data-id="@brand.BrandId"
                                                    data-name="@brand.Name"
                                                    data-role="remove-brand"
                                                    title="Xóa">
                                                <i class="fa fa-times"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_ManualPagination.cshtml", new Tech_Store.Models.ViewModel.ManualPaginationViewModel
            {
                CurrentPage = Model.Page,
                TotalPages = Model.TotalPages,
                BaseUrl = "/Admin/Brands",
                QueryString = string.Join("&", new[]
                {
                    !string.IsNullOrWhiteSpace(Model.Keyword) ? $"keyword={Uri.EscapeDataString(Model.Keyword)}" : null,
                    Model.CategoryId.HasValue ? $"categoryId={Model.CategoryId.Value}" : null,
                    $"pageSize={Model.PageSize}"
                }.Where(x => !string.IsNullOrWhiteSpace(x)))
            })
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $(document).on('click', '[data-role="remove-brand"]', function () {
            const brandId = $(this).data('id');
            const brandName = $(this).data('name');

            Swal.fire({
                title: 'Xóa thương hiệu?',
                text: `Bạn đang chuẩn bị xóa "${brandName}". Hành động này không thể hoàn tác.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Xóa',
                cancelButtonText: 'Hủy',
                confirmButtonColor: '#d33'
            }).then((result) => {
                if (!result.isConfirmed) {
                    return;
                }

                $('.loading-container').show();

                $.ajax({
                    method: 'DELETE',
                    url: `/Admin/Brands/Delete/${brandId}`,
                    success: function () {
                        $('.loading-container').hide();
                        location.reload();
                    },
                    error: function (xhr) {
                        $('.loading-container').hide();
                        Swal.fire('Lỗi', xhr.responseText || 'Không thể xóa thương hiệu.', 'error');
                    }
                });
            });
        });
    });
</script>
