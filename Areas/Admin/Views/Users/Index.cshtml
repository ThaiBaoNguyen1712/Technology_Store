@model Tech_Store.Models.ViewModel.AdminUserIndexViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Khách hàng";
    Layout = "~/Areas/Admin/Views/Shared/Layout.cshtml";
}

<div class="py-3 user-admin-page">
    @Html.AntiForgeryToken()

    @if (TempData["UserAdminSuccess"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm">@TempData["UserAdminSuccess"]</div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-0 pb-0">
            <div class="d-flex flex-wrap gap-3 align-items-center justify-content-between">
                <div>
                    <h4 class="card-title mb-1">Danh sách khách hàng</h4>
                </div>
                <div class="order-admin__header-meta">
                    <span class="order-admin__header-pill">Tổng khách: @Model.TotalItems</span>
                    <span class="order-admin__header-pill">Trang @Model.Page/@Model.TotalPages</span>
                    <a class="btn btn-primary"
                       href="@Url.Action("Create", "Users", new
                       {
                           area = "Admin",
                           page = Model.Page,
                           status = Model.Status,
                           email = Model.Email,
                           phoneNumber = Model.PhoneNumber,
                           revenueFrom = Model.RevenueFrom,
                           revenueTo = Model.RevenueTo,
                           createdDateFrom = Model.CreatedDateFrom?.ToString("yyyy-MM-dd"),
                           createdDateTo = Model.CreatedDateTo?.ToString("yyyy-MM-dd")
                       })">
                        <i class="fa fa-plus me-1"></i>
                        Thêm khách hàng
                    </a>
                </div>
            </div>
        </div>

        <div class="card-body">
            <form method="get" class="brand-admin__filters user-admin__filters row g-3 align-items-end mb-4">
                <input type="hidden" name="page" value="1" />
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Kích hoạt tài khoản</label>
                    <select class="form-select" name="status">
                        <option value="">Tất cả</option>
                        @if (Model.Status == "true")
                        {
                            <option value="true" selected>Đã kích hoạt</option>
                        }
                        else
                        {
                            <option value="true">Đã kích hoạt</option>
                        }
                        @if (Model.Status == "false")
                        {
                            <option value="false" selected>Chưa kích hoạt</option>
                        }
                        else
                        {
                            <option value="false">Chưa kích hoạt</option>
                        }
                    </select>
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Số điện thoại</label>
                    <input type="text"
                           class="form-control"
                           name="phoneNumber"
                           value="@Model.PhoneNumber"
                           placeholder="Nhập số điện thoại" />
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Email</label>
                    <input type="text"
                           class="form-control"
                           name="email"
                           value="@Model.Email"
                           placeholder="Nhập email" />
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Từ ngày</label>
                    <input type="date"
                           class="form-control"
                           name="createdDateFrom"
                           value="@(Model.CreatedDateFrom?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Đến ngày</label>
                    <input type="date"
                           class="form-control"
                           name="createdDateTo"
                           value="@(Model.CreatedDateTo?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Doanh số từ</label>
                    <input type="number"
                           class="form-control"
                           name="revenueFrom"
                           value="@Model.RevenueFrom"
                           min="0"
                           placeholder="0" />
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Doanh số đến</label>
                    <input type="number"
                           class="form-control"
                           name="revenueTo"
                           value="@Model.RevenueTo"
                           min="0"
                           placeholder="0" />
                </div>
                <div class="col-12 admin-search-actions-row">
                    <div class="admin-search-actions">
                        <button type="submit" class="btn btn-primary">Tìm kiếm</button>
                        <a href="/Admin/Users" class="btn btn-light border">Làm mới</a>
                    </div>
                </div>
            </form>

            <div class="table-responsive reusable-admin-table">
                <table class="table table-hover align-middle user-admin__table">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 64px;">Ảnh</th>
                            <th>Khách hàng</th>
                            <th style="width: 160px;">Liên hệ</th>
                            <th style="width: 120px;">Đơn hàng</th>
                            <th style="width: 170px;">Doanh số</th>
                            <th style="width: 170px;">Kích hoạt</th>
                            <th style="width: 150px;">Ngày tạo</th>
                            <th style="width: 140px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Users.Count == 0)
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-5">
                                    Không có khách hàng phù hợp với bộ lọc hiện tại.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var user in Model.Users)
                            {
                                var detailUrl = Url.Action("ViewUser", "Users", new
                                {
                                    area = "Admin",
                                    id = user.UserId,
                                    page = Model.Page,
                                    keyword = Model.Keyword,
                                    status = Model.Status,
                                    email = Model.Email,
                                    phoneNumber = Model.PhoneNumber,
                                    revenueFrom = Model.RevenueFrom,
                                    revenueTo = Model.RevenueTo,
                                    createdDateFrom = Model.CreatedDateFrom?.ToString("yyyy-MM-dd"),
                                    createdDateTo = Model.CreatedDateTo?.ToString("yyyy-MM-dd")
                                }) ?? $"/Admin/Users/View/{user.UserId}";

                                var quickDrawerUrl = Url.Action("QuickDrawer", "Users", new
                                {
                                    area = "Admin",
                                    id = user.UserId,
                                    page = Model.Page,
                                    keyword = Model.Keyword,
                                    status = Model.Status,
                                    email = Model.Email,
                                    phoneNumber = Model.PhoneNumber,
                                    revenueFrom = Model.RevenueFrom,
                                    revenueTo = Model.RevenueTo,
                                    createdDateFrom = Model.CreatedDateFrom?.ToString("yyyy-MM-dd"),
                                    createdDateTo = Model.CreatedDateTo?.ToString("yyyy-MM-dd")
                                }) ?? $"/Admin/Users/QuickDrawer/{user.UserId}";

                                <tr>
                                    <td>
                                        <div class="brand-admin__logo-shell user-admin__avatar-shell">
                                            <img src="/Upload/Avatar/@(string.IsNullOrWhiteSpace(user.ImageUrl) ? "none.png" : user.ImageUrl)"
                                                 class="brand-admin__logo user-admin__avatar"
                                                 alt="@($"{user.LastName} {user.FirstName}")" />
                                        </div>
                                    </td>
                                    <td>
                                        <div class="user-admin__customer">
                                            <a href="@detailUrl" class="user-admin__name">
                                                @($"{user.LastName} {user.FirstName}".Trim())
                                            </a>
                                            <div class="user-admin__meta">
                                                <span>ID #@user.UserId</span>
                                                <span>@(string.IsNullOrWhiteSpace(user.Email) ? "Chưa có email" : user.Email)</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="user-admin__contact">
                                            <strong>@(string.IsNullOrWhiteSpace(user.PhoneNumber) ? "-" : user.PhoneNumber)</strong>
                                            <span>@(string.IsNullOrWhiteSpace(user.Email) ? "-" : user.Email)</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="fw-semibold text-dark">@user.OrderCount</div>
                                        <div class="small text-muted">đơn hàng</div>
                                    </td>
                                    <td>
                                        <div class="user-admin__amount">@user.TotalSpent.ToString("C0", new CultureInfo("vi-VN"))</div>
                                    </td>
                                    <td>
                                        <div class="order-admin__state">
                                            <span class="order-admin__state-dot @(user.IsActive ? "order-admin__state-dot--success" : "order-admin__state-dot--danger")"></span>
                                            <div class="order-admin__state-body">
                                                <strong>@(user.IsActive ? "Đã kích hoạt" : "Chưa kích hoạt")</strong>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="text-dark">@(user.CreatedAt?.ToString("dd/MM/yyyy") ?? "-")</div>
                                        <div class="small text-muted">@(user.CreatedAt?.ToString("HH:mm:ss") ?? "-")</div>
                                    </td>
                                    <td>
                                        <button type="button"
                                                class="btn btn-light border user-admin__action-button open-user-drawer"
                                                data-url="@quickDrawerUrl">
                                            Tác vụ
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_ManualPagination.cshtml", new Tech_Store.Models.ViewModel.ManualPaginationViewModel
            {
                CurrentPage = Model.Page,
                TotalPages = Model.TotalPages,
                BaseUrl = "/Admin/Users",
                QueryString = string.Join("&", new[]
                {
                    !string.IsNullOrWhiteSpace(Model.Status) ? $"status={Uri.EscapeDataString(Model.Status)}" : null,
                    !string.IsNullOrWhiteSpace(Model.Email) ? $"email={Uri.EscapeDataString(Model.Email)}" : null,
                    !string.IsNullOrWhiteSpace(Model.PhoneNumber) ? $"phoneNumber={Uri.EscapeDataString(Model.PhoneNumber)}" : null,
                    Model.RevenueFrom.HasValue ? $"revenueFrom={Model.RevenueFrom.Value}" : null,
                    Model.RevenueTo.HasValue ? $"revenueTo={Model.RevenueTo.Value}" : null,
                    Model.CreatedDateFrom.HasValue ? $"createdDateFrom={Model.CreatedDateFrom.Value:yyyy-MM-dd}" : null,
                    Model.CreatedDateTo.HasValue ? $"createdDateTo={Model.CreatedDateTo.Value:yyyy-MM-dd}" : null
                }.Where(x => !string.IsNullOrWhiteSpace(x)))
            })
        </div>
    </div>
</div>

@await Html.PartialAsync("~/Areas/Admin/Views/Shared/_AdminRightDrawer.cshtml", new Tech_Store.Models.ViewModel.AdminRightDrawerViewModel
{
    DrawerId = "userQuickDrawer",
    Title = "Thao tác khách hàng",
    BodyId = "userQuickDrawerBody",
    WidthClass = "admin-right-drawer--lg"
})
<script>
    $(document).ready(function () {
        const drawerElement = document.getElementById('userQuickDrawer');
        const drawerBody = $('#userQuickDrawerBody');
        const userDrawer = drawerElement ? bootstrap.Offcanvas.getOrCreateInstance(drawerElement) : null;
        const antiForgeryToken = $('input[name="__RequestVerificationToken"]').val();

        $(document).on('click', '.open-user-drawer', function (e) {
            e.preventDefault();

            if (!userDrawer) {
                return;
            }

            const url = $(this).data('url');
            drawerBody.html('<div class="admin-right-drawer__loading">Đang tải thông tin khách hàng...</div>');
            userDrawer.show();
            $('.loading-container').show();

            $.ajax({
                method: 'GET',
                url: url,
                success: function (html) {
                    drawerBody.html(html);
                },
                error: function () {
                    drawerBody.html('<div class="alert alert-danger mb-0">Không thể tải thông tin khách hàng.</div>');
                },
                complete: function () {
                    $('.loading-container').hide();
                }
            });
        });

        function executeUserAction(url, method, successTitle, successMessage) {
            $('.loading-container').show();

            $.ajax({
                method: method,
                url: url,
                headers: {
                    "RequestVerificationToken": antiForgeryToken
                },
                success: function (response) {
                    if (response && response.success === false) {
                        Swal.fire('Không thể thực hiện', response.message, 'error');
                        return;
                    }

                    Swal.fire(successTitle, successMessage, 'success').then(() => {
                        location.reload();
                    });
                },
                error: function (xhr) {
                    const message = xhr.responseJSON && xhr.responseJSON.message
                        ? xhr.responseJSON.message
                        : 'Đã xảy ra lỗi. Vui lòng thử lại.';
                    Swal.fire('Lỗi', message, 'error');
                },
                complete: function () {
                    $('.loading-container').hide();
                }
            });
        }

        $(document).on('click', '.js-user-ban', function (e) {
            e.preventDefault();
            const url = $(this).data('url');

            Swal.fire({
                title: 'Chặn khách hàng này?',
                text: 'Khách hàng sẽ không thể tiếp tục mua hàng.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Chặn khách hàng',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    executeUserAction(url, 'POST', 'Đã chặn', 'Khách hàng đã được chuyển sang trạng thái bị chặn.');
                }
            });
        });

        $(document).on('click', '.js-user-unban', function (e) {
            e.preventDefault();
            const url = $(this).data('url');

            Swal.fire({
                title: 'Bỏ chặn khách hàng này?',
                text: 'Khách hàng sẽ được mua hàng trở lại.',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Bỏ chặn',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    executeUserAction(url, 'POST', 'Đã bỏ chặn', 'Khách hàng đã được kích hoạt lại.');
                }
            });
        });

        $(document).on('click', '.js-user-delete', function (e) {
            e.preventDefault();
            const url = $(this).data('url');

            Swal.fire({
                title: 'Xóa khách hàng này?',
                text: 'Hành động này không thể hoàn tác.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Xóa khách hàng',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    executeUserAction(url, 'DELETE', 'Đã xóa', 'Khách hàng đã được xóa khỏi hệ thống.');
                }
            });
        });
    });
</script>
