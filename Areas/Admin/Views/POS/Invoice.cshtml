@model Tech_Store.Models.Order
@using System.Globalization
@using Tech_Store.Helpers
@{
    ViewData["Title"] = "Hóa đơn";
    Layout = "~/Areas/Admin/Views/Shared/Layout.cshtml";
    var payment = ViewBag.Payment as Tech_Store.Models.Payment;

    string MapOrderStatus(string? status) => (status ?? string.Empty).Trim().ToLowerInvariant() switch
    {
        "pending" => "Chờ xác nhận",
        "confirmed" => "Đã xác nhận",
        "shipping" => "Đang giao",
        "delivered" => "Đã giao",
        "completed" => "Hoàn tất",
        "cancelled" => "Đã hủy",
        "refunded" => "Đã hoàn tiền",
        _ => string.IsNullOrWhiteSpace(status) ? "-" : status
    };

    string MapPaymentMethod(string? method) => (method ?? string.Empty).Trim().ToLowerInvariant() switch
    {
        "cash" => "Tiền mặt",
        "card" => "Thẻ",
        _ => string.IsNullOrWhiteSpace(method) ? "-" : method
    };

    string MapPaymentStatus(string? status) => (status ?? string.Empty).Trim().ToLowerInvariant() switch
    {
        "paid" => "Đã thanh toán",
        "pending" => "Chờ thanh toán",
        "failed" => "Thanh toán thất bại",
        "cancelled" => "Đã hủy",
        "refunded" => "Đã hoàn tiền",
        _ => string.IsNullOrWhiteSpace(status) ? "-" : status
    };
}

<div class="py-3 invoice-admin-page">
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body d-flex flex-wrap justify-content-between align-items-center gap-3">
            <div class="d-flex align-items-center gap-3">
                <div class="rounded-circle bg-success-subtle text-success d-flex align-items-center justify-content-center"
                     style="width:64px;height:64px;">
                    <i class="fas fa-check-circle fs-2"></i>
                </div>
                <div>
                    <h4 class="card-title mb-1">Thanh toán thành công</h4>
                    <p class="text-muted mb-0">Đơn hàng #@Model.OrderId đã được thanh toán thành công.</p>
                </div>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-light border" href="/Admin/POS">
                    <i class="fa fa-arrow-left me-1"></i> Quay lại POS
                </a>
                <button type="button" class="btn btn-light border" id="Print">
                    <i class="fas fa-print text-primary me-1"></i> In hóa đơn
                </button>
                <button type="button" class="btn btn-light border" id="ToFilePDF">
                    <i class="far fa-file-pdf text-danger me-1"></i> Xuất PDF
                </button>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-xl-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white border-0">
                    <h4 class="card-title mb-0">Thông tin khách hàng</h4>
                </div>
                <div class="card-body">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="small text-muted mb-1">Tên khách hàng</div>
                            <div class="fw-semibold text-dark">@Model.User.LastName @Model.User.FirstName</div>
                        </div>
                        <div class="col-md-6">
                            <div class="small text-muted mb-1">Số điện thoại</div>
                            <div class="fw-semibold text-dark">@(!string.IsNullOrWhiteSpace(Model.User.PhoneNumber) ? Model.User.PhoneNumber : "-")</div>
                        </div>
                        <div class="col-md-6">
                            <div class="small text-muted mb-1">Email</div>
                            <div class="fw-semibold text-dark">@(!string.IsNullOrWhiteSpace(Model.User.Email) ? Model.User.Email : "-")</div>
                        </div>
                        <div class="col-md-6">
                            <div class="small text-muted mb-1">Địa chỉ giao hàng</div>
                            <div class="fw-semibold text-dark">@(!string.IsNullOrWhiteSpace(ViewBag.Address as string) ? ViewBag.Address : "-")</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-0">
                    <h4 class="card-title mb-0">Chi tiết đơn hàng</h4>
                </div>
                <div class="card-body">
                    <div class="table-responsive reusable-admin-table">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 70px;">#</th>
                                    <th style="width: 90px;">Ảnh</th>
                                    <th style="width: 150px;">SKU</th>
                                    <th>Sản phẩm</th>
                                    <th style="width: 180px;">Biến thể</th>
                                    <th style="width: 110px;">Số lượng</th>
                                    <th style="width: 160px;">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var itemIndex = 1;
                                }
                                @foreach (var item in Model.OrderItems)
                                {
                                    var imageUrl = string.IsNullOrWhiteSpace(item.Product.Image)
                                        ? Url.Content("~/Upload/Products/no-image.png")
                                        : item.Product.Image.Contains("http")
                                            ? ResizeCDN.Cdn(item.Product.Image, 80, 80)
                                            : Url.Content($"~/Upload/Products/{item.Product.Image}");

                                    <tr>
                                        <td>@itemIndex</td>
                                        <td>
                                            <img src="@imageUrl"
                                                 style="width:60px;height:60px;object-fit:cover;border-radius:12px;"
                                                 alt="@item.Product.Name" />
                                        </td>
                                        <td class="text-muted">@item.VarientProduct.Sku</td>
                                        <td>
                                            <div class="fw-semibold text-dark">@item.Product.Name</div>
                                        </td>
                                        <td>@(!string.IsNullOrWhiteSpace(item.VarientProduct.Attributes) ? item.VarientProduct.Attributes : "-")</td>
                                        <td>@item.Quantity</td>
                                        <td class="fw-semibold text-dark">
                                            @((item.VarientProduct.Price * item.Quantity)?.ToString("C0", new CultureInfo("vi-VN")))
                                        </td>
                                    </tr>
                                    itemIndex++;
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white border-0">
                    <h4 class="card-title mb-0">Tóm tắt hóa đơn</h4>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted">Mã đơn hàng</span>
                        <strong>#@Model.OrderId</strong>
                    </div>
                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted">Ngày đặt</span>
                        <strong>@(Model.OrderDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</strong>
                    </div>
                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted">Trạng thái đơn</span>
                        <strong>@MapOrderStatus(Model.OrderStatus)</strong>
                    </div>
                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted">Phương thức thanh toán</span>
                                <strong>@PaymentDisplayHelper.GetLabel(payment?.Gateway)</strong>
                    </div>
                    <div class="d-flex justify-content-between py-2">
                        <span class="text-muted">Trạng thái thanh toán</span>
                        <strong>@MapPaymentStatus(payment?.PaymentStatus)</strong>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body" id="printSection">
                    <div class="text-center mb-4">
                        <h4 class="mb-1">TechStore.com</h4>
                        <div class="text-muted">Hóa đơn thanh toán</div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-12">
                            <div class="small text-muted">Người nhận</div>
                            <div class="fw-semibold">@Model.User.LastName @Model.User.FirstName</div>
                        </div>
                        <div class="col-12">
                            <div class="small text-muted">Địa chỉ</div>
                            <div class="fw-semibold">@(!string.IsNullOrWhiteSpace(ViewBag.Address as string) ? ViewBag.Address : "-")</div>
                        </div>
                        <div class="col-12">
                            <div class="small text-muted">Số điện thoại</div>
                            <div class="fw-semibold">@(!string.IsNullOrWhiteSpace(Model.User.PhoneNumber) ? Model.User.PhoneNumber : "-")</div>
                        </div>
                        <div class="col-12">
                            <div class="small text-muted">Thông tin đơn hàng</div>
                            <div class="fw-semibold">#@Model.OrderId • @(Model.OrderDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div>
                        </div>
                    </div>

                    <div class="table-responsive mb-4">
                        <table class="table table-sm align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 50px;">#</th>
                                    <th>Sản phẩm</th>
                                    <th style="width: 90px;">SL</th>
                                    <th style="width: 140px;">Đơn giá</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var printIndex = 1;
                                }
                                @foreach (var item in Model.OrderItems)
                                {
                                    <tr>
                                        <td>@printIndex</td>
                                        <td>@item.Product.Name (@(!string.IsNullOrWhiteSpace(item.VarientProduct.Attributes) ? item.VarientProduct.Attributes : "-"))</td>
                                        <td>@item.Quantity</td>
                                        <td>@item.VarientProduct.Price?.ToString("C0", new CultureInfo("vi-VN"))</td>
                                    </tr>
                                    printIndex++;
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="border-top pt-3">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Tổng tiền hàng</span>
                            <strong>@Model.OriginAmount?.ToString("C0", new CultureInfo("vi-VN"))</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Giảm giá khuyến mãi</span>
                            <strong>@Model.DiscountAmount?.ToString("C0", new CultureInfo("vi-VN"))</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Giảm giá thêm</span>
                            <strong>@Model.DeductAmount?.ToString("C0", new CultureInfo("vi-VN"))</strong>
                        </div>
                        <div class="d-flex justify-content-between pt-2 mt-2 border-top">
                            <span class="fw-bold fs-5">Tổng thanh toán</span>
                            <strong class="fs-5">@Model.TotalAmount.ToString("C0", new CultureInfo("vi-VN"))</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script type="text/javascript">
    $(document).ready(function () {
        $('#ToFilePDF').click(function () {
            $('.loading-container').show();
            const id = '@Model.OrderId';

            window.location.href = '/Admin/POS/Print-Invoice?id=' + id;
            setTimeout(function () {
                $('.loading-container').hide();
            }, 3000);
        });

        $('#Print').click(function () {
            const printContent = $("#printSection").html();
            const originalContent = $('body').html();

            $('body').html(printContent);
            window.print();
            $('body').html(originalContent);

            return false;
        });
    });
</script>
