<div class="modal fade" id="productDetail" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content pos-modal border-0">
            <div class="modal-header border-0 pb-0">
                <div>
                    <h5 class="modal-title">Thêm sản phẩm vào hóa đơn</h5>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body pt-3">
                <div class="row g-4 align-items-start">
                    <div class="col-md-5">
                        <div class="pos-modal__image-shell">
                            <img id="imgProduct"
                                 class="pos-modal__image"
                                 src="/Upload/Products/no-image.png"
                                 alt="Ảnh sản phẩm" />
                        </div>
                    </div>

                    <div class="col-md-7">
                        <h3 id="nameProduct" class="pos-modal__title">Tên sản phẩm</h3>
                        <div class="pos-modal__pricing">
                            <span id="priceProduct" class="pos-modal__price">0đ</span>
                            <span id="originalPriceProduct" class="pos-modal__original-price"></span>
                        </div>

                        <div class="mb-3">
                            <span class="badge bg-success stockValue">Còn hàng</span>
                        </div>

                        <div class="pos-modal__meta-grid">
                            <div><span>Danh mục</span><strong id="categoryName">-</strong></div>
                            <div><span>Thương hiệu</span><strong id="brandName">-</strong></div>
                            <div><span>SKU</span><strong id="sku">-</strong></div>
                        </div>

                        <div class="pos-modal__quantity-block">
                            <label class="form-label pos-field-label">Số lượng</label>
                            <div class="input-group" style="max-width: 160px;">
                                <span class="input-group-text">SL</span>
                                <input type="number" class="form-control" name="quantityValue" min="1" value="1" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="pt-4">
                    <label class="form-label pos-field-label">Biến thể khả dụng</label>
                    <div id="variantCardsContainer" class="pos-variant-grid"></div>
                </div>

                <input type="hidden" id="IdProduct" value="" />
            </div>

            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light border" data-bs-dismiss="modal">Hủy</button>
                <button type="button" id="AddToCart" class="btn btn-primary">Thêm vào giỏ hàng</button>
            </div>
        </div>
    </div>
</div>
