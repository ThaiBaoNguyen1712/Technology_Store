@using System.Globalization
@using Tech_Store.Helpers
@{
    ViewData["Title"] = "POS - Bán hàng tại quầy";
    Layout = "~/Areas/Admin/Views/Shared/Layout.cshtml";
    var products = ViewBag.product as IEnumerable<Tech_Store.Models.Product>;
    var categories = ViewBag.category as IEnumerable<Tech_Store.Models.Category>;
}

<div class="pos-page py-4">
    <div class="row g-4">
        <div class="col-xl-7">
            <section class="card pos-panel border-0 shadow-sm h-100">
                <div class="pos-panel__header">
                    <div>
                        <h2>Danh mục sản phẩm</h2>
                    </div>
                </div>

                <div class="pos-panel__body">
                    <div class="row g-3 pos-filter-bar">
                        <div class="col-md-6">
                            <label class="form-label pos-field-label">Danh mục</label>
                            <select class="form-control selectpicker" name="CateId" data-live-search="true">
                                <option value="0">Tất cả danh mục</option>
                                @foreach (var cate in categories ?? Enumerable.Empty<Tech_Store.Models.Category>())
                                {
                                    <option value="@cate.CategoryId">@cate.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label pos-field-label">Tìm sản phẩm</label>
                            <div class="pos-search-input">
                                <i class="fas fa-search"></i>
                                <input class="form-control searchProducts" name="searchProducts" placeholder="Tên sản phẩm, SKU..." type="search" />
                            </div>
                        </div>
                    </div>

                    <div class="pos-catalog" id="CardProducts">
                        <div class="row g-3">
                            @foreach (var product in products ?? Enumerable.Empty<Tech_Store.Models.Product>())
                            {
                                var imageUrl = string.IsNullOrWhiteSpace(product.Image)
                                    ? Url.Content("~/Upload/Products/no-image.png")
                                    : product.Image.Contains("http")
                                        ? ResizeCDN.Cdn(product.Image, 140, 140)
                                        : Url.Content($"~/Upload/Products/{product.Image}");

                                <div class="col-6 col-lg-4">
                                    <button class="pos-product-card getProductInfo" type="button" data-id="@product.ProductId">
                                        <span class="pos-product-card__image-shell">
                                            <img src="@imageUrl" class="pos-product-card__image" alt="@product.Name">
                                        </span>
                                        <span class="pos-product-card__body">
                                            <span class="pos-product-card__title">@product.Name</span>
                                            <span class="pos-product-card__sku">@product.Sku</span>
                                            <span class="pos-product-card__price">
                                                @(product.SellPrice?.ToString("C0", new CultureInfo("vi-VN")) ?? "Liên hệ")
                                            </span>
                                        </span>
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                    @Html.Partial("ViewProduct")
                </div>
            </section>
        </div>

        <div class="col-xl-5">
            <section class="card pos-panel border-0 shadow-sm h-100">
                <div class="pos-panel__header">
                    <div>
                        <h2>Hóa đơn tạm</h2>
                    </div>
                </div>

                <div class="pos-panel__body pos-panel__body--invoice">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-7">
                            <label class="form-label pos-field-label">Khách hàng</label>
                            <input type="hidden" id="selectedCustomerId" name="selectCustomer" />
                            <input type="hidden" id="selectedCustomerEmail" />
                            <button type="button"
                                    class="btn btn-outline-secondary w-100 text-start d-flex align-items-center justify-content-between"
                                    data-bs-toggle="modal"
                                    data-bs-target="#CustomerPickerModal">
                                <span id="selectedCustomerLabel">Chọn khách hàng...</span>
                                <i class="fa fa-chevron-right"></i>
                            </button>
                        </div>
                        <div class="col-md-5">
                            <a class="btn btn-success w-100" href="/Admin/Users/Create">
                                <i class="fa fa-plus me-1"></i>
                                Thêm KH
                            </a>
                        </div>
                    </div>

                    <div class="pos-customer-card">
                        <div class="pos-customer-card__header">
                            <h3>Thông tin khách hàng</h3>
                        </div>
                        <div id="customerInfoEmpty" class="text-center text-muted py-4">
                            <i class="fa fa-user-circle mb-2 d-block" style="font-size:2rem;opacity:.55;"></i>
                            <span>Chưa chọn khách hàng</span>
                        </div>
                        <div id="customerInfoGrid" class="pos-customer-card__grid d-none">
                            <div class="pos-customer-card__row">
                                <span>Tên khách</span>
                                <strong id="nameCustomer">-</strong>
                            </div>
                            <div class="pos-customer-card__row">
                                <span>Số điện thoại</span>
                                <strong id="phoneCustomer">-</strong>
                            </div>
                            <div class="pos-customer-card__row">
                                <span>Email</span>
                                <strong id="emailCustomer">-</strong>
                            </div>
                            <div class="pos-customer-card__row pos-customer-card__row--full">
                                <span>Địa chỉ</span>
                                <strong id="addressCustomer">-</strong>
                            </div>
                        </div>
                    </div>

                    <div class="pos-cart-card">
                        <div class="pos-cart-card__header">
                            <h3>Giỏ hàng</h3>
                        </div>
                        <div class="table-responsive">
                            <table id="shopping-cart" class="table table-hover mb-0 pos-cart-table">
                                <thead>
                                    <tr>
                                        <th>Sản phẩm</th>
                                        <th>Biến thể</th>
                                        <th>Số lượng</th>
                                        <th>Giá</th>
                                        <th>Xóa</th>
                                    </tr>
                                </thead>
                                <tbody id="shoppingCartBody">
                                    <tr class="cart-empty-state">
                                        <td colspan="5" class="text-center text-muted py-4">
                                            <i class="fa fa-shopping-basket mb-2 d-block" style="font-size:2rem;opacity:.55;"></i>
                                            Chưa có sản phẩm trong giỏ hàng
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="pos-inline-card">
                        <div class="row g-3 align-items-end">
                            <div class="col-md-6">
                                <label class="form-label pos-field-label">Voucher</label>
                                <input type="text" class="form-control" name="Voucher" placeholder="Nhập mã voucher" />
                                <p id="resultVoucher" class="text-danger small mt-2 mb-0" style="display:none"></p>
                            </div>
                            <div class="col-md-3">
                                <button type="button"
                                        class="btn btn-outline-primary w-100"
                                        data-bs-toggle="modal"
                                        data-bs-target="#VoucherPickerModal">
                                    Chọn voucher
                                </button>
                            </div>
                            <div class="col-md-3">
                                <button id="Checkvoucher" type="button" class="btn btn-outline-secondary w-100">Kiểm tra voucher</button>
                            </div>
                        </div>
                        <div id="selectedVoucherSummary" class="pos-voucher-summary mt-3" style="display:none;"></div>
                    </div>

                    <div class="pos-summary-card">
                        <div class="pos-summary-card__row">
                            <span>Tổng phụ</span>
                            <strong id="TotalPrice">0đ</strong>
                        </div>
                        <div class="pos-summary-card__row">
                            <span>Giảm giá khuyến mãi</span>
                            <strong class="pos-summary-card__editable">
                                <a href="javascript:void(0)" data-bs-toggle="modal" data-bs-target="#ModalDiscount">
                                    <i class="fas fa-pencil-alt"></i>
                                </a>
                                <span id="Discount">0đ</span>
                            </strong>
                            @Html.Partial("ModalDiscount")
                        </div>
                        <div class="pos-summary-card__row">
                            <span>Giảm giá thêm</span>
                            <strong class="pos-summary-card__editable">
                                <a href="javascript:void(0)" data-bs-toggle="modal" data-bs-target="#ModalDeduct">
                                    <i class="fas fa-pencil-alt"></i>
                                </a>
                                <span id="Deduct">0đ</span>
                            </strong>
                            @Html.Partial("ModalDeduct")
                        </div>
                        <div class="pos-summary-card__divider"></div>
                        <div class="pos-summary-card__row pos-summary-card__row--total">
                            <span>Tổng cộng</span>
                            <strong id="TotalPayment">0đ</strong>
                        </div>
                    </div>

                    <div class="pos-payment-card">
                        <h3>Phương thức thanh toán</h3>
                        <div class="pos-payment-toggle">
                            <label class="pos-payment-toggle__option">
                                <input type="radio" id="cash" value="cash" name="type" checked>
                                <span>Tiền mặt</span>
                            </label>
                            <label class="pos-payment-toggle__option">
                                <input type="radio" value="card" id="card" name="type">
                                <span>Thẻ</span>
                            </label>
                        </div>
                    </div>

                    <div class="row g-3 pt-2">
                        <div class="col-md-4">
                            <button class="btn btn-outline-danger w-100" type="button" onclick="confirm('Bạn có chắc chắn muốn hủy đơn hàng?') ? cancelOrder() : '';">
                                Hủy đơn hàng
                            </button>
                        </div>
                        <div class="col-md-4">
                            <button class="btn btn-outline-primary w-100" type="button" id="PreviewInvoiceBtn">
                                Xem trÆ°á»›c hÃ³a Ä‘Æ¡n
                            </button>
                        </div>
                        <div class="col-md-4">
                            <button class="btn btn-success w-100 btn-Order" type="button">
                                Đặt đơn hàng
                            </button>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>

<div class="modal fade" id="InvoicePreviewModal" tabindex="-1" aria-labelledby="InvoicePreviewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="InvoicePreviewModalLabel">Xem trÆ°á»›c hÃ³a Ä‘Æ¡n</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="invoicePreviewContent"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light border" data-bs-dismiss="modal">ÄÃ³ng</button>
                <button type="button" class="btn btn-success" id="ConfirmOrderFromPreviewBtn">XÃ¡c nháº­n Ä‘áº·t hÃ ng</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="CustomerPickerModal" tabindex="-1" aria-labelledby="CustomerPickerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="CustomerPickerModalLabel">Chọn khách hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3 mb-3">
                    <div class="col-md-8">
                        <input type="search" id="customerKeyword" class="form-control" placeholder="Tìm theo tên, email, số điện thoại..." />
                    </div>
                    <div class="col-md-4 d-flex gap-2">
                        <button type="button" class="btn btn-primary flex-fill" id="searchCustomerBtn">Tìm</button>
                        <button type="button" class="btn btn-light border flex-fill" id="resetCustomerBtn">Làm mới</button>
                    </div>
                </div>

                <div class="reusable-admin-table">
                    <table class="table table-hover align-middle mb-0 w-100">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 90px;">ID</th>
                                <th style="width: 200px;">Khách hàng</th>
                                <th style="width: 150px;">SĐT</th>
                                <th style="width: 250px;">Email</th>
                                <th style="width: 250px;">Địa chỉ</th>
                                <th style="width: 70px;" class="text-center">Chọn</th>
                            </tr>
                        </thead>
                        <tbody id="customerPickerTableBody">
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">Đang tải danh sách khách hàng...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-between align-items-center gap-3 mt-3">
                    <div class="small text-muted" id="customerPickerMeta"></div>
                    <div class="d-flex align-items-center gap-2" id="customerPickerPagination"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="VoucherPickerModal" tabindex="-1" aria-labelledby="VoucherPickerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="VoucherPickerModalLabel">Voucher đang áp dụng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3 mb-3">
                    <div class="col-md-8">
                        <input type="search" id="voucherKeyword" class="form-control" placeholder="Tìm theo mã hoặc tên voucher..." />
                    </div>
                    <div class="col-md-4 d-flex gap-2">
                        <button type="button" class="btn btn-primary flex-fill" id="searchVoucherBtn">Tìm</button>
                        <button type="button" class="btn btn-light border flex-fill" id="resetVoucherBtn">Làm mới</button>
                    </div>
                </div>

                <div id="voucherPickerList" class="row g-3">
                    <div class="col-12">
                        <div class="text-center text-muted py-4">Đang tải voucher...</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="~/Admin/assets/css/pos.css" asp-append-version="true" />
<script src="~/Admin/assets/js/core/jquery-3.7.1.min.js"></script>
<script src="~/Admin/assets/js/view/pos.js" asp-append-version="true"></script>
