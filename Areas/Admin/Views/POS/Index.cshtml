@using System.Globalization
@using Tech_Store.Helpers
@{
    ViewData["Title"] = "POS";
    Layout = "~/Areas/Admin/Views/Shared/Layout.cshtml";
    var products = ViewBag.product as IEnumerable<Tech_Store.Models.Product>;
    var categories = ViewBag.category as IEnumerable<Tech_Store.Models.Category>;
    var users = ViewBag.users as IEnumerable<Tech_Store.Models.User>;
}

<div class="pos-page py-4">
    <div class="row g-4">
        <div class="col-xl-7">
            <section class="card pos-panel border-0 shadow-sm h-100">
                <div class="pos-panel__header">
                    <div>
                        <h2>Danh mục sản phẩm</h2>
                    </div>
                </div>

                <div class="pos-panel__body">
                    <div class="row g-3 pos-filter-bar">
                        <div class="col-md-6">
                            <label class="form-label pos-field-label">Danh mục</label>
                            <select class="form-control selectpicker" name="CateId" data-live-search="true">
                                <option value="0">Tất cả danh mục</option>
                                @foreach (var cate in categories ?? Enumerable.Empty<Tech_Store.Models.Category>())
                                {
                                    <option value="@cate.CategoryId">@cate.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label pos-field-label">Tìm sản phẩm</label>
                            <div class="pos-search-input">
                                <i class="fas fa-search"></i>
                                <input class="form-control searchProducts" name="searchProducts" placeholder="Tên sản phẩm, SKU..." type="search" />
                            </div>
                        </div>
                    </div>

                    <div class="pos-catalog" id="CardProducts">
                        <div class="row g-3">
                            @foreach (var product in products ?? Enumerable.Empty<Tech_Store.Models.Product>())
                            {
                                var imageUrl = string.IsNullOrWhiteSpace(product.Image)
                                    ? Url.Content("~/Upload/Products/no-image.png")
                                    : product.Image.Contains("http")
                                        ? ResizeCDN.Cdn(product.Image, 140, 140)
                                        : Url.Content($"~/Upload/Products/{product.Image}");

                                <div class="col-6 col-lg-4">
                                    <button class="pos-product-card getProductInfo" type="button" data-id="@product.ProductId">
                                        <span class="pos-product-card__image-shell">
                                            <img src="@imageUrl" class="pos-product-card__image" alt="@product.Name">
                                        </span>
                                        <span class="pos-product-card__body">
                                            <span class="pos-product-card__title">@product.Name</span>
                                            <span class="pos-product-card__sku">@product.Sku</span>
                                            <span class="pos-product-card__price">
                                                @(product.SellPrice?.ToString("C0", new CultureInfo("vi-VN")) ?? "Liên hệ")
                                            </span>
                                        </span>
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                    @Html.Partial("ViewProduct")
                </div>
            </section>
        </div>

        <div class="col-xl-5">
            <section class="card pos-panel border-0 shadow-sm h-100">
                <div class="pos-panel__header">
                    <div>
                        <h2>Hóa đơn tạm</h2>
                    </div>
                </div>

                <div class="pos-panel__body pos-panel__body--invoice">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-7">
                            <label class="form-label pos-field-label">Khách hàng</label>
                            <select class="form-control border selectpicker" name="selectCustomer" data-live-search="true" placeholder="Chọn khách hàng..." require>
                                <option disabled selected>Chọn khách hàng...</option>
                                @foreach (var cus in users ?? Enumerable.Empty<Tech_Store.Models.User>())
                                {
                                    <option value="@cus.UserId">@cus.LastName @cus.FirstName (@cus.PhoneNumber)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-5">
                            <button class="btn btn-success w-100"
                                    data-bs-toggle="modal"
                                    data-bs-target="#UserModal">
                                <i class="fa fa-plus me-1"></i>
                                Thêm KH
                            </button>
                            @Html.Partial("ModalUser")
                        </div>
                    </div>

                    <div class="pos-customer-card">
                        <div class="pos-customer-card__header">
                            <h3>Thông tin khách hàng</h3>
                        </div>
                        <div class="pos-customer-card__grid">
                            <div class="pos-customer-card__row">
                                <span>Tên khách</span>
                                <strong id="nameCustomer"></strong>
                            </div>
                            <div class="pos-customer-card__row">
                                <span>Số điện thoại</span>
                                <strong id="phoneCustomer"></strong>
                            </div>
                            <div class="pos-customer-card__row pos-customer-card__row--full">
                                <span>Địa chỉ</span>
                                <strong id="addressCustomer"></strong>
                            </div>
                        </div>
                    </div>

                    <div class="pos-cart-card">
                        <div class="pos-cart-card__header">
                            <h3>Giỏ hàng</h3>
                        </div>
                        <div class="table-responsive">
                            <table id="shopping-cart" class="table table-hover mb-0 pos-cart-table">
                                <thead>
                                    <tr>
                                        <th>Sản phẩm</th>
                                        <th>Biến thể</th>
                                        <th>Số lượng</th>
                                        <th>Giá</th>
                                        <th>Xóa</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="pos-inline-card">
                        <div class="row g-3 align-items-end">
                            <div class="col-md-7">
                                <label class="form-label pos-field-label">Voucher</label>
                                <input type="text" class="form-control" name="Voucher" placeholder="Nhập mã voucher" />
                                <p id="resultVoucher" class="text-danger small mt-2 mb-0" style="display:none"></p>
                            </div>
                            <div class="col-md-5">
                                <button id="Checkvoucher" type="button" class="btn btn-outline-secondary w-100">Kiểm tra voucher</button>
                            </div>
                        </div>
                    </div>

                    <div class="pos-summary-card">
                        <div class="pos-summary-card__row">
                            <span>Tổng phụ</span>
                            <strong id="TotalPrice">0đ</strong>
                        </div>
                        <div class="pos-summary-card__row">
                            <span>Giảm giá khuyến mãi</span>
                            <strong class="pos-summary-card__editable">
                                <a href="javascript:void(0)" data-bs-toggle="modal" data-bs-target="#ModalDiscount">
                                    <i class="fas fa-pencil-alt"></i>
                                </a>
                                <span id="Discount">0đ</span>
                            </strong>
                            @Html.Partial("ModalDiscount")
                        </div>
                        <div class="pos-summary-card__row">
                            <span>Giảm giá thêm</span>
                            <strong class="pos-summary-card__editable">
                                <a href="javascript:void(0)" data-bs-toggle="modal" data-bs-target="#ModalDeduct">
                                    <i class="fas fa-pencil-alt"></i>
                                </a>
                                <span id="Deduct">0đ</span>
                            </strong>
                            @Html.Partial("ModalDeduct")
                        </div>
                        <div class="pos-summary-card__divider"></div>
                        <div class="pos-summary-card__row pos-summary-card__row--total">
                            <span>Tổng cộng</span>
                            <strong id="TotalPayment">0đ</strong>
                        </div>
                    </div>

                    <div class="pos-payment-card">
                        <h3>Phương thức thanh toán</h3>
                        <div class="pos-payment-toggle">
                            <label class="pos-payment-toggle__option">
                                <input type="radio" id="cash" value="cash" name="type" checked>
                                <span>Tiền mặt</span>
                            </label>
                            <label class="pos-payment-toggle__option">
                                <input type="radio" value="card" id="card" name="type">
                                <span>Thẻ</span>
                            </label>
                        </div>
                    </div>

                    <div class="row g-3 pt-2">
                        <div class="col-6">
                            <button class="btn btn-outline-danger w-100" type="button" onclick="confirm('Bạn có chắc chắn muốn hủy đơn hàng?') ? cancelOrder() : '';">
                                Hủy đơn hàng
                            </button>
                        </div>
                        <div class="col-6">
                            <button class="btn btn-success w-100 btn-Order" type="button">
                                Đặt đơn hàng
                            </button>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>

<script src="~/Admin/assets/js/core/jquery-3.7.1.min.js"></script>
<script src="~/Admin/assets/js/view/pos.js"></script>
