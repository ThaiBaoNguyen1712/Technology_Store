@model Tech_Store.Models.ViewModel.AdminStockIndexViewModel
@using System.Globalization
@using Tech_Store.Helpers
@{
    ViewData["Title"] = "Quản lý kho";
    Layout = "~/Areas/Admin/Views/Shared/Layout.cshtml";
}

<div class="py-3 stock-admin-page">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-0 pb-0">
            <div class="d-flex flex-wrap gap-3 align-items-center justify-content-between">
                <div>
                    <h4 class="card-title mb-1">Tồn kho sản phẩm</h4>
                </div>
                <div class="order-admin__header-meta">
                    <span class="order-admin__header-pill">Tổng SKU gốc: @Model.TotalItems</span>
                    <span class="order-admin__header-pill">Trang @Model.Page/@Model.TotalPages</span>
                    <button type="button" class="btn btn-light border stock-admin-page__header-action" id="openStockQuickDrawer">
                        Tác vụ kho
                    </button>
                </div>
            </div>
        </div>

        <div class="card-body">
            <form method="get" action="/Admin/StockManager/Inventory" class="brand-admin__filters order-admin__filters row g-3 align-items-end mb-4">
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">SKU sản phẩm</label>
                    <input type="text" class="form-control" name="sku" value="@Model.Sku" placeholder="Nhập mã SKU..." />
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Tên sản phẩm</label>
                    <input type="text" class="form-control" name="name" value="@Model.Name" placeholder="Nhập tên sản phẩm..." />
                </div>
                <div class="col-md-6 col-xl-2">
                    <label class="form-label fw-semibold text-secondary">Trạng thái kho</label>
                    <select class="form-select" name="status">
                        <option value="">Tất cả trạng thái</option>
                        @if (string.Equals(Model.Status, "available", StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="available" selected>Sẵn hàng</option>
                        }
                        else
                        {
                            <option value="available">Sẵn hàng</option>
                        }
                        @if (string.Equals(Model.Status, "outstock", StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="outstock" selected>Hết hàng</option>
                        }
                        else
                        {
                            <option value="outstock">Hết hàng</option>
                        }
                        @if (string.Equals(Model.Status, "preorder", StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="preorder" selected>Đặt trước</option>
                        }
                        else
                        {
                            <option value="preorder">Đặt trước</option>
                        }
                        @if (string.Equals(Model.Status, "discontinued", StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="discontinued" selected>Ngừng bán</option>
                        }
                        else
                        {
                            <option value="discontinued">Ngừng bán</option>
                        }
                    </select>
                </div>
                <div class="col-md-6 col-xl-2">
                    <label class="form-label fw-semibold text-secondary">Danh mục</label>
                    <select class="form-select" name="categoryId">
                        <option value="">Tất cả danh mục</option>
                        @foreach (var item in Model.Categories)
                        {
                            if (Model.CategoryId == item.CategoryId)
                            {
                                <option value="@item.CategoryId" selected>@item.Name</option>
                            }
                            else
                            {
                                <option value="@item.CategoryId">@item.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-6 col-xl-2">
                    <label class="form-label fw-semibold text-secondary">Thương hiệu</label>
                    <select class="form-select" name="brandId">
                        <option value="">Tất cả thương hiệu</option>
                        @foreach (var item in Model.Brands)
                        {
                            if (Model.BrandId == item.BrandId)
                            {
                                <option value="@item.BrandId" selected>@item.Name</option>
                            }
                            else
                            {
                                <option value="@item.BrandId">@item.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-6 col-xl-2">
                    <label class="form-label fw-semibold text-secondary">Tồn từ</label>
                    <input type="number" class="form-control" name="stockFrom" value="@Model.StockFrom" placeholder="0" min="0" />
                </div>
                <div class="col-md-6 col-xl-2">
                    <label class="form-label fw-semibold text-secondary">Tồn đến</label>
                    <input type="number" class="form-control" name="stockTo" value="@Model.StockTo" placeholder="999" min="0" />
                </div>
                <div class="col-12">
                    <div class="admin-search-actions-row">
                        <div class="admin-search-actions">
                            <button type="submit" class="btn btn-primary">Tìm kiếm</button>
                            <a href="/Admin/StockManager/Inventory" class="btn btn-light border">Làm mới</a>
                        </div>
                    </div>
                </div>
            </form>

            <div class="table-responsive reusable-admin-table">
                <table class="table table-hover align-middle stock-admin-page__table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 72px;">Ảnh</th>
                            <th>Sản phẩm</th>
                            <th style="width: 140px;">SKU</th>
                            <th style="width: 150px;">Thương hiệu</th>
                            <th style="width: 150px;">Danh mục</th>
                            <th style="width: 150px;">Giá bán</th>
                            <th style="width: 90px;">Tồn</th>
                            <th style="width: 160px;">Trạng thái</th>
                            <th style="width: 200px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Items.Count == 0)
                        {
                            <tr>
                                <td colspan="9" class="text-center text-muted py-5">
                                    Không tìm thấy sản phẩm phù hợp với bộ lọc hiện tại.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var product in Model.Items)
                            {
                                var statusLabel = product.Status switch
                                {
                                    "available" => "Sẵn hàng",
                                    "outstock" => "Hết hàng",
                                    "preorder" => "Đặt trước",
                                    "discontinued" => "Ngừng bán",
                                    _ => "Không xác định"
                                };
                                var imageSource = string.IsNullOrEmpty(product.ImageUrl)
                                    ? Url.Content("~/Upload/Products/no-image.png")
                                    : product.ImageUrl!.Contains("http", StringComparison.OrdinalIgnoreCase)
                                        ? ResizeCDN.Cdn(product.ImageUrl, 48, 48)
                                        : Url.Content($"~/Upload/Products/{product.ImageUrl}");

                                <tr>
                                    <td>
                                        <div class="brand-admin__logo-shell">
                                            <img src="@imageSource" alt="@product.Name" class="brand-admin__logo" loading="lazy" />
                                        </div>
                                    </td>
                                    <td>
                                        <div class="stock-admin-page__product-name">@product.Name</div>
                                    </td>
                                    <td>@product.Sku</td>
                                    <td>@(string.IsNullOrWhiteSpace(product.BrandName) ? "-" : product.BrandName)</td>
                                    <td>@(string.IsNullOrWhiteSpace(product.CategoryName) ? "-" : product.CategoryName)</td>
                                    <td class="order-admin__amount">@(product.SellPrice?.ToString("C0", new CultureInfo("vi-VN")) ?? "-")</td>
                                    <td>@product.Stock</td>
                                    <td>
                                        <div class="order-admin__state">
                                            <span class="order-admin__state-dot @($"order-admin__state-dot--{product.Status?.ToLowerInvariant()}")"></span>
                                            <div class="order-admin__state-body">
                                                <strong>@statusLabel</strong>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="stock-admin-page__row-actions">
                                            <a href="/Admin/Products/GenerateCode/@product.ProductId" class="btn btn-light border btn-sm">
                                                In mã
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_ManualPagination.cshtml", new Tech_Store.Models.ViewModel.ManualPaginationViewModel
            {
                CurrentPage = Model.Page,
                TotalPages = Model.TotalPages,
                BaseUrl = "/Admin/StockManager/Inventory",
                QueryString = Model.QueryString
            })
        </div>
    </div>
</div>

@await Html.PartialAsync("~/Areas/Admin/Views/Shared/_AdminRightDrawer.cshtml", new Tech_Store.Models.ViewModel.AdminRightDrawerViewModel
{
    DrawerId = "stockQuickDrawer",
    Title = "Tác vụ kho hàng",
    BodyId = "stockQuickDrawerBody",
    WidthClass = "admin-right-drawer--lg"
})

<div class="d-none" id="stockQuickDrawerTemplate">
    @await Html.PartialAsync("~/Areas/Admin/Views/StockManager/_QuickDrawerContent.cshtml", Model)
</div>

<script>
    $(document).ready(function () {
        const drawerElement = document.getElementById('stockQuickDrawer');
        const drawerBody = $('#stockQuickDrawerBody');
        const stockDrawer = drawerElement ? bootstrap.Offcanvas.getOrCreateInstance(drawerElement) : null;

        $('#openStockQuickDrawer').on('click', function () {
            if (!stockDrawer) {
                return;
            }

            drawerBody.html($('#stockQuickDrawerTemplate').html());
            stockDrawer.show();
        });
    });
</script>
