@model Tech_Store.Models.ViewModel.AdminStockProductPickerViewModel
@using Tech_Store.Helpers

<div class="table-responsive reusable-admin-table">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th style="width: 56px;"></th>
                <th>Sản phẩm</th>
                <th style="width: 140px;">SKU</th>
                <th style="width: 140px;">Thương hiệu</th>
                <th style="width: 140px;">Danh mục</th>
                <th style="width: 90px;">Biến thể</th>
                <th style="width: 90px;">Tồn</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Items.Count == 0)
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">Không tìm thấy sản phẩm phù hợp.</td>
                </tr>
            }
            else
            {
                foreach (var item in Model.Items)
                {
                    var productImage = string.IsNullOrWhiteSpace(item.ProductImageUrl)
                        ? Url.Content("~/Upload/Products/no-image.png")
                        : item.ProductImageUrl!.Contains("http", StringComparison.OrdinalIgnoreCase)
                            ? ResizeCDN.Cdn(item.ProductImageUrl, 48, 48)
                            : Url.Content($"~/Upload/Products/{item.ProductImageUrl}");

                    <tr>
                        <td>
                            <input type="checkbox"
                                   class="form-check-input js-product-picker-checkbox"
                                   value="@item.ProductId"
                                   data-name="@item.Name"
                                   data-sku="@item.Sku"
                                   data-image="@item.ProductImageUrl"
                                   aria-label="Chọn @item.Name" />
                        </td>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <img src="@productImage" alt="@item.Name" style="width: 40px; height: 40px; object-fit: cover; border-radius: 10px;" />
                                <div>
                                    <div class="fw-semibold text-dark">@item.Name</div>
                                </div>
                            </div>
                        </td>
                        <td>@item.Sku</td>
                        <td>@(string.IsNullOrWhiteSpace(item.BrandName) ? "-" : item.BrandName)</td>
                        <td>@(string.IsNullOrWhiteSpace(item.CategoryName) ? "-" : item.CategoryName)</td>
                        <td>@item.VariantCount</td>
                        <td>@item.Stock</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<div class="d-flex align-items-center justify-content-between mt-3">
    <div class="text-muted small">Tổng @Model.TotalItems sản phẩm</div>
    <div class="d-flex gap-2">
        <button type="button"
                class="btn btn-light border btn-sm js-product-picker-page"
                data-page="@(Model.Page - 1)"
                @(Model.Page <= 1 ? "disabled" : null)>
            Trước
        </button>
        <span class="align-self-center text-muted small">Trang @Model.Page/@Model.TotalPages</span>
        <button type="button"
                class="btn btn-light border btn-sm js-product-picker-page"
                data-page="@(Model.Page + 1)"
                @(Model.Page >= Model.TotalPages ? "disabled" : null)>
            Sau
        </button>
    </div>
</div>
