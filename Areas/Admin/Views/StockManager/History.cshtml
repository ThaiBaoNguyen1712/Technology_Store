@using System.Globalization
@model Tech_Store.Models.ViewModel.AdminStockHistoryIndexViewModel
@{
    ViewData["Title"] = "Lịch sử kho";
    Layout = "~/Areas/Admin/Views/Shared/Layout.cshtml";
}

<div class="py-3 stock-history-page">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-0 pb-0">
            <div class="d-flex flex-wrap gap-3 align-items-center justify-content-between">
                <div>
                    <h4 class="card-title mb-1">Lịch sử nhập xuất kho</h4>
                </div>
                <div class="order-admin__header-meta">
                    <span class="order-admin__header-pill">Tổng phiếu: @Model.TotalItems</span>
                    <span class="order-admin__header-pill">Nhập kho: @Model.ImportCount</span>
                    <span class="order-admin__header-pill">Xuất kho: @Model.ExportCount</span>
                    <span class="order-admin__header-pill">Trang @Model.Page/@Model.TotalPages</span>
                </div>
            </div>
        </div>

        <div class="card-body">
            <form method="get" action="/Admin/StockManager/History" class="brand-admin__filters order-admin__filters row g-3 align-items-end mb-4">
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Từ ngày</label>
                    <input type="date" class="form-control" name="startDate" value="@(Model.StartDate?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Đến ngày</label>
                    <input type="date" class="form-control" name="endDate" value="@(Model.EndDate?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Loại phiếu</label>
                    <select class="form-select" name="filterType">
                        <option value="" selected="@string.IsNullOrWhiteSpace(Model.FilterType)">Tất cả loại phiếu</option>
                        <option value="import" selected="@string.Equals(Model.FilterType, "import", StringComparison.OrdinalIgnoreCase)">Nhập kho</option>
                        <option value="export" selected="@string.Equals(Model.FilterType, "export", StringComparison.OrdinalIgnoreCase)">Xuất kho</option>
                    </select>
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Mã phiếu / SKU / tên sản phẩm</label>
                    <input type="text"
                           class="form-control"
                           name="filterCode"
                           value="@Model.FilterCode"
                           placeholder="Nhập mã phiếu, SKU hoặc tên sản phẩm..." />
                </div>
                <div class="col-12 col-xl-4 ms-xl-auto">
                    <div class="order-admin__filter-actions">
                        <button type="submit" class="btn btn-primary">Tìm kiếm</button>
                        <a href="/Admin/StockManager/History" class="btn btn-light border">Làm mới</a>
                    </div>
                </div>
            </form>

            <div class="row g-4">
                <div class="col-xl-7">
                    <div class="stock-history-page__list">
                        @if (Model.Items.Count == 0)
                        {
                            <div class="stock-history-page__empty">
                                Không tìm thấy phiếu kho phù hợp với bộ lọc hiện tại.
                            </div>
                        }
                        else
                        {
                            foreach (var item in Model.Items)
                            {
                                var totalQuantity = item.InventoryTransactionDetail?.Sum(x => x.Quantity) ?? 0;
                                var isImport = string.Equals(item.Type, "Import", StringComparison.OrdinalIgnoreCase);

                                <button type="button"
                                        class="stock-history-card @(isImport ? "stock-history-card--import" : "stock-history-card--export") js-stock-history-card"
                                        data-id="@item.InventoryTransId">
                                    <div class="stock-history-card__head">
                                        <div>
                                            <div class="stock-history-card__title">
                                                @(isImport ? "Phiếu nhập kho" : "Phiếu xuất kho") #@item.InventoryTransId
                                            </div>
                                            <div class="stock-history-card__time">
                                                @item.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss", new CultureInfo("vi-VN"))
                                            </div>
                                        </div>
                                        <div class="order-admin__state">
                                            <span class="order-admin__state-dot @(isImport ? "order-admin__state-dot--success" : "order-admin__state-dot--danger")"></span>
                                            <div class="order-admin__state-body">
                                                <strong>@(isImport ? "Nhập kho" : "Xuất kho")</strong>
                                                <span>@totalQuantity sản phẩm</span>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="stock-history-card__body">
                                        <div class="stock-history-card__meta">
                                            <span>SKU</span>
                                            <strong>@item.Product.Sku</strong>
                                        </div>
                                        <div class="stock-history-card__meta">
                                            <span>Sản phẩm</span>
                                            <strong>@item.Product.Name</strong>
                                        </div>
                                        <div class="stock-history-card__meta">
                                            <span>Người tạo</span>
                                            <strong>@item.UserName (@item.UserRole)</strong>
                                        </div>
                                        <div class="stock-history-card__meta">
                                            <span>Ghi chú</span>
                                            <strong>@(string.IsNullOrWhiteSpace(item.Note) ? "Không có ghi chú" : item.Note)</strong>
                                        </div>
                                    </div>
                                </button>
                            }
                        }
                    </div>

                    @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_ManualPagination.cshtml", new Tech_Store.Models.ViewModel.ManualPaginationViewModel
                    {
                        CurrentPage = Model.Page,
                        TotalPages = Model.TotalPages,
                        BaseUrl = "/Admin/StockManager/History",
                        QueryString = Model.QueryString
                    })
                </div>

                <div class="col-xl-5">
                    <div class="card shadow-sm border-0 stock-history-page__detail-card">
                        <div class="card-header bg-white border-0">
                            <h6 class="mb-0">Chi tiết phiếu kho</h6>
                        </div>
                        <div class="card-body">
                            <div class="stock-history-detail__empty" id="emptyState">
                                <i class="fas fa-file-alt"></i>
                                <p>Chọn một phiếu ở danh sách bên trái để xem chi tiết.</p>
                            </div>

                            <div id="detailView" class="d-none">
                                <div class="order-admin__detail-list mb-4">
                                    <div class="order-admin__detail-row">
                                        <span>Mã phiếu</span>
                                        <strong id="ticketCode"></strong>
                                    </div>
                                    <div class="order-admin__detail-row">
                                        <span>Thời gian</span>
                                        <strong id="ticketTime"></strong>
                                    </div>
                                    <div class="order-admin__detail-row">
                                        <span>Người tạo</span>
                                        <strong id="ticketCreator"></strong>
                                    </div>
                                    <div class="order-admin__detail-row">
                                        <span>Sản phẩm</span>
                                        <strong id="ticketProduct"></strong>
                                    </div>
                                    <div class="order-admin__detail-row">
                                        <span>Loại phiếu</span>
                                        <div class="order-admin__state">
                                            <span id="ticketTypeDot" class="order-admin__state-dot"></span>
                                            <div class="order-admin__state-body">
                                                <strong id="ticketTypeLabel"></strong>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="order-admin__detail-row">
                                        <span>Ghi chú</span>
                                        <strong id="ticketNote"></strong>
                                    </div>
                                </div>

                                <div class="table-responsive reusable-admin-table">
                                    <table class="table table-hover align-middle stock-history-detail__table mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>SKU biến thể</th>
                                                <th>Biến thể</th>
                                                <th class="text-end">Số lượng</th>
                                            </tr>
                                        </thead>
                                        <tbody id="productDetails"></tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            const $cards = $('.js-stock-history-card');
            const $emptyState = $('#emptyState');
            const $detailView = $('#detailView');
            const $detailsBody = $('#productDetails');
            const $ticketTypeDot = $('#ticketTypeDot');
            const $ticketTypeLabel = $('#ticketTypeLabel');

            function renderDetail(history) {
                const isImport = history.type === 'Import';
                $('#ticketCode').text(`#${history.id}`);
                $('#ticketTime').text(new Date(history.createdAt).toLocaleString('vi-VN'));
                $('#ticketCreator').text(`${history.userName} (${history.userRole})`);
                $('#ticketProduct').text(history.product.name);
                $('#ticketNote').text(history.note && history.note.trim() ? history.note : 'Không có ghi chú');

                $ticketTypeLabel.text(isImport ? 'Nhập kho' : 'Xuất kho');
                $ticketTypeDot
                    .removeClass('order-admin__state-dot--success order-admin__state-dot--danger')
                    .addClass(isImport ? 'order-admin__state-dot--success' : 'order-admin__state-dot--danger');

                $detailsBody.empty();

                if (history.inventoryTransactionDetail && history.inventoryTransactionDetail.length) {
                    history.inventoryTransactionDetail.forEach(detail => {
                        $detailsBody.append(`
                            <tr>
                                <td>${detail.varientSku || '-'}</td>
                                <td>${detail.varientName || '-'}</td>
                                <td class="text-end">${detail.quantity}</td>
                            </tr>
                        `);
                    });
                } else {
                    $detailsBody.append(`
                        <tr>
                            <td colspan="3" class="text-center text-muted py-4">Không có chi tiết biến thể.</td>
                        </tr>
                    `);
                }

                $emptyState.addClass('d-none');
                $detailView.removeClass('d-none');
            }

            $cards.on('click', function () {
                const $card = $(this);
                const id = $card.data('id');

                $('.loading-container').show();
                $.ajax({
                    method: 'GET',
                    url: `/Admin/StockManager/GetHistoryDetail/${id}`,
                    success: function (response) {
                        $('.loading-container').hide();

                        if (!response || !response.success) {
                            Swal.fire('Không thể tải dữ liệu', response?.message || 'Có lỗi xảy ra.', 'error');
                            return;
                        }

                        $cards.removeClass('is-active');
                        $card.addClass('is-active');
                        renderDetail(response.history);
                    },
                    error: function () {
                        $('.loading-container').hide();
                        Swal.fire('Không thể tải dữ liệu', 'Vui lòng thử lại.', 'error');
                    }
                });
            });
        });
    </script>
}
