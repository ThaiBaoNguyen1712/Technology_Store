@using System.Globalization
@using System.Text.Json
@using Tech_Store.Helpers
@model Tech_Store.Models.ViewModel.AdminStockHistoryIndexViewModel
@{
    ViewData["Title"] = "Nhập - Xuất Kho";
    Layout = "~/Areas/Admin/Views/Shared/Layout.cshtml";
}

<div class="py-3 stock-history-page">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-0 pb-0">
            <div class="d-flex flex-wrap gap-3 align-items-center justify-content-between">
                <div>
                    <h4 class="card-title mb-1">Nhập - Xuất Kho</h4>
                </div>
                <div class="order-admin__header-meta">
                    <span class="order-admin__header-pill">Tổng phiếu: @Model.TotalItems</span>
                    <span class="order-admin__header-pill">Nhập kho: @Model.ImportCount</span>
                    <span class="order-admin__header-pill">Xuất kho: @Model.ExportCount</span>
                    <span class="order-admin__header-pill">Trang @Model.Page/@Model.TotalPages</span>
                    <a href="/Admin/StockManager/CreateTransaction" class="btn btn-primary">
                        Tạo phiếu nhập - xuất
                    </a>
                </div>
            </div>
        </div>

        <div class="card-body">
            <form method="get" action="/Admin/StockManager/Transactions" class="brand-admin__filters order-admin__filters row g-3 align-items-end mb-4">
                <input type="hidden" name="page" value="1" />
                <input type="hidden" name="pageSize" value="@Model.PageSize" />

                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Từ ngày</label>
                    <input type="date" class="form-control" name="startDate" value="@(Model.StartDate?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Đến ngày</label>
                    <input type="date" class="form-control" name="endDate" value="@(Model.EndDate?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Loại phiếu</label>
                    <select class="form-select" name="filterType">
                        <option value="">Tất cả loại phiếu</option>
                        @if (string.Equals(Model.FilterType, "import", StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="import" selected>Nhập kho</option>
                            <option value="export">Xuất kho</option>
                        }
                        else if (string.Equals(Model.FilterType, "export", StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="import">Nhập kho</option>
                            <option value="export" selected>Xuất kho</option>
                        }
                        else
                        {
                            <option value="import">Nhập kho</option>
                            <option value="export">Xuất kho</option>
                        }
                    </select>
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Mã phiếu / SKU / tên sản phẩm</label>
                    <input type="text" class="form-control" name="filterCode" value="@Model.FilterCode" placeholder="Nhập mã phiếu, SKU hoặc tên sản phẩm..." />
                </div>
                <div class="col-12">
                    <div class="admin-search-actions-row">
                        <div class="admin-search-actions">
                            <button type="submit" class="btn btn-primary">Tìm kiếm</button>
                            <a href="/Admin/StockManager/Transactions" class="btn btn-light border">Làm mới</a>
                        </div>
                    </div>
                </div>
            </form>

            <div class="table-responsive reusable-admin-table">
                <table class="table table-hover align-middle stock-history-page__table">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 120px;">Mã phiếu</th>
                            <th style="width: 140px;">Loại phiếu</th>
                            <th>Thông tin sản phẩm</th>
                            <th style="width: 180px;">Nhà cung cấp</th>
                            <th style="width: 90px;" class="text-end">SL</th>
                            <th style="width: 180px;">Người tạo</th>
                            <th style="width: 160px;">Thời gian</th>
                            <th style="width: 130px;" class="text-center">Tác vụ</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Items.Count == 0)
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-5">Không tìm thấy phiếu kho phù hợp với bộ lọc hiện tại.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model.Items)
                            {
                                var isImport = string.Equals(item.Type, "Import", StringComparison.OrdinalIgnoreCase);
                                var supplierText = isImport
                                    ? (string.IsNullOrWhiteSpace(item.SupplierName) ? "Chưa gắn nhà cung cấp" : $"{item.SupplierCode} - {item.SupplierName}")
                                    : "-";
                                var noteText = string.IsNullOrWhiteSpace(item.Note) ? "Không có ghi chú" : item.Note;
                                var leadProduct = item.Products.FirstOrDefault();
                                var productImage = string.IsNullOrWhiteSpace(leadProduct?.ProductImageUrl)
                                    ? Url.Content("~/Upload/Products/no-image.png")
                                    : leadProduct!.ProductImageUrl!.Contains("http", StringComparison.OrdinalIgnoreCase)
                                        ? ResizeCDN.Cdn(leadProduct.ProductImageUrl, 64, 64)
                                        : Url.Content($"~/Upload/Products/{leadProduct.ProductImageUrl}");
                                var editUrl = Url.Action("EditTransaction", "StockManager", new
                                {
                                    area = "Admin",
                                    id = item.InventoryTransId,
                                    returnPage = Model.Page,
                                    returnPageSize = Model.PageSize,
                                    returnSource = "history",
                                    returnHistoryFilterCode = Model.FilterCode,
                                    returnHistoryFilterType = Model.FilterType,
                                    returnHistoryStartDate = Model.StartDate?.ToString("yyyy-MM-dd"),
                                    returnHistoryEndDate = Model.EndDate?.ToString("yyyy-MM-dd")
                                });

                                <tr class="js-stock-history-row"
                                    data-id="@item.InventoryTransId"
                                    data-edit-url="@editUrl">
                                    <td>
                                        <button type="button" class="btn btn-link p-0 text-decoration-none fw-semibold js-stock-history-open">
                                            #@item.InventoryTransId
                                        </button>
                                    </td>
                                    <td>
                                        <div class="order-admin__state">
                                            <span class="order-admin__state-dot @(isImport ? "order-admin__state-dot--success" : "order-admin__state-dot--danger")"></span>
                                            <div class="order-admin__state-body">
                                                <strong>@(isImport ? "Nhập kho" : "Xuất kho")</strong>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-start gap-3">
                                            <img src="@productImage" alt="@(leadProduct?.ProductName ?? "Sản phẩm")" style="width: 44px; height: 44px; object-fit: cover; border-radius: 12px;" />
                                            <div>
                                                <div class="fw-semibold text-dark">@(leadProduct?.ProductName ?? "Không xác định")</div>
                                                <div class="small text-muted">SKU: @(string.IsNullOrWhiteSpace(leadProduct?.ProductSku) ? "-" : leadProduct?.ProductSku)</div>
                                                @if (item.ProductCount > 1)
                                                {
                                                    <div class="small text-primary">+ @(item.ProductCount - 1) sản phẩm khác</div>
                                                }
                                                <div class="small text-muted text-truncate">@noteText</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-muted">@supplierText</td>
                                    <td class="text-end fw-semibold">@item.TotalQuantity</td>
                                    <td>
                                        <div class="fw-semibold text-dark">@item.UserName</div>
                                        <div class="small text-muted">@item.UserRole</div>
                                    </td>
                                    <td class="text-muted">@item.CreatedAt.ToString("dd/MM/yyyy HH:mm", new CultureInfo("vi-VN"))</td>
                                    <td class="text-center">
                                        <button type="button" class="btn btn-light border btn-sm js-stock-history-open">Chi tiết</button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_ManualPagination.cshtml", new Tech_Store.Models.ViewModel.ManualPaginationViewModel
            {
                CurrentPage = Model.Page,
                TotalPages = Model.TotalPages,
                BaseUrl = "/Admin/StockManager/Transactions",
                QueryString = Model.QueryString
            })
        </div>
    </div>
</div>

@await Html.PartialAsync("~/Areas/Admin/Views/Shared/_AdminRightDrawer.cshtml", new Tech_Store.Models.ViewModel.AdminRightDrawerViewModel
{
    DrawerId = "stockHistoryDrawer",
    Title = "Chi tiết phiếu kho",
    Description = "Theo dõi nhanh thông tin phiếu nhập/xuất, số lượng sản phẩm và thao tác cập nhật liên quan.",
    BodyId = "stockHistoryDrawerBody",
    WidthClass = "admin-right-drawer--lg"
})

<script src="~/Admin/assets/js/core/jquery-3.7.1.min.js"></script>
<script>
    $(function () {
        const $rows = $('.js-stock-history-row');
        const drawerElement = document.getElementById('stockHistoryDrawer');
        const drawerBody = $('#stockHistoryDrawerBody');
        const stockHistoryDrawer = drawerElement ? bootstrap.Offcanvas.getOrCreateInstance(drawerElement) : null;
        const defaultImageUrl = '@Url.Content("~/Upload/Products/no-image.png")';

        function escapeHtml(value) {
            return $('<div/>').text(value || '').html();
        }

        function resolveImageUrl(imageUrl) {
            if (!imageUrl) {
                return defaultImageUrl;
            }

            if (String(imageUrl).toLowerCase().startsWith('http')) {
                return imageUrl;
            }

            return `/Upload/Products/${imageUrl}`;
        }

        function buildProductSections(products) {
            if (!products || !products.length) {
                return '<div class="text-muted">Không có sản phẩm trong phiếu này.</div>';
            }

            return products.map(product => {
                const detailRows = product.details && product.details.length
                    ? product.details.map(detail => `
                        <tr>
                            <td>${escapeHtml(detail.varientSku || '-')}</td>
                            <td>${escapeHtml(detail.varientName || '-')}</td>
                            <td class="text-end">${detail.quantity}</td>
                        </tr>
                    `).join('')
                    : `
                        <tr>
                            <td colspan="3" class="text-center text-muted py-4">Không có chi tiết biến thể.</td>
                        </tr>
                    `;

                return `
                    <section class="transaction-drawer__section">
                        <div class="d-flex align-items-start gap-3 mb-3">
                            <img src="${resolveImageUrl(product.productImageUrl)}" alt="${escapeHtml(product.productName)}" style="width: 48px; height: 48px; object-fit: cover; border-radius: 12px;" />
                            <div>
                                <div class="fw-semibold">${escapeHtml(product.productName)}</div>
                                <div class="text-muted small">SKU: ${escapeHtml(product.productSku || '-')}</div>
                                <div class="text-muted small">Tổng số lượng: ${product.totalQuantity}</div>
                            </div>
                        </div>
                        <div class="table-responsive reusable-admin-table">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>SKU biến thể</th>
                                        <th>Biến thể</th>
                                        <th class="text-end">Số lượng</th>
                                    </tr>
                                </thead>
                                <tbody>${detailRows}</tbody>
                            </table>
                        </div>
                    </section>
                `;
            }).join('');
        }

        function buildDrawerHtml(history) {
            const isImport = history.type === 'Import';
            const supplierText = isImport
                ? (history.supplierCode && history.supplierName
                    ? `${history.supplierCode} - ${history.supplierName}`
                    : 'Chưa gắn nhà cung cấp')
                : 'Phiếu xuất không áp dụng';

            return `
                <div class="transaction-drawer">
                    <div class="transaction-drawer__summary">
                        <div class="transaction-drawer__summary-card">
                            <span>Mã phiếu</span>
                            <strong>#${history.inventoryTransId}</strong>
                        </div>
                        <div class="transaction-drawer__summary-card">
                            <span>Loại phiếu</span>
                            <strong>${isImport ? 'Nhập kho' : 'Xuất kho'}</strong>
                        </div>
                        <div class="transaction-drawer__summary-card">
                            <span>Sản phẩm</span>
                            <strong>${history.productCount}</strong>
                        </div>
                        <div class="transaction-drawer__summary-card">
                            <span>Tổng số lượng</span>
                            <strong>${history.totalQuantity}</strong>
                        </div>
                    </div>

                    <section class="transaction-drawer__section">
                        <div class="transaction-drawer__section-head">
                            <h6>Thông tin phiếu</h6>
                        </div>
                        <div class="transaction-drawer__info-list">
                            <div class="transaction-drawer__info-row">
                                <span>Nhà cung cấp</span>
                                <strong>${supplierText}</strong>
                            </div>
                            <div class="transaction-drawer__info-row">
                                <span>Người tạo</span>
                                <strong>${history.userName || '-'}</strong>
                            </div>
                            <div class="transaction-drawer__info-row">
                                <span>Vai trò</span>
                                <strong>${history.userRole || '-'}</strong>
                            </div>
                            <div class="transaction-drawer__info-row">
                                <span>Thời gian</span>
                                <strong>${new Date(history.createdAt).toLocaleString('vi-VN')}</strong>
                            </div>
                            <div class="transaction-drawer__info-row">
                                <span>Ghi chú</span>
                                <strong>${history.note && history.note.trim() ? history.note : 'Không có ghi chú'}</strong>
                            </div>
                        </div>
                    </section>

                    <section class="transaction-drawer__section">
                        <div class="transaction-drawer__section-head">
                            <h6>HÃ nh Ä‘á»™ng</h6>
                        </div>
                        <div class="transaction-drawer__actions">
                            <a href="${history.editUrl}" class="btn btn-primary">Chá»‰nh sá»­a phiáº¿u</a>
                        </div>
                    </section>

                    ${buildProductSections(history.products)}

                    <section class="transaction-drawer__section">
                        <div class="transaction-drawer__section-head">
                            <h6>Hành động</h6>
                        </div>
                        <div class="transaction-drawer__actions">
                            <a href="${history.editUrl}" class="btn btn-primary">Chỉnh sửa phiếu</a>
                        </div>
                    </section>
                </div>
            `;
        }

        function normalizeDrawerActions() {
            const $drawer = drawerBody.find('.transaction-drawer');
            const $actionSections = $drawer.find('.transaction-drawer__section').filter(function () {
                return $(this).find('.transaction-drawer__actions').length > 0;
            });

            if (!$actionSections.length) {
                return;
            }

            const $actionSection = $actionSections.first();
            $actionSection.find('h6').text('Hanh dong');
            $actionSection.find('.btn').text('Chi tiết phiếu kho');

            const $productSection = $drawer.find('.transaction-drawer__section').filter(function () {
                return $(this).find('table').length > 0 || $(this).find('.transaction-drawer__product').length > 0;
            }).first();

            if ($productSection.length) {
                $actionSection.insertBefore($productSection);
            }

            $actionSections.not($actionSection).remove();
        }

        function openHistoryDetail($row) {
            const id = $row.data('id');
            const editUrl = $row.data('edit-url');

            if (!stockHistoryDrawer) {
                return;
            }

            drawerBody.html('<div class="admin-right-drawer__loading">Đang tải chi tiết phiếu kho...</div>');
            stockHistoryDrawer.show();
            $('.loading-container').show();

            $.ajax({
                method: 'GET',
                url: `/Admin/StockManager/GetHistoryDetail/${id}`,
                success: function (response) {
                    if (!response || !response.success) {
                        drawerBody.html('<div class="alert alert-danger mb-0">Không thể tải dữ liệu phiếu kho.</div>');
                        return;
                    }

                    response.history.editUrl = editUrl;
                    $rows.removeClass('table-active');
                    $row.addClass('table-active');
                    drawerBody.html(buildDrawerHtml(response.history));
                    normalizeDrawerActions();
                },
                error: function () {
                    drawerBody.html('<div class="alert alert-danger mb-0">Không thể tải dữ liệu phiếu kho.</div>');
                },
                complete: function () {
                    $('.loading-container').hide();
                }
            });
        }

        $rows.on('click', function (event) {
            if ($(event.target).closest('a').length > 0) {
                return;
            }

            openHistoryDetail($(this));
        });

        $('.js-stock-history-open').on('click', function (event) {
            event.preventDefault();
            event.stopPropagation();
            openHistoryDetail($(this).closest('.js-stock-history-row'));
        });

        const successMessage = @Html.Raw(JsonSerializer.Serialize(TempData["success"]?.ToString() ?? string.Empty));
        if (successMessage) {
            Swal.fire({
                icon: 'success',
                title: 'Thành công',
                text: successMessage,
                confirmButtonText: 'OK'
            });
        }
    });
</script>
