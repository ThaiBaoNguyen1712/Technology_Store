@model Tech_Store.Models.ViewModel.AdminStockTransactionFormViewModel
@using System.Globalization
@using Tech_Store.Helpers
@{
    ViewData["Title"] = Model.IsEdit ? "Cập nhật phiếu kho" : "Tạo phiếu kho";
    Layout = "~/Areas/Admin/Views/Shared/Layout.cshtml";

    var productImage = string.IsNullOrEmpty(Model.ProductImageUrl)
        ? Url.Content("~/Upload/Products/no-image.png")
        : Model.ProductImageUrl!.Contains("http", StringComparison.OrdinalIgnoreCase)
            ? ResizeCDN.Cdn(Model.ProductImageUrl, 80, 80)
            : Url.Content($"~/Upload/Products/{Model.ProductImageUrl}");
}

<div class="py-3 stock-transaction-page">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-0">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                <div>
                    <h4 class="card-title mb-1">@(Model.IsEdit ? "Cập nhật phiếu nhập xuất" : "Tạo phiếu nhập xuất")</h4>
                    <p class="text-muted mb-0">Quản lý tồn kho theo chuẩn vận hành ecommerce, tách rõ phiếu nhập và phiếu xuất.</p>
                </div>
                <a href="@(string.Equals(Model.ReturnSource, "history", StringComparison.OrdinalIgnoreCase)
                    ? Url.Action("History", "StockManager", new
                    {
                        area = "Admin",
                        page = Model.ReturnPage,
                        pageSize = Model.ReturnPageSize,
                        startDate = Model.ReturnHistoryStartDate?.ToString("yyyy-MM-dd"),
                        endDate = Model.ReturnHistoryEndDate?.ToString("yyyy-MM-dd"),
                        filterType = Model.ReturnHistoryFilterType,
                        filterCode = Model.ReturnHistoryFilterCode
                    })
                    : Url.Action("Index", "StockManager", new
                    {
                        area = "Admin",
                        page = Model.ReturnPage,
                        sku = Model.ReturnSku,
                        name = Model.ReturnName,
                        status = Model.ReturnStatus,
                        categoryId = Model.ReturnCategoryId,
                        brandId = Model.ReturnBrandId,
                        stockFrom = Model.ReturnStockFrom,
                        stockTo = Model.ReturnStockTo
                    }))"
                   class="btn btn-light border">
                    @(string.Equals(Model.ReturnSource, "history", StringComparison.OrdinalIgnoreCase) ? "Quay lại lịch sử kho" : "Quay lại tồn kho")
                </a>
            </div>
        </div>
        <div class="card-body">
            <div class="stock-transaction-page__summary">
                <div class="brand-admin__logo-shell stock-transaction-page__image-shell">
                    <img src="@productImage" alt="@Model.ProductName" class="brand-admin__logo stock-transaction-page__image" />
                </div>
                <div class="stock-transaction-page__summary-body">
                    <strong>@Model.ProductName</strong>
                    <span>SKU gốc: @Model.ProductSku</span>
                    <span>Tổng biến thể: @Model.Variants.Count</span>
                </div>
            </div>

            <form method="post" action="/Admin/StockManager/SaveTransaction" class="stock-transaction-page__form">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="InventoryTransId" />
                <input type="hidden" asp-for="ProductId" />
                <input type="hidden" asp-for="ReturnPage" />
                <input type="hidden" asp-for="ReturnPageSize" />
                <input type="hidden" asp-for="ReturnSku" />
                <input type="hidden" asp-for="ReturnName" />
                <input type="hidden" asp-for="ReturnStatus" />
                <input type="hidden" asp-for="ReturnCategoryId" />
                <input type="hidden" asp-for="ReturnBrandId" />
                <input type="hidden" asp-for="ReturnStockFrom" />
                <input type="hidden" asp-for="ReturnStockTo" />
                <input type="hidden" asp-for="ReturnSource" />
                <input type="hidden" asp-for="ReturnHistoryFilterCode" />
                <input type="hidden" asp-for="ReturnHistoryFilterType" />
                <input type="hidden" asp-for="ReturnHistoryStartDate" />
                <input type="hidden" asp-for="ReturnHistoryEndDate" />

                <div class="row g-3 brand-admin__filters stock-transaction-page__filters">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-secondary">Loại phiếu</label>
                        <select asp-for="Type" class="form-select js-stock-transaction-type">
                            @if (string.Equals(Model.Type, "Import", StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="Import" selected>Phiếu nhập kho</option>
                                <option value="Export">Phiếu xuất kho</option>
                            }
                            else
                            {
                                <option value="Import">Phiếu nhập kho</option>
                                <option value="Export" selected>Phiếu xuất kho</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6 js-stock-supplier-field">
                        <label class="form-label fw-semibold text-secondary">Nhà cung cấp</label>
                        <select asp-for="SupplierId" class="form-select">
                            <option value="">Chọn nhà cung cấp</option>
                            @foreach (var supplier in Model.Suppliers)
                            {
                                if (Model.SupplierId == supplier.SupplierId)
                                {
                                    <option value="@supplier.SupplierId" selected>@supplier.Code - @supplier.Name</option>
                                }
                                else
                                {
                                    <option value="@supplier.SupplierId">@supplier.Code - @supplier.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold text-secondary">Ghi chú vận hành</label>
                        <textarea asp-for="Note" class="form-control" rows="3" placeholder="Ví dụ: nhập đợt đầu tháng, hoàn kho sau kiểm đếm, xuất trả NCC..."></textarea>
                    </div>
                </div>

                <div class="table-responsive reusable-admin-table mt-4">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>SKU biến thể</th>
                                <th>Phân loại</th>
                                <th style="width: 160px;">Giá bán</th>
                                <th style="width: 120px;">Tồn hiện tại</th>
                                <th style="width: 170px;">Số lượng nhập/xuất</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var i = 0; i < Model.Variants.Count; i++)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-semibold text-dark">@Model.Variants[i].Sku</div>
                                    </td>
                                    <td>@Model.Variants[i].AttributeSummary</td>
                                    <td class="order-admin__amount">@(Model.Variants[i].Price?.ToString("C0", new CultureInfo("vi-VN")) ?? "-")</td>
                                    <td>@Model.Variants[i].CurrentStock</td>
                                    <td>
                                        <input type="hidden" asp-for="Variants[@i].VariantId" />
                                        <input type="hidden" asp-for="Variants[@i].Sku" />
                                        <input type="hidden" asp-for="Variants[@i].AttributeSummary" />
                                        <input type="hidden" asp-for="Variants[@i].Price" />
                                        <input type="hidden" asp-for="Variants[@i].CurrentStock" />
                                        <input asp-for="Variants[@i].Quantity" class="form-control" min="0" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="stock-transaction-page__footer">
                    <div class="stock-transaction-page__footer-note">
                        Phiếu nhập bắt buộc gắn nhà cung cấp. Phiếu xuất sẽ tự bỏ thông tin nhà cung cấp khi lưu.
                    </div>
                    <div class="stock-transaction-page__footer-actions">
                        <a href="@Url.Action("History", "StockManager", new { area = "Admin", page = Model.ReturnPage, pageSize = Model.ReturnPageSize, startDate = Model.ReturnHistoryStartDate?.ToString("yyyy-MM-dd"), endDate = Model.ReturnHistoryEndDate?.ToString("yyyy-MM-dd"), filterType = Model.ReturnHistoryFilterType, filterCode = Model.ReturnHistoryFilterCode })" class="btn btn-light border">Xem lịch sử kho</a>
                        <button type="submit" class="btn btn-primary">@(Model.IsEdit ? "Lưu cập nhật" : "Tạo phiếu kho")</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            const $type = $('.js-stock-transaction-type');
            const $supplierField = $('.js-stock-supplier-field');
            const $supplierSelect = $('#SupplierId');

            function syncSupplierField() {
                const isImport = $type.val() === 'Import';
                $supplierField.toggleClass('d-none', !isImport);
                if (!isImport) {
                    $supplierSelect.val('');
                }
            }

            $type.on('change', syncSupplierField);
            syncSupplierField();
        });
    </script>
}
