@model Tech_Store.Models.Product
@using System.Globalization
@using Tech_Store.Helpers
@{
    ViewData["Title"] = "In mã sản phẩm";
    Layout = "/Areas/Admin/Views/Shared/Layout.cshtml";

    var previewImage = string.IsNullOrEmpty(Model.Image)
        ? Url.Content("~/Upload/Products/no-image.png")
        : Model.Image!.Contains("http", StringComparison.OrdinalIgnoreCase)
            ? ResizeCDN.Cdn(Model.Image, 80, 80)
            : Url.Content($"~/Upload/Products/{Model.Image}");

    var selectedContent = ViewBag.Content as string ?? "sku";
    var selectedCodeType = ViewBag.CodeType as string ?? "QRCode";
}

<div class="py-3 barcode-admin-page">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-0">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                <div>
                    <h4 class="card-title mb-1">Tạo mã cho sản phẩm</h4>
                </div>
                <a href="/Admin/StockManager" class="btn btn-light border">Quay lại kho hàng</a>
            </div>
        </div>
        <div class="card-body">
            <div class="barcode-admin-page__summary">
                <div class="brand-admin__logo-shell stock-transaction-page__image-shell">
                    <img src="@previewImage" alt="@Model.Name" class="brand-admin__logo stock-transaction-page__image" />
                </div>
                <div class="stock-transaction-page__summary-body">
                    <strong>@Model.Name</strong>
                    <span>SKU: @Model.Sku</span>
                    <span>Giá bán: @(Model.SellPrice?.ToString("C0", new CultureInfo("vi-VN")) ?? "-")</span>
                </div>
            </div>

            <div class="row g-4 mt-1">
                <div class="col-xl-7">
                    <div class="brand-admin__filters stock-transaction-page__filters">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-secondary">Nội dung mã</label>
                                <select class="form-select" id="contentSelect">
                                    @if (selectedContent == "sku")
                                    {
                                        <option value="sku" selected>SKU</option>
                                        <option value="url">Đường dẫn hiển thị</option>
                                    }
                                    else
                                    {
                                        <option value="sku">SKU</option>
                                        <option value="url" selected>Đường dẫn hiển thị</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-secondary">Loại mã</label>
                                <select class="form-select" id="codeTypeSelect">
                                    @if (selectedCodeType == "QRCode")
                                    {
                                        <option value="QRCode" selected>QR Code</option>
                                        <option value="Barcode">Barcode</option>
                                    }
                                    else
                                    {
                                        <option value="QRCode">QR Code</option>
                                        <option value="Barcode" selected>Barcode</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-secondary">Số lượng tem in</label>
                                <input type="number" min="1" value="1" class="form-control" id="quantityInput" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-secondary">Mã sản phẩm</label>
                                <input type="text" class="form-control" value="@Model.Sku" readonly />
                            </div>
                        </div>
                    </div>

                    <div class="stock-transaction-page__footer mt-4">
                        <div class="stock-transaction-page__footer-note">
                            Barcode chỉ hỗ trợ in theo SKU. QR Code có thể dùng SKU hoặc đường dẫn hiển thị sản phẩm.
                        </div>
                        <div class="stock-transaction-page__footer-actions">
                            <button type="button" class="btn btn-light border" id="reloadCodeButton">Đặt lại</button>
                            <button type="button" class="btn btn-primary" id="generateCodeButton">Tạo mã</button>
                            <button type="button" class="btn btn-light border" id="printCodeButton">In tem</button>
                        </div>
                    </div>
                </div>

                <div class="col-xl-5">
                    <div class="barcode-admin-page__preview card shadow-sm border-0">
                        <div class="card-header bg-white border-0">
                            <h6 class="mb-0">Xem trước tem mã</h6>
                        </div>
                        <div class="card-body text-center">
                            <div class="barcode-admin-page__preview-name">@Model.Name</div>
                            <div class="barcode-admin-page__preview-price">@(Model.SellPrice?.ToString("C0", new CultureInfo("vi-VN")) ?? "-")</div>
                            <div class="barcode-admin-page__preview-code">
                                @if (ViewBag.QRCodeImage != null)
                                {
                                    <img src="@ViewBag.QRCodeImage" alt="QR Code" class="barcode-admin-page__preview-image barcode-admin-page__preview-image--square" />
                                }
                                else if (ViewBag.BarcodeImage != null)
                                {
                                    <img src="@ViewBag.BarcodeImage" alt="Barcode" class="barcode-admin-page__preview-image barcode-admin-page__preview-image--wide" />
                                }
                                else
                                {
                                    <div class="stock-history-detail__empty barcode-admin-page__preview-empty">
                                        <i class="fas fa-qrcode"></i>
                                        <p>Chọn cấu hình và tạo mã để xem trước.</p>
                                    </div>
                                }
                            </div>
                            <div class="barcode-admin-page__preview-sku">SKU: @Model.Sku</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            const productId = @Model.ProductId;
            const $contentSelect = $('#contentSelect');
            const $codeTypeSelect = $('#codeTypeSelect');
            const $quantityInput = $('#quantityInput');

            function syncContentOptions() {
                const isBarcode = $codeTypeSelect.val() === 'Barcode';
                const $urlOption = $contentSelect.find('option[value="url"]');

                if (isBarcode) {
                    if ($contentSelect.val() === 'url') {
                        $contentSelect.val('sku');
                    }
                    $urlOption.prop('disabled', true);
                } else {
                    $urlOption.prop('disabled', false);
                }
            }

            function buildGenerateUrl() {
                return `/Admin/Products/GenerateCode/${productId}/${$contentSelect.val()}/${$codeTypeSelect.val()}`;
            }

            $codeTypeSelect.on('change', syncContentOptions);
            syncContentOptions();

            $('#reloadCodeButton').on('click', function () {
                window.location.href = `/Admin/Products/GenerateCode/${productId}`;
            });

            $('#generateCodeButton').on('click', function () {
                window.location.href = buildGenerateUrl();
            });

            $('#printCodeButton').on('click', function () {
                $('.loading-container').show();
                $.ajax({
                    url: '@Url.Action("PrintCode", "Products", new { area = "Admin" })',
                    data: {
                        id: productId,
                        content: $contentSelect.val(),
                        codeType: $codeTypeSelect.val(),
                        quantity: $quantityInput.val()
                    },
                    success: function (response) {
                        $('.loading-container').hide();

                        if (!response.success) {
                            alert(response.message);
                            return;
                        }

                        printCode(response.html);
                    },
                    error: function () {
                        $('.loading-container').hide();
                        alert('Đã có lỗi xảy ra');
                    }
                });
            });

            function printCode(html) {
                const framePrint = document.createElement('iframe');
                framePrint.className = 'Print-Code';
                framePrint.style.position = 'absolute';
                framePrint.style.top = '-10000px';
                document.body.appendChild(framePrint);

                const frameDoc = framePrint.contentWindow || framePrint.contentDocument.document || framePrint.contentDocument;
                frameDoc.document.open();
                frameDoc.document.write(html);
                frameDoc.document.close();

                setTimeout(function () {
                    framePrint.focus();
                    framePrint.contentWindow.print();
                    document.body.removeChild(framePrint);
                }, 500);
            }
        });
    </script>
}
