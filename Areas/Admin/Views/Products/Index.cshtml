@model Tech_Store.Models.DTO.AdminProductIndexData
@using System.Globalization
@using Tech_Store.Helpers
@{
    ViewData["Title"] = "Sản phẩm";
    Layout = "/Areas/Admin/Views/Shared/Layout.cshtml";
    var filters = Model.Filters;

    string BuildQueryString()
    {
        return string.Join("&", new[]
        {
            !string.IsNullOrWhiteSpace(filters.Status) ? $"status={Uri.EscapeDataString(filters.Status)}" : null,
            !string.IsNullOrWhiteSpace(filters.Sku) ? $"sku={Uri.EscapeDataString(filters.Sku)}" : null,
            !string.IsNullOrWhiteSpace(filters.Name) ? $"name={Uri.EscapeDataString(filters.Name)}" : null,
            filters.CategoryId.HasValue ? $"categoryId={filters.CategoryId.Value}" : null,
            filters.BrandId.HasValue ? $"brandId={filters.BrandId.Value}" : null,
            filters.StockFrom.HasValue ? $"stockFrom={filters.StockFrom.Value}" : null,
            filters.StockTo.HasValue ? $"stockTo={filters.StockTo.Value}" : null,
            $"pageSize={Model.PageSize}"
        }.Where(x => !string.IsNullOrWhiteSpace(x)));
    }
}

<div class="container-fluid">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-0 pb-0">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                <h4 class="card-title mb-0">Danh sách sản phẩm</h4>
                <div class="d-flex flex-wrap gap-2">
                    <a href="~/Admin/Products/ImportExcel" class="btn btn-success">
                        <i class="fa fa-file me-1"></i>
                        Nhập Excel
                    </a>
                    <a href="@Url.Action("Create", "Products", new
                       {
                           area = "Admin",
                           page = Model.Page,
                           pageSize = Model.PageSize,
                           status = filters.Status,
                           sku = filters.Sku,
                           name = filters.Name,
                           categoryId = filters.CategoryId,
                           brandId = filters.BrandId,
                           stockFrom = filters.StockFrom,
                           stockTo = filters.StockTo
                       })" class="btn btn-primary">
                        <i class="fa fa-plus me-1"></i>
                        Thêm sản phẩm
                    </a>
                </div>
            </div>
        </div>

        <div class="card-body">
            <form method="get" class="brand-admin__filters row g-3 align-items-end mb-4">
                <input type="hidden" name="pageSize" value="@Model.PageSize" />
                <div class="col-lg-3">
                    <label class="form-label fw-semibold text-secondary">SKU sản phẩm</label>
                    <input type="text" class="form-control" name="sku" value="@filters.Sku" placeholder="Nhập hoặc quét mã SKU" />
                </div>
                <div class="col-lg-3">
                    <label class="form-label fw-semibold text-secondary">Tên sản phẩm</label>
                    <input type="text" class="form-control" name="name" value="@filters.Name" placeholder="Nhập tên sản phẩm cần tìm" />
                </div>
                <div class="col-lg-3">
                    <label class="form-label fw-semibold text-secondary">Trạng thái</label>
                    <select class="form-select" name="status">
                        <option value="">Tất cả trạng thái</option>
                        <option value="available" selected="@(filters.Status == "available")">Sẵn hàng</option>
                        <option value="outstock" selected="@(filters.Status == "outstock")">Hết hàng</option>
                        <option value="preorder" selected="@(filters.Status == "preorder")">Đặt trước</option>
                        <option value="discontinued" selected="@(filters.Status == "discontinued")">Ngưng bán</option>
                    </select>
                </div>
                <div class="col-lg-3">
                    <label class="form-label fw-semibold text-secondary">Danh mục</label>
                    <select class="form-select" name="categoryId">
                        <option value="">Tất cả danh mục</option>
                        @foreach (var item in Model.Categories)
                        {
                            <option value="@item.CategoryId" selected="@(filters.CategoryId == item.CategoryId)">@item.Name</option>
                        }
                    </select>
                </div>
                <div class="col-lg-3">
                    <label class="form-label fw-semibold text-secondary">Thương hiệu</label>
                    <select class="form-select" name="brandId">
                        <option value="">Tất cả thương hiệu</option>
                        @foreach (var item in Model.Brands)
                        {
                            <option value="@item.BrandId" selected="@(filters.BrandId == item.BrandId)">@item.Name</option>
                        }
                    </select>
                </div>
                <div class="col-lg-3">
                    <label class="form-label fw-semibold text-secondary">Tồn kho từ</label>
                    <input type="number" class="form-control" name="stockFrom" value="@filters.StockFrom" placeholder="Từ" />
                </div>
                <div class="col-lg-3">
                    <label class="form-label fw-semibold text-secondary">Tồn kho đến</label>
                    <input type="number" class="form-control" name="stockTo" value="@filters.StockTo" placeholder="Đến" />
                </div>
                <div class="col-lg-3">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-grow-1">Tìm kiếm</button>
                        <a href="/Admin/Products" class="btn btn-light border">Làm mới</a>
                    </div>
                </div>
            </form>

            <div class="table-responsive reusable-admin-table">
                <table class="table table-hover align-middle brand-admin__table">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 84px;">Ảnh</th>
                            <th>Sản phẩm</th>
                            <th style="width: 140px;">SKU</th>
                            <th style="width: 90px;">Sắp xếp</th>
                            <th style="width: 160px;">Thương hiệu</th>
                            <th style="width: 160px;">Danh mục</th>
                            <th style="width: 140px;">Giá bán</th>
                            <th style="width: 96px;">Tồn</th>
                            <th style="width: 110px;">Hiển thị</th>
                            <th style="width: 130px;">Tình trạng</th>
                            <th style="width: 92px;" class="text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Products.Count == 0)
                        {
                            <tr>
                                <td colspan="11" class="text-center text-muted py-5">
                                    Không có sản phẩm phù hợp với bộ lọc hiện tại.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var product in Model.Products)
                            {
                                var imageUrl = string.IsNullOrWhiteSpace(product.Image)
                                    ? Url.Content("~/Upload/Products/no-image.png")
                                    : product.Image.Contains("http")
                                        ? ResizeCDN.Cdn(product.Image, 50, 50)
                                        : Url.Content($"~/Upload/Products/{product.Image}?v={DateTime.UtcNow.Ticks}");
                                var statusClass = product.Status == "available" ? "bg-success"
                                    : product.Status == "outstock" ? "bg-danger"
                                    : product.Status == "preorder" ? "bg-warning text-dark"
                                    : product.Status == "discontinued" ? "bg-secondary"
                                    : "bg-dark";
                                var statusLabel = product.Status == "available" ? "Còn hàng"
                                    : product.Status == "outstock" ? "Hết hàng"
                                    : product.Status == "preorder" ? "Đặt trước"
                                    : product.Status == "discontinued" ? "Ngưng bán"
                                    : "Không rõ";

                                <tr>
                                    <td>
                                        <div class="brand-admin__logo-shell">
                                            <img src="@imageUrl" alt="@product.Name" class="brand-admin__logo" />
                                        </div>
                                    </td>
                                    <td>
                                        <div class="fw-semibold text-dark">@product.Name</div>
                                        <div class="small text-muted">Cập nhật: @(product.UpdatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div>
                                    </td>
                                    <td class="text-nowrap">@product.Sku</td>
                                    <td class="text-center fw-semibold">@product.SortOrder</td>
                                    <td>@product.Brand?.Name</td>
                                    <td>@product.Category?.Name</td>
                                    <td class="text-nowrap">@product.SellPrice?.ToString("C0", new CultureInfo("vi-VN"))</td>
                                    <td class="text-center fw-semibold">@product.Stock</td>
                                    <td>
                                        <div class="form-check form-switch d-flex justify-content-center">
                                            <input class="form-check-input"
                                                   type="checkbox"
                                                   id="flexSwitchCheckChecked"
                                                   @(product.Visible == true ? "checked" : "")
                                                   data-id="@product.ProductId">
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge @statusClass">@statusLabel</span>
                                    </td>
                                    <td>
                                        <div class="form-button-action justify-content-center">
                                            <a href="@Url.Action("Edit", "Products", new
                                               {
                                                   area = "Admin",
                                                   id = product.ProductId,
                                                   page = Model.Page,
                                                   pageSize = Model.PageSize,
                                                   status = filters.Status,
                                                   sku = filters.Sku,
                                                   name = filters.Name,
                                                   categoryId = filters.CategoryId,
                                                   brandId = filters.BrandId,
                                                   stockFrom = filters.StockFrom,
                                                   stockTo = filters.StockTo
                                               })"
                                               class="btn btn-link btn-primary btn-lg"
                                               data-bs-toggle="tooltip"
                                               title="Chỉnh sửa">
                                                <i class="fa fa-edit"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mt-3">
                <div class="text-muted small">
                    Hiển thị @((Model.TotalItems == 0) ? 0 : ((Model.Page - 1) * Model.PageSize + 1))
                    - @(Math.Min(Model.Page * Model.PageSize, Model.TotalItems))
                    / @Model.TotalItems sản phẩm
                </div>
                @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_ManualPagination.cshtml", new Tech_Store.Models.ViewModel.ManualPaginationViewModel
                {
                    CurrentPage = Model.Page,
                    TotalPages = Model.TotalPages,
                    BaseUrl = "/Admin/Products",
                    QueryString = BuildQueryString()
                })
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    $(document).on('change', '#flexSwitchCheckChecked', function () {
        var id = $(this).data('id');
        var isVisible = $(this).is(':checked') ? 1 : 0;

        var confirmMessage = isVisible
            ? 'Bạn có chắc chắn muốn hiển thị sản phẩm này không?'
            : 'Bạn có chắc chắn muốn ẩn sản phẩm này không?';

        Swal.fire({
            title: 'Xác nhận',
            text: confirmMessage,
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: 'Đồng ý',
            cancelButtonText: 'Hủy',
        }).then((result) => {
            if (result.isConfirmed) {
                $.ajax({
                    method: 'POST',
                    url: '/Admin/Products/ChangeVisible',
                    data: { productId: id },
                    success: function (response) {
                        if (response.success) {
                            Swal.fire({
                                title: 'Thành công!',
                                text: response.message,
                                icon: 'success',
                                timer: 2000,
                                showConfirmButton: false
                            });
                        } else {
                            Swal.fire({
                                title: 'Lỗi!',
                                text: response.message,
                                icon: 'error',
                            });
                        }
                    },
                    error: function (xhr, status, error) {
                        Swal.fire({
                            title: 'Đã xảy ra lỗi!',
                            text: error,
                            icon: 'error',
                        });
                    }
                });
            } else {
                $(this).prop('checked', !isVisible);
            }
        });
    });
</script>
