<script>
    $(document).ready(function () {
        $('.selectpicker').selectpicker();

        function buildAttributeValueIdInputs(variant, rowIndex) {
            var selectedAttributes = $('#variantSelect').val() || [];
            var hiddenInputs = '';

            selectedAttributes.forEach(function (attributeCode, attributeIndex) {
                var selectedValue = variant[attributeCode];
                if (!selectedValue) {
                    return;
                }

                var optionSelector = `#${attributeCode}Select option`;
                var option = $(optionSelector).filter(function () {
                    return $(this).val() === selectedValue;
                }).first();

                var attributeValueId = option.data('id');
                if (!attributeValueId) {
                    return;
                }

                hiddenInputs += '<input type="hidden" name="VarientProducts[' + rowIndex + '].AttributeValueIds[' + attributeIndex + ']" value="' + attributeValueId + '"/>';
            });

            return hiddenInputs;
        }

        function updateVariantTable() {
            // Get all selected attributes and their values
            var selectedAttributes = $('#variantSelect').val() || [];
            var variants = [{}];  // Start with an empty variant

            // For each selected attribute, get its values and create combinations
            selectedAttributes.forEach(function (attributeCode) {
                var selectedValues = $(`#${attributeCode}Select`).val() || [];
                if (selectedValues.length === 0) return;

                // Create new variants array by combining existing variants with new values
                var newVariants = [];
                variants.forEach(function (existingVariant) {
                    selectedValues.forEach(function (value) {
                        var newVariant = { ...existingVariant };
                        newVariant[attributeCode] = value;
                        newVariants.push(newVariant);
                    });
                });
                variants = newVariants;
            });

            // If no valid combinations were created, return
            if (variants.length === 0 || Object.keys(variants[0]).length === 0) return;

            var tableBody = $('#variantTableBody');
            tableBody.empty();

            variants.forEach(function (variant, index) {
                var variantString = Object.entries(variant)
                    .map(([key, value]) => `${key}: ${value}`)
                    .join(', ');

                var skuProduct = $('#SkuCode').val() || '';
                var rawSku  = skuProduct + '-' + Object.values(variant).join('-');
                var sku = removeVietnameseTones(rawSku);
                var price = $('#sellPrice').val();

                var row = $('<tr>');
                row.append($('<td class="text-center fw-semibold">').text(index + 1));
                row.append($('<td style="display:none">').html(
                    '<input type="hidden" name="VarientProducts[' + index + '].Attributes" value="' + variantString + '"/>' +
                    buildAttributeValueIdInputs(variant, index)
                ));
                row.append($('<td>').html('<div class="product-form__variant-name">' + variantString + '</div>'));
                row.append($('<td>').html(
                    '<input type="number" class="form-control" name="VarientProducts[' + index + '].Price" value="' + price + '"/>'
                ));
                row.append($('<td>').html(
                    '<input type="text" class="form-control" name="VarientProducts[' + index + '].Sku" value="' + sku + '" readonly/>'
                ));
                row.append($('<td>').html(
                    '<input type="number" class="form-control variant-stock-input" name="VarientProducts[' + index + '].Stock" value="1" min="0" required/>'
                ));
                row.append($('<td>').html(
                    '<input type="file" class="form-control form-control-sm" name="VarientProducts[' + index + '].Image" accept="image/*"/>'
                ));
                row.append($('<td class="text-center">').html(
                    '<button type="button" class="btn btn-sm btn-outline-danger delete-btn" title="Xóa"><i class="fas fa-trash"></i></button>'
                ));

                tableBody.append(row);
                console.log(variantString)
            });

            $('.table-Varient').show();
            syncVariantStockSummary();
            updateRowNumbers();
        }

        // Handle attribute selection changes
        $('#variantSelect').on('changed.bs.select', function () {
            var selectedOptions = $(this).val() || [];

            // Hide all attribute selection divs first
            // Changed selector to only target attribute containers
            $('.col-md-6[id]').not('#variantSelect').hide();

            // Show only the selected ones
            selectedOptions.forEach(function (attributeCode) {
                $(`#${attributeCode}`).show();
            });

            updateVariantTable();
        });

        // Handle attribute value changes
        $(document).on('change', '.selectpicker', function () {
            updateVariantTable();
        });

        // Initialize tooltips
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        });
    });

    function updateRowNumbers() {
        $('#variantTableBody tr').each(function (index) {
            // Update visible row number
            $(this).find('td:first').text(index + 1);

            // Update hidden input names and visible input names
            $(this).find('input').each(function () {
                var name = $(this).attr('name');
                if (name) {
                    var newName = name.replace(/\[\d+\]/, '[' + index + ']');
                    $(this).attr('name', newName);
                }
            });
        });

        syncVariantStockSummary();
    }

    $(document).on('click', '.delete-btn', function () {
        $(this).closest('tr').remove();
        updateRowNumbers();
    });

    function isVariantEnabled() {
        return $('#useVariant').is(':checked') || $('input[name="IsUseVariant"][value="true"]').length > 0;
    }

    function getVariantStockTotal() {
        var total = 0;
        $('#variantTableBody').find('.variant-stock-input').each(function () {
            total += parseInt($(this).val(), 10) || 0;
        });
        return total;
    }

    function syncVariantStockSummary() {
        var $productStockInput = $('#productStockInput');
        if (!$productStockInput.length) {
            return true;
        }

        if (!isVariantEnabled()) {
            $productStockInput.prop('readonly', false);
            return true;
        }

        var total = getVariantStockTotal();
        $productStockInput.val(total);
        $productStockInput.prop('readonly', true);
        return true;
    }

    function validateVariantStockConsistency() {
        if (!isVariantEnabled()) {
            return true;
        }

        var rowCount = $('#variantTableBody tr').length;
        if (rowCount === 0) {
            Swal.fire({
                icon: 'warning',
                title: 'Thiếu biến thể',
                text: 'Sản phẩm đang dùng biến thể nhưng chưa có dòng biến thể nào.'
            });
            return false;
        }

        syncVariantStockSummary();
        return true;
    }

    $(document).on('input change', '.variant-stock-input', function () {
        syncVariantStockSummary();
    });
</script>
<script>
    $(document).ready(function () {
        // Xử lý URL video YouTube
        $('#videoUrl').change(function () {
            const url = $(this).val();
            const videoId = extractVideoID(url);
            if (videoId) {
                $('#videoPreview').html(`<iframe width="560" height="315" src="https://www.youtube.com/embed/${videoId}" frameborder="0" allowfullscreen></iframe>`);
            } else {
                $('#videoPreview').empty();
            }
        });

        // Hàm trích xuất ID video từ URL YouTube
        function extractVideoID(url) {
            const regExp = /^.*((youtu.be\/)|(v\/)|(\/u\/\w\/)|(embed\/)|(watch\?))\??v?=?([^#&?]*).*/;
            const match = url.match(regExp);
            return (match && match[7].length == 11) ? match[7] : false;
        }
    });


</script>

