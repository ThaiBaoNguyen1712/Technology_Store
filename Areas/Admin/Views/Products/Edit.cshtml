@model Tech_Store.Models.Product
@{
    ViewData["Title"] = "Chỉnh sửa sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/Layout.cshtml";
    var returnPage = (int?)ViewBag.ReturnPage ?? 1;
    var returnPageSize = (int?)ViewBag.ReturnPageSize ?? 25;
    var returnStatus = ViewBag.ReturnStatus as string;
    var returnSkuKeyword = ViewBag.ReturnSkuKeyword as string;
    var returnNameKeyword = ViewBag.ReturnNameKeyword as string;
    var returnCategoryId = (int?)ViewBag.ReturnCategoryId;
    var returnBrandId = (int?)ViewBag.ReturnBrandId;
    var returnStockFrom = (int?)ViewBag.ReturnStockFrom;
    var returnStockTo = (int?)ViewBag.ReturnStockTo;
}
<style>

</style>

<form asp-action="Update" asp-controller="Products" asp-area="Admin" method="post" enctype="multipart/form-data" id="ProductForm">
    <input type="hidden" name="ReturnPage" value="@((int?)ViewBag.ReturnPage ?? 1)" />
    <input type="hidden" name="ReturnPageSize" value="@((int?)ViewBag.ReturnPageSize ?? 25)" />
    <input type="hidden" name="ReturnStatus" value="@ViewBag.ReturnStatus" />
    <input type="hidden" name="ReturnSkuKeyword" value="@ViewBag.ReturnSkuKeyword" />
    <input type="hidden" name="ReturnNameKeyword" value="@ViewBag.ReturnNameKeyword" />
    <input type="hidden" name="ReturnCategoryId" value="@ViewBag.ReturnCategoryId" />
    <input type="hidden" name="ReturnBrandId" value="@ViewBag.ReturnBrandId" />
    <input type="hidden" name="ReturnStockFrom" value="@ViewBag.ReturnStockFrom" />
    <input type="hidden" name="ReturnStockTo" value="@ViewBag.ReturnStockTo" />

    <div class="container-fluid">
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 py-3 ms-3">
            <h3 class="mb-0">
                <i class="fas fa-box text-info pe-2"></i> Chỉnh sửa sản phẩm
            </h3>
            <div class="d-flex flex-wrap gap-2">
                <a href="@Url.Action("Index", "Products", new { area = "Admin", page = returnPage, pageSize = returnPageSize, status = returnStatus, sku = returnSkuKeyword, name = returnNameKeyword, categoryId = returnCategoryId, brandId = returnBrandId, stockFrom = returnStockFrom, stockTo = returnStockTo })" class="btn btn-light border">
                    Quay lại
                </a>
            </div>
        </div>
        @Html.AntiForgeryToken()
        <div class="card mb-4">
            <div class="card-header">
                <h5>
                    <i class="fas fa-sticky-note text-info pe-2"></i> Thông tin sản phẩm
                </h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label name="Name" class="form-label">Tên Sản Phẩm (VN)</label>
                    <input value="@Model.Name" name="Name" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label name="Description" class="form-label">Mô tả</label>
                    <textarea name="Description" class="form-control" id="description">@Html.Raw(Model.Description)</textarea>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">
                <h5><i class="fas fa-cogs text-info pe-2"></i> Thiết lập chung</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <input type="hidden" name="ProductId" value="@Model.ProductId"/>
                        <label name="Category" class="form-label">Danh Mục</label>
                        <select name="CategoryId" class="form-control border selectpicker" data-live-search="true" required>
                            @foreach (var item in ViewBag.Categories)
                            {
                                <option value="@item.CategoryId" @(item.CategoryId == Model.CategoryId ? "Selected" : "")> @item.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label name="Brand" class="form-label">Thương Hiệu</label>
                        <select name="BrandId" class="form-control border selectpicker" data-live-search="true" required>
                            @foreach (var item in ViewBag.Brands)
                            {
                                <option value="@item.BrandId" @(item.BrandId == Model.BrandId ? "selected" : "")> @item.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">SKU Sản Phẩm</label>
                        <span class="input-label-secondary cursor-pointer" data-bs-toggle="tooltip" title='Bạn không thể thay đổi SKU'>
                            <i class="fas fa-info-circle text-info"></i>
                        </span>
                        <input value="@Model.Sku" name="Sku" type="text" class="form-control" id="SkuCode" readonly/>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label name="Brand" class="form-label">Tình trạng</label>
                        <span class="input-label-secondary cursor-pointer" data-bs-toggle="tooltip" title="Nhập tình trạng để xử lý khi bán hàng">
                            <i class="fas fa-info-circle text-info"></i>
                        </span>
                        <select name="Status" class="form-control border selectpicker" data-live-search="true" required>
                            <option value="available" @(Model.Status == "available" ? "selected" : "")> Có sẵn </option>
                            <option value="preorder" @(Model.Status == "preorder" ? "selected" : "")> Đặt trước </option>
                            <option value="outstock" @(Model.Status == "outstock" ? "selected" : "")> Hết hàng </option>
                            <option value="StopSell" @(Model.Status == "discontinued" ? "selected" : "")> Ngưng bán </option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label name="SortOrder" class="form-label">Sắp xếp hiển thị</label>
                        <span class="input-label-secondary cursor-pointer" data-bs-toggle="tooltip" title="Số nhỏ hơn sẽ được ưu tiên hiển thị trước trên danh sách mặc định.">
                            <i class="fas fa-info-circle text-info"></i>
                        </span>
                        <input value="@Model.SortOrder" name="SortOrder" type="number" min="0" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label d-block">Tính phí ship</label>
                        <input type="hidden" name="IsShippingFee" value="false" />
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="IsShippingFee" name="IsShippingFee" value="true" @(Model.IsShippingFee ? "checked" : "") />
                            <label class="form-check-label" for="IsShippingFee">Tính phí ship cho sản phẩm này</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">
                <h5> <i class="fas fa-tags text-info pe-2"></i> Giá và các yếu tố khác  </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label name="ImportPrice" class="form-label">Giá Nhập (đ)</label>
                        <span class="input-label-secondary cursor-pointer" data-bs-toggle="tooltip" title="Thêm giá nhập cho sản phẩm này">
                            <i class="fas fa-info-circle text-info"></i>
                        </span>
                        <input value="@Model.CostPrice" name="CostPrice" type="number" class="form-control" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label name="Price" class="form-label">Đơn Giá Gốc (đ)</label>
                        <span class="input-label-secondary cursor-pointer" data-bs-toggle="tooltip" title="Đặt giá bán cho mỗi đơn vị của sản phẩm này. Phần đơn giá này sẽ không áp dụng nếu bạn đặt biến giá thay đổi">
                            <i class="fas fa-info-circle text-info"></i>
                        </span>
                        <input value="@Model.OriginalPrice" name="OriginalPrice" type="number" class="form-control" id="OriginalPrice" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label name="Stock" class="form-label">Số Lượng</label>
                        <span class="input-label-secondary cursor-pointer" data-bs-toggle="tooltip" title="Nếu sản phẩm dùng biến thể, tồn kho tổng sẽ tự đồng bộ bằng tổng tồn kho của tất cả biến thể.">
                            <i class="fas fa-info-circle text-info"></i>
                        </span>
                        <input id="productStockInput" value="@Model.Stock" name="Stock" type="number" class="form-control" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label name="Stock" class="form-label">Khối Lượng (KG)</label>
                        <span class="input-label-secondary cursor-pointer" data-bs-toggle="tooltip" title="Thêm khối lượng cho sản phẩm này, Đơn vị là kilogram">
                            <i class="fas fa-info-circle text-info"></i>
                        </span>
                        <input value="@Model.Weight" name="Weight" step="0.01" min="0" type="number" class="form-control" />
                    </div>

                </div>
                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label name="Stock" class="form-label">Bảo Hành (Tháng)</label>
                        <span class="input-label-secondary cursor-pointer" data-bs-toggle="tooltip" title="Thêm chế độ bảo hành cho sản phẩm này">
                            <i class="fas fa-info-circle text-info"></i>
                        </span>
                        <input value="@Model.WarrantyPeriod" name="WarrantyPeriod" type="number" class="form-control" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label name="DiscountPercentage" class="form-label">Loại Giảm Giá</label>
                        <span class="input-label-secondary cursor-pointer" data-bs-toggle="tooltip" title="Chọn giảm giá bằng trừ tiền trực tiếp hoặc theo phần trăm (%). Để trống nếu bạn không muốn áp dụng khuyến mãi">
                            <i class="fas fa-info-circle text-info"></i>
                        </span>
                        <select name="DiscountTypeId" id="DiscountType" class="form-select">
                            <option value="1" @(Model.DiscountAmount.HasValue ? "Selected" : "")>Cố định</option>
                            <option value="2" @(Model.DiscountPercentage.HasValue ? "Selected" : "")>Phần trăm</option>
                        </select>
                    </div>

                    <div class="col-md-3 mb-3">
                        <div id="discount-section">
                            @if (Model.DiscountAmount.HasValue)
                            {
                                <div>
                                    <label for="discountAmount" class="form-label">Số Tiền Giảm Giá (đ)</label>
                                    <input name="discountAmount" value="@(Model.DiscountAmount ?? 0)" type="number" class="form-control" id="discountAmount" />
                                </div>
                            }

                            @if (Model.DiscountPercentage.HasValue)
                            {
                                <div>
                                    <label for="discountPercentage" class="form-label">Số Tiền Giảm Giá (%)</label>
                                    <input name="discountPercentage" value="@(Model.DiscountPercentage ?? 0)" type="number" class="form-control" id="discountPercentage" />
                                </div>
                            }
                        </div>

                    </div>

                    <div class="col-md-3 mb-3">
                        <label name="sellPrice" class="form-label">Giá Bán (đ)</label>
                        <span class="input-label-secondary cursor-pointer" data-bs-toggle="tooltip" title="Giá bán sẽ được tự động tính toán. Chỉ thay đổi nếu có sai số để tránh việc sai số sau này">
                            <i class="fas fa-info-circle text-info"></i>
                        </span>
                        <input value="@Model.SellPrice" name="sellPrice" type="number" class="form-control" id="sellPrice" />
                    </div>
                </div>

            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="fas fa-microchip text-info pe-2"></i>Thông số kỹ thuật
                </h5>
            </div>
            <div class="card-body">
                @{
                    var productSpecValues = ViewBag.ProductSpecValues as IEnumerable<Tech_Store.Models.DTO.ProductSpecValueDTo>;
                }
                <div class="row g-3 align-items-end">
                    <div class="col-md-8">
                        <label class="form-label">Chọn thông số để thêm</label>
                        <div class="d-flex align-items-center gap-2 flex-nowrap">
                            <div class="flex-grow-1 min-w-0">
                                <select class="form-control border selectpicker" id="specPicker" data-live-search="true" multiple data-actions-box="true">
                                    @foreach (var spec in ViewBag.Specs)
                                    {
                                        <option value="@spec.SpecId"
                                                data-name="@spec.Name"
                                                data-code="@spec.Code"
                                                data-group="@spec.GroupName"
                                                data-unit="@spec.Unit"
                                                data-input="@spec.InputType"
                                                data-sort="@spec.SortOrder"
                                                data-description="@spec.Description">
                                            @spec.Name (@(string.IsNullOrWhiteSpace(spec.GroupName as string) ? "Thông số chung" : spec.GroupName))
                                        </option>
                                    }
                                </select>
                            </div>
                            <a href="/Admin/Settings/ProductSpecs" class="btn btn-outline-primary d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:38px;min-width:38px;height:38px;padding:0;" title="Quản lý thông số">
                                <i class="fa fa-plus"></i>
                            </a>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <button type="button" class="btn btn-primary w-100" id="addSelectedSpecs">
                            Thêm thông số đã chọn
                        </button>
                    </div>
                </div>

                <div class="table-responsive mt-4">
                    <table class="table table-bordered align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 22%">Thông số</th>
                                <th style="width: 16%">Nhóm</th>
                                <th style="width: 42%">Giá trị</th>
                                <th style="width: 10%">Đơn vị</th>
                                <th style="width: 10%" class="text-center">Xóa</th>
                            </tr>
                        </thead>
                        <tbody id="specEditorTableBody">
                            @foreach (var specValue in productSpecValues ?? Enumerable.Empty<Tech_Store.Models.DTO.ProductSpecValueDTo>())
                            {
                                <tr data-spec-id="@specValue.SpecId">
                                    <td>
                                        <div class="fw-semibold">@specValue.SpecName</div>
                                        <div class="small text-muted"><code>@specValue.SpecCode</code></div>
                                        <input type="hidden" name="SpecValues.Index" value="@specValue.SpecId" />
                                        <input type="hidden" name="SpecValues[@specValue.SpecId].SpecValueId" value="@specValue.SpecValueId" />
                                        <input type="hidden" name="SpecValues[@specValue.SpecId].SpecId" value="@specValue.SpecId" />
                                        <input type="hidden" name="SpecValues[@specValue.SpecId].SpecName" value="@specValue.SpecName" />
                                        <input type="hidden" name="SpecValues[@specValue.SpecId].SpecCode" value="@specValue.SpecCode" />
                                        <input type="hidden" name="SpecValues[@specValue.SpecId].GroupName" value="@specValue.GroupName" />
                                        <input type="hidden" name="SpecValues[@specValue.SpecId].Unit" value="@specValue.Unit" />
                                        <input type="hidden" name="SpecValues[@specValue.SpecId].InputType" value="@specValue.InputType" />
                                        <input type="hidden" name="SpecValues[@specValue.SpecId].SortOrder" value="@specValue.SortOrder" />
                                    </td>
                                    <td>@(string.IsNullOrWhiteSpace(specValue.GroupName) ? "Thông số chung" : specValue.GroupName)</td>
                                    <td>
                                        @if (specValue.InputType == "textarea")
                                        {
                                            <textarea class="form-control" rows="3" name="SpecValues[@specValue.SpecId].Value" placeholder="Nhập @specValue.SpecName">@specValue.Value</textarea>
                                        }
                                        else if (specValue.InputType == "number")
                                        {
                                            <input type="number" step="0.01" class="form-control" name="SpecValues[@specValue.SpecId].Value" value="@specValue.Value" placeholder="Nhập @specValue.SpecName" />
                                        }
                                        else
                                        {
                                            <input type="text" class="form-control" name="SpecValues[@specValue.SpecId].Value" value="@specValue.Value" placeholder="Nhập @specValue.SpecName" />
                                        }
                                    </td>
                                    <td>@(string.IsNullOrWhiteSpace(specValue.Unit) ? "-" : specValue.Unit)</td>
                                    <td class="text-center">
                                        <button type="button" class="btn btn-sm btn-outline-danger remove-spec-row">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">
                <h5>
                    <i class="fas fa-layer-group text-info pe-2"></i>
                    Biến thể sản phẩm
                </h5>
                <div class="form-group d-flex align-items-center">
                    @if (Model.VarientProducts.Any(s => !string.IsNullOrEmpty(s.Attributes)))
                    {
                        <input type="hidden" name="IsUseVariant" value="true" />
                        <input class="form-check-input me-2 mb-2" type="checkbox" checked onclick="return false;" />
                    }
                    else
                    {
                        <input class="form-check-input me-2 mb-2" name="IsUseVariant" id="useVariant" type="checkbox" value="true" />
                        <input type="hidden" name="IsUseVariant" value="false" /> <!-- Thêm input ẩn -->
                    }

                    <label class="form-label mb-0" for="useVariant">Sử dụng biến thể cho sản phẩm</label>
                </div>
             
            </div>
            <div class="card-body">
                @{
                    Dictionary<string, List<string>> attributeMap = new Dictionary<string, List<string>>();

                    foreach (var variant in Model.VarientProducts)
                    {
                        foreach (var variantAttribute in variant.VariantAttributes)
                        {
                            var attributeCode = variantAttribute.AttributeValue?.Attribute?.Code;
                            var attributeValue = variantAttribute.AttributeValue?.Value;

                            if (string.IsNullOrWhiteSpace(attributeCode) || string.IsNullOrWhiteSpace(attributeValue))
                            {
                                continue;
                            }

                            if (!attributeMap.ContainsKey(attributeCode))
                            {
                                attributeMap[attributeCode] = new List<string>();
                            }

                            if (!attributeMap[attributeCode].Contains(attributeValue))
                            {
                                attributeMap[attributeCode].Add(attributeValue);
                            }
                        }
                    }
                }

                <div class="row">
                      <div class="col-md-6 mb-3">
                        <label class="form-label">Chọn thuộc tính</label>
                        <span class="input-label-secondary cursor-pointer" data-bs-toggle="tooltip" title="Sử dụng các biến thể khác để phân biệt sản phẩm">
                            <i class="fas fa-info-circle text-info"></i>
                        </span>
                        <div class="d-flex align-items-center gap-2 flex-nowrap">
                            <div class="flex-grow-1 min-w-0">
                                <select name="VarientSelect" id="variantSelect" class="form-control border selectpicker" multiple="multiple" data-live-search="true">
                                    @foreach (var item in ViewBag.Attributes)
                                    {
                                      <option value="@item.Code" @(ViewBag.Attributes_checked?.Contains(item.AttributeId) == true ? "selected" : "")>
                                        @item.Name
                                    </option>

                                    }
                                </select>
                            </div>
                            <a href="/Admin/Settings/ProductAttributes" class="btn btn-outline-primary d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:38px;min-width:38px;height:38px;padding:0;" title="Quản lý thuộc tính">
                                <i class="fa fa-plus"></i>
                            </a>
                        </div>
                    </div>

                    @foreach (var item in ViewBag.Attributes)
                    {
                        <div class="col-md-6 mb-3" id="@item.Code" style="@(attributeMap.ContainsKey(item.Code) ? "" : "display:none")">
                            <label class="form-label">@item.Name</label>
                            <select name="AttributeValueIds" id="@($"{item.Code}Select")" class="form-control border selectpicker" multiple="multiple" data-live-search="true">
                                @foreach (var value in item.AttributeValues)
                                {
                                    // Chỉ tick nếu thuộc tính và giá trị phù hợp
                                    bool isSelected = attributeMap.ContainsKey(item.Code) && attributeMap[item.Code].Contains(value.Value);

                                    <option value="@value.Value" data-id="@value.AttributeValueId" @(isSelected ? "selected" : "")>@value.Value</option>
                                }
                            </select>
                        </div>
                    }

                </div>
                <div class="table-responsive reusable-admin-table table-Varient mt-4" style="@(Model.VarientProducts.Any(s => !string.IsNullOrEmpty(s.Attributes)) ? "" : "display:none")">
                    <table class="table table-hover align-middle product-form__variant-table">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 72px;">STT</th>
                                <th>Biến thể</th>
                                <th style="width: 180px;">Giá bán</th>
                                <th style="width: 220px;">SKU</th>
                                <th style="width: 160px;">Tồn kho <span class="input-label-secondary cursor-pointer" data-bs-toggle="tooltip" title="Tổng tồn kho của tất cả biến thể phải bằng tồn kho tổng của sản phẩm."><i class="fas fa-info-circle text-info"></i></span></th>
                                <th style="width: 240px;">Ảnh biến thể</th>
                                <th style="width: 96px;" class="text-center">Xóa</th>
                            </tr>
                        </thead>
                        <tbody id="variantTableBody">
                            @{
                                int index = 0;
                            }  

                            @foreach (var varient in Model.VarientProducts)
                            {
                                <tr>
                                    <td class="text-center fw-semibold">@(index + 1)</td>
                                    <td style="display:none">
                                        <input type="hidden" name="VarientProducts[@index].VarientId" value="@varient.VarientId" />
                                        <input type="hidden" name="VarientProducts[@index].ProductId" value="@varient.ProductId" />
                                        <input type="hidden" name="VarientProducts[@index].Attributes" value="@(varient.Attributes?.ToString() ?? "")" />
                                        @{
                                            var variantAttributeValueIds = varient.VariantAttributes.Select(x => x.AttributeValueId).Distinct().ToList();
                                        }
                                        @for (var attributeValueIndex = 0; attributeValueIndex < variantAttributeValueIds.Count; attributeValueIndex++)
                                        {
                                            <input type="hidden" name="VarientProducts[@index].AttributeValueIds[@attributeValueIndex]" value="@variantAttributeValueIds[attributeValueIndex]" />
                                        }

                                    </td>
                                    <td><div class="product-form__variant-name">@varient.Attributes</div></td>
                                    <td>
                                        <input type="number" class="form-control" name="VarientProducts[@index].Price" value="@varient.Price" />
                                    </td>
                                    <td>
                                        <input type="text" class="form-control" name="VarientProducts[@index].Sku" value="@varient.Sku" readonly />
                                    </td>
                                    <td>
                                        <input type="number" class="form-control variant-stock-input" name="VarientProducts[@index].Stock" value="@varient.Stock" min="0" required />
                                    </td>
                                     <td class="align-middle text-center">
                                      <div class="d-flex flex-column align-items-center gap-2">
                                        @if(varient.ImageUrl!= null && varient.ImageUrl.Contains("http"))
                                            {
                                                <img src="@varient.ImageUrl" alt="Product Image" class="img-thumbnail product-form__variant-image" style="width:52px;height:52px;object-fit:cover;">
                                            }
                                            else
                                            {
                                                <img src="~/Upload/Products/@varient.ImageUrl" alt="Product Image" class="img-thumbnail product-form__variant-image" style="width:52px;height:52px;object-fit:cover;">

                                            }
                                        <input type="file" class="form-control form-control-sm" name="VarientProducts[@index].Image" accept="image/*">
                                      </div>
                                    </td>
                                    <td class="text-center">
                                        <button type="button" class="btn btn-sm btn-outline-danger delete-btn">Xóa</button>
                                    </td>
                                </tr>
                                index++;  // Tăng giá trị index sau mỗi lần lặp
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="row mb-4">
            <!-- Hình đại diện -->
