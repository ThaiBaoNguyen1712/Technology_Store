            text: 'Hành động này không thể hoàn tác.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Xóa sản phẩm',
            cancelButtonText: 'Hủy',
            reverseButtons: true
        }).then((result) => {
            if (!result.isConfirmed) {
                return;
            }

            $('.loading-container').show();

            $.ajax({
                method: 'POST',
                url: '/Admin/Products/Delete/' + productId,
                success: function (response) {
                    $('.loading-container').hide();

                    if (!response.success) {
                        Swal.fire({
                            icon: 'error',
                            title: 'Không thể xóa',
                            text: response.message || 'Vui lòng thử lại sau.',
                            confirmButtonText: 'OK'
                        });
                        return;
                    }

                    let deleteIcon = 'success';
                    let deleteTitle = 'Đã xóa sản phẩm';
                    let deleteText = response.message || 'Sản phẩm đã được xóa.';

                    if (response.systemSyncSuccess === false) {
                        deleteIcon = 'warning';
                        deleteTitle = 'Đã xóa sản phẩm';
                        deleteText = 'Sản phẩm đã được xóa nhưng đồng bộ nội bộ thất bại.';
                        if (response.systemSyncMessage) {
                            deleteText += ' ' + response.systemSyncMessage;
                        }
                    } else if (response.recommendationSyncSuccess === false) {
                        deleteIcon = 'warning';
                        deleteTitle = 'Đã xóa sản phẩm';
                        deleteText = 'Sản phẩm đã được xóa nhưng đồng bộ ML thất bại.';
                        if (response.recommendationSyncMessage) {
                            deleteText += ' ' + response.recommendationSyncMessage;
                        }
                    } else if (response.recommendationSyncMessage) {
                        deleteText += ' ' + response.recommendationSyncMessage;
                    }

                    Swal.fire({
                        icon: deleteIcon,
                        title: deleteTitle,
                        text: deleteText,
                        confirmButtonText: 'OK'
                    }).then(() => {
                        const params = new URLSearchParams();
                        const returnStatus = $('input[name="ReturnStatus"]').val();
                        const returnSku = $('input[name="ReturnSkuKeyword"]').val();
                        const returnName = $('input[name="ReturnNameKeyword"]').val();
                        const returnCategoryId = $('input[name="ReturnCategoryId"]').val();
                        const returnBrandId = $('input[name="ReturnBrandId"]').val();
                        const returnStockFrom = $('input[name="ReturnStockFrom"]').val();
                        const returnStockTo = $('input[name="ReturnStockTo"]').val();
                        const returnPage = $('input[name="ReturnPage"]').val();
                        const returnPageSize = $('input[name="ReturnPageSize"]').val();

                        if (returnStatus) params.set('status', returnStatus);
                        if (returnSku) params.set('sku', returnSku);
                        if (returnName) params.set('name', returnName);
                        if (returnCategoryId) params.set('categoryId', returnCategoryId);
                        if (returnBrandId) params.set('brandId', returnBrandId);
                        if (returnStockFrom) params.set('stockFrom', returnStockFrom);
                        if (returnStockTo) params.set('stockTo', returnStockTo);
                        if (returnPage) params.set('page', returnPage);
                        if (returnPageSize) params.set('pageSize', returnPageSize);

                        window.location.href = '/Admin/Products' + (params.toString() ? '?' + params.toString() : '');
                    });
                },
                error: function () {
                    $('.loading-container').hide();
                    Swal.fire({
                        icon: 'error',
                        title: 'Đã xảy ra lỗi',
                        text: 'Vui lòng thử lại sau.',
                        confirmButtonText: 'OK'
                    });
                }
            });
        });
    });
</script>

@* Show & hide I Select Variant *@
<script>
    $(document).ready(function () {
        // Xử lý sự kiện khi click vào checkbox
        $('#useVariant').on('change', function () {
            // Kiểm tra trạng thái của checkbox
            if ($(this).is(':checked')) {
                // Nếu checkbox được check thì enable select box
                $('#variantSelect').prop('disabled', false);
                syncVariantStockSummary();
            } else {
                // Nếu checkbox không được check thì disable select box
                $('#variantSelect').prop('disabled', true);
                $('#productStockInput').prop('readonly', false);
            }

            // Refresh selectpicker để cập nhật giao diện (nếu bạn đang sử dụng bootstrap-select)
            $('#variantSelect').selectpicker('refresh');
        });

        syncVariantStockSummary();
    });
</script>
<script>
    $(document).ready(function () {
        const $specPicker = $('#specPicker');
        const $specTableBody = $('#specEditorTableBody');

        function buildSpecValueInput(specId, specName, inputType, value) {
            const safeValue = value || '';
            if (inputType === 'textarea') {
                return `<textarea class="form-control" rows="3" name="SpecValues[${specId}].Value" placeholder="Nhập ${specName}">${safeValue}</textarea>`;
            }

            if (inputType === 'number') {
                return `<input type="number" step="0.01" class="form-control" name="SpecValues[${specId}].Value" value="${safeValue}" placeholder="Nhập ${specName}" />`;
            }

            return `<input type="text" class="form-control" name="SpecValues[${specId}].Value" value="${safeValue}" placeholder="Nhập ${specName}" />`;
        }

        function appendSpecRow(specData, value = '', specValueId = '') {
            if ($specTableBody.find(`tr[data-spec-id="${specData.id}"]`).length) {
                return;
            }

            const groupName = specData.group || 'Thông số chung';
            const unit = specData.unit || '-';

            const rowHtml = `
                <tr data-spec-id="${specData.id}">
                    <td>
                        <div class="fw-semibold">${specData.name}</div>
                        <div class="small text-muted"><code>${specData.code}</code></div>
                        <input type="hidden" name="SpecValues.Index" value="${specData.id}" />
                        <input type="hidden" name="SpecValues[${specData.id}].SpecValueId" value="${specValueId}" />
                        <input type="hidden" name="SpecValues[${specData.id}].SpecId" value="${specData.id}" />
                        <input type="hidden" name="SpecValues[${specData.id}].SpecName" value="${specData.name}" />
                        <input type="hidden" name="SpecValues[${specData.id}].SpecCode" value="${specData.code}" />
                        <input type="hidden" name="SpecValues[${specData.id}].GroupName" value="${groupName}" />
                        <input type="hidden" name="SpecValues[${specData.id}].Unit" value="${specData.unit || ''}" />
                        <input type="hidden" name="SpecValues[${specData.id}].InputType" value="${specData.input}" />
                        <input type="hidden" name="SpecValues[${specData.id}].SortOrder" value="${specData.sort}" />
                    </td>
                    <td>${groupName}</td>
                    <td>${buildSpecValueInput(specData.id, specData.name, specData.input, value)}</td>
                    <td>${unit}</td>
                    <td class="text-center">
                        <button type="button" class="btn btn-sm btn-outline-danger remove-spec-row">
                            <i class="fas fa-trash"></i>
                        </button>
                    </td>
                </tr>
            `;

            $specTableBody.append(rowHtml);
        }

        $('#addSelectedSpecs').on('click', function () {
            const selectedOptions = $specPicker.find('option:selected');
            selectedOptions.each(function () {
                const $option = $(this);
                appendSpecRow({
                    id: $option.val(),
                    name: $option.data('name'),
                    code: $option.data('code'),
                    group: $option.data('group'),
                    unit: $option.data('unit'),
                    input: $option.data('input'),
                    sort: $option.data('sort')
                });
            });

            $specPicker.selectpicker('deselectAll');
            $specPicker.selectpicker('refresh');
        });

        $specTableBody.on('click', '.remove-spec-row', function () {
            $(this).closest('tr').remove();
        });
    });
</script>
