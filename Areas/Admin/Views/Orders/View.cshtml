@model Tech_Store.Models.ViewModel.AdminOrderDetailViewModel
@using System.Globalization
@using Tech_Store.Helpers
@{
    ViewData["Title"] = "Đơn hàng #" + Model.OrderId;
    Layout = "~/Areas/Admin/Views/Shared/Layout.cshtml";
}

<div class="py-3 order-admin-page">
    <div class="settings-page__hero">
        <div>
            <span class="settings-page__eyebrow">Quản lý đơn hàng</span>
            <h1 class="settings-page__title">Đơn hàng #@Model.OrderId</h1>
        </div>
        <div class="settings-page__hero-meta">
            <div class="settings-page__meta-card">
                <span class="settings-page__meta-label">Trạng thái đơn</span>
                <strong>@Model.OrderStatusLabel</strong>
            </div>
            <div class="settings-page__meta-card">
                <span class="settings-page__meta-label">Thanh toán</span>
                <strong>@Model.PaymentStatusLabel</strong>
            </div>
            <div class="settings-page__meta-card">
                <span class="settings-page__meta-label">Sản phẩm</span>
                <strong>@Model.ItemCount</strong>
            </div>
            <div class="settings-page__meta-card">
                <span class="settings-page__meta-label">Tổng thanh toán</span>
                <strong>@Model.TotalAmount.ToString("C0", new CultureInfo("vi-VN"))</strong>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-xl-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-4">
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
                        <div>
                            <h4 class="card-title mb-1">Sản phẩm trong đơn</h4>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-primary" id="ToFilePDF">
                                <i class="far fa-file-pdf me-1"></i>
                                Xuất PDF
                            </button>
                        </div>
                    </div>

                    <div id="printSection" class="table-responsive reusable-admin-table">
                        <table class="table table-hover align-middle order-admin__table mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 84px;">Ảnh</th>
                                    <th>Sản phẩm</th>
                                    <th style="width: 160px;">Biến thể / SKU</th>
                                    <th style="width: 90px;" class="text-center">SL</th>
                                    <th style="width: 150px;" class="text-end">Đơn giá</th>
                                    <th style="width: 160px;" class="text-end">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    var imageUrl = string.IsNullOrWhiteSpace(item.ProductImage)
                                        ? Url.Content("~/Upload/Products/no-image.png")
                                        : item.ProductImage.Contains("http")
                                            ? ResizeCDN.Cdn(item.ProductImage, 64, 64)
                                            : Url.Content($"~/Upload/Products/{item.ProductImage}");

                                    <tr>
                                        <td>
                                            <div class="brand-admin__logo-shell">
                                                <img src="@imageUrl" alt="@item.ProductName" class="brand-admin__logo" />
                                            </div>
                                        </td>
                                        <td>
                                            <div class="fw-semibold text-dark">@item.ProductName</div>
                                        </td>
                                        <td>
                                            <div class="small fw-semibold text-dark">@item.VariantDisplay</div>
                                            <div class="small text-muted">@item.VariantSku</div>
                                        </td>
                                        <td class="text-center">@item.Quantity</td>
                                        <td class="text-end">@item.UnitPrice.ToString("C0", new CultureInfo("vi-VN"))</td>
                                        <td class="text-end fw-semibold">@item.LineTotal.ToString("C0", new CultureInfo("vi-VN"))</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="settings-page__content">
                <section class="settings-panel">
                    <div class="settings-panel__header">
                        <div>
                            <span class="settings-panel__eyebrow">Khách hàng</span>
                            <h2>Thông tin nhận hàng</h2>
                        </div>
                    </div>
                    <div class="settings-panel__body">
                        <div class="order-admin__detail-list">
                            <div class="order-admin__detail-row">
                                <span>Khách hàng</span>
                                <strong>@Model.CustomerName</strong>
                            </div>
                            <div class="order-admin__detail-row">
                                <span>Số điện thoại</span>
                                <strong>@(string.IsNullOrWhiteSpace(Model.PhoneNumber) ? "-" : Model.PhoneNumber)</strong>
                            </div>
                            <div class="order-admin__detail-row">
                                <span>Email</span>
                                <strong>@Model.Email</strong>
                            </div>
                            <div class="order-admin__detail-row">
                                <span>Địa chỉ</span>
                                <strong>@Model.Address</strong>
                            </div>
                            <div class="order-admin__detail-row">
                                <span>Ghi chú</span>
                                <strong>@(string.IsNullOrWhiteSpace(Model.Note) ? "-" : Model.Note)</strong>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="settings-panel">
                    <div class="settings-panel__header">
                        <div>
                            <span class="settings-panel__eyebrow">Thanh toán</span>
                            <h2>Thông tin giao dịch</h2>
                        </div>
                    </div>
                    <div class="settings-panel__body">
                        <div class="order-admin__detail-list">
                            <div class="order-admin__detail-row">
                                <span>Mã đơn hàng</span>
                                <strong>#@Model.OrderId</strong>
                            </div>
                            <div class="order-admin__detail-row">
                                <span>Ngày đặt</span>
                                <strong>@(Model.OrderDate?.ToString("dd/MM/yyyy HH:mm:ss") ?? "-")</strong>
                            </div>
                            <div class="order-admin__detail-row">
                                <span>Cập nhật gần nhất</span>
                                <strong>@(Model.UpdatedAt?.ToString("dd/MM/yyyy HH:mm:ss") ?? "-")</strong>
                            </div>
                            <div class="order-admin__detail-row">
                                <span>Trạng thái đơn</span>
                                <strong>@Model.OrderStatusLabel</strong>
                            </div>
                            <div class="order-admin__detail-row">
                                <span>Trạng thái thanh toán</span>
                                <strong>@Model.PaymentStatusLabel</strong>
                            </div>
                            <div class="order-admin__detail-row">
                                <span>Phương thức</span>
                                <strong>@Model.PaymentMethod</strong>
                            </div>
                            <div class="order-admin__detail-row">
                                <span>Ngày thanh toán</span>
                                <strong>@(Model.PaymentDate?.ToString("dd/MM/yyyy HH:mm:ss") ?? "-")</strong>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="settings-panel">
                    <div class="settings-panel__header">
                        <div>
                            <span class="settings-panel__eyebrow">Tổng hợp</span>
                            <h2>Giá trị đơn hàng</h2>
                        </div>
                    </div>
                    <div class="settings-panel__body">
                        <div class="order-admin__summary-list">
                            <div class="order-admin__summary-row">
                                <span>Tổng tiền hàng</span>
                                <strong>@Model.OriginAmount.ToString("C0", new CultureInfo("vi-VN"))</strong>
                            </div>
                            <div class="order-admin__summary-row">
                                <span>Giảm giá khuyến mãi</span>
                                <strong>@Model.DiscountAmount.ToString("C0", new CultureInfo("vi-VN"))</strong>
                            </div>
                            <div class="order-admin__summary-row">
                                <span>Giảm giá thêm</span>
                                <strong>@Model.DeductAmount.ToString("C0", new CultureInfo("vi-VN"))</strong>
                            </div>
                            <div class="order-admin__summary-row">
                                <span>Phí vận chuyển</span>
                                <strong>@Model.ShippingAmount.ToString("C0", new CultureInfo("vi-VN"))</strong>
                            </div>
                            <div class="order-admin__summary-row order-admin__summary-row--total">
                                <span>Tổng thanh toán</span>
                                <strong>@Model.TotalAmount.ToString("C0", new CultureInfo("vi-VN"))</strong>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script type="text/javascript">
    $(document).ready(function () {
        $('#ToFilePDF').click(function () {
            $('.loading-container').show();
            const id = '@Model.OrderId';
            window.location.href = '/Admin/POS/Print-Invoice?id=' + id;
            setTimeout(function () {
                $('.loading-container').hide();
            }, 3000);
        });
    });
</script>
