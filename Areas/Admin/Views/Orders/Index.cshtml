@model Tech_Store.Models.ViewModel.AdminOrderIndexViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Đơn hàng";
    Layout = "~/Areas/Admin/Views/Shared/Layout.cshtml";
}

<div class="py-3 order-admin-page">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-0 pb-0">
            <div class="d-flex flex-wrap gap-3 align-items-center justify-content-between">
                <div>
                    <h4 class="card-title mb-1">Danh sách đơn hàng</h4>
                </div>
                <div class="order-admin__header-meta">
                    <span class="order-admin__header-pill">Tổng đơn: @Model.TotalItems</span>
                    <span class="order-admin__header-pill">Trang @Model.Page/@Model.TotalPages</span>
                </div>
            </div>
        </div>

        <div class="card-body">
            <form method="get" class="brand-admin__filters order-admin__filters row g-3 align-items-end mb-4">
                <input type="hidden" name="pageSize" value="@Model.PageSize" />
                <div class="col-xl-4">
                    <label class="form-label fw-semibold text-secondary">Tìm kiếm</label>
                    <input type="text"
                           class="form-control"
                           name="keyword"
                           value="@Model.Keyword"
                           placeholder="Mã đơn, khách hàng, SĐT, SKU hoặc tên sản phẩm..." />
                </div>
                <div class="col-md-4 col-xl-2">
                    <label class="form-label fw-semibold text-secondary">Trạng thái đơn</label>
                    <select class="form-select" name="status">
                        <option value="">Tất cả trạng thái</option>
                        @if (Model.Status == "Pending")
                        {
                            <option value="Pending" selected>Đang chờ</option>
                        }
                        else
                        {
                            <option value="Pending">Đang chờ</option>
                        }
                        @if (Model.Status == "Confirmed")
                        {
                            <option value="Confirmed" selected>Đã xác nhận</option>
                        }
                        else
                        {
                            <option value="Confirmed">Đã xác nhận</option>
                        }
                        @if (Model.Status == "Shipping")
                        {
                            <option value="Shipping" selected>Đang giao hàng</option>
                        }
                        else
                        {
                            <option value="Shipping">Đang giao hàng</option>
                        }
                        @if (Model.Status == "Delivered")
                        {
                            <option value="Delivered" selected>Đã giao hàng</option>
                        }
                        else
                        {
                            <option value="Delivered">Đã giao hàng</option>
                        }
                        @if (Model.Status == "Completed")
                        {
                            <option value="Completed" selected>Hoàn thành</option>
                        }
                        else
                        {
                            <option value="Completed">Hoàn thành</option>
                        }
                        @if (Model.Status == "Cancelled")
                        {
                            <option value="Cancelled" selected>Đã hủy</option>
                        }
                        else
                        {
                            <option value="Cancelled">Đã hủy</option>
                        }
                        @if (Model.Status == "Refunded")
                        {
                            <option value="Refunded" selected>Đã hoàn tiền</option>
                        }
                        else
                        {
                            <option value="Refunded">Đã hoàn tiền</option>
                        }
                    </select>
                </div>
                <div class="col-md-4 col-xl-2">
                    <label class="form-label fw-semibold text-secondary">Thanh toán</label>
                    <select class="form-select" name="paymentStatus">
                        <option value="">Tất cả trạng thái</option>
                        @if (Model.PaymentStatus == "Paid")
                        {
                            <option value="Paid" selected>Đã thanh toán</option>
                        }
                        else
                        {
                            <option value="Paid">Đã thanh toán</option>
                        }
                        @if (Model.PaymentStatus == "Unpaid")
                        {
                            <option value="Unpaid" selected>Chưa thanh toán</option>
                        }
                        else
                        {
                            <option value="Unpaid">Chưa thanh toán</option>
                        }
                    </select>
                </div>
                <div class="col-md-4 col-xl-2">
                    <label class="form-label fw-semibold text-secondary">Từ ngày</label>
                    <input type="date" class="form-control" name="dateFrom" value="@(Model.DateFrom?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-4 col-xl-2">
                    <label class="form-label fw-semibold text-secondary">Đến ngày</label>
                    <input type="date" class="form-control" name="dateTo" value="@(Model.DateTo?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-4 col-xl-2">
                    <label class="form-label fw-semibold text-secondary">Từ giá trị</label>
                    <input type="number" class="form-control" name="amountFrom" value="@Model.AmountFrom" placeholder="0" />
                </div>
                <div class="col-md-4 col-xl-2">
                    <label class="form-label fw-semibold text-secondary">Đến giá trị</label>
                    <input type="number" class="form-control" name="amountTo" value="@Model.AmountTo" placeholder="0" />
                </div>
                <div class="col-12 col-xl-4 ms-xl-auto">
                    <div class="order-admin__filter-actions">
                        <button type="submit" class="btn btn-primary">Tìm kiếm</button>
                        <a href="/Admin/Orders" class="btn btn-light border">Làm mới</a>
                    </div>
                </div>
            </form>

            <div class="table-responsive reusable-admin-table">
                <table class="table table-hover align-middle order-admin__table">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 100px;">Mã đơn</th>
                            <th style="width: 160px;">Ngày đặt</th>
                            <th>Khách hàng</th>
                            <th>Sản phẩm</th>
                            <th style="width: 150px;">Thanh toán</th>
                            <th style="width: 150px;">Trạng thái</th>
                            <th style="width: 170px;">Tổng tiền</th>
                            <th style="width: 160px;">Xử lý nhanh</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Orders.Count == 0)
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-5">
                                    Không có đơn hàng phù hợp với bộ lọc hiện tại.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var order in Model.Orders)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-semibold text-dark">#@order.OrderId</div>
                                    </td>
                                    <td>
                                        <div class="text-dark">@(order.OrderDate?.ToString("dd/MM/yyyy") ?? "-")</div>
                                        <div class="small text-muted">@(order.OrderDate?.ToString("HH:mm:ss") ?? "-")</div>
                                    </td>
                                    <td>
                                        <div class="fw-semibold text-dark">@order.CustomerName</div>
                                        <div class="small text-muted">@order.PhoneNumber</div>
                                        <div class="small text-muted">@order.Email</div>
                                    </td>
                                    <td>
                                        <div class="order-admin__product-summary">@order.ProductSummary</div>
                                        <div class="small text-muted">@order.ItemCount sản phẩm</div>
                                    </td>
                                    <td>
                                        <div class="order-admin__state order-admin__state--payment">
                                            <span class="order-admin__state-dot @(order.PaymentStatus == "Paid" ? "order-admin__state-dot--success" : "order-admin__state-dot--danger")"></span>
                                            <div class="order-admin__state-body">
                                                <strong>@order.PaymentStatusLabel</strong>
                                                <span>@order.PaymentMethod</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="order-admin__state order-admin__state--order">
                                            <span class="order-admin__state-dot @($"order-admin__state-dot--{order.OrderStatus?.ToLowerInvariant()}")"></span>
                                            <div class="order-admin__state-body">
                                                <strong>@order.OrderStatusLabel</strong>
                                                <span>@order.OrderStatus</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="order-admin__amount">@order.TotalAmount.ToString("C0", new CultureInfo("vi-VN"))</div>
                                    </td>
                                    <td>
                                        <button type="button"
                                                class="btn btn-light border order-admin__quick-action open-order-drawer"
                                                data-id="@order.OrderId">
                                            Xử lý đơn
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_ManualPagination.cshtml", new Tech_Store.Models.ViewModel.ManualPaginationViewModel
            {
                CurrentPage = Model.Page,
                TotalPages = Model.TotalPages,
                BaseUrl = "/Admin/Orders",
                QueryString = string.Join("&", new[]
                {
                    !string.IsNullOrWhiteSpace(Model.Keyword) ? $"keyword={Uri.EscapeDataString(Model.Keyword)}" : null,
                    !string.IsNullOrWhiteSpace(Model.Status) ? $"status={Uri.EscapeDataString(Model.Status)}" : null,
                    !string.IsNullOrWhiteSpace(Model.PaymentStatus) ? $"paymentStatus={Uri.EscapeDataString(Model.PaymentStatus)}" : null,
                    Model.DateFrom.HasValue ? $"dateFrom={Model.DateFrom.Value:yyyy-MM-dd}" : null,
                    Model.DateTo.HasValue ? $"dateTo={Model.DateTo.Value:yyyy-MM-dd}" : null,
                    Model.AmountFrom.HasValue ? $"amountFrom={Model.AmountFrom.Value}" : null,
                    Model.AmountTo.HasValue ? $"amountTo={Model.AmountTo.Value}" : null,
                    $"pageSize={Model.PageSize}"
                }.Where(x => !string.IsNullOrWhiteSpace(x)))
            })
        </div>
    </div>
</div>

@await Html.PartialAsync("~/Areas/Admin/Views/Shared/_AdminRightDrawer.cshtml", new Tech_Store.Models.ViewModel.AdminRightDrawerViewModel
{
    DrawerId = "orderQuickDrawer",
    Title = "Xử lý đơn hàng",
    BodyId = "orderQuickDrawerBody",
    WidthClass = "admin-right-drawer--lg"
})

<script src="~/Admin/assets/js/core/jquery-3.7.1.min.js"></script>
<script>
    $(document).ready(function () {
        $('[data-bs-toggle="tooltip"]').tooltip();
        const drawerElement = document.getElementById('orderQuickDrawer');
        const drawerBody = $('#orderQuickDrawerBody');
        const orderDrawer = drawerElement ? bootstrap.Offcanvas.getOrCreateInstance(drawerElement) : null;
        const processingFlags = {};

        $(document).on('click', '.open-order-drawer', function (e) {
            e.preventDefault();
            const id = $(this).data('id');

            if (!orderDrawer) {
                return;
            }

            drawerBody.html('<div class="admin-right-drawer__loading">Đang tải thông tin đơn hàng...</div>');
            orderDrawer.show();
            $('.loading-container').show();

            $.ajax({
                method: 'GET',
                url: '/admin/Orders/QuickDrawer/' + id,
                success: function (html) {
                    drawerBody.html(html);
                },
                error: function () {
                    drawerBody.html('<div class="alert alert-danger mb-0">Không thể tải thông tin đơn hàng.</div>');
                },
                complete: function () {
                    $('.loading-container').hide();
                }
            });
        });

        $(document).on('click', '#applyDrawerOrderStatus', function (e) {
            e.preventDefault();

            const $button = $(this);
            const id = $button.data('id');
            const $select = $('#drawerOrderStatus');
            const newStatus = $select.val();
            const currentStatus = $select.data('current-status');

            if (processingFlags[id]) {
                return;
            }

            if (newStatus === currentStatus) {
                Swal.fire('Chưa có thay đổi', `Đơn #${id} chưa có thay đổi trạng thái.`, 'info');
                return;
            }

            processingFlags[id] = true;
            $button.prop('disabled', true);

            Swal.fire({
                title: 'Xác nhận thay đổi trạng thái',
                text: `Bạn có muốn đổi trạng thái đơn #${id} sang "${newStatus}" không?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Đổi trạng thái',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (!result.isConfirmed) {
                    processingFlags[id] = false;
                    $button.prop('disabled', false);
                    return;
                }

                $('.loading-container').show();

                $.ajax({
                    method: 'POST',
                    url: '/admin/Orders/ChangeStatus',
                    data: {
                        status: newStatus,
                        id: id
                    },
                    success: function (response) {
                        if (!response.success) {
                            Swal.fire('Lỗi', response.message, 'error');
                            $select.val(currentStatus);
                            return;
                        }

                        Swal.fire('Thành công', response.message, 'success');
                        location.reload();
                    },
                    error: function () {
                        Swal.fire('Lỗi', 'Không thể cập nhật trạng thái đơn hàng.', 'error');
                        $select.val(currentStatus);
                    },
                    complete: function () {
                        processingFlags[id] = false;
                        $button.prop('disabled', false);
                        $('.loading-container').hide();
                    }
                });
            });
        });
    });
</script>
