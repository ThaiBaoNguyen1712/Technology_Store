@model Tech_Store.Models.ViewModel.AdminPaymentGatewaySettingsViewModel

@{
    ViewData["Title"] = "Cổng thanh toán";
    Layout = "~/Areas/Admin/Views/Shared/Layout.cshtml";
}

<div class="page-inner settings-page">
    <div class="settings-page__hero">
        <div>
            <span class="settings-page__eyebrow">Thanh toán</span>
            <h1 class="settings-page__title">Cổng thanh toán</h1>
        </div>
        <div class="settings-page__hero-meta">
            <div class="settings-page__meta-card">
                <span class="settings-page__meta-label">Đang mở</span>
                <strong>@Model.EnabledGatewayCount/@Model.TotalGatewayCount</strong>
            </div>
        </div>
    </div>

    <div class="settings-panel">
        <div class="settings-panel__body">
            <div class="table-responsive reusable-admin-table">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Cổng thanh toán</th>
                            <th style="width: 180px;">Loại</th>
                            <th style="width: 140px;" class="text-center">Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var gateway in Model.Gateways)
                        {
                            var inputId = $"gateway-{gateway.Code}";
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="@gateway.LogoUrl" alt="@gateway.DisplayName" style="width: 48px; height: 48px; object-fit: contain;" />
                                        <div class="fw-semibold text-dark">@gateway.DisplayName</div>
                                    </div>
                                </td>
                                <td>@gateway.ChannelLabel</td>
                                <td class="text-center">
                                    <div class="form-check form-switch d-inline-flex justify-content-center">
                                        <input class="form-check-input"
                                               type="checkbox"
                                               id="@inputId"
                                               @(gateway.IsEnabled ? "checked" : null) />
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="settings-page__actions mt-4">
        <button id="savePaymentGatewaySettings" class="btn btn-primary btn-lg ms-auto">
            <i class="fas fa-save me-2"></i>Lưu thay đổi
        </button>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            $('#savePaymentGatewaySettings').on('click', function () {
                Swal.fire({
                    title: 'Lưu thay đổi?',
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#1572e8',
                    cancelButtonColor: '#6b7280',
                    confirmButtonText: 'Lưu',
                    cancelButtonText: 'Hủy'
                }).then((result) => {
                    if (!result.isConfirmed) {
                        return;
                    }

                    $('.loading-container').show();

                    $.ajax({
                        url: '/Admin/Settings/UpdatePaymentGateways',
                        type: 'POST',
                        data: {
                            IsMomoEnabled: $('#gateway-momo').is(':checked'),
                            IsVnPayEnabled: $('#gateway-vnpay').is(':checked'),
                            IsSePayEnabled: $('#gateway-sepay').is(':checked')
                        },
                        success: function (response) {
                            $('.loading-container').hide();

                            Swal.fire({
                                title: response.success ? 'Đã lưu' : 'Không thể lưu',
                                text: response.message,
                                icon: response.success ? 'success' : 'error',
                                confirmButtonText: 'Đóng'
                            }).then(() => {
                                if (response.success) {
                                    window.location.reload();
                                }
                            });
                        },
                        error: function () {
                            $('.loading-container').hide();

                            Swal.fire({
                                title: 'Có lỗi xảy ra',
                                text: 'Không thể cập nhật trạng thái cổng thanh toán.',
                                icon: 'error',
                                confirmButtonText: 'Đóng'
                            });
                        }
                    });
                });
            });
        });
    </script>
}
