@model Tech_Store.Models.ViewModel.AdminSettingsHubViewModel

@{
    ViewData["Title"] = "Cài đặt trang web";
    Layout = "~/Areas/Admin/Views/Shared/Layout.cshtml";
}

<div class="page-inner settings-page">
    <div class="settings-page__hero">
        <div>
            <span class="settings-page__eyebrow">Quản trị hệ thống</span>
            <h1 class="settings-page__title">Cài đặt trang web</h1>
        </div>
        <div class="settings-page__hero-meta">
            <div class="settings-page__meta-card">
                <span class="settings-page__meta-label">Website</span>
                <strong>@(string.IsNullOrWhiteSpace(Model.WebsiteName) ? "Chưa cấu hình" : Model.WebsiteName)</strong>
            </div>
            <div class="settings-page__meta-card">
                <span class="settings-page__meta-label">Email hỗ trợ</span>
                <strong>@(string.IsNullOrWhiteSpace(Model.SupportEmail) ? "Chưa cấu hình" : Model.SupportEmail)</strong>
            </div>
        </div>
    </div>

    <div class="settings-hub">
        <a class="settings-hub__card" href="/Admin/Settings/General">
            <div class="settings-hub__icon">
                <i class="fas fa-cog"></i>
            </div>
            <div class="settings-hub__body">
                <h2>Cài đặt chung</h2>
            </div>
        </a>

        <a class="settings-hub__card" href="/Admin/Settings/ProductSpecs">
            <div class="settings-hub__icon">
                <i class="fas fa-list-ul"></i>
            </div>
            <div class="settings-hub__body">
                <h2>Thông số sản phẩm</h2>
            </div>
        </a>

        <a class="settings-hub__card" href="/Admin/Settings/ProductAttributes">
            <div class="settings-hub__icon">
                <i class="fas fa-sliders-h"></i>
            </div>
            <div class="settings-hub__body">
                <h2>Thuộc tính biến thể</h2>
            </div>
        </a>
    </div>
</div>
