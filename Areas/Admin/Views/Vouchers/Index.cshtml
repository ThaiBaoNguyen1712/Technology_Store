@model Tech_Store.Models.ViewModel.AdminVoucherIndexViewModel

@{
    ViewData["Title"] = "Mã khuyến mãi";
    Layout = "~/Areas/Admin/Views/Shared/Layout.cshtml";
}

<div class="py-3 voucher-admin-page">
    @Html.AntiForgeryToken()

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-0 pb-0">
            <div class="d-flex flex-wrap gap-3 align-items-center justify-content-between">
                <div>
                    <h4 class="card-title mb-1">Danh sách mã khuyến mãi</h4>
                </div>
                <div class="order-admin__header-meta">
                    <span class="order-admin__header-pill">Tổng voucher: @Model.TotalItems</span>
                    <span class="order-admin__header-pill">Trang @Model.Page/@Model.TotalPages</span>
                    <a href="@Url.Action("Form", "Vouchers", new
                       {
                           area = "Admin",
                           page = Model.Page,
                           code = Model.Code,
                           name = Model.Name,
                           dateFrom = Model.DateFrom?.ToString("yyyy-MM-dd"),
                           dateTo = Model.DateTo?.ToString("yyyy-MM-dd")
                       })"
                       class="btn btn-primary">
                        <i class="fa fa-plus me-1"></i>
                        Thêm mã khuyến mãi
                    </a>
                </div>
            </div>
        </div>

        <div class="card-body">
            <form method="get" class="brand-admin__filters voucher-admin__filters row g-3 align-items-end mb-4">
                <input type="hidden" name="page" value="1" />
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Mã khuyến mãi</label>
                    <input type="text"
                           class="form-control"
                           name="code"
                           value="@Model.Code"
                           placeholder="Nhập mã khuyến mãi" />
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Tên voucher</label>
                    <input type="text"
                           class="form-control"
                           name="name"
                           value="@Model.Name"
                           placeholder="Nhập tên voucher" />
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Ngày bắt đầu</label>
                    <input type="date"
                           class="form-control"
                           name="dateFrom"
                           value="@(Model.DateFrom?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label fw-semibold text-secondary">Ngày kết thúc</label>
                    <input type="date"
                           class="form-control"
                           name="dateTo"
                           value="@(Model.DateTo?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-12 admin-search-actions-row">
                    <div class="admin-search-actions">
                        <button type="submit" class="btn btn-primary">Tìm kiếm</button>
                        <a href="/Admin/Vouchers" class="btn btn-light border">Làm mới</a>
                    </div>
                </div>
            </form>

            <div class="table-responsive reusable-admin-table">
                <table class="table table-hover align-middle voucher-admin__table">
                    <thead class="table-light">
                        <tr>
                            <th>Tên voucher</th>
                            <th style="width: 150px;">Mã</th>
                            <th style="width: 130px;">Khuyến mãi</th>
                            <th>Mô tả</th>
                            <th style="width: 120px;">Số lượng</th>
                            <th style="width: 160px;">Hiệu lực</th>
                            <th style="width: 160px;">Trạng thái</th>
                            <th style="width: 140px;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Vouchers.Count == 0)
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-5">
                                    Không có voucher phù hợp với bộ lọc hiện tại.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var voucher in Model.Vouchers)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-semibold text-dark">@voucher.Name</div>
                                        <div class="small text-muted">ID #@voucher.VoucherId</div>
                                    </td>
                                    <td>
                                        <span class="badge text-bg-warning-subtle text-warning-emphasis border voucher-admin__code-badge">
                                            @voucher.Code
                                        </span>
                                    </td>
                                    <td>
                                        <div class="voucher-admin__promotion">@voucher.Promotion</div>
                                    </td>
                                    <td class="text-muted">@(string.IsNullOrWhiteSpace(voucher.Description) ? "-" : voucher.Description)</td>
                                    <td>
                                        <div class="fw-semibold text-dark">@voucher.Quantity</div>
                                        <div class="small text-muted">lượt áp dụng</div>
                                    </td>
                                    <td>
                                        <div class="text-dark">@(voucher.StartedAt?.ToString("dd/MM/yyyy") ?? "-")</div>
                                        <div class="small text-muted">đến @(voucher.ExpiredAt?.ToString("dd/MM/yyyy") ?? "-")</div>
                                    </td>
                                    <td>
                                        <div class="order-admin__state">
                                            <span class="order-admin__state-dot @($"order-admin__state-dot--{voucher.StatusTone}")"></span>
                                            <div class="order-admin__state-body">
                                                <strong>@voucher.StatusLabel</strong>
                                                <span>@(voucher.StartedAt?.ToString("HH:mm:ss") ?? "-") - @(voucher.ExpiredAt?.ToString("HH:mm:ss") ?? "-")</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="form-button-action justify-content-center">
                                            <a href="@Url.Action("Form", "Vouchers", new
                                               {
                                                   area = "Admin",
                                                   id = voucher.VoucherId,
                                                   page = Model.Page,
                                                   code = Model.Code,
                                                   name = Model.Name,
                                                   dateFrom = Model.DateFrom?.ToString("yyyy-MM-dd"),
                                                   dateTo = Model.DateTo?.ToString("yyyy-MM-dd")
                                               })"
                                               class="btn btn-link btn-primary btn-lg"
                                               data-bs-toggle="tooltip"
                                               title="Cập nhật">
                                                <i class="fa fa-edit"></i>
                                            </a>
                                            <button type="button"
                                                    class="btn btn-link btn-danger"
                                                    data-id="@voucher.VoucherId"
                                                    data-name="@voucher.Name"
                                                    data-role="remove-voucher"
                                                    title="Xóa">
                                                <i class="fa fa-times"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_ManualPagination.cshtml", new Tech_Store.Models.ViewModel.ManualPaginationViewModel
            {
                CurrentPage = Model.Page,
                TotalPages = Model.TotalPages,
                BaseUrl = "/Admin/Vouchers",
                QueryString = string.Join("&", new[]
                {
                    !string.IsNullOrWhiteSpace(Model.Code) ? $"code={Uri.EscapeDataString(Model.Code)}" : null,
                    !string.IsNullOrWhiteSpace(Model.Name) ? $"name={Uri.EscapeDataString(Model.Name)}" : null,
                    Model.DateFrom.HasValue ? $"dateFrom={Model.DateFrom.Value:yyyy-MM-dd}" : null,
                    Model.DateTo.HasValue ? $"dateTo={Model.DateTo.Value:yyyy-MM-dd}" : null
                }.Where(x => !string.IsNullOrWhiteSpace(x)))
            })
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        const antiForgeryToken = $('input[name="__RequestVerificationToken"]').val();

        $(document).on('click', '[data-role="remove-voucher"]', function () {
            const voucherId = $(this).data('id');
            const voucherName = $(this).data('name');

            Swal.fire({
                title: 'Xóa mã khuyến mãi?',
                text: `Bạn đang chuẩn bị xóa "${voucherName}". Hành động này không thể hoàn tác.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Xóa',
                cancelButtonText: 'Hủy',
                confirmButtonColor: '#d33'
            }).then((result) => {
                if (!result.isConfirmed) {
                    return;
                }

                $('.loading-container').show();

                $.ajax({
                    method: 'DELETE',
                    url: `/Admin/Vouchers/Delete/${voucherId}`,
                    headers: {
                        "RequestVerificationToken": antiForgeryToken
                    },
                    success: function () {
                        $('.loading-container').hide();
                        location.reload();
                    },
                    error: function (xhr) {
                        $('.loading-container').hide();
                        const message = xhr.responseJSON && xhr.responseJSON.message
                            ? xhr.responseJSON.message
                            : 'Không thể xóa mã khuyến mãi.';
                        Swal.fire('Lỗi', message, 'error');
                    }
                });
            });
        });
    });
</script>
