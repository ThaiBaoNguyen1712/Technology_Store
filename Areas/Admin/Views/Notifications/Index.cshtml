@model Tech_Store.Models.ViewModel.AdminNotificationIndexViewModel

@{
    ViewData["Title"] = "Tất cả thông báo";
    Layout = "/Areas/Admin/Views/Shared/Layout.cshtml";
}

<div class="py-3 notification-admin-page">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-0 pb-0">
            <div class="d-flex flex-wrap gap-3 align-items-center justify-content-between">
                <div>
                    <h4 class="card-title mb-1">Danh sách thông báo</h4>
                </div>
                <div class="order-admin__header-meta">
                    <span class="order-admin__header-pill">Tổng thông báo: @Model.TotalItems</span>
                    <span class="order-admin__header-pill">Trang @Model.Page/@Model.TotalPages</span>
                </div>
            </div>
        </div>

        <div class="card-body">
            <div class="d-flex flex-wrap gap-2 justify-content-end mb-4">
                <form action="/Admin/Notifications/Delete_Read" method="get" class="d-inline"
                      onsubmit="return confirm('Xóa tất cả thông báo đã đọc?')">
                    <input type="hidden" name="page" value="@Model.Page" />
                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                    <button type="submit" class="btn btn-dark">
                        <i class="fa fa-trash"></i> Xóa thông báo đã đọc
                    </button>
                </form>

                <button type="button" class="btn btn-success" id="markAllNotificationsAsRead">
                    <i class="fa fa-check"></i> Đánh dấu tất cả đã đọc
                </button>
            </div>

            <div class="table-responsive reusable-admin-table">
                <table class="table table-hover align-middle notification-admin__table">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 150px;">Trạng thái</th>
                            <th style="width: 280px;">Tiêu đề</th>
                            <th>Nội dung</th>
                            <th style="width: 170px;">Thời gian</th>
                            <th style="width: 220px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Notifications.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-5">
                                    Không có thông báo nào.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var notification in Model.Notifications)
                            {
                                <tr class="@(notification.IsRead ? string.Empty : "notification-admin__row--unread")">
                                    <td>
                                        <div class="notification-admin__state">
                                            <span class="notification-admin__state-dot @(notification.IsRead ? "notification-admin__state-dot--read" : "notification-admin__state-dot--unread")"></span>
                                            <div class="notification-admin__state-body">
                                                <strong>@(notification.IsRead ? "Đã đọc" : "Chưa đọc")</strong>
                                                <span>@notification.TypeLabel</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="notification-admin__title-wrap">
                                            @if (!notification.IsRead)
                                            {
                                                <i class="fa fa-thumbtack notification-admin__pin"></i>
                                            }
                                            <span class="fw-semibold text-dark">@notification.Title</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="notification-admin__message">@notification.Message</div>
                                    </td>
                                    <td>
                                        <div class="text-dark">@(notification.CreatedAt?.ToString("dd/MM/yyyy") ?? "-")</div>
                                        <div class="small text-muted">@(notification.CreatedAt?.ToString("HH:mm:ss") ?? "-")</div>
                                    </td>
                                    <td>
                                        <div class="d-flex flex-wrap gap-2">
                                            <a href="@notification.RedirectUrl"
                                               class="btn btn-light border btn-sm btn-view-noti"
                                               data-id="@notification.UserNotificationId">
                                                <i class="fa fa-eye"></i> Xem
                                            </a>

                                            @if (!notification.IsRead)
                                            {
                                                <button type="button"
                                                        class="btn btn-success btn-sm notification-page-mark-as-read"
                                                        data-id="@notification.UserNotificationId">
                                                    <i class="fa fa-check"></i> Đã đọc
                                                </button>
                                            }

                                            <form action="/Admin/Notifications/Delete"
                                                  method="get"
                                                  class="d-inline"
                                                  onsubmit="return confirm('Xóa thông báo này?')">
                                                <input type="hidden" name="id" value="@notification.NotificationId" />
                                                <input type="hidden" name="page" value="@Model.Page" />
                                                <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                                <button type="submit" class="btn btn-danger btn-sm">
                                                    <i class="fa fa-trash"></i> Xóa
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_ManualPagination.cshtml", new Tech_Store.Models.ViewModel.ManualPaginationViewModel
            {
                CurrentPage = Model.Page,
                TotalPages = Model.TotalPages,
                BaseUrl = "/Admin/Notifications/Index",
                QueryString = $"pageSize={Model.PageSize}"
            })
        </div>
    </div>
</div>

<script src="~/Admin/assets/js/core/jquery-3.7.1.min.js"></script>
<script>
    $(document).ready(function () {
        $('.notification-page-mark-as-read').on('click', function () {
            const id = $(this).data('id');
            $.post('/admin/notifications/mark-as-read', { id: id }, function (response) {
                if (response.success) {
                    window.location.reload();
                } else {
                    alert('Không thể đánh dấu thông báo. Vui lòng thử lại.');
                }
            });
        });

        $('#markAllNotificationsAsRead').on('click', function () {
            $.post('/admin/notifications/mark-all-as-read', function (response) {
                if (response.success) {
                    window.location.reload();
                } else {
                    alert('Không thể đánh dấu tất cả thông báo. Vui lòng thử lại.');
                }
            });
        });

        $('.btn-view-noti').on('click', function (e) {
            e.preventDefault();

            const url = $(this).attr('href');
            const id = $(this).data('id');

            $.post('/admin/notifications/mark-as-read', { id: id })
                .always(function () {
                    window.location.href = url;
                });
        });
    });
</script>
