@{
    Layout = null;
    var actionDirect = ViewData["actionDirect"]?.ToString() ?? string.Empty;
    var otpExpiresInSeconds = ViewData["OtpExpiresInSeconds"] as int? ?? 0;
    var resendAvailableInSeconds = ViewData["ResendAvailableInSeconds"] as int? ?? 0;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Xác thực OTP</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
            min-height: 100vh;
            display: flex;
            align-items: center;
            padding: 40px 0;
        }

        .auth-card {
            max-width: 420px;
            width: 100%;
            margin: auto;
            border: none;
            border-radius: 16px;
            box-shadow: 0 12px 32px rgba(15, 23, 42, 0.08);
        }

        .auth-body {
            padding: 32px 24px;
        }

        .auth-logo {
            color: #ff0000;
            font-size: 2rem;
            font-weight: 700;
            text-align: center;
            margin-bottom: 12px;
        }

        .otp-fields {
            display: grid;
            grid-template-columns: repeat(6, minmax(0, 1fr));
            gap: 10px;
            margin: 24px 0 18px;
        }

        .otp-input {
            width: 100%;
            min-width: 0;
            height: 52px;
            text-align: center;
            font-size: 1.15rem;
            font-weight: 600;
            border: 1px solid #d0d7de;
            border-radius: 12px;
        }

        .otp-input:focus {
            border-color: #ff4d4f;
            box-shadow: 0 0 0 0.2rem rgba(255, 77, 79, 0.12);
            outline: none;
        }

        .otp-input:disabled {
            background-color: #f3f4f6;
        }

        .otp-input::-webkit-outer-spin-button,
        .otp-input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        .otp-input[type=number] {
            -moz-appearance: textfield;
        }

        .otp-meta {
            font-size: 0.92rem;
            color: #6b7280;
        }

        .otp-link {
            color: #ff0000;
            text-decoration: none;
            font-weight: 500;
        }

        .otp-link.disabled {
            pointer-events: none;
            color: #9ca3af;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="card auth-card">
            <div class="auth-body">
                <div class="auth-logo">Tech Store</div>
                <div class="text-center">
                    <h4 class="mb-2">Xác thực OTP</h4>
                    <p class="text-muted mb-0">Nhập mã gồm 6 số đã được gửi đến email của bạn.</p>
                </div>

                <form id="otpForm" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Action" value="@actionDirect" />
                    <input type="hidden" id="completeOtp" name="OtpToken" />

                    <div class="otp-fields">
                        <input type="number" class="otp-input" maxlength="1" inputmode="numeric" autofocus>
                        <input type="number" class="otp-input" maxlength="1" inputmode="numeric" disabled>
                        <input type="number" class="otp-input" maxlength="1" inputmode="numeric" disabled>
                        <input type="number" class="otp-input" maxlength="1" inputmode="numeric" disabled>
                        <input type="number" class="otp-input" maxlength="1" inputmode="numeric" disabled>
                        <input type="number" class="otp-input" maxlength="1" inputmode="numeric" disabled>
                    </div>

                    <div id="ErrorMessage" class="text-danger small mb-3">@ViewBag.Error</div>

                    <button type="submit" class="btn btn-danger w-100 d-flex justify-content-center align-items-center" id="verifyButton" disabled>
                        Xác thực
                        <span class="spinner-border spinner-border-sm text-light ms-2 d-none" id="verifyLoading" role="status"></span>
                    </button>

                    <div class="text-center mt-3 otp-meta">
                        Mã còn hiệu lực: <strong id="otpExpiryLabel">00:00</strong>
                    </div>

                    <div class="text-center mt-2 otp-meta">
                        Chưa nhận được mã?
                        <a href="#" id="resendBtn" class="otp-link disabled">Gửi lại</a>
                    </div>

                    <div class="text-center mt-1 otp-meta" id="resendHint"></div>
                </form>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const inputs = Array.from(document.querySelectorAll(".otp-input"));
            const form = document.getElementById("otpForm");
            const submitButton = document.getElementById("verifyButton");
            const loadingIndicator = document.getElementById("verifyLoading");
            const completeOtpInput = document.getElementById("completeOtp");
            const errorMessage = document.getElementById("ErrorMessage");
            const resendButton = document.getElementById("resendBtn");
            const otpExpiryLabel = document.getElementById("otpExpiryLabel");
            const resendHint = document.getElementById("resendHint");

            let otpExpiresInSeconds = @otpExpiresInSeconds;
            let resendAvailableInSeconds = @resendAvailableInSeconds;
            let timerId = null;

            function formatSeconds(totalSeconds) {
                const safeValue = Math.max(0, totalSeconds);
                const minutes = Math.floor(safeValue / 60);
                const seconds = safeValue % 60;
                return `${String(minutes).padStart(2, "0")}:${String(seconds).padStart(2, "0")}`;
            }

            function updateTimerUi() {
                otpExpiryLabel.textContent = formatSeconds(otpExpiresInSeconds);

                if (resendAvailableInSeconds > 0) {
                    resendButton.classList.add("disabled");
                    resendHint.textContent = `Bạn có thể gửi lại sau ${resendAvailableInSeconds} giây.`;
                } else {
                    resendButton.classList.remove("disabled");
                    resendHint.textContent = "Bạn có thể yêu cầu mã mới ngay bây giờ.";
                }
            }

            function startTimer() {
                if (timerId) {
                    window.clearInterval(timerId);
                }

                updateTimerUi();

                timerId = window.setInterval(function () {
                    if (otpExpiresInSeconds > 0) {
                        otpExpiresInSeconds -= 1;
                    }

                    if (resendAvailableInSeconds > 0) {
                        resendAvailableInSeconds -= 1;
                    }

                    updateTimerUi();
                }, 1000);
            }

            function resetInputs() {
                inputs.forEach(function (input, index) {
                    input.value = "";
                    if (index === 0) {
                        input.removeAttribute("disabled");
                    } else {
                        input.setAttribute("disabled", "disabled");
                    }
                });

                completeOtpInput.value = "";
                submitButton.setAttribute("disabled", "disabled");
                inputs[0].focus();
            }

            function collectOtp() {
                let otp = "";
                let isComplete = true;

                inputs.forEach(function (input) {
                    if (!input.value) {
                        isComplete = false;
                    }

                    otp += input.value;
                });

                completeOtpInput.value = isComplete ? otp : "";
                submitButton.disabled = !isComplete;
            }

            inputs.forEach(function (input, index) {
                input.addEventListener("input", function (event) {
                    const value = event.target.value.replace(/\D/g, "").slice(0, 1);
                    event.target.value = value;

                    if (value && index < inputs.length - 1) {
                        inputs[index + 1].removeAttribute("disabled");
                        inputs[index + 1].focus();
                    }

                    collectOtp();
                });

                input.addEventListener("keydown", function (event) {
                    if (event.key === "Backspace" && !input.value && index > 0) {
                        inputs[index - 1].focus();
                        inputs[index - 1].value = "";
                        collectOtp();
                    }
                });
            });

            inputs[0].addEventListener("paste", function (event) {
                event.preventDefault();
                const pasted = (event.clipboardData || window.clipboardData).getData("text").replace(/\D/g, "").slice(0, 6).split("");

                pasted.forEach(function (value, index) {
                    inputs[index].value = value;
                    if (index > 0) {
                        inputs[index].removeAttribute("disabled");
                    }
                });

                if (pasted.length > 0) {
                    const focusIndex = Math.min(pasted.length, inputs.length - 1);
                    inputs[focusIndex].focus();
                }

                collectOtp();
            });

            form.addEventListener("submit", function (event) {
                event.preventDefault();
                errorMessage.textContent = "";
                loadingIndicator.classList.remove("d-none");
                submitButton.disabled = true;

                $.ajax({
                    method: "POST",
                    url: '@Url.Action("VerifyOTP", "Authentication")',
                    headers: {
                        RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    data: {
                        Action: $('input[name="Action"]').val(),
                        OtpToken: completeOtpInput.value
                    },
                    success: function (response) {
                        loadingIndicator.classList.add("d-none");

                        if (response.success) {
                            if (response.action === "Register") {
                                window.location.href = '@Url.Action("Index", "Home")';
                                return;
                            }

                            if (response.action === "ForgotPassword") {
                                window.location.href = '@Url.Action("ChangePassword", "Authentication")';
                                return;
                            }
                        }

                        submitButton.disabled = false;
                        errorMessage.textContent = response.message || "Không thể xác thực mã.";
                        otpExpiresInSeconds = response.otpExpiresInSeconds ?? otpExpiresInSeconds;
                        resendAvailableInSeconds = response.resendAvailableInSeconds ?? resendAvailableInSeconds;
                        updateTimerUi();
                    },
                    error: function (xhr) {
                        loadingIndicator.classList.add("d-none");
                        submitButton.disabled = false;
                        errorMessage.textContent = xhr.responseJSON?.message || "Đã xảy ra lỗi khi xác thực mã.";
                    }
                });
            });

            resendButton.addEventListener("click", function (event) {
                event.preventDefault();

                if (resendButton.classList.contains("disabled")) {
                    return;
                }

                resendButton.classList.add("disabled");
                errorMessage.textContent = "";

                $.ajax({
                    method: "POST",
                    url: '@Url.Action("ResendOTP", "Authentication")',
                    headers: {
                        RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (response) {
                        if (response.success) {
                            otpExpiresInSeconds = response.otpExpiresInSeconds ?? otpExpiresInSeconds;
                            resendAvailableInSeconds = response.resendAvailableInSeconds ?? resendAvailableInSeconds;
                            resetInputs();
                            updateTimerUi();
                            return;
                        }

                        errorMessage.textContent = response.message || "Không thể gửi lại mã lúc này.";
                        resendAvailableInSeconds = response.resendAvailableInSeconds ?? resendAvailableInSeconds;
                        updateTimerUi();
                    },
                    error: function (xhr) {
                        errorMessage.textContent = xhr.responseJSON?.message || "Đã xảy ra lỗi khi gửi lại mã.";
                        updateTimerUi();
                    }
                });
            });

            startTimer();
        });
    </script>
</body>
</html>
