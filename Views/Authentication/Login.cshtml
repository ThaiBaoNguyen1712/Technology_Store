@{
    Layout = null;
}
@model Tech_Store.Models.DTO.Authentication.LoginDTo
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/vendor/fontawesome/css/all.min.css">

    <style>
        body {
            background-color: #f8f9fa;
            min-height: 100vh;
            display: flex;
            align-items: center;
            padding: 40px 0;
        }

        .login-container {
            max-width: 400px;
            width: 100%;
            margin: auto;
        }

        .card {
            border: none;
            border-radius: 10px;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.1);
        }

        .logo {
            color: #ff0000;
            font-size: 2rem;
            font-weight: bold;
            text-align: center;
            margin-bottom: 1rem;
        }

        a {
            color: #ff0000;
            font-size: 0.85rem;
        }

        .form-label {
            font-weight: 500;
            color: #212529;
        }

        .btn-danger {
            padding: 0.8rem;
            font-weight: 500;
        }

        .captcha-container {
            background-color: #f8f9fa;
            border-radius: 6px;
            padding: 10px;
            display: flex;
            justify-content: center;
            overflow: hidden;
        }

        .turnstile-box {
            width: 100%;
            display: flex;
            justify-content: center;
        }

        .demo-accounts {
            margin-top: 1rem;
            border: 1px solid #ffe1e1;
            border-radius: 10px;
            background: #fff8f8;
            overflow: hidden;
        }

        .demo-accounts__toggle {
            display: flex;
            align-items: center;
            justify-content: space-between;
            width: 100%;
            padding: 0.75rem 0.9rem;
            border: 0;
            background: transparent;
            color: #b02a37;
            font-size: 0.9rem;
            font-weight: 700;
            text-align: left;
        }

        .demo-accounts__toggle-text {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            min-width: 0;
        }

        .demo-accounts__toggle-icon {
            transition: transform 0.18s ease;
        }

        .demo-accounts__toggle[aria-expanded="true"] .demo-accounts__toggle-icon {
            transform: rotate(180deg);
        }

        .demo-accounts__body {
            padding: 0 0.9rem 0.9rem;
        }

        .demo-accounts__hint {
            margin-bottom: 0.65rem;
            color: #b02a37;
            font-size: 0.78rem;
            line-height: 1.35;
        }

        .demo-accounts__grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 0.55rem;
        }

        .demo-account {
            padding: 0.65rem;
            border: 1px solid #f3d7d7;
            border-radius: 8px;
            background: #ffffff;
        }

        .demo-account__role {
            margin-bottom: 0.35rem;
            color: #212529;
            font-size: 0.82rem;
            font-weight: 700;
        }

        .demo-account__line {
            display: flex;
            align-items: flex-start;
            gap: 0.35rem;
            margin-bottom: 0.2rem;
            color: #495057;
            font-size: 0.8rem;
            line-height: 1.35;
            word-break: break-word;
        }

        .demo-account__line:last-child {
            margin-bottom: 0;
        }

        .demo-account__label {
            flex: 0 0 auto;
            font-weight: 600;
        }

        .demo-account__value {
            min-width: 0;
            font-family: Consolas, "Courier New", monospace;
        }

        .demo-account__actions {
            margin-top: 0.6rem;
        }

        .demo-account__actions .btn {
            width: 100%;
            min-height: 34px;
            font-size: 0.78rem;
            font-weight: 600;
        }

        @@media (min-width: 576px) {
            .login-container {
                max-width: 460px;
            }
        }

        @@media (max-width: 400px) {
            body {
                padding: 20px 0;
            }

            .card {
                border-radius: 8px;
            }

            .demo-accounts__toggle {
                padding: 0.7rem 0.75rem;
            }

            .demo-accounts__body {
                padding: 0 0.75rem 0.75rem;
            }

            .turnstile-box {
                transform: scale(0.92);
                transform-origin: center;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="login-container">
            <div class="card d-flex" style="padding: 15px;">
                <div class="mx-auto" style="width: 90%;">
                    <div class="logo">Tech Store</div>
                    <h4 class="text-center mb-1">Đăng nhập</h4>

                    <div class="demo-accounts" aria-label="Tai khoan demo">
                        <button class="demo-accounts__toggle" type="button" data-bs-toggle="collapse" data-bs-target="#demoAccountsPanel" aria-expanded="false" aria-controls="demoAccountsPanel">
                            <span class="demo-accounts__toggle-text">
                            <i class="fa fa-circle-info"></i>
                            <span>Tài khoản demo</span>
                            </span>
                            <i class="fa fa-chevron-down demo-accounts__toggle-icon"></i>
                        </button>
                        <div class="collapse" id="demoAccountsPanel">
                            <div class="demo-accounts__body">
                                <div class="demo-accounts__hint">B&#7845;m D&#249;ng &#273;&#7875; t&#7921; &#273;i&#7873;n email v&#224; m&#7853;t kh&#7849;u v&#224;o form.</div>
                                <div class="demo-accounts__grid">
                            <div class="demo-account">
                                <div class="demo-account__role">Admin</div>
                                <div class="demo-account__line">
                                    <span class="demo-account__label">Email:</span>
                                    <span class="demo-account__value">nthaibao1712@gmail.com</span>
                                </div>
                                <div class="demo-account__line">
                                    <span class="demo-account__label">Mật khẩu:</span>
                                    <span class="demo-account__value">ntbao123</span>
                                </div>
                                <div class="demo-account__actions">
                                    <button class="btn btn-danger btn-sm demo-fill-account" type="button" data-email="nthaibao1712@gmail.com" data-password="ntbao123">
                                        <i class="fa fa-bolt me-1"></i>D&#249;ng
                                    </button>
                                </div>
                            </div>
                            <div class="demo-account">
                                <div class="demo-account__role">Client</div>
                                <div class="demo-account__line">
                                    <span class="demo-account__label">Email:</span>
                                    <span class="demo-account__value">24410266@ms.uit.edu.vn</span>
                                </div>
                                <div class="demo-account__line">
                                    <span class="demo-account__label">Mật khẩu:</span>
                                    <span class="demo-account__value">ntbao123</span>
                                </div>
                                <div class="demo-account__actions">
                                    <button class="btn btn-danger btn-sm demo-fill-account" type="button" data-email="24410266@ms.uit.edu.vn" data-password="ntbao123">
                                        <i class="fa fa-bolt me-1"></i>D&#249;ng
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                    </div>
                    </div>

                    <form method="post" action="@Url.Action("Login", "Authentication")">
                        @Html.AntiForgeryToken()

                        <div class="mb-3 pt-3">
                            <label class="form-label">Email của bạn</label>
                            <input type="email" name="Email" class="form-control" placeholder="email@address.com" value="@Model?.Email" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Mật khẩu</label>
                            <div class="input-group">
                                <input type="password" class="form-control" name="Password" placeholder="Nhập mật khẩu" id="passwordInput" required>
                                <button class="btn btn-outline-secondary" type="button" id="togglePassword">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-eye" viewBox="0 0 16 16" id="eyeIcon">
                                        <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M8 3.5a4.5 4.5 0 1 1 0 9 4.5 4.5 0 0 1 0-9" />
                                        <path d="M8 10a2 2 0 1 0 0-4 2 2 0 0 0 0 4" />
                                    </svg>
                                </button>
                            </div>
                        </div>

                        @if (ViewData["ValidateMessage"] != null)
                        {
                            <div class="mb-3">
                                <span class="text-danger">@ViewData["ValidateMessage"]</span>
                            </div>
                        }

                        <div class="row">
                            <div class="col-sm-6">
                                <div class="mb-3 form-check">
                                    <input type="checkbox" class="form-check-input" name="Remember" id="remember" value="true">
                                    <label class="form-check-label" for="remember" style="font-size: 0.85rem;">Ghi nhớ tôi</label>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="mb-3 text-sm-end">
                                    <a href="~/Auth/forgot-password">Quên mật khẩu?</a>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3 captcha-container">
                            <label style="font-size: 0.85rem;">Chưa có tài khoản? <a href="~/Auth/Register">Đăng ký ngay</a></label>
                        </div>

                        <div class="mb-3 captcha-container">
                            <div id="login-turnstile" class="turnstile-box"></div>
                        </div>

                        <button type="submit" class="btn btn-danger w-100 p-3">Đăng nhập</button>

                        <div class="text-center my-3">
                            <span>Hoặc đăng nhập bằng</span>
                        </div>

                        <div class="d-flex justify-content-center">
                            <a href="/Auth/LoginByGoogle" class="btn btn-light me-2">
                                <img src="/Upload/Logo/icons8-google-48.png" alt="Google" style="width: 20px; height: 20px;" class="me-1"> Google
                            </a>
                            <a href="/Auth/LoginByFacebook" class="btn btn-light">
                                <img src="/Upload/Logo/icons8-facebook-48.png" alt="Facebook" style="width: 20px; height: 20px;" class="me-1"> Facebook
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let loginTurnstileWidgetId = null;

        function onLoginTurnstileLoad() {
            if (!window.turnstile || loginTurnstileWidgetId !== null) {
                return;
            }

            loginTurnstileWidgetId = window.turnstile.render('#login-turnstile', {
                sitekey: '@Configuration["CloudflareTurnstile:SiteKey"]',
                theme: 'light'
            });
        }

        document.addEventListener("DOMContentLoaded", function () {
            const togglePassword = document.getElementById("togglePassword");
            const passwordInput = document.getElementById("passwordInput");
            const emailInput = document.querySelector('input[name="Email"]');
            const eyeIcon = document.getElementById("eyeIcon");

            if (togglePassword && passwordInput && eyeIcon) {
                togglePassword.addEventListener("click", function () {
                    const type = passwordInput.getAttribute("type") === "password" ? "text" : "password";
                    passwordInput.setAttribute("type", type);
                    eyeIcon.setAttribute("fill", type === "text" ? "green" : "currentColor");
                });
            }

            document.querySelectorAll(".demo-fill-account").forEach(function (button) {
                button.addEventListener("click", function () {
                    if (emailInput) {
                        emailInput.value = button.dataset.email || "";
                        emailInput.dispatchEvent(new Event("input", { bubbles: true }));
                    }

                    if (passwordInput) {
                        passwordInput.value = button.dataset.password || "";
                        passwordInput.dispatchEvent(new Event("input", { bubbles: true }));
                    }
                });
            });

        });
    </script>
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit&onload=onLoginTurnstileLoad" async defer></script>
</body>
</html>
