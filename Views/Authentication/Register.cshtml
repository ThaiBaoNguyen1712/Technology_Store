@{
    Layout = null;
}
@model Tech_Store.Models.DTO.Authentication.RegisterDTo
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng ký</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <style>
        body {
            background-color: #f8f9fa;
            min-height: 100vh;
            display: flex;
            align-items: center;
            padding: 40px 0;
        }

        .login-container {
            max-width: 400px;
            width: 100%;
            margin: auto;
        }

        .card {
            border: none;
            border-radius: 10px;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.1);
        }

        .logo {
            color: #ff0000;
            font-size: 2rem;
            font-weight: bold;
            text-align: center;
            margin-bottom: 1rem;
        }

        .form-label {
            font-weight: 500;
            color: #212529;
        }

        .btn-danger {
            padding: 0.8rem;
            font-weight: 500;
        }

        .captcha-container {
            background-color: #f8f9fa;
            border-radius: 6px;
            padding: 10px;
            display: flex;
            justify-content: center;
            overflow: hidden;
        }

        .turnstile-box {
            width: 100%;
            display: flex;
            justify-content: center;
        }

        @@media (max-width: 400px) {
            .turnstile-box {
                transform: scale(0.92);
                transform-origin: center;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="login-container">
            <div class="card d-flex" style="padding: 15px;">
                <div class="mx-auto" style="width: 90%;">
                    <div class="logo">Tech Store</div>
                    <h4 class="text-center mb-1">Đăng ký</h4>

                    <form method="post" id="register">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label">Email của bạn</label>
                            <input type="email" name="Email" class="form-control" placeholder="email@address.com" value="@Model?.Email" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Mật khẩu</label>
                            <div class="input-group">
                                <input type="password" class="form-control" name="Password" placeholder="Nhập mật khẩu" id="passwordInput1" required>
                                <button class="btn btn-outline-secondary" type="button" id="togglePassword1">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-eye" viewBox="0 0 16 16" id="eyeIcon1">
                                        <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M8 3.5a4.5 4.5 0 1 1 0 9 4.5 4.5 0 0 1 0-9" />
                                        <path d="M8 10a2 2 0 1 0 0-4 2 2 0 0 0 0 4" />
                                    </svg>
                                </button>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Nhập lại mật khẩu</label>
                            <div class="input-group">
                                <input type="password" class="form-control" name="ConfirmPassword" placeholder="Nhập lại mật khẩu" id="passwordInput2" required>
                                <button class="btn btn-outline-secondary" type="button" id="togglePassword2">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-eye" viewBox="0 0 16 16" id="eyeIcon2">
                                        <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M8 3.5a4.5 4.5 0 1 1 0 9 4.5 4.5 0 0 1 0-9" />
                                        <path d="M8 10a2 2 0 1 0 0-4 2 2 0 0 0 0 4" />
                                    </svg>
                                </button>
                            </div>
                        </div>

                        <div class="mb-3">
                            <span class="text-danger" id="ErrorMessage">@ViewBag.Error</span>
                        </div>

                        <div class="mb-3 captcha-container">
                            <div id="register-turnstile" class="turnstile-box"></div>
                        </div>

                        <button type="submit" class="btn btn-danger w-100 d-flex justify-content-center align-items-center">
                            Đăng ký
                            <div class="spinner-border text-light ms-2 loading" role="status" style="width: 1rem; height: 1rem; display: none;">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        let registerTurnstileWidgetId = null;

        function onRegisterTurnstileLoad() {
            if (!window.turnstile || registerTurnstileWidgetId !== null) {
                return;
            }

            registerTurnstileWidgetId = window.turnstile.render('#register-turnstile', {
                sitekey: '@Configuration["CloudflareTurnstile:SiteKey"]',
                theme: 'light'
            });
        }

        function resetRegisterTurnstile() {
            if (!window.turnstile || registerTurnstileWidgetId === null) {
                return;
            }

            window.turnstile.reset(registerTurnstileWidgetId);
        }

        document.addEventListener("DOMContentLoaded", function () {
            const togglePassword1 = document.getElementById("togglePassword1");
            const passwordInput1 = document.getElementById("passwordInput1");
            const eyeIcon1 = document.getElementById("eyeIcon1");
            const togglePassword2 = document.getElementById("togglePassword2");
            const passwordInput2 = document.getElementById("passwordInput2");
            const eyeIcon2 = document.getElementById("eyeIcon2");

            togglePassword1.addEventListener("click", function () {
                const type = passwordInput1.getAttribute("type") === "password" ? "text" : "password";
                passwordInput1.setAttribute("type", type);
                eyeIcon1.setAttribute("fill", type === "text" ? "green" : "currentColor");
            });

            togglePassword2.addEventListener("click", function () {
                const type = passwordInput2.getAttribute("type") === "password" ? "text" : "password";
                passwordInput2.setAttribute("type", type);
                eyeIcon2.setAttribute("fill", type === "text" ? "green" : "currentColor");
            });
        });

        $(document).ready(function () {
            $('#register').on('submit', function (event) {
                event.preventDefault();

                var formData = new FormData(this);
                $('.loading').show();

                $.ajax({
                    method: 'POST',
                    url: '@Url.Action("Register", "Authentication")',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function (response) {
                        if (response.success) {
                            $.ajax({
                                method: 'GET',
                                url: '@Url.Action("VerifyOTP", "Authentication")',
                                data: {
                                    Email: response.email,
                                    Action: response.action
                                },
                                success: function () {
                                    $('.loading').hide();
                                    window.location.href = '@Url.Action("VerifyOTP", "Authentication")?actionDirect=' + encodeURIComponent(response.action);
                                },
                                error: function () {
                                    $('.loading').hide();
                                    $('#ErrorMessage').text('Đã có lỗi xảy ra khi xác thực. Vui lòng thử lại.');
                                    resetRegisterTurnstile();
                                }
                            });
                        } else {
                            $('#ErrorMessage').text(response.message);
                            $('.loading').hide();
                            resetRegisterTurnstile();
                        }
                    },
                    error: function () {
                        $('#ErrorMessage').text('Đã có lỗi xảy ra. Vui lòng thử lại.');
                        $('.loading').hide();
                        resetRegisterTurnstile();
                    }
                });
            });
        });
    </script>
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit&onload=onRegisterTurnstileLoad" async defer></script>
</body>
</html>
