@{
    Layout = null;
}
@model Tech_Store.Models.DTO.Authentication.LoginDTo
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quên mật khẩu</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
            min-height: 100vh;
            display: flex;
            align-items: center;
            padding: 40px 0;
        }

        .auth-card {
            max-width: 400px;
            width: 100%;
            margin: auto;
            border: none;
            border-radius: 16px;
            box-shadow: 0 12px 32px rgba(15, 23, 42, 0.08);
        }

        .auth-body {
            padding: 28px 24px;
        }

        .auth-logo {
            color: #ff0000;
            font-size: 2rem;
            font-weight: 700;
            text-align: center;
            margin-bottom: 12px;
        }

        .auth-link {
            color: #ff0000;
            text-decoration: none;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="card auth-card">
            <div class="auth-body">
                <div class="auth-logo">Tech Store</div>
                <h4 class="text-center mb-2">Quên mật khẩu</h4>
                <p class="text-center text-muted mb-4">Nhập email để nhận mã xác thực.</p>

                <form method="post" id="forgotPasswordForm">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label">Email của bạn</label>
                        <input type="email" name="Email" class="form-control" placeholder="email@address.com" value="@Model?.Email" required>
                    </div>

                    <div class="mb-3">
                        <span class="text-danger small" id="ErrorMessage">@ViewData["ValidateMessage"]</span>
                    </div>

                    <div class="mb-3">
                        <a href="~/Auth/Login" class="auth-link">Quay lại đăng nhập</a>
                    </div>

                    <button type="submit" class="btn btn-danger w-100 d-flex justify-content-center align-items-center">
                        Tiếp tục
                        <span class="spinner-border spinner-border-sm text-light ms-2 d-none" id="forgotLoading" role="status"></span>
                    </button>
                </form>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $(function () {
            $('#forgotPasswordForm').on('submit', function (event) {
                event.preventDefault();

                const loading = $('#forgotLoading');
                const errorMessage = $('#ErrorMessage');

                errorMessage.text('');
                loading.removeClass('d-none');

                $.ajax({
                    method: 'POST',
                    url: '@Url.Action("ForgotPassword", "Authentication")',
                    data: {
                        Email: $('input[name="Email"]').val()
                    },
                    success: function (response) {
                        loading.addClass('d-none');

                        if (response.success) {
                            window.location.href = '@Url.Action("VerifyOTP", "Authentication")?actionDirect=' + encodeURIComponent(response.action);
                            return;
                        }

                        errorMessage.text(response.message || 'Không thể gửi mã xác thực lúc này.');
                    },
                    error: function (xhr) {
                        loading.addClass('d-none');
                        errorMessage.text(xhr.responseJSON?.message || 'Đã xảy ra lỗi. Vui lòng thử lại.');
                    }
                });
            });
        });
    </script>
</body>
</html>
