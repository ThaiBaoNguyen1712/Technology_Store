@model IEnumerable<Tech_Store.Models.ViewModel.OrderViewModelClient>
@using System.Globalization
@using Tech_Store.Helpers
@{
    ViewData["Title"] = "Đơn hàng của tôi";
    Layout = "~/Views/Shared/_Layout.cshtml";

    string GetStatusData(string status) => status switch
    {
        "Completed" => "completed",
        "Processing" => "processing",
        "Shipping" => "shipping",
        "Delivered" => "delivered",
        "Pending" => "pending",
        "Confirmed" => "confirmed",
        "Cancelled" => "cancelled",
        "Refunded" => "refunded",
        _ => "pending"
    };

    string GetStatusLabel(string status) => status switch
    {
        "Completed" => "Đã hoàn thành",
        "Processing" => "Đang xử lý",
        "Shipping" => "Đang giao hàng",
        "Delivered" => "Đã giao hàng",
        "Pending" => "Đang chờ xử lý",
        "Confirmed" => "Đã xác nhận",
        "Cancelled" => "Đã hủy",
        "Refunded" => "Đã hoàn tiền",
        _ => "Đang xử lý"
    };
}
<link rel="stylesheet" href="~/client/asset/css/ordersview.css" asp-append-version="true" />
<div class="orders-page">
    <div class="container">
        <div class="orders-shell">
            <div class="orders-hero">
                <div>
                    <h1>Theo dõi đơn hàng</h1>
                </div>
                <div class="orders-summary-chip">
                    <span>Tổng đơn hàng</span>
                    <strong>@ViewBag.OrderCount</strong>
                </div>
            </div>

            <div class="orders-filter-card animate-fade-in">
                <div class="orders-filter-grid">
                    <div>
                        <label for="statusFilter">Lọc theo trạng thái</label>
                        <select class="form-select" id="statusFilter">
                            <option value="all">Tất cả đơn hàng</option>
                            <option value="completed">Đã hoàn thành</option>
                            <option value="processing">Đang xử lý</option>
                            <option value="pending">Đang chờ xử lý</option>
                            <option value="confirmed">Đã xác nhận</option>
                            <option value="shipping">Đang giao hàng</option>
                            <option value="delivered">Đã giao hàng</option>
                            <option value="cancelled">Đã hủy</option>
                            <option value="refunded">Đã hoàn tiền</option>
                        </select>
                    </div>
                    <div class="orders-filter-meta">
                        Hiển thị <strong>@ViewBag.OrderCount</strong> đơn
                    </div>
                </div>
            </div>

            @if (!Model.Any())
            {
                <div class="orders-empty">
                    <i class="fas fa-box-open fa-2x mb-3"></i>
                    <div>Bạn chưa có đơn hàng nào.</div>
                </div>
            }
            else
            {
                <div class="orders-list">
                    @foreach (var item in Model)
                    {
                        var statusKey = GetStatusData(item.OrderStatus);
                        <div class="user-order-card animate-fade-in" data-status="@statusKey">
                            <div class="user-order-card__grid">
                                <div class="user-order-card__image">
                                    @if (string.IsNullOrWhiteSpace(item.ImageUrl))
                                    {
                                        <img src="/Upload/Products/default-image.png" alt="Product" class="user-order-thumb">
                                    }
                                    else if (item.ImageUrl.Contains("http"))
                                    {
                                        <img src="@ResizeCDN.Cdn(item.ImageUrl,358,358)" alt="Product" class="user-order-thumb">
                                    }
                                    else
                                    {
                                        <img src="/Upload/Products/@item.ImageUrl" alt="Product" class="user-order-thumb">
                                    }
                                </div>

                                <div class="user-order-card__meta">
                                    <div class="user-order-card__head">
                                        <div>
                                            <h2 class="user-order-card__code">Đơn hàng #@item.Id</h2>
                                            <div class="user-order-card__date">Đặt ngày @item.OrderDate.ToString("dd/MM/yyyy")</div>
                                        </div>
                                        <span class="order-status status-@statusKey">
                                            <span class="timeline-dot dot-@statusKey"></span>
                                            @GetStatusLabel(item.OrderStatus)
                                        </span>
                                    </div>

                                    <div class="user-order-card__stats">
                                        <div class="user-order-card__stat">
                                            <span class="user-order-card__stat-label">Tổng thanh toán</span>
                                            <span class="user-order-card__stat-value user-order-card__stat-value--price">@item.Amount.ToString("C0", new CultureInfo("vi-VN"))</span>
                                        </div>
                                        <div class="user-order-card__stat">
                                            <span class="user-order-card__stat-label">Trạng thái hiện tại</span>
                                            <span class="user-order-card__stat-value">@GetStatusLabel(item.OrderStatus)</span>
                                        </div>
                                    </div>
                                </div>

                                <div class="user-order-card__actions">
                                    <a class="orders-btn orders-btn--secondary" href="/user/MyOrders/OrderDetail/@item.Id">Xem chi tiết</a>
                                    @if (item.OrderStatus == "Completed" && !item.Is_Reviewed)
                                    {
                                        <button class="orders-btn orders-btn--primary review-btn"
                                                data-orderid="@item.Id"
                                                data-items='@Newtonsoft.Json.JsonConvert.SerializeObject(item.ReviewItems)'>
                                            <i class="fas fa-star"></i>
                                            <span>Đánh giá</span>
                                        </button>
                                    }
                                    @if (item.OrderStatus == "Pending")
                                    {
                                        <button class="orders-btn orders-btn--danger cancel-btn" data-orderid="@item.Id" id="cancelOrder-btn" data-bs-toggle="modal" data-bs-target="#cancelOrderModal">
                                            <span>Hủy đơn hàng</span>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="reviewModal" data-orderid="" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Đánh giá đơn hàng #<span id="OrderIdText"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="reviewItemsContainer" class="order-review-list"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="orders-btn orders-btn--secondary" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="orders-btn orders-btn--primary" id="submitReview">
                    <i class="fas fa-paper-plane me-2"></i>Gửi đánh giá
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="cancelOrderModal" tabindex="-1" aria-labelledby="cancelOrderModalLabel" data-OrderId ="" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="cancelOrderModalLabel">Hủy Đơn Hàng #<span id="OrderIdText-cancel"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-3">Vui lòng cho chúng tôi biết lý do bạn muốn hủy đơn hàng:</p>
                <form id="cancelOrderForm">
                    <div class="mb-3">
                        <label for="cancelReason" class="form-label">Lý do hủy:</label>
                        <select class="form-select" id="cancelReason" name="cancelReason" required>
                            <option value="" disabled selected>Chọn lý do</option>
                            <option value="Đổi ý, không muốn mua nữa">Đổi ý, không muốn mua nữa</option>
                            <option value="Tìm thấy giá rẻ hơn">Tìm thấy giá rẻ hơn</option>
                            <option value="Tôi muốn thay đổi nơi nhận hàng">Tôi muốn thay đổi nơi nhận hàng</option>
                            <option value="Khác">Khác</option>
                        </select>
                    </div>
                    <div class="mb-3" id="otherReasonContainer" style="display: none;">
                        <label for="otherReason" class="form-label">Lý do khác:</label>
                        <textarea class="form-control" id="otherReason" name="otherReason" rows="3" placeholder="Nhập lý do..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="orders-btn orders-btn--secondary" data-bs-dismiss="modal">Đóng</button>
                <button type="submit" class="orders-btn orders-btn--danger" form="cancelOrderForm">Xác nhận hủy</button>
            </div>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script>
    $(document).ready(function () {
        const notyf = new Notyf({
            position: {
                x: 'right',
                y: 'bottom'
            }
        });

        $('#statusFilter').change(function () {
            const status = $(this).val();
            $('.user-order-card').each(function () {
                $(this).removeClass('animate-fade-in');
                if (status === 'all' || $(this).data('status') === status) {
                    $(this).show().addClass('animate-fade-in');
                } else {
                    $(this).hide();
                }
            });
        });

        function getReviewImageUrl(imageUrl) {
            if (!imageUrl) {
                return '/Upload/Products/no-image.png';
            }

            if (imageUrl.indexOf('http') === 0) {
                return imageUrl;
            }

            return '/Upload/Products/' + imageUrl;
        }

        function updateStars($scope, rating) {
            $scope.find('i').each(function () {
                const starRating = $(this).data('rating');
                $(this).toggleClass('fas', starRating <= rating);
                $(this).toggleClass('far', starRating > rating);
            });
        }

        function bindReviewStarEvents() {
            $('#reviewItemsContainer .rating i').off('mouseenter mouseleave click');
            $('#reviewItemsContainer .rating').off('mouseleave');

            $('#reviewItemsContainer .rating i').on('mouseenter', function () {
                const $rating = $(this).closest('.rating');
                updateStars($rating, $(this).data('rating'));
            });

            $('#reviewItemsContainer .rating').on('mouseleave', function () {
                updateStars($(this), Number($(this).attr('data-selected-rating')) || 0);
            });

            $('#reviewItemsContainer .rating i').on('click', function () {
                const $rating = $(this).closest('.rating');
                const value = $(this).data('rating');
                $rating.attr('data-selected-rating', value);
                updateStars($rating, value);
            });
        }

        function renderReviewItems(items) {
            const container = $('#reviewItemsContainer');
            container.empty();

            (items || []).forEach(function (item) {
                const attributes = item.Attributes ? `<div class="order-review-item__meta">${item.Attributes}</div>` : '';
                container.append(`
                    <div class="order-review-item" data-variant-id="${item.VariantId}">
                        <div class="order-review-item__head">
                            <img src="${getReviewImageUrl(item.ImageUrl)}" alt="${item.ProductName}" class="order-review-item__image">
                            <div class="order-review-item__info">
                                <div class="order-review-item__name">${item.ProductName}</div>
                                ${attributes}
                            </div>
                        </div>
                        <div class="order-review-item__rating rating" data-selected-rating="0">
                            <i class="far fa-star text-warning" data-rating="1"></i>
                            <i class="far fa-star text-warning" data-rating="2"></i>
                            <i class="far fa-star text-warning" data-rating="3"></i>
                            <i class="far fa-star text-warning" data-rating="4"></i>
                            <i class="far fa-star text-warning" data-rating="5"></i>
                        </div>
                        <textarea class="form-control order-review-item__textarea" rows="3" placeholder="Chia sẻ trải nghiệm của bạn về sản phẩm này"></textarea>
                    </div>
                `);
            });

            bindReviewStarEvents();
        }

        $('.review-btn').click(function () {
            const items = $(this).data('items');
            const orderId = $(this).data('orderid');

            $('#reviewModal')
                .data('items', items)
                .attr('data-orderid', orderId);

            $('#OrderIdText').text(orderId);
            renderReviewItems(items || []);
            $('#reviewModal').modal('show');
        });

        $('.cancel-btn').click(function () {
            var orderId = $(this).data('orderid');
            $('#cancelOrderModal').attr('data-OrderId', orderId);
            $('#OrderIdText-cancel').text(orderId);
            $('#cancelOrderModal').modal('show');
        });

        $('#cancelOrderForm').on('submit', function (e) {
            e.preventDefault();
            var orderId = $('#cancelOrderModal').data('orderid');
            var reason = $('#cancelReason').val();
            var otherReason = $('#otherReason').val();

            if (reason === 'Khác') {
                reason = otherReason;
            }

            $.ajax({
                type: 'POST',
                url: '/User/CancelOrder',
                data: {
                    orderId: orderId,
                    reason: reason
                },
                success: function (response) {
                    if (response.success) {
                        notyf.success(response.message);
                        $('#cancelOrderModal').modal('hide');
                        location.reload();
                    } else {
                        notyf.error(response.message);
                    }
                },
                error: function () {
                    notyf.error('Đã xảy ra lỗi. Vui lòng thử lại.');
                }
            });
        });

        $('#submitReview').click(function () {
            var orderId = Number($('#reviewModal').attr('data-orderid'));
            var reviewItems = [];
            var hasInvalidItem = false;

            $('#reviewItemsContainer .order-review-item').each(function () {
                const variantId = Number($(this).data('variant-id'));
                const starPoint = Number($(this).find('.rating').attr('data-selected-rating')) || 0;
                const content = ($(this).find('.order-review-item__textarea').val() || '').trim();

                if (starPoint <= 0 || !content) {
                    hasInvalidItem = true;
                    return false;
                }

                reviewItems.push({
                    variantId: variantId,
                    starPoint: starPoint,
                    content: content
                });
            });

            if (hasInvalidItem || reviewItems.length === 0) {
                notyf.error('Vui lòng nhập đủ số sao và nhận xét cho từng sản phẩm.');
                return;
            }

            $.ajax({
                type: 'POST',
                url: '/user/SendReview',
                contentType: 'application/json; charset=utf-8',
                data: JSON.stringify({
                    orderId: orderId,
                    items: reviewItems
                }),
                success: function (response) {
                    if (!response.success) {
                        notyf.error(response.message || 'Không thể gửi đánh giá.');
                        return;
                    }

                    notyf.success(response.message || 'Đánh giá của bạn đã được gửi thành công!');
                    $('#reviewModal').modal('hide');
                    location.reload();
                },
                error: function (xhr) {
                    notyf.error(xhr.responseJSON?.message || 'Đã có lỗi xảy ra, vui lòng thử lại!');
                }
            });
        });

        $('#cancelReason').change(function () {
            if ($(this).val() === 'Khác') {
                $('#otherReasonContainer').show();
            } else {
                $('#otherReasonContainer').hide();
            }
        });
    });
</script>
