@using System.Globalization
@using Tech_Store.Helpers
@model Tech_Store.Models.ViewModel.OrderDetailVM

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";

    string statusKey = Model.OrderStatus switch
    {
        "Completed" => "completed",
        "Processing" => "processing",
        "Shipping" => "shipping",
        "Delivered" => "delivered",
        "Pending" => "pending",
        "Confirmed" => "confirmed",
        "Cancelled" => "cancelled",
        "Refunded" => "refunded",
        _ => "pending"
    };

    string statusLabel = Model.OrderStatus switch
    {
        "Completed" => "Đã hoàn thành",
        "Processing" => "Đang xử lý",
        "Shipping" => "Đang giao hàng",
        "Delivered" => "Đã giao hàng",
        "Pending" => "Đang chờ xử lý",
        "Confirmed" => "Đã xác nhận",
        "Cancelled" => "Đã hủy",
        "Refunded" => "Đã hoàn tiền",
        _ => "Đang xử lý"
    };

    string paymentLabel = Model.PaymentMethod switch
    {
        "COD" => "Thanh toán khi nhận hàng (COD)",
        "MoMo" => "Thanh toán qua ví MoMo",
        "VNPay" => "Thanh toán qua VNPay",
        "cash" => "Thanh toán tiền mặt",
        _ => "Không xác định"
    };
    if (Model.PaymentMethod == "SePay")
    {
        paymentLabel = "Thanh toán qua SePay";
    }
    paymentLabel = PaymentDisplayHelper.GetLabel(Model.PaymentMethod);
    var paymentLogoUrl = PaymentDisplayHelper.GetLogoUrl(Model.PaymentMethod);
}

<link rel="stylesheet" href="~/client/asset/css/ordersview.css" asp-append-version="true" />

<div class="orders-detail-page">
    <div class="container">
        <div class="orders-shell">
            <a href="/User/MyOrders" class="orders-detail-back">
                <i class="fas fa-arrow-left"></i>
                <span>Quay lại danh sách đơn hàng</span>
            </a>

            <div class="orders-detail-hero">
                <div>
                    <h1>Chi tiết đơn hàng #@Model.OrderId</h1>
                    <div class="orders-detail-hero__meta">Theo dõi tiến độ xử lý, danh sách sản phẩm và tổng thanh toán của đơn hàng này.</div>
                </div>
                <span class="order-status status-@statusKey">
                    <span class="timeline-dot dot-@statusKey"></span>
                    @statusLabel
                </span>
            </div>

            @if (Model.OrderStatus != "Cancelled" && Model.OrderStatus != "Refunded")
            {
                <div class="order-detail-card mb-3">
                    <div class="order-detail-card__header">
                        <h5>Tiến trình đơn hàng</h5>
                    </div>
                    <div class="order-detail-card__body">
                        <div class="order-progress">
                            <div class="step @(Model.OrderStatus == "Pending" || Model.OrderStatus == "Confirmed" || Model.OrderStatus == "Shipping" || Model.OrderStatus == "Delivered" || Model.OrderStatus == "Completed" ? "completed" : "active")">
                                <div class="step-icon"><i class="fas fa-check"></i></div>
                                <div class="step-label">Đã đặt hàng</div>
                            </div>
                            <div class="step @(Model.OrderStatus == "Confirmed" || Model.OrderStatus == "Shipping" || Model.OrderStatus == "Delivered" || Model.OrderStatus == "Completed" ? "completed active" : "")">
                                <div class="step-icon"><i class="fas fa-clipboard-check"></i></div>
                                <div class="step-label">Đã xác nhận</div>
                            </div>
                            <div class="step @(Model.OrderStatus == "Shipping" || Model.OrderStatus == "Delivered" || Model.OrderStatus == "Completed" ? "completed active" : "")">
                                <div class="step-icon"><i class="fas fa-truck"></i></div>
                                <div class="step-label">Đang giao hàng</div>
                            </div>
                            <div class="step @(Model.OrderStatus == "Delivered" || Model.OrderStatus == "Completed" ? "completed active" : "")">
                                <div class="step-icon"><i class="fas fa-box-open"></i></div>
                                <div class="step-label">Đã giao hàng</div>
                            </div>
                            <div class="step @(Model.OrderStatus == "Completed" ? "completed" : Model.OrderStatus == "Delivered" ? "active" : "")">
                                <div class="step-icon"><i class="fas fa-check-circle"></i></div>
                                <div class="step-label">Hoàn tất</div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="orders-detail-grid">
                <div>
                    <div class="order-detail-card">
                        <div class="order-detail-card__header">
                            <h5>Sản phẩm đã đặt</h5>
                        </div>
                        <div class="order-detail-card__body">
                            @foreach (var item in Model.ListVarientProduct)
                            {
                                <div class="order-line-item">
                                    <div class="order-line-item__image">
                                        @if (!string.IsNullOrWhiteSpace(item.ImageUrl) && item.ImageUrl.Contains("http"))
                                        {
                                            <img src="@ResizeCDN.Cdn(item.ImageUrl)" alt="@item.NameProduct">
                                        }
                                        else if (string.IsNullOrWhiteSpace(item.ImageUrl))
                                        {
                                            <img src="/Upload/Products/no-image.png" alt="@item.NameProduct">
                                        }
                                        else
                                        {
                                            <img src="/Upload/Products/@item.ImageUrl" alt="@item.NameProduct">
                                        }
                                    </div>

                                    <div class="order-line-item__body">
                                        <h6 class="order-line-item__title">
                                            <a href="/View/@item.Slug">@item.NameProduct</a>
                                        </h6>
                                        <div class="order-line-item__meta">@item.Attributes</div>
                                    </div>

                                    <div class="order-line-item__price">
                                        <strong>@item.Price</strong>
                                        <span>Số lượng x @item.Quantity</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <aside>
                    <div class="order-detail-sidebar-card mb-3">
                        <div class="order-detail-sidebar-card__header">
                            <h5>Tổng quan đơn hàng</h5>
                        </div>
                        <div class="order-detail-sidebar-card__body">
                            <div class="order-summary-list">
                                <div class="order-summary-row">
                                    <span>Tổng tiền hàng</span>
                                    <strong>@Model.OriginTotalPrice.ToString("C0", new CultureInfo("vi-VN"))</strong>
                                </div>
                                <div class="order-summary-row">
                                    <span>Phí vận chuyển</span>
                                    <strong>@(string.IsNullOrWhiteSpace(Model.ShippingPrice) ? "0 đ" : Model.ShippingPrice)</strong>
                                </div>
                                <div class="order-summary-row">
                                    <span>Giảm giá</span>
                                    <strong class="text-danger">@(string.IsNullOrWhiteSpace(Model.DiscountPrice) ? "0 đ" : Model.DiscountPrice)</strong>
                                </div>
                                <div class="order-summary-row order-summary-row--total">
                                    <strong>Tổng thanh toán</strong>
                                    <strong>@Model.TotalPrice</strong>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="order-detail-sidebar-card mb-3">
                        <div class="order-detail-sidebar-card__header">
                            <h5>Thông tin giao hàng</h5>
                        </div>
                        <div class="order-detail-sidebar-card__body">
                            <div class="order-contact-block">
                                <strong>@Model.User.FullName</strong>
                                <span>@Model.User.PhoneNumber</span>
                                <span>@Model.User.Address</span>
                            </div>
                        </div>
                    </div>

                    <div class="order-detail-sidebar-card">
                        <div class="order-detail-sidebar-card__header">
                            <h5>Phương thức thanh toán</h5>
                        </div>
                        <div class="order-detail-sidebar-card__body">
                            <div class="payment-method">
                                <div class="payment-method__icon">
                                    @if (!string.IsNullOrWhiteSpace(paymentLogoUrl))
                                    {
                                        <img src="@paymentLogoUrl" alt="@Model.PaymentMethod" />
                                    }
                                    else if (Model.PaymentMethod == "cash")
                                    {
                                        <i class="fas fa-money-bill-wave"></i>
                                    }
                                    else
                                    {
                                        <i class="fas fa-wallet"></i>
                                    }
                                </div>
                                <div class="payment-method__text">@paymentLabel</div>
                            </div>
                        </div>
                    </div>
                </aside>
            </div>
        </div>
    </div>
</div>
