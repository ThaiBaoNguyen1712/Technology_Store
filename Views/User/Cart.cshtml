@model Tech_Store.Models.Cart
@{
    ViewData["Title"] = "Giỏ hàng của tôi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@using System.Globalization
@using Tech_Store.Helpers
<section class="client-list-page client-list-page--cart">
    <div class="container">
        <div class="client-list-page__header">
            <div>
                <span class="client-list-page__eyebrow">Tech Store</span>
                <h1>Giỏ hàng của tôi</h1>
            </div>
            <a href="~/" class="client-list-page__back-link">
                <i class="fa fa-arrow-left"></i>
                Tiếp tục mua sắm
            </a>
        </div>

        <div class="client-list-page__content">
        @if (Model != null && Model.CartItems != null && Model.CartItems.Any())
        {
            <div class="client-list-toolbar">
                <div>
                    <strong>@Model.CartItems.Count</strong>
                    <span>sản phẩm trong giỏ hàng</span>
                </div>
                <div class="form-check m-0">
                    <input class="form-check-input" type="checkbox" id="selectAll">
                    <label class="form-check-label ms-2" for="selectAll">
                        Chọn tất cả
                    </label>
                </div>
            </div>


            <div id="cartItemsContainer">
                @foreach (var item in Model.CartItems)
                {
                    <article class="client-list-card cart-item" data-item-id="@item.VarientProductId">
                        <div class="client-list-card__select">
                            <input type="checkbox" class="form-check-input product-checkbox"
                                   data-price="@item.VarientProduct.Price"
                                   data-VarientId="@item.VarientProduct.VarientId"
                                   data-productId="@item.ProductId">
                        </div>

                        <div class="client-list-card__image">
                            @if(item.VarientProduct.ImageUrl == null)
                            {
                                <img src="/Upload/Products/no-image.png"
                                     alt="No Image">
                            }
                            else if(item.VarientProduct.ImageUrl.Contains("http"))
                            {
                                <img src="@ResizeCDN.Cdn(item.VarientProduct.ImageUrl, 358,358)"
                                     alt="Product Image">
                            }
                            else
                            {
                                <img src="/Upload/Products/@item.VarientProduct.ImageUrl"
                                     alt="Product Image">
                            }
                        </div>

                        <div class="client-list-card__body">
                            <input type="hidden" name="ProductId" value="@item.ProductId"/>
                            <h2 class="client-list-card__title">@item.Product.Name</h2>
                            @if (!string.IsNullOrWhiteSpace(item.VarientProduct.Attributes))
                            {
                                <p class="client-list-card__meta">@item.VarientProduct.Attributes</p>
                            }
                        </div>

                        <div class="client-list-card__actions">
                            <div class="client-list-card__price">
                                @((item.VarientProduct.Price ?? 0).ToString("C0", new CultureInfo("vi-VN")))
                            </div>
                            <div class="client-list-card__control-row">
                                <div class="input-group input-group-sm qty-control">
                                    <button class="btn btn-outline-secondary minus-btn" type="button">-</button>
                                    <input type="number" class="form-control text-center qty-input"
                                           value="@item.Quantity" min="1" data-price="@item.VarientProduct.Price">
                                    <button class="btn btn-outline-secondary plus-btn" type="button">+</button>
                                </div>
                                <button class="btn client-list-card__delete delete-item" type="button" data-item-id="@item.ProductId" aria-label="Xóa sản phẩm">
                                    <i class="fa fa-trash"></i>
                                </button>
                            </div>
                        </div>
                    </article>
                }
            </div>

            <div class="client-checkout-bar" id="checkout-form">
                <div>
                    <span>Tổng giá tạm tính</span>
                    <strong id="subtotal">0₫</strong>
                </div>
                <button type="button" id="PayBtn" class="btn btn-danger">
                    Thanh toán
                    <i class="fa fa-arrow-right"></i>
                </button>
            </div>

        }
        else
        {
            <div class="client-empty-state">
                <div class="client-empty-state__icon">
                    <i class="fa fa-shopping-cart"></i>
                </div>
                <h2>Giỏ hàng đang trống</h2>
                <p>Thêm sản phẩm yêu thích vào giỏ để bắt đầu thanh toán nhanh hơn.</p>
                <a href="~/" class="btn btn-danger">Khám phá sản phẩm</a>
            </div>
        }
        </div>
    </div>
</section>
<section class="products">
    <div class="container">
        <div class="product-section">
            <div class="client-recommendation-head">
                <h3 class="text-dark mb-0">Gợi ý cho bạn</h3>
            </div>

            <button class="btn-scroll btn-prev" data-target="suggestion">
                <i class="fa fa-chevron-left"></i>
            </button>
            <button class="btn-scroll btn-next" data-target="suggestion">
                <i class="fa fa-chevron-right"></i>
            </button>

            <div class="scrolling-wrapper" data-wrapper="suggestion">
                <div id="recommendation-container" class="row pt-2 mx-auto">
                    <div class="text-center w-100 py-5">
                        <div class="spinner-border text-danger" role="status"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function () {

        RecommendationManager.init('cart', 10);

        // Chọn tất cả sản phẩm
        $("#selectAll").change(function () {
            $(".product-checkbox").prop('checked', $(this).prop('checked'));
            calculateSubtotal();
        });

        // Sự kiện checkbox riêng lẻ
        $(document).on('change', '.product-checkbox', calculateSubtotal);

        // Sự kiện thay đổi số lượng
        $(document).on('input', '.qty-input', calculateSubtotal);

        // Xử lý nút xóa
        $(document).on('click', '.delete-item', function () {
            const itemId = $(this).data('item-id');
            const cartItem = $(this).closest('.cart-item');

            $.ajax({
                url: '@Url.Action("DeleteCartItem", "User")',
                type: 'POST',
                data: { itemId: itemId },
                success: function (response) {
                    if (response.success) {
                        let currentCartNumb = parseInt($('#Cart_numb').text()) || 0; // Nếu không có giá trị, gán mặc định là 0
                        $('#Cart_numb').text(currentCartNumb - 1);
                        cartItem.fadeOut(300, function () {
                            $(this).remove();
                            if ($('.cart-item').length === 0) {
                                $('#checkout-form').addClass('d-none');
                                $('#cartItemsContainer').html(
                                    '<div class="client-empty-state">' +
                                    '<div class="client-empty-state__icon"><i class="fa fa-shopping-cart"></i></div>' +
                                    '<h2>Giỏ hàng đang trống</h2>' +
                                    '<p>Thêm sản phẩm yêu thích vào giỏ để bắt đầu thanh toán nhanh hơn.</p>' +
                                    '<a href="/" class="btn btn-danger">Khám phá sản phẩm</a>' +
                                    '</div>'
                                );
                            }
                            calculateSubtotal();
                        });
                    }
                },
                error: function () {
                    console.error('Lỗi khi xóa sản phẩm');
                }
            });
        });

        // Nút giảm số lượng
        $(document).on('click', '.minus-btn', function () {
            const input = $(this).siblings('.qty-input');
            const currentValue = parseInt(input.val()) || 1;
            if (currentValue > 1) {
                input.val(currentValue - 1);
                calculateSubtotal();
            }
        });

        // Nút tăng số lượng
        $(document).on('click', '.plus-btn', function () {
            const input = $(this).siblings('.qty-input');
            const currentValue = parseInt(input.val()) || 1;
            input.val(currentValue + 1);
            calculateSubtotal();
        });

        // Tính tổng giá
        function calculateSubtotal() {
            let subtotal = 0;
            $('.product-checkbox:checked').each(function () {
                const row = $(this).closest('.cart-item');
                const price = parseFloat($(this).data('price')) || 0;
                const quantity = parseInt(row.find('.qty-input').val()) || 1;
                subtotal += price * quantity;
            });
            $('#subtotal').text(new Intl.NumberFormat('vi-VN', {
                style: 'currency',
                currency: 'VND'
            }).format(subtotal));
        }

        // Khởi tạo tổng giá ban đầu khi trang được tải lại
        calculateSubtotal();
    });

</script>
<script>
    $(document).ready(function () {
        const notyf = new Notyf({
            position: {
                x: 'right', // Căn phải
                y: 'top'    // Căn trên
            }
        });

        $('#PayBtn').on('click', function () {
            var cartItems = [];
        
            $('#cartItemsContainer .cart-item').each(function () {
                var item = $(this);

                // Lấy các giá trị cần thiết từ các thuộc tính của phần tử
                var varientId = item.find('.product-checkbox').data('varientid');
                var productId = item.find('input[name="ProductId"]').val();
                var quantity = item.find('.qty-input').val();
                var isChecked = item.find('.product-checkbox').prop('checked');  

                // Chỉ thêm sản phẩm vào mảng nếu checkbox được chọn
                if (isChecked) {
                    cartItems.push({
                        VarientProductId: varientId,
                        ProductId: productId,
                        Quantity: quantity
                    });
                }

            });
            if (cartItems.length === 0) {
                notyf.error("Vui lòng chọn ít nhất 1 sản phẩm trước khi đến thanh toán");
                return;
            }
            $.ajax({
                method: 'POST',
                url: '@Url.Action("ToCheckout", "User")',
                contentType: 'application/json', // Đặt Content-Type cho JSON
                data: JSON.stringify({ cartDTos: cartItems }), // Chuyển đổi mảng thành chuỗi JSON
                dataType: 'json',
                success: function (response) {
                    $('.loading-container').hide();

                    if (response.success) {
                        window.location.href = response.redirectUrl; // Chuyển hướng đến trang thanh toán
                    } else {
                        notyf.error(response.message); // Hiển thị lỗi từ server
                        var additionalInfoUserModal = new bootstrap.Modal(document.getElementById('infoRequiredModal'));
                        additionalInfoUserModal.show();
                    }
                },
                error: function () {
                    $('.loading-container').hide();
                    var loginModal = new bootstrap.Modal(document.getElementById('loginRequiredModal'));
                    loginModal.show();
                }
            });
        });
    });
</script>

