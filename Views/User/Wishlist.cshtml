@{
    ViewData["Title"] = "Yêu thích của tôi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@model IEnumerable<Tech_Store.Models.ViewModel.WishlistVM>
@using System.Globalization
@using Tech_Store.Helpers
<section class="client-list-page client-list-page--wishlist">
    <div class="container">
        <div class="client-list-page__header">
            <div>
                <span class="client-list-page__eyebrow">Tech Store</span>
                <h1>Danh sách yêu thích</h1>
            </div>
            <a href="~/" class="client-list-page__back-link">
                <i class="fa fa-arrow-left"></i>
                Tiếp tục mua sắm
            </a>
        </div>

        <div class="client-list-page__content">
            @if (Model != null && Model.Any())
            {
                <div class="client-list-toolbar">
                    <div>
                        <strong>@Model.Count()</strong>
                        <span>sản phẩm đã lưu</span>
                    </div>
                </div>

                <div id="cartItemsContainer">
                    @foreach (var item in Model)
                    {
                        <article class="client-list-card client-list-card--wishlist" data-item-id="@item.ProductId">
                            <div class="client-list-card__image product-link" data-slug="@item.Slug">
                                @if (item.ImageUrl == null)
                                {
                                    <img src="/Upload/Products/no-image.png"
                                         alt="No Image Available">
                                }
                                else if(item.ImageUrl.Contains("http"))
                                {
                                    <img src="@ResizeCDN.Cdn(item.ImageUrl,358,358)"
                                         alt="@item.ProductName">
                                }
                                else
                                {
                                    <img src="/Upload/Products/@item.ImageUrl"
                                         alt="@item.ProductName">
                                }
                            </div>

                            <div class="client-list-card__body product-link" data-slug="@item.Slug">
                                <input type="hidden" name="ProductId" value="@item.ProductId" />
                                <h2 class="client-list-card__title">@item.ProductName</h2>
                                <p class="client-list-card__meta">
                                    <i class="fa fa-heart"></i>
                                    Đã thêm vào @item.CreatedAt.ToString("dd/MM/yyyy")
                                </p>
                            </div>

                            <div class="client-list-card__actions">
                                <div class="client-list-card__price">@item.Price</div>
                                <div class="client-list-card__control-row">
                                    <button class="btn btn-outline-danger btn-sm delete-item"
                                            type="button"
                                            data-id="@item.ProductId"
                                            onclick="event.stopPropagation();">
                                        <i class="fa fa-trash"></i>
                                        Xóa
                                    </button>
                                </div>
                            </div>
                        </article>
                    }
                </div>

              
            }

            else
            {
                <div class="client-empty-state">
                    <div class="client-empty-state__icon">
                        <i class="fa fa-heart"></i>
                    </div>
                    <h2>Danh sách yêu thích đang trống</h2>
                    <p>Lưu lại những sản phẩm bạn quan tâm để so sánh và mua sau.</p>
                    <a href="~/" class="btn btn-danger">Khám phá sản phẩm</a>
                </div>
            }
        </div>
    </div>
</section>

    <section class="products">
        <div class="container">
            <div class="product-section">
                <div class="client-recommendation-head">
                    <h3 class="text-dark mb-0">Gợi ý cho bạn</h3>
                </div>

                <button class="btn-scroll btn-prev" data-target="suggestion">
                    <i class="fa fa-chevron-left"></i>
                </button>
                <button class="btn-scroll btn-next" data-target="suggestion">
                    <i class="fa fa-chevron-right"></i>
                </button>

                <div class="scrolling-wrapper" data-wrapper="suggestion">
                    <div id="recommendation-container" class="row pt-2 mx-auto">
                        <div class="text-center w-100 py-5">
                            <div class="spinner-border text-danger" role="status"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script type="text/javascript">
    $(document).ready(function () {

        RecommendationManager.init('wishlist', 10);

        const notyf = new Notyf({
            position: {
                x: 'right', // Căn phải
                y: 'top'    // Căn trên
            }
        });

        $('.delete-item').on('click', function () {
            var id = $(this).data('id');
            // Hiển thị hộp thoại xác nhận
            var confirmation = confirm('Bạn có chắc chắn muốn xóa sản phẩm này khỏi danh sách yêu thích?');

            if (confirmation) {
                $.ajax({
                    method: 'POST',
                    url: '@Url.Action("RemoveItemFromWishlist", "User")',
                    data: { productId: id },
                    success: function (response) {
                        if (response.success) {
                            notyf.success(response.message); // Thông báo thành công
                            location.reload();
                        } else {
                            notyf.error(response.message); // Thông báo lỗi
                        }
                    },
                    error: function (response) {
                        notyf.error('Có lỗi xảy ra, vui lòng thử lại.');
                    }
                });
            } else {
                // Nếu người dùng hủy bỏ
                notyf.error('Đã hủy bỏ hành động xóa sản phẩm.');
            }
        });
    });

</script>
