@model Tech_Store.Models.DTO.UserDTo
@{
    ViewData["Title"] = "Thông tin tài khoản";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var avatarUrl = string.IsNullOrWhiteSpace(Model?.ImageUrl) ? Url.Content("~/Upload/Avatar/none.png") : Url.Content($"~/Upload/Avatar/{Model.ImageUrl}");
}

<section class="account-shell user-information-page user-information-page--simple">
    <div class="container">
        <div class="account-page-header">
            <h1 class="account-page-header__title mb-1">Thông tin tài khoản</h1>
            <p class="account-page-header__subtitle mb-0">Cập nhật thông tin cá nhân, địa chỉ và mật khẩu của bạn.</p>
        </div>

        <div class="account-layout">
            <aside class="account-sidebar">
                <div class="account-profile-card">
                    <div class="account-profile-card__top">
                        <img src="@avatarUrl" alt="Ảnh đại diện" id="avatarPreview" class="account-profile-card__avatar" />
                        <div class="account-profile-card__meta">
                            <strong>@($"{Model?.LastName} {Model?.FirstName}".Trim())</strong>
                            <span>@Model?.Email</span>
                            @if (!string.IsNullOrWhiteSpace(Model?.PhoneNumber))
                            {
                                <span>@Model.PhoneNumber</span>
                            }
                        </div>
                    </div>

                </div>

                <nav class="account-nav" id="profileTabs" aria-label="Điều hướng tài khoản">
                    <button type="button" class="account-nav__item active" data-account-tab="info">
                        <i class="fa fa-user"></i>
                        <span>Thông tin cá nhân</span>
                    </button>
                    <button type="button" class="account-nav__item" data-account-tab="address">
                        <i class="fa fa-location-dot"></i>
                        <span>Địa chỉ nhận hàng</span>
                    </button>
                    <button type="button" class="account-nav__item" data-account-tab="password">
                        <i class="fa fa-lock"></i>
                        <span>Đổi mật khẩu</span>
                    </button>
                </nav>
            </aside>

            <div class="account-content">
                <section class="account-panel active" id="panel-info" data-account-panel="info">
                    <div class="account-panel__header">
                        <div>
                            <h2>Thông tin cá nhân</h2>
                            <p>Giữ thông tin của bạn luôn chính xác để đặt hàng nhanh hơn.</p>
                        </div>
                    </div>

                    <form id="personalInfoForm" class="account-form" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div class="account-avatar-editor">
                            <img src="@avatarUrl" alt="Ảnh đại diện" class="account-avatar-editor__preview" id="avatarPreviewCard" />
                            <div class="account-avatar-editor__content">
                                <label for="avatarInput" class="account-upload__label">Chọn ảnh đại diện</label>
                                <input type="file" class="form-control account-upload__input" id="avatarInput" name="ImageAvatar" accept="image/*" />
                                <small>Định dạng hỗ trợ: `.jpg`, `.jpeg`, `.png`.</small>
                            </div>
                        </div>

                        <div class="account-form__grid">
                            <div class="account-field">
                                <label for="LastName">Họ và tên đệm</label>
                                <input id="LastName" type="text" class="form-control" name="LastName" value="@Model?.LastName" required>
                            </div>
                            <div class="account-field">
                                <label for="FirstName">Tên</label>
                                <input id="FirstName" type="text" class="form-control" name="FirstName" value="@Model?.FirstName" required>
                            </div>
                            <div class="account-field">
                                <label for="Email">Email</label>
                                <input id="Email" type="email" class="form-control" name="Email" value="@Model?.Email" required>
                            </div>
                            <div class="account-field">
                                <label for="PhoneNumber">Số điện thoại</label>
                                <input id="PhoneNumber" type="tel" class="form-control" name="PhoneNumber" value="@Model?.PhoneNumber">
                            </div>
                        </div>

                        <p class="account-form__result" id="resultChangePersonalInfo"></p>

                        <div class="account-form__actions">
                            <button type="submit" class="btn btn-danger account-primary-btn">
                                <i class="fa fa-save me-2"></i>Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </section>

                <section class="account-panel" id="panel-address" data-account-panel="address">
                    <div class="account-panel__header">
                        <div>
                            <h2>Địa chỉ nhận hàng</h2>
                        </div>
                    </div>

                    <div class="account-address-card">
                        @if (ViewBag.Address_User != null)
                        {
                            <div id="addressLoad" class="account-address-card__summary">
                                <div>
                                    <div class="account-section-title">Địa chỉ hiện tại</div>
                                    <p class="mb-0">@ViewBag.Address_User</p>
                                </div>
                                <button type="button" id="showAddressForm" class="btn btn-outline-danger account-outline-btn">Thay đổi địa chỉ</button>
                            </div>
                        }

                        <form id="addressForm" class="account-form @(ViewBag.Address_User != null ? "d-none" : string.Empty)">
                            @Html.AntiForgeryToken()
                            <div class="account-field">
                                <label for="AddressLine">Số nhà, tên đường</label>
                                <input id="AddressLine" type="text" class="form-control" name="AddressLine" value="@Model?.AddressLine" required>
                            </div>

                            <div class="account-form__grid account-form__grid--triple">
                                <div class="account-field">
                                    <label for="citySelect">Tỉnh/Thành phố</label>
                                    <select id="citySelect" class="form-control selectpicker" name="Province" value="@Model?.Province" data-live-search="true" title="Chọn Tỉnh/Thành phố" required></select>
                                </div>
                                <div class="account-field">
                                    <label for="districtSelect">Quận/Huyện</label>
                                    <select id="districtSelect" class="form-control selectpicker" name="District" value="@Model?.District" data-live-search="true" title="Chọn Quận/Huyện" required></select>
                                </div>
                                <div class="account-field">
                                    <label for="wardSelect">Phường/Xã</label>
                                    <select id="wardSelect" class="form-control selectpicker" name="Ward" value="@Model?.Ward" data-live-search="true" title="Chọn Phường/Xã" required></select>
                                </div>
                            </div>

                            <p class="account-form__result" id="resultChangeAddress"></p>

                            <div class="account-form__actions">
                                <button type="submit" class="btn btn-danger account-primary-btn">
                                    <i class="fa fa-save me-2"></i>Lưu địa chỉ
                                </button>
                            </div>
                        </form>
                    </div>
                </section>

                <section class="account-panel" id="panel-password" data-account-panel="password">
                    <div class="account-panel__header">
                        <div>
                            <h2>Đổi mật khẩu</h2>
                        </div>
                    </div>

                    <form id="passwordForm" class="account-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Email" value="@Model?.Email" />

                        <div class="account-field">
                            <label for="OldPassword">Mật khẩu hiện tại</label>
                            <input id="OldPassword" type="password" name="OldPassword" placeholder="Nhập mật khẩu hiện tại" class="form-control" required minlength="8">
                        </div>
                        <div class="account-field">
                            <label for="Password">Mật khẩu mới</label>
                            <input id="Password" type="password" name="Password" class="form-control" placeholder="Nhập mật khẩu mới" required minlength="8">
                        </div>
                        <div class="account-field">
                            <label for="ConfirmPassword">Xác nhận mật khẩu mới</label>
                            <input id="ConfirmPassword" type="password" name="ConfirmPassword" placeholder="Nhập lại mật khẩu mới" class="form-control" required minlength="8">
                        </div>

                        <p class="account-form__result" id="resultChangePassword"></p>

                        <div class="account-form__actions">
                            <button type="submit" class="btn btn-danger account-primary-btn">
                                <i class="fa fa-key me-2"></i>Cập nhật mật khẩu
                            </button>
                        </div>
                    </form>
                </section>
            </div>
        </div>
    </div>
</section>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/js/provincevn.js"></script>
<script>
    $(document).ready(function () {
        function setResult($el, success, message) {
            $el.removeClass('text-success text-danger')
                .addClass(success ? 'text-success' : 'text-danger')
                .text(message || '');
        }

        function switchTab(tabName) {
            $('[data-account-tab]').removeClass('active');
            $('[data-account-panel]').removeClass('active');
            $('[data-account-tab="' + tabName + '"]').addClass('active');
            $('[data-account-panel="' + tabName + '"]').addClass('active');
        }

        $('[data-account-tab]').on('click', function () {
            switchTab($(this).data('account-tab'));
        });

        $('[data-account-tab-target]').on('click', function (event) {
            event.preventDefault();
            switchTab($(this).data('account-tab-target'));
            const targetId = $(this).attr('href');
            if (targetId) {
                document.querySelector(targetId)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        });

        $('#avatarInput').on('change', function (e) {
            const file = e.target.files && e.target.files[0];
            if (!file) {
                return;
            }

            const reader = new FileReader();
            reader.onload = function (event) {
                $('#avatarPreview, #avatarPreviewCard').attr('src', event.target.result);
            };
            reader.readAsDataURL(file);
        });

        $('#passwordForm').on('submit', function (event) {
            event.preventDefault();
            $('.loading-container').show();

            const formData = new FormData(this);

            $.ajax({
                method: 'POST',
                url: '@Url.Action("ChangePassword2", "Authentication")',
                data: formData,
                contentType: false,
                processData: false,
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').first().val()
                },
                success: function (response) {
                    setResult($('#resultChangePassword'), response.success, response.message);
                    if (response.success) {
                        $('#passwordForm')[0].reset();
                    }
                    $('.loading-container').hide();
                },
                error: function () {
                    setResult($('#resultChangePassword'), false, 'Có lỗi xảy ra. Vui lòng thử lại.');
                    $('.loading-container').hide();
                }
            });
        });

        $('#showAddressForm').on('click', function () {
            $('#addressForm').removeClass('d-none');
            $('#addressLoad').addClass('d-none');
        });

        $('#addressForm').on('submit', function (event) {
            event.preventDefault();
            $('.loading-container').show();

            $.ajax({
                method: 'POST',
                url: '@Url.Action("ChangeAddress", "User")',
                headers: {
                    'RequestVerificationToken': $(this).find('input[name="__RequestVerificationToken"]').val()
                },
                data: {
                    addressLine: $('input[name="AddressLine"]').val(),
                    ward: $('select[name="Ward"]').val(),
                    district: $('select[name="District"]').val(),
                    province: $('select[name="Province"]').val()
                },
                success: function (response) {
                    setResult($('#resultChangeAddress'), response.success, response.message);
                    $('.loading-container').hide();
                },
                error: function () {
                    setResult($('#resultChangeAddress'), false, 'Có lỗi xảy ra. Vui lòng thử lại.');
                    $('.loading-container').hide();
                }
            });
        });

        $('#personalInfoForm').on('submit', function (event) {
            event.preventDefault();
            $('.loading-container').show();

            const formData = new FormData(this);

            $.ajax({
                method: 'POST',
                url: '@Url.Action("ChangePersonalInfo", "User")',
                headers: {
                    'RequestVerificationToken': $(this).find('input[name="__RequestVerificationToken"]').val()
                },
                data: formData,
                contentType: false,
                processData: false,
                success: function (response) {
                    setResult($('#resultChangePersonalInfo'), response.success, response.message);
                    $('.loading-container').hide();
                },
                error: function () {
                    setResult($('#resultChangePersonalInfo'), false, 'Có lỗi xảy ra. Vui lòng thử lại.');
                    $('.loading-container').hide();
                }
            });
        });
    });
</script>
