@{
    ViewData["Title"] = "Thanh toán thất bại";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="client-status-page">
    <div class="container">
        <div class="client-status-card client-status-card--danger">
            <div class="client-status-card__icon">
                <i class="fas fa-times"></i>
            </div>
            <p class="client-status-card__eyebrow">Thanh toán chưa thành công</p>
            <h1 class="client-status-card__title">Bạn chưa hoàn tất thanh toán</h1>
            <p class="client-status-card__message">@(TempData["Message"]?.ToString() ?? "Thanh toán chưa được ghi nhận. Bạn có thể thử lại với phương thức khác.")</p>

            <div class="client-status-card__notes">
                <div class="client-status-card__note">
                    <i class="fas fa-credit-card"></i>
                    <span>Kiểm tra lại thông tin thanh toán trước khi thử lại.</span>
                </div>
                <div class="client-status-card__note">
                    <i class="fas fa-undo"></i>
                    <span>Bạn có thể quay lại bước thanh toán để chọn phương thức khác.</span>
                </div>
            </div>

            <div class="client-status-card__actions">
                <a href="@Url.Action("Checkout", "Payment")" class="btn btn-danger">Thử lại thanh toán</a>
                <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary">Về trang chủ</a>
            </div>
        </div>
    </div>
</section>
