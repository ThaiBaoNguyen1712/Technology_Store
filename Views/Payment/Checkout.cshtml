@using System.Globalization
@using Tech_Store.Helpers
@model Tech_Store.Models.ViewModel.CheckoutPageViewModel

@{
    ViewData["Title"] = "Thanh toán";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var provinceCode = string.IsNullOrWhiteSpace(Model.Customer.Province) ? "null" : Model.Customer.Province;
    var districtCode = string.IsNullOrWhiteSpace(Model.Customer.District) ? "null" : Model.Customer.District;
    var wardCode = string.IsNullOrWhiteSpace(Model.Customer.Ward) ? "null" : Model.Customer.Ward;
}

<section class="checkout-page">
    <div class="container">
        <div class="checkout-page__head">
            <div>
                <p class="checkout-page__eyebrow">Thanh toán</p>
                <h1 class="checkout-page__title">Xác nhận đơn hàng</h1>
            </div>
            <div class="checkout-page__count">@Model.Products.Count sản phẩm</div>
        </div>

        <div class="checkout-page__shell">
            <div class="checkout-page__main">
                <section class="checkout-page__section">
                    <div class="checkout-page__section-head">
                        <h2>Thông tin nhận hàng</h2>
                    </div>

                    <form id="checkoutForm" class="checkout-page__form">
                        <div class="checkout-page__grid">
                            <div class="checkout-page__field">
                                <label class="form-label">Họ và tên *</label>
                                <input type="text" class="form-control" value="@Model.Customer.LastName @Model.Customer.FirstName" required>
                            </div>
                            <div class="checkout-page__field">
                                <label class="form-label">Số điện thoại *</label>
                                <input type="tel" class="form-control" value="@Model.Customer.PhoneNumber" required>
                            </div>
                            <div class="checkout-page__field checkout-page__field--full">
                                <label class="form-label">Email</label>
                                <input type="email" class="form-control" value="@Model.Customer.Email">
                            </div>
                        </div>

                        @if (ViewBag.Address != null)
                        {
                            <div class="checkout-page__saved-address">
                                <div>
                                    <span class="checkout-page__saved-label">Địa chỉ hiện tại</span>
                                    <strong>@ViewBag.Address</strong>
                                </div>
                                <label class="checkout-page__toggle">
                                    <input type="checkbox" name="IsOldAddress" id="isOldAddressCheckbox" />
                                    <span>Giao đến địa chỉ khác</span>
                                </label>
                            </div>
                        }

                        <div id="FormNewAddress" class="checkout-page__new-address" style="@(ViewBag.Address == null ? "" : "display:none")">
                            <div class="checkout-page__field checkout-page__field--full">
                                <label class="form-label">Địa chỉ nhận hàng *</label>
                                <input type="text" class="form-control" name="AddressLine" value="@Model.Customer.AddressLine" required>
                            </div>

                            <div class="checkout-page__grid checkout-page__grid--triple">
                                <div class="checkout-page__field">
                                    <label class="form-label">Tỉnh/Thành phố</label>
                                    <select id="citySelect" class="form-control selectpicker" name="Ward" data-live-search="true" title="Chọn thành phố" required>
                                    </select>
                                </div>
                                <div class="checkout-page__field">
                                    <label class="form-label">Quận/Huyện</label>
                                    <select id="districtSelect" class="form-control selectpicker" name="District" data-live-search="true" title="Chọn quận/huyện" required>
                                    </select>
                                </div>
                                <div class="checkout-page__field">
                                    <label class="form-label">Phường/Xã</label>
                                    <select id="wardSelect" class="form-control selectpicker" name="Province" data-live-search="true" title="Chọn phường/xã" required>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="checkout-page__field checkout-page__field--full">
                            <label class="form-label">Ghi chú</label>
                            <textarea class="form-control" name="Note" rows="3" placeholder="Ghi chú cho người bán hoặc đơn vị giao hàng"></textarea>
                        </div>
                    </form>
                </section>

                <section class="checkout-page__section">
                    <div class="checkout-page__section-head">
                        <h2>Sản phẩm</h2>
                    </div>

                    <div class="checkout-page__items">
                        @foreach (var item in Model.Products)
                        {
                            var originalPrice = item.OriginPrice ?? item.SellPrice;
                            var lineTotal = item.SellPrice * item.Quantity;

                            <article class="checkout-page__item product-row"
                                     data-variantid="@item.VarientId"
                                     data-productid="@item.ProductId">
                                <div class="checkout-page__item-media">
                                    @if (string.IsNullOrWhiteSpace(item.ImageUrl))
                                    {
                                        <img src="~/Upload/Products/no-image.png" alt="@item.ProductName">
                                    }
                                    else if (item.ImageUrl.Contains("http"))
                                    {
                                        <img src="@ResizeCDN.Cdn(item.ImageUrl, 120, 120)" alt="@item.ProductName">
                                    }
                                    else
                                    {
                                        <img src="~/Upload/Products/@item.ImageUrl" alt="@item.ProductName">
                                    }
                                </div>

                                <div class="checkout-page__item-body">
                                    <h3 class="checkout-page__item-name">@item.ProductName</h3>
                                    @if (!string.IsNullOrWhiteSpace(item.Attributes))
                                    {
                                        <p class="checkout-page__item-variant">@item.Attributes</p>
                                    }
                                    <div class="checkout-page__item-meta">
                                        <span class="checkout-page__item-qty">SL: @item.Quantity</span>
                                        @if (originalPrice > item.SellPrice)
                                        {
                                            <del>@originalPrice.ToString("C0", new CultureInfo("vi-VN"))</del>
                                        }
                                    </div>
                                </div>

                                <div class="checkout-page__item-price">
                                    <strong>@lineTotal.ToString("C0", new CultureInfo("vi-VN"))</strong>
                                    <span>@item.SellPrice.ToString("C0", new CultureInfo("vi-VN"))/sp</span>
                                </div>
                            </article>
                        }
                    </div>
                </section>

                <section class="checkout-page__section">
                    <div class="checkout-page__section-head">
                        <h2>Phương thức thanh toán</h2>
                    </div>

                    <div class="checkout-page__payment-list">
                        @foreach (var gateway in Model.AvailableOnlineGateways)
                        {
                            <button type="button" class="checkout-page__payment-method payment-method" data="@gateway.Code">
                                <img src="@gateway.LogoUrl" alt="@gateway.DisplayName" class="checkout-page__payment-logo">
                                <div class="checkout-page__payment-content">
                                    <strong>@gateway.DisplayName</strong>
                                </div>
                                <span class="checkout-page__payment-check">
                                    <i class="fas fa-check"></i>
                                </span>
                            </button>
                        }

                        <button type="button" class="checkout-page__payment-method payment-method" data="cod">
                            <img src="/Upload/Logo/shipcod.png" alt="Ship COD" class="checkout-page__payment-logo">
                            <div class="checkout-page__payment-content">
                                <strong>Thanh toán khi nhận hàng</strong>
                            </div>
                            <span class="checkout-page__payment-check">
                                <i class="fas fa-check"></i>
                            </span>
                        </button>
                    </div>
                </section>
            </div>

            <aside class="checkout-page__sidebar">
                <div class="checkout-page__summary">
                    <div class="checkout-page__summary-head">
                        <h2>Đơn hàng</h2>
                    </div>

                    <div class="checkout-page__voucher">
                        <div class="input-group">
                            <input type="hidden" id="validVoucherCode" name="validVoucherCode" value="">
                            <input type="text" class="form-control" name="Voucher" placeholder="Mã giảm giá" aria-describedby="button-Checkvoucher">
                            <button class="btn btn-outline-danger" type="button" id="button-Checkvoucher">Áp dụng</button>
                        </div>
                        <p class="checkout-page__voucher-result text-success mb-0" id="resultVoucher"></p>
                    </div>

                    <div class="checkout-page__summary-list">
                        <div class="checkout-page__summary-row">
                            <span>Tạm tính</span>
                            <strong id="subtotal">@Model.SubtotalAmount.ToString("C0", new CultureInfo("vi-VN"))</strong>
                        </div>
                        <div class="checkout-page__summary-row">
                            <span>Giảm giá</span>
                            <strong id="Discount">0₫</strong>
                        </div>
                        <div class="checkout-page__summary-row">
                            <span>Phí vận chuyển</span>
                            <strong id="shipFee">@Model.ShippingAmount.ToString("C0", new CultureInfo("vi-VN"))</strong>
                        </div>
                    </div>

                    <div class="checkout-page__total">
                        <span>Tổng thanh toán</span>
                        <strong id="totalPrice">0₫</strong>
                    </div>

                    <button class="btn btn-danger checkout-page__submit" id="PayBtn" type="button" form="checkoutForm">
                        Đặt hàng
                    </button>
                </div>
            </aside>
        </div>
    </div>
</section>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/js/provincevn.js"></script>
<script>
    $(document).ready(function () {
        $('.payment-method').on('click', function () {
            $('.payment-method').removeClass('is-selected');
            $(this).addClass('is-selected');
            $('#PayBtn').data('selectedMethod', $(this).attr('data'));
        });

        $('#button-Checkvoucher').on('click', function () {
            var voucher = $('input[name=Voucher]').val();
            if (voucher.length > 8) {
                $.ajax({
                    method: 'GET',
                    url: '@Url.Action("CheckVoucher", "Payment")',
                    data: { code: voucher },
                    success: function (res) {
                        if (res.success) {
                            $('#resultVoucher').text('Voucher đã được áp dụng thành công').removeClass('text-danger').addClass('text-success').show();

                            if (res.voucher.promotion[res.voucher.promotion.length - 1] != '%') {
                                var promotionAmount = parseFloat(res.voucher.promotion.replace(/,/g, ''));
                                var formattedPromotion = promotionAmount.toLocaleString() + 'đ';
                                $('#validVoucherCode').val(voucher);
                                $('#Discount').text(formattedPromotion);
                            } else {
                                $('#validVoucherCode').val('');
                                $('#Discount').text(res.voucher.promotion);
                            }

                            updateTotalPayment();
                        } else {
                            $('#resultVoucher').text(res.message).removeClass('text-success').addClass('text-danger').show();
                        }
                    },
                    error: function (xhr, message) {
                        $('#resultVoucher').text('Có lỗi xảy ra: ' + message).removeClass('text-success').addClass('text-danger').show();
                    }
                });
            } else {
                $('#resultVoucher').removeClass('text-success').addClass('text-danger').text('Voucher không hợp lệ!');
            }
        });

        function updateTotalPayment() {
            var totalPricetxt = $('#subtotal').text().replace(/[.,đ₫\s]/g, '');
            var totalPrice = parseInt(totalPricetxt, 10) || 0;
            var shipFeeTxt = $('#shipFee').text().replace(/[.,đ₫\s]/g, '');
            var shipFee = parseInt(shipFeeTxt, 10) || 0;
            var discountPricetxt = $('#Discount').text().trim();
            var discountPrice = 0;

            if (discountPricetxt) {
                if (discountPricetxt.includes('%')) {
                    var percent = parseFloat(discountPricetxt.replace('%', '')) / 100;
                    if (!isNaN(percent)) {
                        discountPrice = totalPrice * percent;
                    }
                } else {
                    discountPrice = parseInt(discountPricetxt.replace(/[.,đ₫\s]/g, ''), 10) || 0;
                }
            }

            var total = Math.max(0, totalPrice - discountPrice + shipFee);
            $('#totalPrice').text(total.toLocaleString() + 'đ');
        }

        $('#isOldAddressCheckbox').change(function () {
            if ($(this).is(':checked')) {
                $('#FormNewAddress').slideDown();
            } else {
                $('#FormNewAddress').slideUp();
            }
        });

        $('#PayBtn').on('click', function () {
            var addressline, ward, district, province;
            var validVoucher = $('#validVoucherCode').val();
            var note = $('textarea[name="Note"]').val();
            var isNewAddress = false;
            var paymentMethod = $(this).data('selectedMethod');

            if (!paymentMethod) {
                alert('Vui lòng chọn phương thức thanh toán');
                return;
            }

            if ($('#isOldAddressCheckbox').is(':checked')) {
                addressline = $('input[name="AddressLine"]').val();
                ward = $('select[name="Ward"]').val();
                district = $('select[name="District"]').val();
                province = $('select[name="Province"]').val();
                isNewAddress = true;
            }

            var products = [];

            $('.product-row').each(function () {
                products.push({
                    VarientProductID: $(this).data('variantid'),
                    ProductId: $(this).data('productid'),
                    Quantity: $(this).find('.checkout-page__item-qty').text().replace('SL: ', '').trim()
                });
            });

            $.ajax({
                method: 'POST',
                url: '@Url.Action("Checkout", "Payment")',
                data: {
                    Products: products,
                    VoucherCode: validVoucher,
                    Note: note,
                    NewAddress: isNewAddress,
                    Address: isNewAddress ? {
                        AddressLine: addressline,
                        Ward: ward,
                        District: district,
                        Province: province
                    } : null,
                    PaymentMethod: paymentMethod
                },
                success: function (response) {
                    if (response.vnPayUrl) {
                        window.location.href = response.vnPayUrl;
                    } else if (response.momoPayUrl) {
                        window.location.href = response.momoPayUrl;
                    } else if (response.sePayUrl) {
                        window.location.href = response.sePayUrl;
                    } else if (response.success && response.redirectTo) {
                        window.location.href = response.redirectTo;
                    } else if (response.message) {
                        alert(response.message);
                    } else {
                        alert('Đã có lỗi khi chuyển hướng');
                    }
                },
                error: function (xhr, status, error) {
                    var serverMessage = xhr.responseJSON && xhr.responseJSON.message
                        ? xhr.responseJSON.message
                        : 'Có lỗi xảy ra khi xử lý thanh toán.';
                    alert(serverMessage);
                    console.error('Có lỗi xảy ra:', error);
                }
            });
        });

        updateTotalPayment();
    });
</script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const provinceCode = @Html.Raw(provinceCode);
        const districtCode = @Html.Raw(districtCode);
        const wardCode = @Html.Raw(wardCode);

        fillAddressData(provinceCode, districtCode, wardCode);
    });
</script>
