@{
    ViewData["Title"] = "Đặt hàng thành công";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="client-status-page">
    <div class="container">
        <div class="client-status-card client-status-card--success">
            <div class="client-status-card__icon">
                <i class="fas fa-check"></i>
            </div>
            <p class="client-status-card__eyebrow">Đặt hàng thành công</p>
            <h1 class="client-status-card__title">Đơn hàng đã được ghi nhận</h1>
            <p class="client-status-card__message">@(TempData["Message"]?.ToString() ?? "Cửa hàng đã nhận đơn của bạn và sẽ sớm xử lý.")</p>

            <div class="client-status-card__notes">
                <div class="client-status-card__note">
                    <i class="fas fa-receipt"></i>
                    <span>Bạn có thể theo dõi đơn trong mục đơn mua.</span>
                </div>
                <div class="client-status-card__note">
                    <i class="fas fa-truck"></i>
                    <span>Trạng thái giao hàng sẽ được cập nhật khi đơn được xử lý.</span>
                </div>
            </div>

            <div class="client-status-card__actions">
                <a href="/user/MyOrders" class="btn btn-danger">Xem đơn hàng</a>
                <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary">Tiếp tục mua sắm</a>
            </div>
        </div>
    </div>
</section>
