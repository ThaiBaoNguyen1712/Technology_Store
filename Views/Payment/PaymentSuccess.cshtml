@{
    ViewData["Title"] = "Thanh toán thành công";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="client-status-page">
    <div class="container">
        <div class="client-status-card client-status-card--success">
            <div class="client-status-card__icon">
                <i class="fas fa-check"></i>
            </div>
            <p class="client-status-card__eyebrow">Thanh toán thành công</p>
            <h1 class="client-status-card__title">Đơn hàng đã được xác nhận</h1>
            <p class="client-status-card__message">@(TempData["Message"]?.ToString() ?? "Khoản thanh toán của bạn đã được ghi nhận thành công.")</p>

            <div class="client-status-card__notes">
                <div class="client-status-card__note">
                    <i class="fas fa-wallet"></i>
                    <span>Thanh toán đã hoàn tất và đơn hàng đang chờ xử lý.</span>
                </div>
                <div class="client-status-card__note">
                    <i class="fas fa-truck"></i>
                    <span>Bạn có thể theo dõi tiến trình giao hàng trong đơn mua.</span>
                </div>
            </div>

            <div class="client-status-card__actions">
                <a href="/user/MyOrders" class="btn btn-danger">Xem đơn hàng</a>
                <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary">Tiếp tục mua sắm</a>
            </div>
        </div>
    </div>
</section>
