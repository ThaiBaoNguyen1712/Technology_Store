@model IReadOnlyList<Tech_Store.Models.ViewModel.BannerRenderItemViewModel>

@if (Model != null && Model.Count > 0)
{
    var carouselId = $"bannerCarousel-{Guid.NewGuid():N}";
    <div id="@carouselId" class="carousel slide banner-slot banner-slot--carousel banner-slot--surface" data-bs-ride="carousel">
        @if (Model.Count > 1)
        {
            <div class="carousel-indicators">
                @for (var i = 0; i < Model.Count; i++)
                {
                    <button type="button"
                            data-bs-target="#@carouselId"
                            data-bs-slide-to="@i"
                            class="@(i == 0 ? "active" : string.Empty)"
                            aria-current="@(i == 0 ? "true" : "false")"
                            aria-label="Slide @(i + 1)"></button>
                }
            </div>
        }

        <div class="carousel-inner">
            @for (var i = 0; i < Model.Count; i++)
            {
                var banner = Model[i];
                <div class="carousel-item @(i == 0 ? "active" : string.Empty)">
                    <a href="@banner.NavigateUrl" class="banner-slot__link" target="@(banner.OpenInNewTab ? "_blank" : "_self")">
                        <picture class="banner-slot__picture">
                            @if (!string.IsNullOrWhiteSpace(banner.MobileImageUrl))
                            {
                                <source media="(max-width: 767.98px)" srcset="@banner.MobileImageUrl" />
                            }
                            <img src="@banner.DesktopImageUrl" class="d-block w-100 banner-slot__image" alt="@banner.AltText" loading="lazy" />
                        </picture>
                    </a>
                </div>
            }
        </div>

        @if (Model.Count > 1)
        {
            <button class="carousel-control-prev" type="button" data-bs-target="#@carouselId" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#@carouselId" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </button>
        }
    </div>
}
