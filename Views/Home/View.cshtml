<script>
    function openFullscreen(img) {
        let overlay = document.querySelector('.fullscreen-overlay');
        if (!overlay) {
            overlay = document.createElement('div');
            overlay.className = 'fullscreen-overlay';
            document.body.appendChild(overlay);
        }

        overlay.innerHTML = '';
        const imgClone = img.cloneNode();
        imgClone.className = 'fullscreen-image';
        overlay.appendChild(imgClone);
        overlay.classList.add('active');

        imgClone.onclick = function (e) {
            e.stopPropagation();
            imgClone.classList.toggle('is-zoomed');
        };

        overlay.onclick = function (e) {
            if (e.target === overlay) {
                overlay.classList.remove('active');
            }
        };

        document.onkeydown = function (e) {
            if (e.key === 'Escape') {
                overlay.classList.remove('active');
            }
        };
    }
</script>
<script>
    // Đợi cho DOM load xong
    window.addEventListener('DOMContentLoaded', function () {
        // Kiểm tra xem các element có tồn tại không
        const productDetail = document.querySelector('.product-detail');
        const seeMoreBtn = document.querySelector('.btn-see-more');
        const content = document.querySelector('.description-content');
        const productSpecCompact = document.getElementById('productSpecCompact');
        const productSpecToggle = document.getElementById('productSpecToggle');

        // Chỉ thực hiện nếu tìm thấy tất cả các element cần thiết
        if (productDetail && seeMoreBtn && content) {
            // Hàm kiểm tra chiều cao nội dung
            function checkContentHeight() {
                try {
                    const contentHeight = content.offsetHeight;
                    const maxHeight = 300; // Chiều cao tối đa trước khi hiện nút xem thêm

                    if (contentHeight <= maxHeight) {
                        seeMoreBtn.style.display = 'none';
                        productDetail.style.maxHeight = 'none';
                        const fadeBottom = document.querySelector('.fade-bottom');
                        if (fadeBottom) {
                            fadeBottom.style.display = 'none';
                        }
                    } else {
                        seeMoreBtn.style.display = 'block';
                        if (!productDetail.classList.contains('expanded')) {
                            productDetail.style.maxHeight = '300px';
                        }
                    }
                } catch (error) {
                    console.error('Error checking content height:', error);
                }
            }

            // Xử lý sự kiện click
            seeMoreBtn.addEventListener('click', function () {
                if (productDetail.classList.contains('expanded')) {
                    productDetail.classList.remove('expanded');
                    this.textContent = 'Xem thêm';
                    productDetail.style.maxHeight = '300px';
                    // Scroll back to top of description
                    productDetail.scrollIntoView({ behavior: 'smooth', block: 'start' });
                } else {
                    productDetail.classList.add('expanded');
                    this.textContent = 'Thu gọn';
                    productDetail.style.maxHeight = 'none';
                }
            });

            // Chạy kiểm tra ban đầu sau một khoảng thời gian ngắn để đảm bảo nội dung đã được render
            setTimeout(checkContentHeight, 100);

            // Thêm sự kiện resize
            window.addEventListener('resize', checkContentHeight);
        } else {
            console.warn('Some elements are missing from the DOM');
        }

        if (productSpecCompact && productSpecToggle) {
            productSpecToggle.addEventListener('click', function () {
                productSpecCompact.classList.toggle('product-spec-compact--collapsed');
                this.textContent = productSpecCompact.classList.contains('product-spec-compact--collapsed')
                    ? 'Xem cấu hình chi tiết'
                    : 'Thu gọn cấu hình';
            });
        }
    });
</script>

<script>
    // Auto-resize textarea
    function autoResize(textarea) {
        textarea.style.height = 'auto';
        textarea.style.height = textarea.scrollHeight + 'px';
    }

    // Add auto-resize to all textareas
    document.querySelectorAll('textarea').forEach(textarea => {
        textarea.addEventListener('input', () => autoResize(textarea));
    });

    // Toggle reply form
    document.querySelectorAll('.comments-product-reply-link').forEach(link => {
        link.addEventListener('click', (e) => {
            const replyForm = e.target.closest('.comments-product-reply-container').querySelector('.comments-product-reply-form');
            replyForm.classList.toggle('active');
            if (replyForm.classList.contains('active')) {
                const textarea = replyForm.querySelector('.comments-product-reply-input');
                textarea.focus();
            }
        });
    });

    // Handle click outside to close reply form
    document.addEventListener('click', (e) => {
        if (!e.target.closest('.reply-container')) {
            document.querySelectorAll('.reply-form').forEach(form => {
                form.classList.remove('active');
            });
        }
    });
</script>

<script>
    let variantId = null;

    document.querySelectorAll('.varient-card').forEach(function (card, index) {
        // Đảm bảo rằng thẻ đầu tiên được chọn mặc định
        if (index === 0 && card.classList.contains('selected')) {
            variantId = card.getAttribute('data-id');  // Lưu ID của thẻ đầu tiên
        }

        card.addEventListener('click', function () {
            // Xóa lớp 'selected' khỏi tất cả các thẻ
            document.querySelectorAll('.varient-card').forEach(function (c) {
                c.classList.remove('selected');
            });

            // Thêm lớp 'selected' vào thẻ được nhấp vào
            this.classList.add('selected');

            // Lấy ID của biến thể được chọn
            variantId = this.getAttribute('data-id');
          
        });
    });

    // Kiểm tra sản phẩm không có biến thể
    let hiddenVariantId = document.querySelector('input[name="VarientId"]');
    if (hiddenVariantId) {
        variantId = hiddenVariantId.value;
    }

    // Kiểm tra trường hợp không có click (người dùng mua thẻ đầu tiên mà không click)
    if (variantId === null) {
        const firstSelectedCard = document.querySelector('.varient-card.selected');
        if (firstSelectedCard) {
            variantId = firstSelectedCard.getAttribute('data-id');
        }
     
    }


</script>

<script type="text/javascript">
    $(document).ready(function () {
        const notyf = new Notyf({
            position: {
                x: 'right', // Căn phải
                y: 'bottom' // Căn dưới
            }
        });

        $('#AddToCart').on('click', function () {
            if (!variantId) {
                notyf.error("Vui lòng chọn một biến thể trước khi thêm vào giỏ hàng.");

                return;
            }
            $('.loading-container').show();

            $.ajax({
                method: 'POST',
                url: '@Url.Action("AddToCart", "User")',
                data: {
                    itemId: variantId,  // Sử dụng variantId đã chọn
                    quantity: 1
                },
                success: function (response) {
                    if (response.success) {
                        let currentCartNumb = parseInt($('#Cart_numb').text()) || 0; // Nếu không có giá trị, gán mặc định là 0
                        $('#Cart_numb').text(currentCartNumb + 1);

                        notyf.success("Đã thêm vào giỏ hàng");
                    } 
                    else if (response.message === "login require") {
                        // Hứng lỗi đăng nhập
                        var loginModal = new bootstrap.Modal(document.getElementById('loginRequiredModal'));
                        loginModal.show();
                    }
                    else {
                        notyf.error("Đã có lỗi " + response.message);
                    }
                    $('.loading-container').hide();

                },
                error: function (response) {
                    $('.loading-container').hide();

                    alert("Có lỗi xảy ra, vui lòng thử lại.");
                    return false;
                }
            });
        });
        $('#ToCheckOutBtn').on('click', function () {
            if (!variantId) {
                notyf.error("Vui lòng chọn một biến thể trước khi thêm vào giỏ hàng.");
                return;
            }
            var ProductId = $(this).data('id');

            $('.loading-container').show();

            $.ajax({
                method: 'POST',
                url: '@Url.Action("ToCheckout", "User")',
                contentType: 'application/json',
                data: JSON.stringify({
                    cartDTos: [
                        {
                            VarientProductId: variantId,
                            ProductId: ProductId,
                            Quantity: 1
                        }
                    ]
                }),
                success: function (response) {
                    $('.loading-container').hide();

                    if (response.success) {
                        window.location.href = response.redirectUrl; // Chuyển hướng đến trang thanh toán
                    } else {
                        notyf.error(response.message); // Hiển thị lỗi từ server
                        var additionalInfoUserModal = new bootstrap.Modal(document.getElementById('infoRequiredModal'));
                        additionalInfoUserModal.show();
                    }
                },
                error: function () {
                    $('.loading-container').hide();
                    var loginModal = new bootstrap.Modal(document.getElementById('loginRequiredModal'));
                    loginModal.show();
                }
            });
        });

    });
</script>
<script>
    $(document).ready(function () {
        // Kiểm tra nếu URL Youtube tồn tại
        const urlYoutube = '@Model.UrlYoutube';
        const videoId = extractVideoID(urlYoutube);

        if (videoId) {
            // Thêm iframe hoặc xử lý thumbnail
            $('#youtubeThumbnail').html(`
                                            <div class="thumbnail active" data-src="https://www.youtube.com/embed/${videoId}"
                                                 style="background-image: url('https://img.youtube.com/vi/${videoId}/0.jpg')">
                                            </div>
                                        `);
        }

        // Hàm trích xuất ID video từ URL YouTube
        function extractVideoID(url) {
            const regExp = /^.*((youtu.be\/)|(v\/)|(\/u\/\w\/)|(embed\/)|(watch\?))\??v?=?([^#&?]*).*/;
            const match = url.match(regExp);
            return (match && match[7].length == 11) ? match[7] : false;
        }
    });
</script>
