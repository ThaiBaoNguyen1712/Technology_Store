@model Tech_Store.Models.Product
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@using System.Globalization;
@using Tech_Store.Helpers
@using Tech_Store.Models
@using Tech_Store.Models.ViewModel



@functions {
    public string BuildProductImageUrl(string? path, int width = 0, int height = 0)
    {
        const string fallbackImage = "/Upload/Products/none.png";

        if (string.IsNullOrWhiteSpace(path))
        {
            return fallbackImage;
        }

        var trimmedPath = path.Trim();

        if (trimmedPath.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
            trimmedPath.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
        {
            return width > 0 || height > 0
                ? ResizeCDN.Cdn(trimmedPath, width, height)
                : trimmedPath;
        }

        if (trimmedPath.StartsWith("/Upload/", StringComparison.OrdinalIgnoreCase))
        {
            return trimmedPath;
        }

        return $"/Upload/Products/{trimmedPath.TrimStart('/')}";
    }

    public string BuildAvatarUrl(string? avatarFileName)
    {
        return string.IsNullOrWhiteSpace(avatarFileName)
            ? "/Upload/Avatar/none.png"
            : $"/Upload/Avatar/{avatarFileName.Trim()}";
    }

    public string extractVideoID(string url)
    {
        if (string.IsNullOrEmpty(url)) return string.Empty;

        var regex = new System.Text.RegularExpressions.Regex(@"^.*((youtu.be\/)|(v\/)|(\/u\/\w\/)|(embed\/)|(watch\?))\??v?=?([^#&?]*).*");
        var match = regex.Match(url);

        if (match.Success && match.Groups[7].Length == 11)
            return match.Groups[7].Value;

        return string.Empty;
    }
}
@{
    var productName = string.IsNullOrWhiteSpace(Model?.Name) ? "Chi tiết sản phẩm" : Model.Name;
    ViewData["Title"] = productName;

    var productSpecs = ViewBag.specs as IEnumerable<Tech_Store.Models.Specs>;
    List<(string Name, string? Value)> productSpecEntries = productSpecs?
        .SelectMany(spec => (spec.SpecValues ?? Enumerable.Empty<Tech_Store.Models.SpecValue>())
            .OrderBy(x => x.SortOrder)
            .Select(v => (Name: spec.Name ?? "Thông số", Value: (string?)v.Value)))
        .ToList() ?? new List<(string Name, string? Value)>();

    var categoryName = string.IsNullOrWhiteSpace(Model.Category?.Name) ? "Danh mục đang cập nhật" : Model.Category.Name;
    var categorySlug = Model.Category?.EngTitle;
    var brandName = string.IsNullOrWhiteSpace(Model.Brand?.Name) ? "Thương hiệu đang cập nhật" : Model.Brand.Name;
    var productStatus = string.IsNullOrWhiteSpace(Model.Status) ? "Đang cập nhật" : Model.Status;
    var descriptionHtml = string.IsNullOrWhiteSpace(Model.Description)
        ? "<p class=\"text-muted mb-0\">Thông tin sản phẩm đang được cập nhật.</p>"
        : Model.Description;

    var fallbackProductImage = "/Upload/Products/none.png";
    var galleryImages = new List<string> { BuildProductImageUrl(Model.Image, 358, 358) };
    galleryImages.AddRange((Model.Galleries ?? Enumerable.Empty<Gallery>())
        .Select(g => BuildProductImageUrl(g.Path, 358, 358))
        .Where(url => !string.IsNullOrWhiteSpace(url)));
    galleryImages = galleryImages
        .Where(url => !string.IsNullOrWhiteSpace(url))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .ToList();

    if (!galleryImages.Any())
    {
        galleryImages.Add(fallbackProductImage);
    }

    var displayMainImageUrl = galleryImages.FirstOrDefault() ?? fallbackProductImage;
    var hasThumbnailGallery = galleryImages.Count > 1;
    var variants = (Model.VarientProducts ?? Enumerable.Empty<VarientProduct>())
        .OrderBy(v => v.Price ?? decimal.MaxValue)
        .ToList();
    var firstAvailableVariant = variants.FirstOrDefault(v => (v.Stock ?? 0) > 0 && (v.Price ?? 0) > 0);
    var showBasePrice = variants.Any(v => string.IsNullOrWhiteSpace(v.Attributes));
    var sellPrice = Model.SellPrice ?? 0m;
    var originalPrice = Model.OriginalPrice ?? 0m;
    var hasDiscount = originalPrice > 0 && sellPrice > 0 && originalPrice > sellPrice;
    var discountPercent = hasDiscount ? Math.Round((double)(100 - (sellPrice / originalPrice * 100m))) : 0d;
    var hasSpecs = productSpecEntries.Any();
    var compactSpecLimit = 8;
    var youtubeVideoId = extractVideoID(Model.UrlYoutube ?? string.Empty);
    var hasYoutubeVideo = !string.IsNullOrWhiteSpace(youtubeVideoId);
    var reviewCount = ViewBag.review_count is int count ? count : 0;
    var averageRating = ViewBag.averageRating is double avgDouble
        ? avgDouble
        : ViewBag.averageRating is decimal avgDecimal
            ? (double)avgDecimal
            : 0d;
    var ratingSummary = ViewBag.ratingSummary as IDictionary<int, int> ?? new Dictionary<int, int>();
    var reviews = ViewBag.reviews as IEnumerable<Review> ?? Enumerable.Empty<Review>();
    var comments = ViewBag.comments as IEnumerable<CommentVM> ?? Enumerable.Empty<CommentVM>();
}

<style>
    .gallery-wrapper--single .product-gallery {
        width: 100%;
    }

    .thumbnail {
        border: 0;
        padding: 0;
        background: transparent;
        display: block;
    }

    .thumbnail img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }
</style>

<div class="container my-3">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="ms-2" style="font-size:0.85rem">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="/Category" class="text-decoration-none">Danh mục</a></li>
            <li class="breadcrumb-item">
                @if (!string.IsNullOrWhiteSpace(categorySlug))
                {
                    <a href="/Category/@categorySlug" class="text-decoration-none">@categoryName</a>
                }
                else
                {
                    <span>@categoryName</span>
                }
            </li>
            <li class="breadcrumb-item">
                @if (!string.IsNullOrWhiteSpace(Model.Brand?.Name))
                {
                    <a href="/Brand/@Model.Brand.Name" class="text-decoration-none">@brandName</a>
                }
                else
                {
                    <span>@brandName</span>
                }
            </li>
            <li class="breadcrumb-item active" aria-current="page">@productName</li>

        </ol>
    </nav>
    <div class="row">
        <div class="col-md-6">
            <div class="gallery-wrapper @(hasThumbnailGallery ? string.Empty : "gallery-wrapper--single")">
                @if (hasThumbnailGallery)
                {
                    <div class="thumbnail-container-wrapper">
                        <button type="button" class="thumbnail-control prev">
                            <i class="fas fa-chevron-up"></i>
                        </button>
                        <div class="thumbnail-container">
                            @for (var imageIndex = 0; imageIndex < galleryImages.Count; imageIndex++)
                            {
                                var imageUrl = galleryImages[imageIndex];
                                <button type="button"
                                        class="thumbnail @(imageIndex == 0 ? "active" : string.Empty)"
                                        data-src="@imageUrl"
                                        aria-label="Ảnh sản phẩm @(imageIndex + 1)">
                                    <img src="@imageUrl"
                                         alt="@productName"
                                         loading="lazy"
                                         onerror="this.onerror=null; this.src='@fallbackProductImage'; this.closest('.thumbnail').setAttribute('data-src', '@fallbackProductImage');" />
                                </button>
                            }
                        </div>
                        <button type="button" class="thumbnail-control next">
                            <i class="fas fa-chevron-down"></i>
                        </button>
                    </div>
                }

                <div class="product-gallery">
                    <img id="mainImage"
                         src="@displayMainImageUrl"
                         alt="@productName"
                         data-fallback-src="@fallbackProductImage"
                         onerror="this.onerror=null; this.src=this.dataset.fallbackSrc || '@fallbackProductImage';"
                         onclick="openFullscreen(this)">
                </div>
            </div>

        </div>

        <div class="col-md-6 product-info">
            <h3>@productName</h3>
            <div class="rating pb-3">
                <span class="text-muted">(@reviewCount đánh giá)</span>
                <span class="text-muted">(@productStatus)</span>
            </div>

            @if (showBasePrice)
            {
                <div class="product-price-box d-flex align-items-center gap-3 p-3 border rounded-3 mb-3 bg-light">
                    <div class="main-price">
                        <div class="text-secondary fs-6">Giá sản phẩm</div>
                        <div class="d-flex align-items-baseline gap-2">
                            <span class="text-danger fw-bold fs-2">
                                @(sellPrice > 0 ? $"{sellPrice.ToString("N0", new CultureInfo("vi-VN"))}₫" : "Liên hệ")
                            </span>

                            @if (hasDiscount)
                            {
                                <span class="text-decoration-line-through text-secondary fs-6">
                                    @originalPrice.ToString("N0", new CultureInfo("vi-VN"))₫
                                </span>

                                <span class="badge bg-danger">
                                    -@discountPercent%
                                </span>
                            }
                        </div>
                    </div>
                </div>
            }


            <div class="d-flex flex-wrap gap-3">
                @foreach (var varient in variants)
                {
                    var isFirst = firstAvailableVariant == varient;
                    var variantImageUrl = BuildProductImageUrl(varient.ImageUrl, 358, 358);
                    var variantFullImageUrl = BuildProductImageUrl(varient.ImageUrl);
                    var variantStock = varient.Stock ?? 0;
                    var variantPrice = varient.Price ?? 0m;
                    var variantAttributeValues = (varient.VariantAttributes ?? Enumerable.Empty<Tech_Store.Models.VariantAttribute>())
                        .Select(attr => attr.AttributeValue?.Value)
                        .Where(value => !string.IsNullOrWhiteSpace(value))
                        .ToList();

                    @if (!string.IsNullOrWhiteSpace(varient.Attributes))
                    {
                        <div class="card mb-3 varient-card @(variantStock <= 0 || variantPrice <= 0 ? "disabled" : "") @(isFirst ? "selected" : "")"
                             data-id="@varient.VarientId"
                             @(variantStock <= 0 ? "style='pointer-events: none; opacity: 0.5;'" : "")>

                            <div class="d-flex align-items-center gap-3 p-2">
                                <img src="@variantImageUrl"
                                     alt="@productName"
                                     style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px;"
                                     data-full="@variantFullImageUrl"
                                     onerror="this.onerror=null; this.src='@fallbackProductImage'; this.dataset.full='@fallbackProductImage';"
                                     class="variant-thumb" />

                                <div class="flex-grow-1">
                                    <div class="varient-attributes mb-1">
                                        @if (variantAttributeValues.Any())
                                        {
                                            <span>@string.Join(" - ", variantAttributeValues)</span>
                                        }
                                        else
                                        {
                                            <span>Phiên bản đang cập nhật</span>
                                        }
                                    </div>

                                    <div class="varient-price">
                                        @if (variantStock <= 0 || variantPrice <= 0)
                                        {
                                            <p class="price" style="font-size: 14px !important; margin: 0;">(Hết hàng)</p>
                                        }
                                        else
                                        {
                                            <span class="price" style="font-size: 14px !important;">
                                                @variantPrice.ToString("C0", new CultureInfo("vi-VN"))
                                            </span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>

                    }
                    else
                    {
                        <!-- Sản phẩm không có biến thể, chỉ render input hidden để lấy VarientId -->
                        <input type="hidden" name="VarientId" value="@varient.VarientId" />
                    }
                }


            </div>

            <input type="hidden" id="selectedVariantId" value="" />
          
      
            <div class="product-action-grid py-3">
                <!-- Nút Mua ngay -->
                <div class="product-action-grid__buy">
                    <button type="button" id="ToCheckOutBtn" data-id="@Model.ProductId"
                            class="btn btn-buy-now text-white w-100 product-action-btn fw-semibold text-uppercase shadow">
                        <i class="fas fa-bolt me-2"></i>
                        <span>Mua ngay</span>
                    </button>
                </div>
                <!-- Nút Thêm vào giỏ -->
                <div class="product-action-grid__cart">
                    <button type="button" id="AddToCart"
                            class="btn btn-cart btn-outline-danger w-100 product-action-btn">
                        <i class="fa fa-cart-plus" aria-hidden="true"></i>
                        <span>Thêm vào giỏ</span>
                    </button>
                </div>
            </div>

        </div>
    </div>
    <div class="row pt-3">
        <div class="col-12">
                <div class="title-container">
                    <h4 class="text-center">Thông tin sản phẩm</h4>
                </div>

                @if (hasSpecs || hasYoutubeVideo)
                {
                    <div class="product-detail-top row g-3 mb-3">
                        @if (hasSpecs)
                        {
                            <div class="col-12 @(hasYoutubeVideo ? "col-lg-5" : "col-lg-12")">
                                <aside class="product-detail-top__specs">
                                    <div class="product-spec-compact @(productSpecEntries.Count > compactSpecLimit ? "product-spec-compact--collapsed" : string.Empty)" id="productSpecCompact">
                                        <div class="product-spec-compact__head">
                                            <h5>Thông số kỹ thuật</h5>
                                        </div>
                                        <div class="product-spec-compact__grid">
                                            @foreach (var specEntry in productSpecEntries)
                                            {
                                                <div class="product-spec-compact__item">
                                                    <span>@specEntry.Name</span>
                                                    <strong>@(string.IsNullOrWhiteSpace(specEntry.Value) ? "-" : specEntry.Value)</strong>
                                                </div>
                                            }
                                        </div>
                                        @if (productSpecEntries.Count > compactSpecLimit)
                                        {
                                            <button type="button" class="product-spec-compact__toggle" id="productSpecToggle">
                                                Xem cấu hình chi tiết
                                            </button>
                                        }
                                    </div>
                                </aside>
                            </div>
                        }

                        @if (hasYoutubeVideo)
                        {
                            <div class="col-12 @(hasSpecs ? "col-lg-7" : "col-lg-12")">
                                <div class="product-detail-top__video">
                                    <div class="product-video-compact">
                                        <div class="product-video-compact__head">
                                            <h5>Video sản phẩm</h5>
                                        </div>
                                        <div class="video-container">
                                            <iframe src="https://www.youtube.com/embed/@youtubeVideoId"
                                                    title="Video @productName"
                                                    loading="lazy"
                                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                                                    allowfullscreen>
                                            </iframe>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }

                <div class="product-detail">
                    <div class="description-content">
                        <div class="product-description">@Html.Raw(descriptionHtml)</div>
                    </div>
                
                  
                    <div class="fade-bottom"></div>
                    <button class="btn btn-outline-danger btn-see-more">Xem thêm</button>
                </div>
         
        </div>
    </div>
    <section class="products">
        <div class="container">
            <div class="product-section">
                <div style="max-width: 85vw; padding: 10px; display: flex; justify-content: space-between; align-items: center;">
                    <h3 class="text-dark mb-0">Gợi ý cho bạn</h3>
                </div>

                <button class="btn-scroll btn-prev" data-target="suggestion">
                    <i class="fa fa-chevron-left"></i>
                </button>
                <button class="btn-scroll btn-next" data-target="suggestion">
                    <i class="fa fa-chevron-right"></i>
                </button>

                <div class="scrolling-wrapper" data-wrapper="suggestion">
                    <div id="recommendation-container" class="row pt-2 mx-auto">
                        <div class="text-center w-100 py-5">
                            <div class="spinner-border text-danger" role="status"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <div class="container-md">
        <div class="reviews-section">
            <div class="reviews-section__header">
                <h3>Đánh giá sản phẩm</h3>
            </div>
            <div class="rating-summary">
                <div class="average-rating">
                    <span class="rating-number">@averageRating.ToString("F1", CultureInfo.InvariantCulture)</span>
                    <div class="stars rating-stars">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= Math.Floor(averageRating))
                            {
                                <i class="fas fa-star"></i>
                            }
                            else if (i - averageRating < 1)
                            {
                                <i class="fas fa-star-half-alt"></i>
                            }
                            else
                            {
                                <i class="far fa-star"></i>
                            }
                        }
                    </div>
                    <span class="total-reviews">(@reviewCount đánh giá)</span>
                </div>

                <div class="rating-bars">
                    @for (int i = 5; i >= 1; i--)
                    {
                        var ratingCount = ratingSummary.ContainsKey(i) ? ratingSummary[i] : 0;
                        var percentage = reviewCount > 0 ? (ratingCount * 100 / reviewCount) : 0;

                        <div class="rating-bar-item">
                            <span class="star-count">@i <i class="fas fa-star stars"></i></span>
                            <div class="progress">
                                <div class="progress-bar" style="width: @percentage%"></div>
                            </div>
                            <span class="rating-count">@ratingCount</span>
                        </div>
                    }
                </div>
            </div>

            <div class="review-list">
                @if (reviews.Any())
                {
                    @foreach (var review in reviews)
                    {
                        <div class="review-item">
                            <div class="review-item__inner">
                            <img src="@BuildAvatarUrl(review.User?.Img)" class="user-avatar" alt="Ảnh người dùng">

                                <div class="review-content">
                                    <div class="review-header">
                                        <h5>@(string.IsNullOrWhiteSpace($"{review.User?.LastName} {review.User?.FirstName}".Trim()) ? "Khách hàng" : $"{review.User?.LastName} {review.User?.FirstName}".Trim())</h5>
                                        <div class="review-rating">
                                            <span class="review-rating__value">@review.Rating</span>
                                            <i class="fas fa-star stars"></i>
                                        </div>
                                        <small class="review-date">
                                            @(review.ReviewDate != default ? review.ReviewDate.TimeAgo() : "Không xác định")
                                        </small>
                                    </div>
                                    <p class="review-text">@(string.IsNullOrWhiteSpace(review.Comment) ? "Người dùng chưa để lại nội dung đánh giá." : review.Comment)</p>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-center text-muted">Chưa có đánh giá nào cho sản phẩm này.</p>
                }
            </div>
        </div>
    </div>
    <div class="comments-product-container">
        <div class="comments-product-section">
            <div class="comments-product-title">
                <h3>Bình luận</h3>
            </div>

            <div class="comments-product-new-comment">
                @if (ViewBag.User != null)
                {
                    <img src="@BuildAvatarUrl(ViewBag.User.Img)"
                         class="comments-product-new-comment-avatar"
                         alt="Ảnh người dùng">
                }
                else
                {
                    <img src="/Upload/Avatar/none.png"
                         class="comments-product-new-comment-avatar"
                         alt="Ảnh người dùng">
                }
                <input type="text"
                       class="comments-product-comment-input"
                       id="CmContent"
                               placeholder="Viết bình luận của bạn..."
                               rows="1" />
                <button id="CreateCm"
                        data-userId="@(ViewBag.User != null ? ViewBag.User.UserId : "")"
                        data-product-id="@Model.ProductId"
                        class="comments-product-send-btn">
                    <i class="fas fa-paper-plane"></i>
                    <span class="comments-product-send-btn__label">Gửi</span>
                </button>
            </div>

            <div class="comments-product-list">
                @if (comments.Any())
                {
                    @foreach (var parentComment in comments)
                    {
                        <div class="comments-product-item">
                            <img src="@BuildAvatarUrl(parentComment.UserAvatar)"
                                 class="comments-product-item-avatar"
                                 alt="Ảnh người dùng">

                            <div class="comments-product-item-content">
                                <div class="comments-product-item-header">
                                    <div class="comments-product-item-meta">
                                        <h5 class="comments-product-item-username">@(string.IsNullOrWhiteSpace(parentComment.UserName) ? "Khách hàng" : parentComment.UserName)</h5>
                                        <small class="comments-product-item-date">
                                            @((parentComment.CreatedAt as DateTime?)?.TimeAgo() ?? "Không xác định")
                                        </small>
                                    </div>
                                    @if (ViewBag.User != null && ViewBag.User.UserId == parentComment.UserId)
                                    {
                                        <div class="dropdown">
                                            <a class="text-muted" href="#" role="button"
                                               id="dropdownMenuLink-@parentComment.CommentId"
                                               data-bs-toggle="dropdown" aria-expanded="false">
                                                <i class="fas fa-ellipsis-h"></i>
                                            </a>
                                            <ul class="dropdown-menu dropdown-menu-end"
                                                aria-labelledby="dropdownMenuLink-@parentComment.CommentId">
                                                <li>
                                                    <button class="dropdown-item delete-comment"
                                                       data-comment-id="@parentComment.CommentId">
                                                        <i class="fas fa-trash"></i> Xóa
                                                    </button>
                                                </li>
                                            </ul>
                                        </div>
                                    }
                                </div>

                                <p class="comments-product-item-text">@(string.IsNullOrWhiteSpace(parentComment.Content) ? "Bình luận đang được cập nhật." : parentComment.Content)</p>

                                <div class="comments-product-reply-container">
                                    <button type="button" class="comments-product-reply-link">
                                        <i class="fas fa-reply"></i> Trả lời
                                    </button>
                                    <div class="comments-product-reply-form">
                                        <input type="text"
                                               class="comments-product-reply-input reply-text"
                                               data-parent-id="@parentComment.CommentId"
                                               placeholder="Trả lời bình luận..." />
                                        <button class="comments-product-reply-btn reply-btn"
                                                data-userId="@(ViewBag.User != null ? ViewBag.User.UserId : "")"
                                                data-product-id="@Model.ProductId"
                                                data-comment-id="@parentComment.CommentId">
                                            <i class="fas fa-paper-plane"></i>
                                            <span>Gửi</span>
                                        </button>
                                    </div>
                                </div>

                                @if (parentComment.Replies != null)
                                {
                                    <div class="comments-product-replies-container">
                                        @foreach (var reply in parentComment.Replies)
                                        {
                                            <div class="comments-product-item comments-product-reply">
                                                <img src="@BuildAvatarUrl(reply.UserAvatar)"
                                                     class="comments-product-item-avatar"
                                                     alt="Ảnh người dùng">
                                                <div class="comments-product-item-content">
                                                    <div class="comments-product-item-header">
                                                        <div class="comments-product-item-meta">
                                                            <h6 class="comments-product-item-username">@(string.IsNullOrWhiteSpace(reply.UserName) ? "Khách hàng" : reply.UserName)</h6>
                                                            <span class="comments-product-item-replying-to">
                                                                đã trả lời bình luận của
                                                                <span>@(string.IsNullOrWhiteSpace(parentComment.UserName) ? "Khách hàng" : parentComment.UserName)</span>
                                                            </span>
                                                            <small class="comments-product-item-date">
                                                                @((reply.CreatedAt as DateTime?)?.TimeAgo() ?? "Không xác định")
                                                            </small>
                                                        </div>
                                                        @if (ViewBag.User != null && ViewBag.User.UserId == reply.UserId)
                                                        {
                                                            <div class="dropdown">
                                                                <a class="text-muted" href="#" role="button"
                                                                   id="dropdownMenuLink-@reply.CommentId"
                                                                   data-bs-toggle="dropdown" aria-expanded="false">
                                                                    <i class="fas fa-ellipsis-h"></i>
                                                                </a>
                                                                 <ul class="dropdown-menu dropdown-menu-end"
                                                                     aria-labelledby="dropdownMenuLink-@reply.CommentId">
                                                                    <li>
                                                                        <button type="button" class="dropdown-item delete-comment text-danger fw-bold d-flex align-items-center"
                                                                                data-comment-id="@reply.CommentId">
                                                                            <i class="fas fa-trash me-2"></i> Xóa
                                                                        </button>
                                                                    </li>

                                                                </ul>
                                                            </div>
                                                        }
                                                    </div>
                                                    <p class="comments-product-item-text">@(string.IsNullOrWhiteSpace(reply.Content) ? "Bình luận đang được cập nhật." : reply.Content)</p>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-center text-muted">Chưa có bình luận</p>
                }
            </div>
        </div>
    </div>
</div>

