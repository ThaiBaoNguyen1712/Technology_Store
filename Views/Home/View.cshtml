<script>
    $(document).ready(function () {
        // Gửi bình luận mới
        $('#CreateCm').on('click', function () {
            $('.loading-container').show();

            var content = $('#CmContent').val();
            var productId = $(this).data('product-id');

            const userId = $(this).data('userid');
            if (!userId) {
                var loginModal = new bootstrap.Modal(document.getElementById('loginRequiredModal'));
                loginModal.show();
                return false;
            }
            $.ajax({
                method: 'POST',
                url: '@Url.Action("CreateComment", "User")',
                contentType: 'application/json',
                data: JSON.stringify({
                    Content: content,
                    ProductId: productId,
                    ParentCommentId: 0
                }),
                success: function (response) {
                    if (response.success) {
                       
                        location.reload(); // Tải lại trang
                    } else {
                        notyf.error(response.message);
                    }
                    $('.loading-container').hide();

                },
                error: function () {
                    $('.loading-container').hide();

                    notyf.error('Có lỗi xảy ra!');
                }
            });
        });

        // Gửi trả lời bình luận
        $('.reply-btn').on('click', function () {
            $('.loading-container').show();

            var content = $(this).siblings('.reply-text').val();
            var productId = $(this).data('product-id');
            var parentCommentId = $(this).data('comment-id');

            const userId = $(this).data('userid');
            if (!userId) {
                var loginModal = new bootstrap.Modal(document.getElementById('loginRequiredModal'));
                loginModal.show();
                return false;
            }

            $.ajax({
                method: 'POST',
                url: '@Url.Action("CreateComment", "User")',
                contentType: 'application/json',
                data: JSON.stringify({
                    Content: content,
                    ProductId: productId,
                    ParentCommentId: parentCommentId
                }),
                success: function (response) {
                    if (response.success) {
                      
                        location.reload(); // Tải lại trang
                    } else {
                        notyf.error(response.message);
                    }
                    $('.loading-container').hide();

                },
                error: function () {
                    notyf.error('Có lỗi xảy ra!');
                    $('.loading-container').hide();

                }
            });
        });

        //Xóa bình luận
        $('.delete-comment').on('click', function () {
            $('.loading-container').show();

            var commentId = $(this).data('comment-id');

            $.ajax({
                method: 'POST',
                url: '@Url.Action("DeleteComment","User")',
                data: {
                    id: commentId
                },
                success: function (response) {
                    if (response.success) {
                        location.reload();
                    }
                    else {
                        notyf.error(response.message);
                    }
                    $('.loading-container').hide();

                },
                error: function () {
                    $('.loading-container').hide();

                    notyf.error('Có lỗi xảy ra');
                }
            });
        })

    });
</script>
