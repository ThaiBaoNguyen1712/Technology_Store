
@{
    ViewData["Title"] = $"Tìm kiếm {ViewBag.Key}";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@model IPagedList<Tech_Store.Models.Product>
@using System.Globalization;
@using Tech_Store.Helpers
@using X.PagedList;
@using X.PagedList.Mvc.Core


<link href="~/client/asset/css/searchview.css" rel="stylesheet" />


<div class="container mt-3">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Trang chủ</a></li>
            <li class="breadcrumb-item"><a class="text-decoration-none">Tìm kiếm</a></li>
            <li class="breadcrumb-item active" aria-current="page">Theo từ khóa : <strong> @ViewBag.Key</strong></li>

        </ol>
    </nav>

    <!-- Filter Section -->
 <div class="filter-toolbar mb-4 p-3 bg-white rounded-4 shadow-sm border">
    <form action="~/Search/@ViewBag.Key" method="get" id="filterForm" autocomplete="off">
        <input type="hidden" name="key" value="@ViewBag.Key" />

        <div class="d-flex flex-column gap-3">
            <div class="filter-group">
                <div class="d-flex align-items-center gap-2 overflow-auto pb-2 no-scrollbar">
                    <span class="text-secondary small fw-bold text-nowrap me-2"><i class="fas fa-sort-amount-down me-1"></i>Sắp xếp:</span>
                        <input type="radio" onchange="this.form.submit()" class="btn-check" name="order" id="ord_default" value="" @(string.IsNullOrEmpty(ViewBag.Order) ? "checked" : "")>
                        <label class="btn btn-outline-light btn-sm rounded-pill text-dark shadow-none border text-nowrap" for="ord_default">Liên quan</label>

                        <input type="radio" class="btn-check" onchange="this.form.submit()"
                               name="order" id="ord_price_desc" value="price_desc"
                               @(ViewBag.Order == "price_desc" ? "checked" : "")> <label class="btn btn-outline-light btn-sm rounded-pill text-dark shadow-none border text-nowrap" for="ord_price_desc">
                            Giá cao <i class="fas fa-sort-amount-down-alt me-1"></i>
                        </label>

                        <input type="radio" class="btn-check" onchange="this.form.submit()"
                               name="order" id="ord_price_asc" value="price"
                               @(ViewBag.Order == "price" ? "checked" : "")> <label class="btn btn-outline-light btn-sm rounded-pill text-dark shadow-none border text-nowrap" for="ord_price_asc">
                            Giá thấp <i class="fas fa-sort-amount-up me-1"></i>
                        </label>
                </div>
            </div>

            <div class="row g-2">
                <div class="col-6 col-md-3">
                        <select name="price" class="form-select ..." onchange="this.form.submit()">
                            <option value="">Mọi mức giá</option>
                            <option value="max5" selected="@(ViewBag.Price == "max5")">Dưới 5tr</option>
                            <option value="max10" selected="@(ViewBag.Price == "max10")">5 - 10tr</option>
                            <option value="max20" selected="@(ViewBag.Price == "max20")">10 - 20tr</option>
                            <option value="max50" selected="@(ViewBag.Price == "max50")">20 - 50tr</option>
                            <option value="more" selected="@(ViewBag.Price == "more")">Trên 50tr</option>
                        </select>
                </div>
                <div class="col-6 col-md-3">
                        <select name="category" class="form-select ..." onchange="this.form.submit()">
                            <option value="">Tất cả danh mục</option>
                            @foreach (var cate in ViewBag.list_category)
                            {
                                <option value="@cate.CategoryId" selected="@(ViewBag.Category == cate.CategoryId.ToString())">
                                    @cate.Name
                                </option>
                            }
                        </select>
                </div>
                <div class="col-6 col-md-3">
                        <select name="brand" class="form-select ..." onchange="this.form.submit()">
                            <option value="">Thương hiệu</option>
                            @foreach (var brand in ViewBag.list_brand)
                            {
                                <option value="@brand.BrandId" selected="@(ViewBag.Brand == brand.BrandId.ToString())">
                                    @brand.Name
                                </option>
                            }
                        </select>
                </div>
                <div class="col-6 col-md-3">
                    <button type="button" id="resetBtn" class="btn btn-sm btn-white w-100 py-2 border rounded-3 text-danger fw-bold shadow-sm">
                        <i class="fas fa-undo-alt me-1"></i> Làm mới
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>
</div>
<div class="container">
    @if (!Model.Any())
    {
        <div class="container d-flex flex-column align-items-center justify-content-center py-5">
            <div class="text-center">
                <i class="fas fa-box-open fa-3x text-muted mb-3"></i>
                <h4 class="text-secondary">Không có sản phẩm phù hợp</h4>
                <p class="text-muted">Hãy thử thay đổi bộ lọc hoặc tìm kiếm từ khóa khác.</p>
            </div>
        </div>
    }
    else
    {
        <div class="row g-2">
            @foreach (var item in Model)
            {
                <div class="col-6 col-md-3 product-card-ct" data-id="@item.ProductId">
                    <div class="product-link" data-slug="@item.Slug">
                        <div class="card h-100">
                            <!-- Sale Badge -->
                            <div class="position-absolute d-flex flex-column gap-1 d-md-block" style="top: 5px; left: 5px; z-index: 2;">
                                @if (item.SellPrice != item.OriginalPrice)
                                {
                                    @if (item.DiscountPercentage != null)
                                    {
                                        <span class="badge bg-danger small p-1 d-block">Giảm @item.DiscountPercentage%</span>
                                    }
                                    @if (item.DiscountAmount != null)
                                    {
                                        <span class="badge bg-danger small p-1 d-block">Giảm @((item.OriginalPrice - item.SellPrice)?.ToString("C0", new CultureInfo("vi-VN")))</span>
                                    }
                                }
                            </div>
                            <!-- Installment Badge -->
                            @*  <div class="position-absolute" style="top: 5px; right: 5px; z-index: 2;" class="d-md-block" id="installment-badge-@item.ProductId">
                    <span class="badge bg-white text-primary border border-primary small p-1">Trả góp 0%</span>
                    </div> *@

                            <div class="image-container" style="overflow: hidden;">
                                @if(item.Image == null)
                                {
                                    <img src="/Upload/Products/no-image.png" class="product-image" alt="No Image Available" />
                                }
                                else if (item.Image.Contains("http"))
                                {
                                    <img src="@ResizeCDN.Cdn(item.Image,358,358)" class="product-image" alt="@item.Name" />
                                }
                                else
                                {
                                    <img src="/Upload/Products/@item.Image" class="product-image" alt="@item.Name" />
                                }
                            </div>

                            <div class="card-body p-3 d-flex flex-column">
                                <h6 class="card-title mb-2 product-title" style="font-size: 0.9rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">@item.Name</h6>
                                <div class="d-flex align-items-center gap-1 mb-2 flex-wrap">
                                    <span class="text-danger fw-bold" style="font-size: 0.9rem;">@item.SellPrice?.ToString("C0", new CultureInfo("vi-VN"))</span>
                                    @if (item.SellPrice != item.OriginalPrice)
                                    {
                                        <span class="text-decoration-line-through text-muted" style="font-size: 0.7rem;">@item.OriginalPrice?.ToString("C0", new CultureInfo("vi-VN"))</span>
                                    }
                                </div>
                                <button class="btn btn-outline-danger btn-sm w-100 mt-auto addToWishList" data-id="@item.ProductId">
                                    <i class="far fa-heart"></i> Yêu thích
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        <style>
          
        </style>
        <!-- Pagination -->
         <div class="d-flex justify-content-center mt-4">
                @Html.PagedListPager(Model, page => Url.Action(
                    "Search",
                    new {
                        key = ViewBag.Key,
                        category = ViewBag.Category,
                        brand = ViewBag.Brand,
                        order = ViewBag.Order,
                        price = ViewBag.Price,
                        page
                    }
                ), new PagedListRenderOptions
                {
                    UlElementClasses = new[] { "pagination" },
                    LiElementClasses = new[] { "page-item" },
                    PageClasses = new[] { "page-link" },
                    ActiveLiElementClass = "active",

                    // Thay icon để nhìn sang hơn
                    LinkToPreviousPageFormat = "‹",
                    LinkToNextPageFormat = "›",
                    LinkToFirstPageFormat = "«",
                    LinkToLastPageFormat = "»",

                    // Giới hạn số con số hiển thị (VD: 1 2 3 ... 10)
                    MaximumPageNumbersToDisplay = 4,
                    DisplayEllipsesWhenNotShowingAllPageNumbers = true
                    })
        </div>

    }
   
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function () {
        // Giá trị từ ViewBag
        var orderValue = "@ViewBag.Order";
        var priceValue = "@ViewBag.Price";
        var brandValue = "@ViewBag.Brand";
        var categoryValue = "@ViewBag.Category";

        // Set giá trị cho dropdown và bỏ selected ở option mặc định
        if (orderValue) {
            $('#order').val(orderValue);  // Chọn giá trị từ ViewBag
        } else {
            $('#order option:first').prop('selected', true);  // Nếu không có giá trị, chọn option đầu tiên
        }

        if (priceValue) {
            $('#price').val(priceValue);  // Chọn giá trị từ ViewBag
        } else {
            $('#price option:first').prop('selected', true);  // Nếu không có giá trị, chọn option đầu tiên
        }

        if (brandValue) {
            $('#brand').val(brandValue);  // Chọn giá trị từ ViewBag
        } else {
            $('#brand option:first').prop('selected', true);  // Nếu không có giá trị, chọn option đầu tiên
        }
        if(categoryValue){
        $('#category').val(categoryValue);  // Chọn giá trị từ ViewBag
        } else {
            $('#category option:first').prop('selected', true);  // Nếu không có giá trị, chọn option đầu tiên
        }
        $('#resetBtn').on('click', function () {
            window.location.href = '/Search/' + '@ViewBag.Key';
        });

    });
</script>
 