@{
    ViewData["Title"] = "Trang chủ";
}
@using System.Globalization;
@using Tech_Store.Helpers
@using Tech_Store.Models.ViewModel
<!-- carousel -->
<section class="home-hero">
    <div class="container">
        <div class="home-hero__grid">
            <aside class="home-hero__categories">
                <div class="categories-menu">
                    <ul class="list-group list-group-flush">
                        @foreach (var item in ViewBag.list_cate)
                        {
                            <li class="list-group-item category-item"
                                data-name="@item.Name">
                                <a href="~/Category/@item.EngTitle"
                                   class="category-link text-decoration-none text-dark d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center gap-2">
                                        <img src="~/Upload/Logo/@item.Image" width="30" height="30" />
                                        <span>@item.Name</span>
                                    </div>
                                    <i class="fa fa-angle-right"></i>
                                </a>
                                <div class="category-data-source d-none p-3">

                                    <!-- HOT SEARCH -->
                                    <div class="mb-4">
                                        <h6 class="fw-bold mb-3 text-uppercase text-danger">
                                            <i class="fa fa-fire me-2"></i>
                                            Tìm kiếm phổ biến cho @item.Name
                                        </h6>

                                        @{
                                            var hotKeywords =
                                            ViewBag.HotSearchByCategory != null &&
                                            ViewBag.HotSearchByCategory.ContainsKey(item.EngTitle)
                                            ? ViewBag.HotSearchByCategory[item.EngTitle] as List<string>
                                            : new List<string>();
                                        }

                                        @if (hotKeywords.Any())
                                        {
                                            <div class="row g-2">
                                                @foreach (var keyword in hotKeywords)
                                                {
                                                    <div class="col-6 col-lg-4">
                                                        <a href="/Search?key=@Uri.EscapeDataString(keyword)"
                                                           class="keyword-tag d-block text-decoration-none">
                                                            @keyword
                                                        </a>
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="text-muted small">Chưa có xu hướng tìm kiếm</div>
                                        }
                                    </div>

                                    <!-- BRANDS -->
                                    @if (ViewBag.BrandsByCategory != null && ViewBag.BrandsByCategory.ContainsKey(item.CategoryId))
                                    {
                                        <div class="brand-section">
                                            <h6 class="fw-bold mb-3 text-uppercase">
                                                Thương hiệu nổi bật
                                            </h6>

                                            <div class="row g-2">
                                                @foreach (var brand in ViewBag.BrandsByCategory[item.CategoryId])
                                                {
                                                    <div class="col-6 col-lg-4">
                                                        <a href="@Url.Action("Brand", "Home", new { brand_name = brand.Name })"
                                                           class="brand-item d-block text-decoration-none">
                                                            @brand.Name
                                                        </a>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }

                                </div>

                            </li>
                        }
                    </ul>
                </div>

                <!-- EXPAND -->
                <div class="category-expand">
                    <div class="expand-content"></div>
                </div>
            </aside>

            <div class="home-hero__main">
                <div class="home-hero__slider">
                    @await Html.PartialAsync(
                        "~/Views/Shared/Banners/_CarouselBannerZone.cshtml",
                        ViewBag.HomeHeroMainBanners as IReadOnlyList<BannerRenderItemViewModel> ?? [])
                </div>
            </div>

            <aside class="home-hero__promos" aria-label="Khuyến mãi nổi bật">
                @await Html.PartialAsync(
                    "~/Views/Shared/Banners/_PromoBannerZone.cshtml",
                    ViewBag.HomeHeroPromoBanners as IReadOnlyList<BannerRenderItemViewModel> ?? [])
            </aside>
        </div>
    </div>
</section>
<!-- end carousel -->
<!--Recommendation section -->
<section class="products">
    <div class="container">
        <div class="product-section">
            <div style="max-width: 85vw; padding: 10px; display: flex; justify-content: space-between; align-items: center;">
                <h3 class="text-dark mb-0">Gợi ý dành cho bạn</h3>
            </div>

            <button class="btn-scroll btn-prev" data-target="suggestion">
                <i class="fa fa-chevron-left"></i>
            </button>
            <button class="btn-scroll btn-next" data-target="suggestion">
                <i class="fa fa-chevron-right"></i>
            </button>

            <div class="scrolling-wrapper" data-wrapper="suggestion">
                <div id="recommendation-container" class="row pt-2 mx-auto">
                    <div class="text-center w-100 py-5">
                        <div class="spinner-border text-danger" role="status"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* Hot sale *@
<section class="container pt-3" data-section="hot-sale">
    <div class="home-hot-sale">
        <div class="home-hot-sale__header">
            <div>
                <span class="home-hot-sale__label">Ưu đãi nổi bật</span>
                <h3>Hot sale tháng này</h3>
                <p>Giá tốt cho các sản phẩm đang được quan tâm nhiều.</p>
            </div>
            <a href="/Search?key=hot%20sale" class="home-hot-sale__link">
                Xem tất cả
                <i class="fa fa-angle-right"></i>
            </a>
        </div>

        <div class="home-hot-sale__body">
            <button class="btn-scroll btn-prev" data-target="hot-sale" data-section="hot-sale" aria-label="Sản phẩm trước">
                <i class="fa fa-chevron-left"></i>
            </button>
            <button class="btn-scroll btn-next" data-target="hot-sale" data-section="hot-sale" aria-label="Sản phẩm tiếp theo">
                <i class="fa fa-chevron-right"></i>
            </button>

            <div class="scrolling-wrapper home-hot-sale__scroller" data-wrapper="hot-sale">
                <div class="row g-2 pt-2 mx-auto flex-nowrap">
                    @foreach (var hot in ViewBag.productsHotSale)
                    {
                        <div class="col-6 col-md-3 card product-card" style="max-width: 235px;" data-id="@hot.ProductId">
                            <div class="product-card-promos product-card-promos--left">
                                @if (hot.SellPrice != hot.OriginalPrice)
                                {
                                    @if (hot.DiscountPercentage != null)
                                    {
                                        <span class="product-promo-badge product-promo-badge--sale">Giảm @hot.DiscountPercentage%</span>
                                    }
                                    @if (hot.DiscountAmount != null)
                                    {
                                        <span class="product-promo-badge product-promo-badge--sale">Giảm @((hot.OriginalPrice - hot.SellPrice).ToString("C0", new CultureInfo("vi-VN")))</span>
                                    }
                                }
                            </div>

                            <div class="product-card-promos product-card-promos--right">
                                <span class="product-promo-badge product-promo-badge--installment">Trả góp 0%</span>
                            </div>

                            <div class="product-link" data-slug="@hot.Slug" data-product-id="@hot.ProductId" data-product-sys-id="@hot.ProductSysId" data-track-event="homepage_click" data-track-source="homepage_hot_sale" data-track-placement="hot-sale">
                                <div class="image-container">
                                    @if (hot.Image.Contains("http"))
                                    {
                                        <img src="@hot.Image" alt="Product Image" class="product-image-csl-hotSale" alt="@hot.Name">

                                    }
                                    else
                                    {
                                        <img src="~/Upload/Products/@hot.Image" alt="Product Image" class="product-image-csl-hotSale" alt="@hot.Name">
                                    }
                                    @* <img src="/Upload/Products/@hot.Image" class="product-image-csl-hotSale" alt="@hot.Name"> *@
                                </div>

                                <div class="card-body p-3 d-flex flex-column">
                                    <h6 class="card-title mb-2 product-title" style="font-size: 0.9rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">@hot.Name</h6>
                                    <div class="price-wrapper d-flex align-items-center text-center gap-1 mb-2 flex-wrap">
                                        <span class="price-text text-danger fw-bold" style="font-size: 1.05rem;">@hot.SellPrice?.ToString("C0", new CultureInfo("vi-VN"))</span>
                                        @if (hot.SellPrice != hot.OriginalPrice)
                                        {
                                            <span class="text-decoration-line-through text-muted" style="font-size: 0.9rem;">@hot.OriginalPrice?.ToString("C0", new CultureInfo("vi-VN"))</span>
                                        }
                                    </div>
                                    <button class="btn btn-outline-danger btn-sm w-100 mt-auto addToWishList d-inline-flex align-items-center justify-content-center text-nowrap"
                                            style="font-size: 0.9rem;"
                                            data-id="@hot.ProductId">
                                        <i class="far fa-heart pe-1"></i><span>Yêu thích</span>
                                    </button>

                                </div>
                            </div>
                        </div>

                    }
                </div>
            </div>
        </div>
    </div>
</section>

@foreach (var item in ViewBag.ProductsByCategory)
{
    <section class="products">
        <div class="container">
            <div class="product-section" data-section="@item.Category.Name">

                <div class="d-flex justify-content-between align-items-center flex-wrap px-3 mb-3" style="max-width: 90vw;">
                    <!-- Tên danh mục -->
                    <h4 class="text-dark mb-2 mb-md-0">@item.Category.Name</h4>

                    <!-- Hot search + Xem tất cả -->
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        @{
                            var keywords = new List<string>();
                            if (ViewBag.List_TopHotSearch != null)
                            {
                                var hotSearchDict = ViewBag.List_TopHotSearch as Dictionary<string, List<string>>;
                                var slug = item.Category.EngTitle;
                                keywords = (hotSearchDict != null && hotSearchDict.ContainsKey(slug))
                                ? hotSearchDict[slug]
                                : null;

                            }
                        }

                        @if (keywords != null)
                        {
                            <div class="d-none d-md-block">
                                @foreach (var keyword in keywords)
                                {
                                    <a href="/Search?key=@Uri.EscapeDataString(keyword)"
                                       class="badge bg-light text-dark border px-3 py-2"
                                       style="font-weight: 500;text-decoration:none">
                                        @(keyword.Length > 20 ? keyword.Substring(0, 20) + "..." : keyword)
                                    </a>

                                }
                            </div>
                        }

                        <a href="~/Category/@item.Category.EngTitle"
                           class="badge bg-light text-danger border border-danger px-3 py-2"
                           style="font-weight: 500; text-decoration: none;">
                            <span>Xem thêm</span>

                        </a>

                    </div>
                </div>



                <!-- Nút điều hướng cho phần sản phẩm mới -->
                <button class="btn-scroll btn-prev" data-target="@item.Category.Name">
                    <i class="fa fa-chevron-left"></i>
                </button>
                <button class="btn-scroll btn-next" data-target="@item.Category.Name">
                    <i class="fa fa-chevron-right"></i>
                </button>
                <div class="scrolling-wrapper" data-wrapper="@item.Category.Name" style="overflow-x: auto; scroll-behavior: smooth;">
                    <div class="row g-2 pt-1 mx-auto flex-nowrap">
                        @foreach (var product in item.Products)
                        {
                            <div class="col-6 col-md-3 card product-card" style="max-width: 240px;" data-id="@product.ProductId">
                                <!-- Sale Badge -->
                                <div class="position-absolute d-flex gap-1" style="top: 8px; left: 8px; z-index: 2; font-size:0.9rem">
                                    @if (product.SellPrice != product.OriginalPrice)
                                    {
                                        @if (product.DiscountPercentage != null)
                                        {
                                            <span class="badge bg-danger p-1 px-2 text-xs d-md-inline p-md-2">Giảm @product.DiscountPercentage%</span>
                                        }
                                        @if (product.DiscountAmount != null)
                                        {
                                            <span class="badge bg-danger p-1 px-2 text-xs d-md-inline p-md-2">Giảm @((product.OriginalPrice - product.SellPrice).ToString("C0", new CultureInfo("vi-VN")))</span>
                                        }
                                    }
                                </div>
                                <!-- Installment Badge -->
                                @*    <div class="position-absolute" style="top: 10px; right: 10px; z-index: 2;">
                                    <span class="badge bg-white text-primary border border-primary p-2">Trả góp 0%</span>
                                </div> *@
                                <div class="product-link" data-slug="@product.Slug" data-product-id="@product.ProductId" data-product-sys-id="@product.ProductSysId" data-track-event="homepage_click" data-track-source="homepage_category" data-track-placement="@item.Category.EngTitle">
                                    <div class="image-container">
                                        @if (product.Image.Contains("http"))
                                        {
                                            <img src="@ResizeCDN.Cdn(product.Image, 358, 358)" class="product-image-csl-hotSale" alt="@product.Name">
                                        }
                                        else
                                        {
                                            <img src="/Upload/Products/@product.Image" class="product-image-csl-hotSale" alt="@product.Name">

                                        }
                                        @* <img src="/Upload/Products/@product.Image" class="product-image-csl-hotSale" alt="@product.Name"> *@
                                    </div>

                                    <div class="card-body p-3 d-flex flex-column">
                                        <h6 class="card-title mb-2 product-title" style="font-size: 0.9rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">@product.Name</h6>
                                        <div class="price-wrapper d-flex align-items-center text-center gap-1 mb-2 flex-wrap" style="min-height: 3rem;">
                                            <span class="price-text text-danger fw-bold" style="font-size: 1rem;">@product.SellPrice?.ToString("C0", new CultureInfo("vi-VN"))</span>
                                            @if (product.SellPrice != product.OriginalPrice)
                                            {
                                                <span class="text-decoration-line-through text-muted" style="font-size: 0.85rem;">@product.OriginalPrice?.ToString("C0", new CultureInfo("vi-VN"))</span>
                                            }
                                        </div>
                                        <button class="btn btn-outline-danger btn-sm w-100 mt-auto addToWishList d-inline-flex align-items-center justify-content-center text-nowrap"
                                                style="font-size: 0.9rem;"
                                                data-id="@product.ProductId">
                                            <i class="far fa-heart pe-1"></i><span>Yêu thích</span>
                                        </button>

                                    </div>
                                </div>
                            </div>

                        }
                    </div>
                </div>
            </div>
        </div>
    </section>
}



<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Lấy tất cả các liên kết danh mục
        const categoryLinks = document.querySelectorAll('.category-link');

        // Xử lý cho từng liên kết
        categoryLinks.forEach(link => {
            let isTap = true;
            let startY = 0;
            let startX = 0; // Thêm để kiểm tra cả cuộn ngang nếu cần

            // Bắt sự kiện touchstart
            link.addEventListener('touchstart', function (e) {
                isTap = true; // Reset isTap mỗi khi chạm mới
                startY = e.touches[0].clientY;
                startX = e.touches[0].clientX; // Lưu cả X để kiểm tra cuộn ngang
            }, { passive: true });

            // Bắt sự kiện touchmove để phát hiện cuộn
            link.addEventListener('touchmove', function (e) {
                const moveY = Math.abs(e.touches[0].clientY - startY);
                const moveX = Math.abs(e.touches[0].clientX - startX);
                // Nếu di chuyển quá 10px (dọc hoặc ngang), coi như đang cuộn
                if (moveY > 10 || moveX > 10) {
                    isTap = false;
                }
            }, { passive: true });

            // Bắt sự kiện touchend để xử lý nhấp
            link.addEventListener('touchend', function (e) {
                // Kiểm tra nếu là mobile
                if (/Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent)) {
                    if (isTap) {
                        // Nếu là tap, chuyển hướng thủ công
                        window.location.href = link.getAttribute('href');
                    }
                }
            }, { passive: true });

            // Sự kiện click cho desktop (không can thiệp trên mobile)
            link.addEventListener('click', function (e) {
                if (!/Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent)) {
                    // Trên desktop, luôn cho phép chuyển hướng mặc định
                    return;
                }
                // Trên mobile, ngăn click mặc định vì đã xử lý ở touchend
                e.preventDefault();
            });
        });
    });
</script>
<script>
      $(document).ready(function () {

        RecommendationManager.init('homepage', null, 20);

        var timeout;

        $('.category-item').mouseenter(function () {
            clearTimeout(timeout); // Hủy lệnh ẩn nếu đang chờ
            var subContent = $(this).find('.category-data-source').html();
            $('.category-expand .expand-content').html(subContent);
            $('.category-expand').stop(true, true).show(); // Dùng show() cho cảm giác nhanh hơn
        });

        // Gom cả 2 vào một khu vực chung để xử lý
        $('.categories-menu, .category-expand').mouseleave(function () {
            timeout = setTimeout(function () {
                // Kiểm tra lại một lần nữa xem chuột có đang nằm trên 1 trong 2 không
                if (!$('.category-expand:is(:hover)').length && !$('.categories-menu:is(:hover)').length) {
                    $('.category-expand').fadeOut(120);
                }
            }, 200); // Khoảng thời gian chờ đủ để chuột di chuyển qua khoảng trống
        });

        // Khi di chuột vào lại expand thì phải hủy lệnh ẩn
        $('.category-expand').mouseenter(function() {
            clearTimeout(timeout);
        });
    });
</script>
