@{
    ViewData["Title"] = "Danh mục";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@using System.Globalization;
@using Tech_Store.Helpers

<link href="~/client/asset/css/searchview.css" rel="stylesheet" />

<div class="container mt-3">
    <nav aria-label="breadcrumb" class="mb-3" style="font-size:0.9rem">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Trang chủ</a></li>
            <li class="breadcrumb-item active" aria-current="page">Danh mục</li>
        </ol>
    </nav>

    <section class="mb-4">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h4 class="text-dark mb-0">Danh mục sản phẩm</h4>
        </div>

        <div class="row g-3">
            @foreach (var category in ViewBag.CategoryCards)
            {
                var productCount = ViewBag.CategoryProductCounts != null && ViewBag.CategoryProductCounts.ContainsKey(category.CategoryId)
                    ? ViewBag.CategoryProductCounts[category.CategoryId]
                    : 0;

                <div class="col-6 col-md-4 col-lg-3">
                    <a href="/Category/@category.EngTitle" class="text-decoration-none text-dark">
                        <div class="card h-100 border shadow-sm category-card">
                            <div class="card-body d-flex align-items-center gap-3">
                                <div class="category-card-image d-flex align-items-center justify-content-center bg-light rounded-3">
                                    @if (!string.IsNullOrEmpty(category.Image))
                                    {
                                        <img src="/Upload/Logo/@category.Image" alt="@category.Name" class="img-fluid" />
                                    }
                                    else
                                    {
                                        <i class="fas fa-layer-group text-danger"></i>
                                    }
                                </div>
                                <div class="min-w-0">
                                    <h6 class="mb-1 text-truncate">@category.Name</h6>
                                    <span class="text-muted small">@productCount sản phẩm</span>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    </section>

    <section class="mb-4">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h4 class="text-dark mb-0">Sản phẩm nổi bật</h4>
        </div>

        @if (ViewBag.FeaturedProducts == null || ViewBag.FeaturedProducts.Count == 0)
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-box-open fa-3x mb-3"></i>
                <p class="mb-0">Chưa có sản phẩm nổi bật.</p>
            </div>
        }
        else
        {
            <div class="row g-3 search-product-grid">
                @foreach (var item in ViewBag.FeaturedProducts)
                {
                    <div class="col-6 col-lg-3 product-card-ct" data-id="@item.ProductId">
                        <div class="product-link" data-slug="@item.Slug">
                            <div class="card h-100 search-product-card">
                                <div class="position-absolute d-flex flex-column gap-1 d-md-block" style="top: 5px; left: 5px; z-index: 2;">
                                    @if (item.SellPrice != item.OriginalPrice)
                                    {
                                        @if (item.DiscountPercentage != null)
                                        {
                                            <span class="badge bg-danger small p-1 d-block">Giảm @item.DiscountPercentage%</span>
                                        }
                                        @if (item.DiscountAmount != null)
                                        {
                                            <span class="badge bg-danger small p-1 d-block">Giảm @((item.OriginalPrice - item.SellPrice)?.ToString("C0", new CultureInfo("vi-VN")))</span>
                                        }
                                    }
                                </div>

                                <div class="image-container">
                                    @if (item.Image == null)
                                    {
                                        <img src="/Upload/Products/no-image.png" class="product-image" alt="No Image Available" />
                                    }
                                    else if (item.Image.Contains("http"))
                                    {
                                        <img src="@ResizeCDN.Cdn(item.Image, 358, 358)" class="product-image" alt="@item.Name" />
                                    }
                                    else
                                    {
                                        <img src="/Upload/Products/@item.Image" class="product-image" alt="@item.Name" />
                                    }
                                </div>

                                <div class="card-body p-3 d-flex flex-column">
                                    <h6 class="card-title mb-2 product-title">@item.Name</h6>
                                    <div class="price-wrapper d-flex align-items-center gap-1 mb-2 flex-wrap">
                                        <span class="price-text text-danger fw-bold">
                                            @item.SellPrice?.ToString("C0", new CultureInfo("vi-VN"))
                                        </span>

                                        @if (item.SellPrice != item.OriginalPrice)
                                        {
                                            <span class="text-decoration-line-through text-muted">
                                                @item.OriginalPrice?.ToString("C0", new CultureInfo("vi-VN"))
                                            </span>
                                        }
                                    </div>
                                    <button class="btn btn-outline-danger btn-sm w-100 mt-auto addToWishList" data-id="@item.ProductId">
                                        <i class="far fa-heart"></i><span>Yêu thích</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </section>
</div>

<style>
    .category-card {
        border-radius: 8px;
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    }

    .category-card:hover {
        border-color: rgba(220, 53, 69, 0.35);
        box-shadow: 0 .5rem 1rem rgba(0, 0, 0, .08) !important;
        transform: translateY(-2px);
    }

    .category-card-image {
        width: 56px;
        height: 56px;
        flex: 0 0 56px;
    }

    .category-card-image img {
        max-width: 42px;
        max-height: 42px;
        object-fit: contain;
    }

    .min-w-0 {
        min-width: 0;
    }
</style>
