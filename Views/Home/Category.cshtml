
@{
    ViewData["Title"] = $"Danh mục - {(ViewBag.Category?.Name ?? "")}";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@model IPagedList<Tech_Store.Models.Product>
@using System.Globalization;
@using Tech_Store.Helpers
@using X.PagedList;
@using X.PagedList.Mvc.Core

<link href="~/client/asset/css/searchview.css" rel="stylesheet" />

<div class="container mt-3">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3" style="font-size:0.9rem">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="/Category" class="text-decoration-none">Danh mục</a></li>
            <li class="breadcrumb-item active" aria-current="page">@ViewBag.Category.Name</li>

        </ol>
    </nav>

    @await Html.PartialAsync("~/Views/Shared/Banners/_CatalogHeroBanner.cshtml", ViewBag.CategoryHeroBanners as IReadOnlyList<Tech_Store.Models.ViewModel.BannerRenderItemViewModel> ?? [])

    <!-- Filter Section -->
    <div class="filter-toolbar mb-4 p-3 bg-white rounded-4 shadow-sm border">
        <form action="~/Category/@ViewBag.Category.EngTitle" method="get" id="filterCategoryForm" autocomplete="off">
            <input type="hidden" name="eng_title" value="@ViewBag.Category.EngTitle" />

            <div class="d-flex flex-column gap-3">
                <div class="filter-group">
                    <div class="d-flex align-items-center gap-2 overflow-auto pb-2 no-scrollbar">
                        <span class="text-secondary small fw-bold text-nowrap me-2">
                            <i class="fas fa-sort-amount-down me-1"></i>Sắp xếp:
                        </span>

                        <input type="radio" class="btn-check" name="order" id="cat_ord_default" value=""
                               onchange="this.form.submit()" @(string.IsNullOrEmpty(ViewBag.Order) ? "checked" : "")>
                        <label class="btn btn-outline-light btn-sm rounded-pill text-dark shadow-none border text-nowrap" for="cat_ord_default">Mặc định</label>

                        <input type="radio" class="btn-check" name="order" id="cat_ord_price_desc" value="price_desc"
                               onchange="this.form.submit()" @(ViewBag.Order == "price_desc" ? "checked" : "")>
                        <label class="btn btn-outline-light btn-sm rounded-pill text-dark shadow-none border text-nowrap" for="cat_ord_price_desc">
                            <i class="fas fa-sort-amount-down-alt me-1"></i>Giá cao
                        </label>

                        <input type="radio" class="btn-check" name="order" id="cat_ord_price_asc" value="price"
                               onchange="this.form.submit()" @(ViewBag.Order == "price" ? "checked" : "")>
                        <label class="btn btn-outline-light btn-sm rounded-pill text-dark shadow-none border text-nowrap" for="cat_ord_price_asc">
                            <i class="fas fa-sort-amount-up me-1"></i>Giá thấp
                        </label>
                    </div>
                </div>

                <div class="row g-2">
                    <div class="col-6 col-md-4">
                        <select name="price" class="form-select form-select-sm border-light bg-light rounded-3 py-2" onchange="this.form.submit()">
                            <option value="">Mọi mức giá</option>
                            <option value="max5" selected="@(ViewBag.Price == "max5")">Dưới 5tr</option>
                            <option value="max10" selected="@(ViewBag.Price == "max10")">5 - 10tr</option>
                            <option value="max20" selected="@(ViewBag.Price == "max20")">10 - 20tr</option>
                            <option value="max50" selected="@(ViewBag.Price == "max50")">20 - 50tr</option>
                            <option value="more" selected="@(ViewBag.Price == "more")">Trên 50tr</option>
                        </select>
                    </div>

                    <div class="col-6 col-md-4">
                        <select name="brand" class="form-select form-select-sm border-light bg-light rounded-3 py-2" onchange="this.form.submit()">
                            <option value="">Thương hiệu</option>
                            @foreach (var brand in ViewBag.list_brand)
                            {
                                <option value="@brand.BrandId" selected="@(ViewBag.Brand == brand.BrandId.ToString())">@brand.Name</option>
                            }
                        </select>
                    </div>

                    <div class="col-12 col-md-4">
                        <button type="button" id="resetBtn" class="btn btn-sm btn-white w-100 py-2 border rounded-3 text-danger fw-bold shadow-sm">
                            <i class="fas fa-undo-alt me-1"></i> Làm mới bộ lọc
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>


    @if (ViewBag.list_HotSearch !=null)
    {
        <div class="d-none d-md-block d-flex flex-wrap align-items-center gap-3 pb-3">
            @foreach (var item in ViewBag.list_HotSearch)
            {
                <a href="/Search?key=@Uri.EscapeDataString(@item)"
                   class="badge bg-light text-dark border border-secondary px-3 py-2"
                   style="font-weight: 500;text-decoration:none">
                    @item
                </a>
            }
        </div>
    }
  
    @* <div class="d-flex flex-wrap align-items-center gap-2 pb-3">
        @foreach (var brand in ViewBag.list_brand)
        {
            <a class="d-flex align-items-center justify-content-center border rounded p-2 shadow-sm" style="width: 80px; height: 80px;">
                <img src="/Upload/Logo/@brand.Image" class="img-fluid" style="max-height: 55px; object-fit: contain;" />
            </a>
        }
    </div> *@

</div>
<div class="container">
    @if (!Model.Any())
    {
        <div class="container d-flex flex-column align-items-center justify-content-center py-5">
            <div class="text-center">
                <i class="fas fa-box-open fa-3x text-muted mb-3"></i>
                <h4 class="text-secondary">Không có sản phẩm phù hợp</h4>
                <p class="text-muted">Hãy thử thay đổi bộ lọc hoặc tìm kiếm từ khóa khác.</p>
            </div>
        </div>
    }
    else
    {
       <div class="row g-3 search-product-grid">
            @foreach (var item in Model)
            {
                <div class="col-6 col-lg-3 product-card-ct" data-id="@item.ProductId">
                    <div class="product-link" data-slug="@item.Slug">
                        <div class="card h-100 search-product-card">
                            <!-- Sale Badge -->
                            <div class="position-absolute d-flex flex-column gap-1 d-md-block" style="top: 5px; left: 5px; z-index: 2;">
                                @if (item.SellPrice != item.OriginalPrice)
                                {
                                    @if (item.DiscountPercentage != null)
                                    {
                                        <span class="badge bg-danger small p-1 d-block">Giảm @item.DiscountPercentage%</span>
                                    }
                                    @if (item.DiscountAmount != null)
                                    {
                                        <span class="badge bg-danger small p-1 d-block">Giảm @((item.OriginalPrice - item.SellPrice)?.ToString("C0", new CultureInfo("vi-VN")))</span>
                                    }
                                }
                            </div>

                            <div class="image-container">
                                @if (item.Image == null)
                                {
                                    <img src="/Upload/Products/no-image.png" class="product-image" alt="No Image Available" />
                                }
                                else if (item.Image.Contains("http"))
                                {
                                    <img src="@ResizeCDN.Cdn(item.Image,358,358)" class="product-image" alt="@item.Name" />
                                }
                                else
                                {
                                    <img src="/Upload/Products/@item.Image" class="product-image" alt="@item.Name" />
                                }

                            </div>

                            <div class="card-body p-3 d-flex flex-column">
                                <h6 class="card-title mb-2 product-title" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">@item.Name</h6>
                                <div class="price-wrapper d-flex align-items-center gap-1 mb-2 flex-wrap">
                                    <span class="price-text text-danger fw-bold">
                                        @item.SellPrice?.ToString("C0", new CultureInfo("vi-VN"))
                                    </span>

                                    @if (item.SellPrice != item.OriginalPrice)
                                    {
                                        <span class="text-decoration-line-through text-muted">
                                            @item.OriginalPrice?.ToString("C0", new CultureInfo("vi-VN"))
                                        </span>
                                    }
                                </div>
                                <button class="btn btn-outline-danger btn-sm w-100 mt-auto addToWishList" data-id="@item.ProductId">
                                    <i class="far fa-heart"></i><span>Yêu thích</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
</div>

        <!-- Pagination -->
        <div class="d-flex justify-content-center mt-3">
           @Html.PagedListPager(Model, page => Url.Action("Category", new {
                        eng_title = ViewBag.Category?.EngTitle,
                        brand = ViewBag.Brand,
                        order = ViewBag.Order,
                        price = ViewBag.Price,
                        page
                    }
                ), new PagedListRenderOptions
               {
                   UlElementClasses = new[] { "pagination" }, // Sử dụng lớp `pagination` của Bootstrap
                   LiElementClasses = new[] { "page-item" },  // Sử dụng lớp `page-item` của Bootstrap
                   PageClasses = new[] { "page-link" },       // Sử dụng lớp `page-link` của Bootstrap
                   ActiveLiElementClass = "active",          // Đánh dấu trang hiện tại bằng `active`
                                                                 // Thay icon để nhìn sang hơn
                       LinkToPreviousPageFormat = "‹",
                       LinkToNextPageFormat = "›",
                       LinkToFirstPageFormat = "«",
                       LinkToLastPageFormat = "»",
                   MaximumPageNumbersToDisplay = 4,
                   DisplayEllipsesWhenNotShowingAllPageNumbers = true    // Hiển thị dấu "..." nếu không hiển thị hết số trang
               })
        </div>

    }
   
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script>
    $(document).ready(function () {


        // Giá trị từ ViewBag
        var orderValue = "@ViewBag.Order";
        var priceValue = "@ViewBag.Price";
        var brandValue = "@ViewBag.Brand";

        // Set giá trị cho dropdown và bỏ selected ở option mặc định
        if (orderValue) {
            $('#order').val(orderValue);  // Chọn giá trị từ ViewBag
        } else {
            $('#order option:first').prop('selected', true);  // Nếu không có giá trị, chọn option đầu tiên
        }

        if (priceValue) {
            $('#price').val(priceValue);  // Chọn giá trị từ ViewBag
        } else {
            $('#price option:first').prop('selected', true);  // Nếu không có giá trị, chọn option đầu tiên
        }

        if (brandValue) {
            $('#brand').val(brandValue);  // Chọn giá trị từ ViewBag
        } else {
            $('#brand option:first').prop('selected', true);  // Nếu không có giá trị, chọn option đầu tiên
        }

        $('#resetBtn').on('click', function () {
            window.location.href = '/Category/' + '@ViewBag.Category.EngTitle';
        });

    });
</script>
 
